// T0560: Task[T] field drop — completes the Task field-drop story after T0508
// (added Task to opaque-container types) and T0558 (wired the local-variable
// Optional[Task[T]] drop). Four sibling field-drop paths previously had no
// Task case and silently leaked the G handle:
//
//   1. emitFieldDropsFor                — plain Task[T] field at scope exit
//   2. emitOptionalValueDrop            — Optional[Task[T]] field at scope exit
//   3. emitOptionalFieldReassignDrop    — Optional[Task[T]] field on reassign
//   4. genMemberAssign handle block     — plain Task[T] field on reassign
worker_t0560_int() int {
  return 17;
}

worker_t0560_void() {
}

worker_t0560_string() string {
  return "task result";
}

worker_t0560_vec() int[] {
  return[1, 2, 3];
}

// --- Site 1: plain Task[T] field, synthesized drop ---

type T0560SynthHolder {
  Task[int] t;
}

test_task_field_synth_drop() `test(exclude: wasm) {
  h := T0560SynthHolder(t: go worker_t0560_int());
  // synthesized drop must call Task[int].drop on field at scope exit.
}

// --- Site 1: plain Task[T] field, explicit empty drop body (T0553 append) ---

type T0560ExplicitHolder {
  Task[int] t;
  drop(~this) {
  }
}

test_task_field_explicit_drop() `test(exclude: wasm) {
  h := T0560ExplicitHolder(t: go worker_t0560_int());
  // T0553 appends field drops to the explicit drop body.
}

// --- Site 1: Task field alongside other droppable fields ---

type T0560MixedHolder {
  string name;
  Task[int] t;
}

test_task_field_with_other_droppable() `test(exclude: wasm) {
  h := T0560MixedHolder(name: "hello" + "", t: go worker_t0560_int());
  // both the string and the Task must drop at scope exit.
}

// --- Site 2: Optional[Task[T]] field, synthesized drop, some ---

type T0560SynthOptHolder {
  Task[int]? t;
}

test_optional_task_field_some_drop() `test(exclude: wasm) {
  h := T0560SynthOptHolder(t: go worker_t0560_int());
  // emitOptionalValueDrop branches on has-value and drops the inner Task.
}

// --- Site 2: Optional[Task[T]] field, none initializer (no-op path) ---

test_optional_task_field_none_drop() `test(exclude: wasm) {
  h := T0560SynthOptHolder(t: none);
  // has-value flag false — drop is a no-op.
}

// --- Site 4: plain Task[T] field reassignment ---

test_task_field_reassign() `test(exclude: wasm) {
  h := T0560SynthHolder(t: go worker_t0560_int());
  h.t = go worker_t0560_int();
  // genMemberAssign must Task[int].drop the old field before overwriting.
}

// --- Site 4: plain Task[T] field same-pointer reassign (no-op guard) ---

test_task_field_reassign_same() `test(exclude: wasm) {
  t := go worker_t0560_int();
  h := T0560SynthHolder(t: t);
  // Same-pointer guard prevents UAF; field still drops once at scope exit.
}

// --- Site 3: Optional[Task[T]] field reassignment some → some ---

test_optional_task_field_reassign() `test(exclude: wasm) {
  h := T0560SynthOptHolder(t: go worker_t0560_int());
  h.t = go worker_t0560_int();
  // emitOptionalFieldReassignDrop must drop the old inner Task.
}

// --- Site 3: Optional[Task[T]] field reassignment some → none ---

test_optional_task_field_reassign_to_none() `test(exclude: wasm) {
  h := T0560SynthOptHolder(t: go worker_t0560_int());
  h.t = none;
  // The old some(Task) must drop before clearing the flag.
}

// --- Generic holder with Task field — exercises typeSubst path in all four sites ---

type T0560Box[T] {
  Task[T] t;
}

spawn_t0560_int() int {
  return 7;
}

spawn_t0560_string() string {
  return "g" + "en";
}

test_generic_holder_task_field_int() `test(exclude: wasm) {
  b := T0560Box[int](t: go spawn_t0560_int());
  // Generic field type Task[T] must resolve via c.typeSubst to Task[int].
}

test_generic_holder_task_field_string() `test(exclude: wasm) {
  b := T0560Box[string](t: go spawn_t0560_string());
  // Non-trivial concrete T — inner string also dropped by Task[string].drop.
}

// --- Generic holder with Optional[Task[T]] field — exercises typeSubst path
//     in emitOptionalValueDrop and emitOptionalFieldReassignDrop ---

type T0560OptBox[T] {
  Task[T]? t;
}

test_generic_optional_task_field_some() `test(exclude: wasm) {
  b := T0560OptBox[int](t: go spawn_t0560_int());
  // Generic Optional[Task[T]] field at scope exit — emitOptionalValueDrop
  // must resolve Task[T] → Task[int] via c.typeSubst.
}

test_generic_optional_task_field_reassign() `test(exclude: wasm) {
  b := T0560OptBox[int](t: go spawn_t0560_int());
  b.t = go spawn_t0560_int();
  // Reassignment — emitOptionalFieldReassignDrop must resolve Task[T] → Task[int]
  // via c.typeSubst and drop the old some(Task) before overwriting.
}

// --- Task[void] field — exercises the isVoid branch of Task[T].drop ---

type T0560VoidHolder {
  task[void] t;
}

test_void_task_field() `test(exclude: wasm) {
  h := T0560VoidHolder(t: go worker_t0560_void());
  // Task[void].drop skips the result drop step but still frees G.
}

// --- Task with droppable result — exercises emitVariantFieldDrop inside Task drop ---

type T0560StringHolder {
  Task[string] t;
}

test_task_field_string_result_drop() `test(exclude: wasm) {
  h := T0560StringHolder(t: go worker_t0560_string());
  // Task[string].drop must promise_string_drop the inner result.
}

type T0560VecHolder {
  Task[int[]] t;
}

test_task_field_vec_result_drop() `test(exclude: wasm) {
  h := T0560VecHolder(t: go worker_t0560_vec());
  // Task[int[]].drop must Vector.drop the inner result before freeing result_ptr.
}

// --- `<-h.field` consumes the task — field must be nulled so scope-exit drop is a no-op ---

test_task_field_await_consume() `test(exclude: wasm) {
  h := T0560SynthHolder(t: go worker_t0560_int());
  int r = <-h.t;
  assert(r == 17, "expected 17");
  // h.t was freed by <-; field-drop must null-check and no-op at scope exit.
}

// --- `<-this.field` inside a method body — same null-out path through ThisExpr target ---

type T0560MethodBox {
  Task[int] t;
  drop(~this) {
  }
  consume_task(~this) int `public {
    return <-this.t;
  }
}

test_task_field_method_consume() `test(exclude: wasm) {
  b := T0560MethodBox(t: go worker_t0560_int());
  int r = b.consume_task();
  assert(r == 17, "method consume expected 17");
}

// --- `<-this.field` inside a generic method — exercises typeSubst path in
//     the genReceiveTask MemberExpr null-out logic ---

type T0560GenericMethodBox[T] {
  Task[T] t;
  drop(~this) {
  }
  consume_task(~this) T `public {
    return <-this.t;
  }
}

test_task_field_generic_method_consume() `test(exclude: wasm) {
  b := T0560GenericMethodBox[int](t: go worker_t0560_int());
  int r = b.consume_task();
  assert(r == 17, "generic method consume expected 17");
}

// --- Site 5: Arc/Mutex wrapping Task[T] (emitInnerDrop) — T0546 ---
//
// emitInnerDrop dispatches the inner-element drop for Ref[T].drop and
// Mutex[T].drop. Before T0546 it had no Task case, so it fell through to
// the user-type branch which mis-reads the i8* Task slot as a 16-byte
// {i8*,i8*} value struct and calls pal_free on garbage (SIGSEGV/leak).

test_arc_task_int() `test(exclude: wasm) {
  a := Ref[Task[int]](go worker_t0560_int());
  // Arc drop runs Task[int].drop on the inner G handle.
}

test_arc_task_void() `test(exclude: wasm) {
  a := Ref[Task[void]](go worker_t0560_void());
  // Task[void].drop skips the result drop step but still frees G.
}

test_arc_task_string() `test(exclude: wasm) {
  a := Ref[Task[string]](go worker_t0560_string());
  // Task[string].drop must promise_string_drop the inner result.
}

test_arc_task_vec() `test(exclude: wasm) {
  a := Ref[Task[int[]]](go worker_t0560_vec());
  // Task[int[]].drop must Vector.drop the inner result before freeing result_ptr.
}

test_arc_task_shared() `test(exclude: wasm) {
  a := Ref[Task[int]](go worker_t0560_int());
  b := a.clone();
  // Two strong refs; only the last drop runs Task[int].drop (refcount 2 → 1 → 0).
}

test_mutex_task_int() `test(exclude: wasm) {
  m := Mutex[Task[int]](go worker_t0560_int());
  // Mutex drop runs Task[int].drop on the inner G handle.
}

test_mutex_task_string() `test(exclude: wasm) {
  m := Mutex[Task[string]](go worker_t0560_string());
  // Mutex drop with droppable inner result — Task[string].drop frees inner string.
}

// emitInnerDrop's third caller is the MutexGuard borrow setter
// (genMutexGuardBorrowSet, expr.go:3484). Reassigning through the setter
// must drop the OLD Task before storing the new one. Before T0546 this
// path mis-read the i8* Task slot as a 16-byte value struct → SIGSEGV/leak.

test_mutex_task_setter_reassign_int() `test(exclude: wasm) {
  m := Mutex[Task[int]](go worker_t0560_int());
  use guard := m.lock();
  guard.borrow = go worker_t0560_int();
  // emitInnerDrop runs on the OLD Task[int] before storing the new G.
}

test_mutex_task_setter_reassign_string() `test(exclude: wasm) {
  m := Mutex[Task[string]](go worker_t0560_string());
  use guard := m.lock();
  guard.borrow = go worker_t0560_string();
  // Droppable inner result — old Task[string].drop must run inside emitInnerDrop.
}

// --- Site 6: captured-task consumed inside closure (T0547) ---
//
// emitLambdaWritebacks runs at return-statement entry — before `<-t` evaluates —
// writing local→env. genReceiveTask then frees G. Without the T0547 null-out,
// env_drop would load the freed G from the env field and call Task[T].drop on
// it (spin-wait on freed memory → segfault or infinite spin). Fix nulls the
// local alloca and env field after each pal_free(G) in genReceiveTask, so
// env_drop sees null and no-ops.

test_closure_capture_consume_int() `test(exclude: wasm) {
  task[int] t = go worker_t0560_int();
  f := move || -> int {
    return <-t;
  };
  int r = f();
  assert(r == 17, "captured task int");
}

test_closure_capture_consume_void() `test(exclude: wasm) {
  task[void] t = go worker_t0560_void();
  f := move || {
    <-t;
  };
  f();
  // void sentinel branch of Task[T].drop must not run on freed G.
}

test_closure_capture_consume_string() `test(exclude: wasm) {
  task[string] t = go worker_t0560_string();
  f := move || -> string {
    return <-t;
  };
  string s = f();
  assert(s == "task result", "captured task string");
}

test_closure_capture_consume_vector() `test(exclude: wasm) {
  task[int[]] t = go worker_t0560_vec();
  f := move || -> int[] {
    return <-t;
  };
  int[] v = f();
  assert(v.len == 3, "captured task vec");
  assert(v[0] == 1, "captured task vec[0]");
}

// Regression guard: closure captures task but does NOT consume it inside.
// env_drop must still drop the live G (this path was already covered by
// analyzeEnvCaptureDrop; verifies our null-out doesn't break it).
test_closure_capture_no_consume() `test(exclude: wasm) {
  task[int] t = go worker_t0560_int();
  f := move || -> int {
    return 1;
  };
  int r = f();
  assert(r == 1, "no-consume branch");
  // env_drop must Task[int].drop the captured (live) task.
}

// Conditional consume — when the no-consume branch runs at runtime, env_drop
// must drop the live task; when the consume branch runs, env_drop must no-op
// because the env field was nulled by the receive.
test_closure_capture_consume_branch_taken() `test(exclude: wasm) {
  task[int] t = go worker_t0560_int();
  bool flag = true;
  f := move || -> int {
    if flag {
      return <-t;
    }
    return 0;
  };
  int r = f();
  assert(r == 17, "consume branch taken");
}

test_closure_capture_consume_branch_not_taken() `test(exclude: wasm) {
  task[int] t = go worker_t0560_int();
  bool flag = false;
  f := move || -> int {
    if flag {
      return <-t;
    }
    return 0;
  };
  int r = f();
  assert(r == 0, "consume branch not taken");
  // captured t still live; env_drop runs Task[int].drop.
}

// Two captured tasks, consume only one — writeback iteration must find the
// right entry and leave the other field intact (env_drop drops the second).
test_closure_capture_multiple_tasks() `test(exclude: wasm) {
  task[int] t1 = go worker_t0560_int();
  task[int] t2 = go worker_t0560_int();
  f := move || -> int {
    return <-t1;
  };
  int r = f();
  assert(r == 17, "multiple captures, one consumed");
  // t2 still in env; env_drop must Task[int].drop t2 (not the freed t1).
}

// Two captured tasks, consume BOTH — each `<-t` invocation runs its own
// nullCapturedEnvField pass over lambdaWritebacks. Each must find its own
// matching entry and null only that local/env-field pair. env_drop must
// then see both env fields null and no-op for both.
test_closure_capture_consume_both_tasks() `test(exclude: wasm) {
  task[int] t1 = go worker_t0560_int();
  task[int] t2 = go worker_t0560_int();
  f := move || -> int {
    int a = <-t1;
    int b = <-t2;
    return a + b;
  };
  int r = f();
  assert(r == 34, "both captures consumed");
  // Both env fields nulled; env_drop must no-op for both.
}

// ExprBody-form lambda — `move || -> <-t` (Promise's expr-body form omits
// the explicit return type). emitLambdaWritebacks doesn't run on the ExprBody
// path before the expression evaluates, but the receive's env-field null
// still defends env_drop. Smoke test for the ExprBody path.
test_closure_capture_consume_exprbody() `test(exclude: wasm) {
  task[int] t = go worker_t0560_int();
  f := move || -> <-t;
  int r = f();
  assert(r == 17, "exprbody captured task");
}

// Note: the rePanicBlk path (captured task whose worker panics, consume +
// re-panic) is covered by tests/e2e/t0547_panic_test.pr — a separate file is
// needed because Promise treats files with a `main() \`test(expected: ...)`
// as snapshot tests and skips batch tests in the same file.
