// T0556: pushing a borrowed Mutex/Task/MutexGuard param into a heap
// container double-free'd at runtime because sema's `tryMove` is a no-op for
// Borrowed sources but codegen has no dup path for these single-owner native
// handles. Sema now rejects the unsafe pattern at the call site and directs
// the user to add `~` to the parameter — at which point the caller transfers
// ownership and the runtime is correct.
//
// This file is the runtime-correctness companion to the Go-level rejection
// tests in compiler/internal/ownership/ownership_test.go (TestT0556_*).
// --- Ref[T] (duppable, control case) ------------------------------------
// Arc pushes from a borrowed param still work — codegen emits dupArc at the
// call site so the caller's drop and the vector's element drop reach the
// same Arc with refcount 2.
push_arc(Ref[int] a) {
  v := Vector[Ref[int]]();
  v.push(a);
}

test_arc_param_push_ok() `test {
  a := Ref[int](7);
  push_arc(a);
}

// --- Mutex[T] -----------------------------------------------------------

push_mutex(Mutex[int] move m) {
  v := Vector[Mutex[int]]();
  v.push(move m);
}

test_mutex_consume_push() `test {
  m := Mutex[int](42);
  push_mutex(move m);
}

// --- Task[T] ------------------------------------------------------------

worker_t0556() int {
  return 17;
}

push_task(Task[int] move t) {
  v := Vector[Task[int]]();
  v.push(move t);
}

test_task_consume_push() `test(exclude: wasm) {
  t := go worker_t0556();
  push_task(move t);
}

// --- MutexGuard[T] ------------------------------------------------------

push_guard(MutexGuard[int] move g) {
  v := Vector[MutexGuard[int]]();
  v.push(move g);
}

test_guard_consume_push() `test {
  m := Mutex[int](42);
  g := m.lock();
  push_guard(move g);
}
