// Test fixtures generated with Python:
//   zlib.compress(s)[2:-4]   # strip 2-byte zlib header and 4-byte adler trailer
_bytes(int[] xs) u8[] {
  u8[] r = u8[]();
  for v in xs {
    r.push(v as! u8);
  }
  return r;
}

_assert_eq(u8[] got, u8[] want, string label) {
  assert(got.len == want.len, label + " length");
  int i = 0;
  while i < want.len {
    assert(got[i] == want[i], label + " byte " + i.to_string());
    i = i + 1;
  }
}

inflate_empty_stored_test() `test {
  // Empty stored block: BFINAL=1, BTYPE=00, padding-aligned, LEN=0, NLEN=0xFFFF.
  // Bit layout: 0x01 (BFINAL=1, BTYPE=00, then alignment pad), 00 00, FF FF.
  int[] raw = int[]();
  raw.push(0x01);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0xFF);
  raw.push(0xFF);
  u8[] data = _bytes(raw);
  u8[] result = inflate(move data)?!;
  assert(result.len == 0, "empty stored block decompresses to 0 bytes");
}

inflate_fixed_hello_test() `test {
  // zlib.compress(b'hello')[2:-4] = cb 48 cd c9 c9 07 00 (fixed Huffman block).
  int[] raw = int[]();
  raw.push(0xCB);
  raw.push(0x48);
  raw.push(0xCD);
  raw.push(0xC9);
  raw.push(0xC9);
  raw.push(0x07);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  u8[] result = inflate(move data)?!;
  string s = "hello";
  u8[] want = s.bytes();
  _assert_eq(result, want, "hello");
}

inflate_fixed_aaaa_test() `test {
  // zlib.compress(b'AAAA')[2:-4] — fixed-Huffman with literal+length back-reference.
  int[] raw = int[]();
  raw.push(0x73);
  raw.push(0x74);
  raw.push(0x74);
  raw.push(0x74);
  raw.push(0x04);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  u8[] result = inflate(move data)?!;
  string s = "AAAA";
  u8[] want = s.bytes();
  _assert_eq(result, want, "AAAA");
}

inflate_fixed_long_aaa_test() `test {
  // 20 'A' bytes — exercises a longer back-reference (length code with extra bits).
  int[] raw = int[]();
  raw.push(0x73);
  raw.push(0x74);
  raw.push(0xC4);
  raw.push(0x04);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  u8[] result = inflate(move data)?!;
  string s = "AAAAAAAAAAAAAAAAAAAA";
  u8[] want = s.bytes(); // T0331 workaround: bind temp to local
  _assert_eq(result, want, "20 As");
}

inflate_fixed_repeated_test() `test {
  // 'abcdefghij' repeated 10 times — fixed Huffman with overlapping back-references.
  int[] raw = int[]();
  raw.push(0x4B);
  raw.push(0x4C);
  raw.push(0x4A);
  raw.push(0x4E);
  raw.push(0x49);
  raw.push(0x4D);
  raw.push(0x4B);
  raw.push(0xCF);
  raw.push(0xC8);
  raw.push(0xCC);
  raw.push(0x4A);
  raw.push(0xA4);
  raw.push(0x19);
  raw.push(0x0B);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  u8[] result = inflate(move data)?!;
  string s = "abcdefghijabcdefghijabcdefghijabcdefghijabcdefghijabcdefghijabcdefghijabcdefghijabcdefghijabcdefghij";
  u8[] want = s.bytes(); // T0331 workaround: bind temp to local
  _assert_eq(result, want, "10x abcdefghij");
}

