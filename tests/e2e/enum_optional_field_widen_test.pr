}

// --- droppable inner (map[K,V]): bare-value widening ---

map_bare_widen() `test {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  MaybeMap j = MaybeMap.Slot(move m);
  match j {
    MaybeMap.Slot(s) => {
      if v := s {
        assert(v["a"]! == 1, "bare-widened map value a");
        assert(v["b"]! == 2, "bare-widened map value b");
      } else {
        assert(false, "expected present map?");
      }
    },
    MaybeMap.Empty => assert(false, "expected Slot"),
