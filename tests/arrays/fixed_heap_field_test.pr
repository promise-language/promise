  Ref[int][2] arr = [Ref[int](100), Ref[int](200)];
  Ref[int] x = arr[0];
  assert(x.borrow == 100, "x intact");
  assert(arr[0].borrow == 100, "slot 0 still alive");
}

// Arc let-then-overwrite.
test_let_then_overwrite_arc() `test {
  Ref[int][2] arr = [Ref[int](100), Ref[int](200)];
  Ref[int] x = arr[0];
  arr[0] = Ref[int](999);
  assert(x.borrow == 100, "x preserved");
  assert(arr[0].borrow == 999, "slot 0 reassigned");
}

// Channel let-then-overwrite.
test_let_then_overwrite_channel() `test {
  channel[int] c0 = channel[int]();
  channel[int] c1 = channel[int]();
  channel[int][2] arr = [c0, c1];
  channel[int] x = arr[0];
  channel[int] c2 = channel[int]();
  arr[0] = c2;
  assert(true, "leak-free");
}

// _CloneBox let-then-overwrite — clone-bearing heap user not previously tested
// in the let-then-X forms.
test_let_then_overwrite_clone_box() `test {
  _CloneBox[2] arr = [_CloneBox(n: 1), _CloneBox(n: 2)];
  _CloneBox x = arr[0];
  arr[0] = _CloneBox(n: 99);
  assert(x.n == 1, "x preserved");
  assert(arr[0].n == 99, "slot 0 reassigned");
}

// _CloneBox let-then-scope-exit.
test_let_then_scope_exit_clone_box() `test {
  _CloneBox[2] arr = [_CloneBox(n: 1), _CloneBox(n: 2)];
  _CloneBox x = arr[0];
  assert(x.n == 1, "x intact");
}

// --- T0599: bare-T RHS assigned to an Optional[T] fixed-array slot. Pre-fix
// the IndexExpr-LHS path in genAssignStmt had no Optional-wrap (the MemberExpr
// and IdentExpr paths did), so `arr[i] = bareValue` panicked at codegen with
// "store operands are not compatible: src=T; dst={i1,T}*". These exercise the
// natural form a user writes; zero-leak + PAL double-free guard verify the
// pre-wrap claimStringTemp / post-wrap claimHeapTemp ownership handoff.

// Heap user type: bare _BoxA → _BoxA? slot. Post-wrap claimHeapTemp must
// claim the ctor temp via its {i1,{vtable,instance}} struct-extraction path.
test_bare_heap_user_to_optional_slot() `test {
  _BoxA? a = _BoxA(n: 7);
  _BoxA? b = _BoxA(n: 8);
  _BoxA?[2] arr = [a, b];
  arr[0] = _BoxA(n: 99);
  assert(arr[0] is present, "slot 0 present after bare assign");
  assert(arr[1] is present, "slot 1 untouched");
}

// String: bare heap-string concat temp → string? slot. The old slot value is
// dropped via promise_string_drop; the new temp must be claimed BEFORE the
// Optional wrap (val identity changes after wrapOptional).
test_bare_string_to_optional_slot() `test {
  string sa = "al" + "pha";
  string sb = "be" + "ta";
  string? oa = sa;
  string? ob = sb;
  string?[2] arr = [oa, ob];
  arr[0] = "ne" + "w";
  assert(arr[0] is present, "slot 0 present after bare-string assign");
  assert(arr[1] is present, "slot 1 untouched");
}

// Container: bare Vector[int] → Vector[int]? slot. Exercises the container
// branch of the pre-wrap temp claim.
test_bare_vector_to_optional_slot() `test {
  Vector[int] v0 = Vector[int]();
  v0.push(1);
  Vector[int] v1 = Vector[int]();
  v1.push(2);
  Vector[int]? a = v0;
  Vector[int]? b = v1;
  Vector[int]?[2] arr = [a, b];
  Vector[int] v2 = Vector[int]();
  v2.push(42);
  arr[0] = v2;
  assert(arr[0] is present, "slot 0 present after bare-vector assign");
  assert(arr[1] is present, "slot 1 untouched");
}

// Regression guard: `arr[i] = none` must keep working (the exprType==TypNone
// guard skips the wrap; none is handled as zeroinit by genExpr).
test_none_to_optional_slot() `test {
  _BoxA? a = _BoxA(n: 1);
  _BoxA? b = _BoxA(n: 2);
  _BoxA?[2] arr = [a, b];
  arr[0] = none;
  assert(arr[0] is absent, "slot 0 cleared to none");
  assert(arr[1] is present, "slot 1 untouched");
}

// Field-array: bare _BoxA → _BoxA? slot via the MemberExpr→IndexExpr LHS form
// (h.data[0] = ...). Same IndexExpr branch; one fix covers local + field.
test_field_arr_bare_to_optional_slot() `test {
  _BoxA? a = _BoxA(n: 7);
  _BoxA? b = _BoxA(n: 8);
  _HolderOptBox h = _HolderOptBox(data: [a, b]);
  h.data[0] = _BoxA(n: 99);
  assert(h.data[0] is present, "field slot 0 present after bare assign");
  assert(h.data[1] is present, "field slot 1 untouched");
}

// Arc: bare Arc → Ref[int]? slot. Exercises the types.IsArc(exprType)
// disjunct of the T0599 pre-wrap claim (only string & Vector were covered by
// the cases above). Arc is refcounted — a missed pre-wrap claim would
// leak/double-decrement; the zero-tolerance leak policy verifies the handoff.
test_bare_arc_to_optional_slot() `test {
  Ref[int]? a = Ref[int](1);
  Ref[int]? b = Ref[int](2);
  Ref[int]?[2] arr = [a, b];
  arr[0] = Ref[int](99);
  assert(arr[0] is present, "arc slot 0 present after bare assign");
  assert(arr[0]!.borrow == 99, "arc slot 0 value");
  assert(arr[1] is present, "arc slot 1 untouched");
}

// Channel: bare channel → channel[int]? slot. Exercises the
// types.IsChannel(exprType) disjunct of the T0599 pre-wrap claim.
test_bare_channel_to_optional_slot() `test {
  channel[int]? a = channel[int]();
  channel[int]? b = channel[int]();
  channel[int]?[2] arr = [a, b];
  arr[0] = channel[int]();
  assert(arr[0] is present, "chan slot 0 present after bare assign");
  assert(arr[1] is present, "chan slot 1 untouched");
}

// Generic typeSubst path: a generic free function whose body assigns a bare
// T into a T?[N] slot — exercises the `c.typeSubst != nil` branch of the
// T0599 block (slotType/exprType types.Substitute), which no other case
// covers. Instantiated with both a primitive (int) and a heap type (string).
_set_opt_arr_first[T](T move x) bool {
  T? z0 = none;
  T? z1 = none;
  T?[2] a = [z0, z1];
  a[0] = x;
  return a[0] is present;
}

test_bare_generic_typeparam_to_optional_slot() `test {
  assert(_set_opt_arr_first[int](7), "generic int slot present");
  assert(_set_opt_arr_first[string]("hi" + "!"), "generic string slot present");
}

// T0595: push on a nested slice (arr[i].push) — previously panicked in codegen.
// The grown inner Vector's pointer is stored back into the array slot.

test_nested_push_fixed_array() `test {
  // Fixed array of Vectors: push into one slot, verify the right slot grew and
  // the other slot is untouched (slot independence).
  Vector[int][2] arr = [Vector[int](), Vector[int]()];
  arr[1].push(99);
  assert(arr[1].len == 1, "slot 1 grew");
  assert(arr[1][0] == 99, "slot 1 value");
  assert(arr[0].len == 0, "slot 0 untouched");
  arr[0].push(7);
  arr[0].push(8);
  assert(arr[0].len == 2, "slot 0 grew independently");
  assert(arr[0][0] == 7, "slot 0 value 0");
  assert(arr[0][1] == 8, "slot 0 value 1");
  assert(arr[1].len == 1, "slot 1 still independent");
}

test_nested_pop_remove_fixed_array() `test {
  // pop()/remove() on a slot exercise the same store-back path (bonus paths).
  Vector[int][2] arr = [Vector[int](), Vector[int]()];
  arr[0].push(10);
  arr[0].push(20);
  arr[0].push(30);
  popped := arr[0].pop();
  assert(popped! == 30, "popped last");
  assert(arr[0].len == 2, "len after pop");
  arr[0].remove(0);
  assert(arr[0].len == 1, "len after remove");
  assert(arr[0][0] == 20, "value after remove");
  assert(arr[1].len == 0, "other slot untouched");
}

test_nested_push_vector_of_vectors() `test {
  // Vector of Vectors: push into a heap-stored inner Vector slot.
  Vector[int][] vov = [Vector[int](), Vector[int]()];
  vov[0].push(1);
  vov[0].push(2);
  vov[1].push(42);
  assert(vov[0].len == 2, "vov[0] grew");
  assert(vov[0][0] == 1, "vov[0][0]");
  assert(vov[0][1] == 2, "vov[0][1]");
  assert(vov[1].len == 1, "vov[1] grew independently");
  assert(vov[1][0] == 42, "vov[1][0]");
}

test_nested_push_inner_realloc() `test {
  // Force the inner Vector to realloc (grow past its initial capacity) and
  // verify the stored-back relocated pointer is read correctly afterwards.
  Vector[int][] vov = [Vector[int]()];
  i := 0;
  while (i < 200) {
    vov[0].push(i * 2);
    i = i + 1;
  }
  assert(vov[0].len == 200, "inner len after realloc");
  assert(vov[0][0] == 0, "first element after realloc");
  assert(vov[0][199] == 398, "last element after realloc");
  assert(vov[0][100] == 200, "middle element after realloc");
}

type T0595Counter {
  int n;
  // `next` mutates and returns the pre-increment value, so two evaluations of the
  // same call yield different indices.
  next(~this) int {
    v := this.n;
    this.n = v + 1;
    return v;
  }
}

test_nested_push_impure_index_evaluated_once() `test {
  // T0595: the receiver index must be evaluated exactly once. A naive store-back
  // that recomputes the slot re-runs the index: the grown buffer lands in the
  // WRONG slot, the real slot dangles at the freed pre-push buffer (use-after-free
  // + leak). With one evaluation the same slot is read and written back.
  T0595Counter c = T0595Counter(n: 0);
  Vector[int][] vov = [Vector[int](), Vector[int]()];
  vov[c.next()].push(99);
  assert(c.n == 1, "index evaluated exactly once");
  assert(vov[0].len == 1, "the evaluated slot grew");
  assert(vov[0][0] == 99, "the evaluated slot holds the pushed value");
  assert(vov[1].len == 0, "the other slot is untouched");
}

test_nested_index_assign_fixed_array() `test {
  // T0595 bonus path: index-assign into a nested slice (arr[i][j] = x) reaches
  // storeBackSlicePtr's IndexExpr case (slot store-back via the assignment route,
  // not the push receiver route). Pre-fix this panicked the same way as push.
  Vector[int][2] arr = [Vector[int](), Vector[int]()];
  arr[0].push(1);
  arr[0].push(2);
  arr[0][1] = 20;
  assert(arr[0][0] == 1, "slot 0 elem 0 preserved");
  assert(arr[0][1] == 20, "slot 0 elem 1 reassigned");
  assert(arr[1].len == 0, "slot 1 untouched");
}

test_nested_index_assign_vector_of_vectors() `test {
  // Same store-back path for a heap-stored inner Vector slot.
  Vector[int][] vov = [Vector[int](), Vector[int]()];
  vov[1].push(5);
  vov[1].push(6);
  vov[1][0] = 50;
  assert(vov[1][0] == 50, "vov[1] elem 0 reassigned");
  assert(vov[1][1] == 6, "vov[1] elem 1 preserved");
  assert(vov[0].len == 0, "vov[0] untouched");
}

// T0595: nested push reached from a monomorphized generic body — the receiver's
// outer-container type is substituted before genIndexSlotPtr computes the slot
// (exercises the c.typeSubst != nil prologue). Verifies the slot store-back is
// correct under monomorphization for both Vector-of-Vectors and array-of-Vectors,
// and for a droppable element type (string) so the no-leak gate covers it.

push_into_vov[T](Vector[Vector[T]] vov, int i, T val) {
  vov[i].push(val);
}

push_into_arr[T](Vector[T][2] arr, int i, T val) {
  arr[i].push(val);
}

test_generic_nested_push_vov_int() `test {
  Vector[Vector[int]] vov = [Vector[int](), Vector[int]()];
  push_into_vov[int](vov, 1, 7);
  assert(vov[1].len == 1, "generic slot grew");
  assert(vov[1][0] == 7, "generic slot value");
  assert(vov[0].len == 0, "other generic slot untouched");
}

test_generic_nested_push_vov_string() `test {
  Vector[Vector[string]] vov = [Vector[string]()];
  push_into_vov[string](vov, 0, "hi" + "!");
  assert(vov[0].len == 1, "generic string slot grew");
  assert(vov[0][0] == "hi!", "generic string slot value");
}

test_generic_nested_push_fixed_array() `test {
  Vector[int][2] arr = [Vector[int](), Vector[int]()];
  push_into_arr[int](arr, 0, 42);
  assert(arr[0].len == 1, "generic array slot grew");
  assert(arr[0][0] == 42, "generic array slot value");
  assert(arr[1].len == 0, "other generic array slot untouched");
}

// ---------------------------------------------------------------------------
// T1176: reading a whole fixed-Array[heap-user] field out by value and letting
// it escape (return / store-to-outer / constructor field / move-param) must
// element-wise deep-clone. Before the fix genFieldAccess aliased the
// [N x {vtable,instance}] aggregate and the owner's synth drop freed each
// element at scope exit while the escaped copy still pointed in → UAF/segfault.
// ---------------------------------------------------------------------------

type _T1176Row {
  string name;
}
type _T1176Wrap {
  _T1176Row[2] rows;
}

// return-escape sink: build the owner locally, return its whole array field.
_t1176_esc() _T1176Row[2] {
  _T1176Wrap w = _T1176Wrap(rows: [_T1176Row(name: "de" + "ep"), _T1176Row(name: "x" + "x")]);
  return w.rows; // owner w dropped at scope exit; returned copy must be independent
}

test_t1176_return_array_field_escape() `test {
  _T1176Row[2] r = _t1176_esc();
  assert(r[0].name == "deep", "return: elem 0 survives owner drop");
  assert(r[1].name == "xx", "return: elem 1 survives owner drop");
}

// store-to-outer sink: `out = w.rows` while w drops at the inner block exit.
test_t1176_store_to_outer_array_field() `test {
  _T1176Row[2] out = [_T1176Row(name: "a" + "a"), _T1176Row(name: "b" + "b")];
  {
    _T1176Wrap w = _T1176Wrap(rows: [_T1176Row(name: "de" + "ep"), _T1176Row(name: "x" + "x")]);
    out = w.rows; // drop-old of out + clone of w.rows; w freed at block exit
  }
  assert(out[0].name == "deep", "store: elem 0 survives owner drop");
  assert(out[1].name == "xx", "store: elem 1 survives owner drop");
}

// constructor-field sink (owning position): sema requires `move w.rows`, so
// ownership TRANSFERS into Outer (no clone — the owner's synth drop skips the
// moved-out field). Balance check: no double-free, no leak of the elements.
type _T1176Outer {
  _T1176Row[2] held;
}

_t1176_wrap_into_outer() _T1176Outer {
  _T1176Wrap w = _T1176Wrap(rows: [_T1176Row(name: "de" + "ep"), _T1176Row(name: "x" + "x")]);
  return _T1176Outer(held: move w.rows); // ownership moves into Outer; w's drop skips rows
}

test_t1176_constructor_field_move() `test {
  _T1176Outer o = _t1176_wrap_into_outer();
  assert(o.held[0].name == "deep", "ctor: moved elem 0 intact");
  assert(o.held[1].name == "xx", "ctor: moved elem 1 intact");
}

// move-param sink (owning position): sema requires `move w.rows` — ownership
// transfers into the callee, w is consumed. Balance check: no double-free/leak.
_t1176_consume(_T1176Row[2] move rows) string {
  return rows[0].name + "/" + rows[1].name;
}

test_t1176_move_param() `test {
  _T1176Wrap w = _T1176Wrap(rows: [_T1176Row(name: "de" + "ep"), _T1176Row(name: "x" + "x")]);
  string s = _t1176_consume(move w.rows); // ownership moves into callee
  assert(s == "deep/xx", "move-param: callee sees moved elements");
}

// no-drop-but-pal-free element parity: a heap-user type with only scalar fields
// has no synth drop but is still pal_free'd, exercising the isHeapUserNoDropPalFree
// branch of arrayHeapDupElem (droppable-element tests above miss it).
type _T1176Plain {
  int n;
}
type _T1176PlainWrap {
  _T1176Plain[2] cells;
}

_t1176_esc_plain() _T1176Plain[2] {
  _T1176PlainWrap w = _T1176PlainWrap(cells: [_T1176Plain(n: 11), _T1176Plain(n: 22)]);
  return w.cells;
}

test_t1176_nodrop_palfree_element_escape() `test {
  _T1176Plain[2] c = _t1176_esc_plain();
  assert(c[0].n == 11, "nodrop: elem 0 survives owner drop");
  assert(c[1].n == 22, "nodrop: elem 1 survives owner drop");
}

// in-scope control: reading an element of the array field WITHOUT escaping must
// stay zero-copy and leak-clean (guards against over-eager cloning).
test_t1176_inscope_no_overclone() `test {
  _T1176Wrap w = _T1176Wrap(rows: [_T1176Row(name: "de" + "ep"), _T1176Row(name: "x" + "x")]);
  assert(w.rows[0].name == "deep", "in-scope read elem 0");
  assert(w.rows[1].name == "xx", "in-scope read elem 1");
}

// Variant-payload sink parity: the T1176 fix lives in the SHARED
// dupHeapFieldForEscape array branch, so a whole Array[heap-user] match-borrowed
// variant payload escaping an `if is`/`match` (genIdentExpr, line ~1063) is
// deep-cloned too — the subject enum's synth drop frees the originals at scope
// exit while the returned copy stays valid. (Distinct from T1173, which tracks
// the string[N]/Vector[N]-element variant payload — deliberately out of scope of
// arrayHeapDupElem, still aliased.)
// The subject enum is built and OWNED inside the function so it is dropped at
// scope exit — forcing the escaped array to be an independent clone (an alias
// would be a UAF once the returned copy is read by the caller).
enum _T1176Holder {
  Pair(_T1176Row[2] rows), Empty,
}

_t1176_variant_if_is() _T1176Row[2] {
  _T1176Holder h = _T1176Holder.Pair(rows: [_T1176Row(name: "de" + "ep"), _T1176Row(name: "x" + "x")]);
  if h is Pair(rows) {
    return rows; // aliases h's payload; h dropped at scope exit → must clone
  }
  return[_T1176Row(name: "z" + "z"), _T1176Row(name: "y" + "y")];
}

test_t1176_variant_payload_whole_array_escape_if_is() `test {
  _T1176Row[2] r = _t1176_variant_if_is();
  assert(r[0].name == "deep", "variant if-is: elem 0 survives subject drop");
  assert(r[1].name == "xx", "variant if-is: elem 1 survives subject drop");
}

_t1176_variant_match() _T1176Row[2] {
  _T1176Holder h = _T1176Holder.Pair(rows: [_T1176Row(name: "fo" + "o"), _T1176Row(name: "ba" + "r")]);
  match h {
    Pair(rows) => {
      return rows;
    },
    Empty => {
      return[_T1176Row(name: "z" + "z"), _T1176Row(name: "y" + "y")];
    },
  }
}

test_t1176_variant_payload_whole_array_escape_match() `test {
  _T1176Row[2] r = _t1176_variant_match();
  assert(r[0].name == "foo", "variant match: elem 0 survives subject drop");
  assert(r[1].name == "bar", "variant match: elem 1 survives subject drop");
}

// Generic-field escape: the array element type is a type parameter (`T[2]`)
// resolved to a heap-user type at mono time. This exercises the `typeSubst`
// substitution branch of arrayHeapDupElem — the concrete-field tests above have
// no active substitution, so the field type is already `_T1176Row[2]` and the
// substitute path is never taken. The escaped clone must still be independent.
type _T1176GenHolder[T] {
  T[2] data;
}

_t1176_esc_generic() _T1176Row[2] {
  _T1176GenHolder[_T1176Row] h = _T1176GenHolder[_T1176Row](data: [_T1176Row(name: "de" + "ep"), _T1176Row(name: "x" + "x")]);
  return h.data; // owner h dropped at scope exit; T resolves to _T1176Row → must clone
}

test_t1176_generic_array_field_escape() `test {
  _T1176Row[2] r = _t1176_esc_generic();
  assert(r[0].name == "deep", "generic: elem 0 survives owner drop");
  assert(r[1].name == "xx", "generic: elem 1 survives owner drop");
}

// Deep sub-field clone: the escaping element is a heap-user type whose own field
// is a droppable container (Vector). A shallow per-element alias would leave the
// clone's Vector pointing at the owner's storage — freed by the owner's synth
// drop at scope exit (UAF) or double-freed. dupHeapValue must recurse into the
// element's droppable sub-fields, so the returned copy owns independent vectors.
type _T1176Cell {
  Vector[int] xs;
  drop(~this) {
  }
}
type _T1176CellWrap {
  _T1176Cell[2] cells;
}

_t1176_esc_deep() _T1176Cell[2] {
  Vector[int] a = Vector[int]();
  a.push(1);
  a.push(2);
  Vector[int] b = Vector[int]();
  b.push(9);
  _T1176CellWrap w = _T1176CellWrap(cells: [_T1176Cell(xs: move a), _T1176Cell(xs: move b)]);
  return w.cells; // must deep-clone each _T1176Cell AND its Vector sub-field
}

test_t1176_deep_subfield_clone_escape() `test {
  _T1176Cell[2] r = _t1176_esc_deep();
  assert(r[0].xs.len == 2, "deep: cell 0 vector length independent");
  assert(r[0].xs[0] == 1, "deep: cell 0 elem 0");
  assert(r[0].xs[1] == 2, "deep: cell 0 elem 1");
  assert(r[1].xs[0] == 9, "deep: cell 1 elem 0");
}
