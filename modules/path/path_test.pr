// Test the path module (compiled as part of the module).

join_test() `test {
    assert(join("/home", "user") == "/home/user", "join basic");
    assert(join("/home/", "user") == "/home/user", "join trailing slash");
    assert(join("", "file") == "file", "join empty base");
    assert(join("/home", "") == "/home", "join empty child");
    assert(join("/home", "user", "file.txt") == "/home/user/file.txt", "join three");
    assert(join("/", "a", "b", "c") == "/a/b/c", "join four");
}

file_name_test() `test {
    assert(file_name("/home/user/file.txt") == "file.txt", "file_name file");
    assert(file_name("/home/user/") == "user", "file_name trailing slash");
    assert(file_name("file.txt") == "file.txt", "file_name no dir");
    assert(file_name("/") == "", "file_name root");
    assert(file_name("") == "", "file_name empty");
}

parent_test() `test {
    assert(parent("/home/user/file.txt") == "/home/user", "parent basic");
    assert(parent("file.txt") == ".", "parent no dir");
    assert(parent("/file.txt") == "/", "parent root file");
    assert(parent("") == ".", "parent empty");
}

extension_test() `test {
    assert(extension("file.txt") == ".txt", "ext basic");
    assert(extension("archive.tar.gz") == ".gz", "ext double");
    assert(extension("Makefile") == "", "ext none");
    assert(extension(".hidden") == "", "ext dot file");
}

stem_test() `test {
    assert(stem("file.txt") == "file", "stem basic");
    assert(stem("archive.tar.gz") == "archive.tar", "stem double");
    assert(stem("Makefile") == "Makefile", "stem no ext");
}

is_absolute_test() `test {
    assert(is_absolute("/home"), "abs /home");
    assert(!is_absolute("home"), "rel home");
    assert(!is_absolute(""), "empty not abs");
}

is_relative_test() `test {
    assert(is_relative("home/user"), "rel basic");
    assert(!is_relative("/home"), "abs not rel");
}
