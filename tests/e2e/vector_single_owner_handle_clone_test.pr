// T0545: containers transitively containing a single-owner native handle
// (Task/Mutex/MutexGuard) are non-cloneable. The unsound paths
// (Vector[Task].clone()/.filled(), Map[K,Task].clone(), nested
// Vector[Vector[Task]]) are rejected at sema with clean errors — those
// negative cases live in sema_test.go (TestT0545_*) since a compile-fail
// cannot be a batch test. This file pins the *positive* runtime behavior
// that must keep working: T0508 flat move-only handle collections, and
// clone() on refcounted (Arc/Channel) handle vectors which are duplicable
// and must NOT be gated. Zero leaks (T0067).
worker_t0545() int {
  return 42;
}

// --- T0508: flat Vector[Task[int]] push / literal / iterate / scope-exit drop
// (awaiting a vector-held Task then drop is the separate pre-existing T0617) ---

test_flat_task_vec_push() `test(exclude: wasm) {
  v := Vector[Task[int]]();
  v.push(go worker_t0545());
  v.push(go worker_t0545());
  assert(v.len == 2, "task vec len");
}

test_flat_task_vec_literal() `test(exclude: wasm) {
  v := [go worker_t0545(), go worker_t0545()];
  assert(v.len == 2, "task literal len");
}

// Iterate a flat Vector[Task] without awaiting (awaiting a vector-held Task
// then scope-exit drop double-frees — separate pre-existing bug T0617).
test_flat_task_vec_iterate() `test(exclude: wasm) {
  v := [go worker_t0545(), go worker_t0545(), go worker_t0545()];
  int count = 0;
  for handle in v {
    count = count + 1;
  }
  assert(count == 3, "iterated count");
}

// Explicit Vector[Task[int]] type annotation (direct handle element OK).
test_explicit_task_vec_type() `test(exclude: wasm) {
  Vector[Task[int]] v = Vector[Task[int]]();
  v.push(go worker_t0545());
  assert(v.len == 1, "explicit task vec len");
}

// --- Refcounted handles are duplicable — clone() must NOT be gated ---

test_arc_vec_clone() `test {
  v := Vector[Ref[int]]();
  v.push(Ref[int](7));
  v2 := v.clone();
  assert(v2.len == 1, "arc clone len");
  assert(v2[0].borrow == 7, "arc clone shares value");
  assert(v.len == 1, "arc src intact");
}

test_channel_vec_clone() `test {
  v := Vector[Channel[int]]();
  v.push(Channel[int]());
  v2 := v.clone();
  assert(v2.len == 1, "channel clone len");
  assert(v.len == 1, "channel src intact");
}

// A tuple element containing only a refcounted handle is duplicable — the
// non-cloneable rule must NOT over-gate it. firstSingleOwnerHandle recurses
// the tuple, finds Arc (refcounted, not single-owner), and returns nil.
test_tuple_arc_vec_clone() `test {
  v := Vector[(Ref[int], int)]();
  v.push((Ref[int](7), 1));
  v2 := v.clone();
  assert(v2.len == 1, "tuple arc clone len");
  assert(v.len == 1, "tuple arc src intact");
}

// T1099: dropping the source vector must NOT free the cloned tuple's Ref — the
// clone must hold an INDEPENDENT strong reference. The `.len`-only test above
// could never catch the shallow-copy bug (refcount stays 1 → silent double-drop
// nets alloc_count to 0 → no leak/abort). This observes ownership via a Weak:
// after the source is consumed/dropped, the weak still upgrades because the
// clone keeps the value alive. With the bug, the source drop frees the inner
// Ref (refcount 0) → upgrade returns none AND the later read/clone-drop is UAF.
consume_tuple_ref_vec(Vector[(Ref[int], int)] ~v) {
  // v (and its tuple's Ref) drops at the end of this function.
}

test_tuple_ref_clone_independent_ownership() `test {
  r := Ref[int](7);
  w := r.downgrade();
  v := Vector[(Ref[int], int)]();
  v.push((r, 1));
  v2 := v.clone();
  consume_tuple_ref_vec(v); // drop the source; clone must keep the Ref alive
  alive := false;
  if strong := w.upgrade() {
    alive = strong.borrow == 7;
  }
  assert(alive, "clone keeps independent strong ref after source drop");
  // The value is still readable through the clone itself.
  (cr, cn) := v2[0];
  assert(cr.borrow == 7, "clone tuple Ref value");
  assert(cn == 1, "clone tuple int value");
}

// T1099: enum variant carrying a tuple-of-Ref, cloned inside a Vector, must
// deep-clone the tuple's Ref. This enum has no synthesized clone() method, so
// Vector clone routes through dupEnumElementInPlace → emitVariantFieldDup, whose
// tuple case (the compiler.go half of the fix) deep-clones the Ref. Without it
// the cloned variant's Ref aliases the source → double-free at scope exit.
enum _T1099Holder[T] {
  _Empty, _Pair((Ref[T], int) pair),
}

test_tuple_ref_in_enum_variant_clone() `test {
  v := Vector[_T1099Holder[int]]();
  v.push(_T1099Holder[int]._Pair((Ref[int](9), 2)));
  v2 := v.clone();
  assert(v2.len == 1, "enum-tuple vec clone len");
  match v2[0] {
    _Pair(p) => {
      (pr, pn) := p;
      assert(pr.borrow == 9, "cloned variant tuple Ref value");
      assert(pn == 2, "cloned variant tuple int value");
    },
    _Empty => assert(false, "expected _Pair"),
  }
  assert(v.len == 1, "enum-tuple vec src intact");
}

// T1099: tuple-of-Ref as a Map value (direct, not wrapped in an enum) must
// deep-clone the Ref on Map.clone() — exercises the Map-value clone path.
test_tuple_ref_map_value_clone() `test {
  m := Map[int, (Ref[int], int)]();
  m[1] = (Ref[int](5), 3);
  m2 := m.clone();
  assert(m2.len == 1, "tuple-ref map clone len");
  (mr, mn) := m2[1]!;
  assert(mr.borrow == 5, "cloned map tuple Ref value");
  assert(mn == 3, "cloned map tuple int value");
  assert(m.len == 1, "tuple-ref map src intact");
}

// T1099: tuple field that is a STRING (not Ref) — exercises dupTupleValue's
// dupString branch (the Ref tests above all take the maybeDupPushElement `else`
// branch). Without a per-element clone the cloned tuple's heap string would
// alias the source's → double-free at scope exit. The "x"+"y" forces a heap
// (non-literal) string so the alias would actually be freed twice.
test_tuple_string_vec_clone() `test {
  v := Vector[(string, int)]();
  v.push(("he" + "llo", 1));
  v2 := v.clone();
  (a, b) := v2[0];
  assert(a == "hello", "cloned tuple string value");
  assert(b == 1, "cloned tuple int value");
  v2.push(("world", 2)); // mutate clone only
  assert(v2.len == 2 && v.len == 1, "clone independent of source");
}

// T1099: NESTED vector of tuple-of-Ref — Vector[Vector[(Ref,int)]].clone()
// recurses through emitVectorElementCloneLoop (outer isVector branch → inner
// clone loop → tuple branch → dupTupleValue → Ref dup). Proves the tuple case
// composes with the existing nested-container recursion.
test_nested_vec_tuple_ref_clone() `test {
  r := Ref[int](3);
  w := r.downgrade();
  v := Vector[Vector[(Ref[int], int)]]();
  inner := Vector[(Ref[int], int)]();
  inner.push((r, 30));
  v.push(move inner);
  v2 := v.clone();
  consume_nested_tuple_ref_vec(v); // drop source; clone must keep Ref alive
  alive := false;
  if strong := w.upgrade() {
    alive = strong.borrow == 3;
  }
  assert(alive, "nested clone keeps independent strong ref after source drop");
  (cr, cn) := v2[0][0];
  assert(cr.borrow == 3, "nested clone tuple Ref value");
  assert(cn == 30, "nested clone tuple int value");
}

consume_nested_tuple_ref_vec(Vector[Vector[(Ref[int], int)]] ~v) {
  // v and its nested tuple Refs drop here.
}

// T1099 acceptance #4: slice of a tuple-of-Ref vector must deep-clone the inner
// Ref (slice `[:]` pushes each element into a fresh vector). Source and slice
// must own independent strong references.
test_tuple_ref_vec_slice() `test {
  v := Vector[(Ref[int], int)]();
  v.push((Ref[int](1), 10));
  v.push((Ref[int](2), 20));
  s := v[0:1];
  assert(s.len == 1, "slice len");
  (a, b) := s[0];
  assert(a.borrow == 1 && b == 10, "slice tuple value");
  assert(v.len == 2, "slice source intact");
}

// T1099 acceptance #4: Vector.filled with a tuple-of-Ref must deep-clone the
// Ref for each of the `count` copies — otherwise the single source value's Ref
// is aliased `count` times → multi-free at scope exit.
test_tuple_ref_vec_filled() `test {
  v := Vector[(Ref[int], int)].filled((Ref[int](5), 7), 3);
  assert(v.len == 3, "filled len");
  (a0, b0) := v[0];
  (a2, b2) := v[2];
  assert(a0.borrow == 5 && b0 == 7, "filled[0] value");
  assert(a2.borrow == 5 && b2 == 7, "filled[2] value");
}

// A vector whose elements are plain cloneable values still clones deeply.
test_string_vec_clone_unaffected() `test {
  v := ["a", "b", "c"];
  v2 := v.clone();
  v2.push("d");
  assert(v2.len == 4, "clone is independent");
  assert(v.len == 3, "original unchanged");
}

// --- Optional[Task[T]] standalone (not a container element) — T0558 ---

test_optional_task_standalone() `test(exclude: wasm) {
  Task[int]? opt = go worker_t0545();
  // opt drops at scope exit — awaits worker and frees G.
}

// === T0482/T0619: positive runtime controls for the deep non-cloneable
// predicate (firstNestedSingleOwnerHandle). The negative cases (clone/filled/
// slice/push/match of a value transitively owning a single-owner handle
// through a user-type field or enum variant) are clean sema errors pinned in
// sema_test.go (TestT0482_*). These pin the behavior that must NOT regress:
// the predicate must yield nil for cloneable shapes, and fresh-temp moves of
// handle-owning user types must still work. Zero leaks (T0067). ===

type T0482Wrap {
  Ref[int] a;
}

// A user type owning only a refcounted handle (Arc) is cloneable — the deep
// predicate must skip the std Arc origin and return nil, so native vector
// clone() stays valid and deep-copies independently.
test_t0482_arc_field_vec_clone() `test {
  v := Vector[T0482Wrap]();
  v.push(T0482Wrap(a: Ref[int](7)));
  v2 := v.clone();
  assert(v2.len == 1, "arc-field wrap clone len");
  assert(v2[0].a.borrow == 7, "arc-field wrap clone shares value");
  assert(v.len == 1, "arc-field wrap src intact");
}

type T0482Holder {
  Task[int] t;
}

// Pushing a freshly-constructed handle-owning value is a MOVE (not an implicit
// clone) and must stay valid — the vector drops each Holder at scope exit,
// which drops the owned Task exactly once (no double-free, zero leaks).
test_t0482_fresh_named_handle_push() `test(exclude: wasm) {
  dest := Vector[T0482Holder]();
  dest.push(T0482Holder(t: go worker_t0545()));
  dest.push(T0482Holder(t: go worker_t0545()));
  assert(dest.len == 2, "fresh holder push len");
}

enum T0482Str {
  Empty, Has(string v),
}

// A string-variant enum match-destructure is safe — strings are deep-copied
// (dupString), so the deep predicate yields nil for string. Must compile and
// run, copying the bound string independently of the subject.
test_t0482_string_variant_match() `test {
  s := T0482Str.Has("hello");
  string got = "";
  match s {
    T0482Str.Empty => assert(false, "unexpected empty"),
    T0482Str.Has(x) => {
      got = x;
    },
  }
  assert(got == "hello", "string variant copied");
}

type T0482Node {
  T0482Node? next;
  int v;
}

// A recursive user type with NO handle must clone cleanly inside a native
// container — proves firstNestedSingleOwnerHandle's cycle guard terminates
// without a false positive.
test_t0482_recursive_named_no_handle_clone() `test {
  v := Vector[T0482Node]();
  v.push(T0482Node(next: none, v: 1));
  v2 := v.clone();
  assert(v2.len == 1, "recursive node clone len");
  assert(v2[0].v == 1, "recursive node clone value");
  assert(v.len == 1, "recursive node src intact");
}

enum T0482IsHeld {
  Empty, Held(Task[int] t),
}

// A single-owner-handle (Task) payload of an `is`-destructure binding is NOT
// dup-cloneable, so codegen's bindIsDestructureEnum does a plain non-owning
// load+store and registers NO drop binding — only the subject drops the handle
// (exactly once). T1012 made `is`-destructure dup *heap* payloads (string/vector)
// for escape safety, but explicitly gates that on FirstNestedSingleOwnerHandle:
// handle fields must stay a borrow. This pins that structural-safety invariant —
// if a future change dropped that gate, cloneResolvedValue on a Task would crash
// / double-free. Zero leaks (T0067).
test_t0482_enum_is_destructure_handle() `test(exclude: wasm) {
  e := T0482IsHeld.Held(go worker_t0545());
  if e is Held(tk) {
    assert(true, "enum is-destructure binds handle non-owningly");
  }
  // e drops here: the variant's Task is awaited + freed exactly once.
}

type T0482IsBox {
  int kind;
  Task[int] t;
}

// Same invariant for a named-type RTTI `is`-destructure binding all fields
// (including a Task field). The binding `tk` aliases but does not own the
// handle; only `b` drops it. Zero leaks (T0067).
test_t0482_named_is_destructure_handle() `test(exclude: wasm) {
  T0482IsBox b = T0482IsBox(kind: 7, t: go worker_t0545());
  if b is T0482IsBox(k, tk) {
    assert(k == 7, "named is-destructure binds handle non-owningly");
  }
  // b drops here: its Task is awaited + freed exactly once.
}
