// Round-trip with methods

round_trip_method_test() `test {
  map[string, JsonValue] fields = {
    "items": JsonValue.Array([JsonValue.Number(1.0), JsonValue.Number(2.0)]),
    "ok": JsonValue.Bool(true),
  };
  JsonValue obj = JsonValue.Object(move fields);
  string s = obj.format()?!;
  JsonValue parsed = parse_value(move s)?!;
  assert(parsed.is_object, "round trip is object");
  assert(parsed.get("ok") is present, "round trip has ok");
  assert(parsed.get("items") is present, "round trip has items");
}

// Chained method calls

chained_access_test() `test {
  // Build: {"user": {"name": "Alice", "scores": [10, 20]}}
  map[string, JsonValue] user_fields = {
    "name": JsonValue.Str("Alice"),
    "scores": JsonValue.Array([JsonValue.Number(10.0), JsonValue.Number(20.0)]),
  };
  map[string, JsonValue] root_fields = {
    "user": JsonValue.Object(move user_fields),
  };
  JsonValue root = JsonValue.Object(move root_fields);

  // Access nested value: root.get("user").get("name")
  JsonValue? user = root.get("user");
  assert(user is present, "chained: has user");
  JsonValue? name = user!.get("name");
  assert(name is present, "chained: has name");
  assert(name!.as_string()! == "Alice", "chained: name is Alice");

  // Access nested array element
  JsonValue? scores = user!.get("scores");
  assert(scores is present, "chained: has scores");
  JsonValue? first = scores!.at(0);
  assert(first is present, "chained: has first score");
  assert(first!.as_number()! == 10.0, "chained: first score is 10");
}

as_bool_false_test() `test {
  // Verify as_bool returns false (not just "present") for Bool(false)
  bool? b = JsonValue.Bool(false).as_bool();
  assert(b is present, "as_bool(false) present");
  assert(b! == false, "as_bool(false) value is false");
}

as_number_edge_cases_test() `test {
