// --- T0479 coverage: failable generator with owned param ---

type T0479Err is error {
  string detail;
}

t0479_failable_owned!(~string s) stream[int] {
  yield 1;
  yield 2;
}

t0479_failable_raise!(~string s) stream[int] {
  yield 1;
  raise T0479Err(message: "boom", detail: "mid");
}

t0479_collect_failable_owned!() int {
  int total = 0;
  for x in t0479_failable_owned("a".to_string())?^ {
    total = total + x;
  }
  return total;
}

t0479_break_failable_owned!() int {
  for x in t0479_failable_owned("b".to_string())?^ {
    return 1;
  }
  return 0;
}

t0479_run_failable_raise!() int {
  int total = 0;
  for x in t0479_failable_raise("c".to_string())?^ {
    total = total + x;
  }
  return total;
}

test_t0479_failable_owned_break() `test {
  int n = t0479_break_failable_owned()?!;
  assert(n == 1, "break path should return 1");
}

test_t0479_failable_owned_run() `test {
  int sum = t0479_collect_failable_owned()?!;
  assert(sum == 3, "failable owned generator should yield 1+2");
}

test_t0479_failable_raise_propagate() `test {
  bool caught = false;
  t0479_run_failable_raise()? e {
    caught = true;
  };
  assert(caught, "mid-stream raise should propagate");
}

