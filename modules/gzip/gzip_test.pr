gunzip_corrupt_crc_test() `test {
  // Same as gunzip_hello_test but with CRC trailer XOR'd to break it.
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  raw.push(0xCB);
  raw.push(0x48);
  raw.push(0xCD);
  raw.push(0xC9);
  raw.push(0xC9);
  raw.push(0x07);
  raw.push(0x00);
  raw.push(0xFF);
  raw.push(0xA6);
  raw.push(0x10);
  raw.push(0x36);
  raw.push(0x05);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "corrupt CRC raises");
}

gunzip_truncated_test() `test {
  // Just the magic + CM, no body.
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "truncated stream raises");
}
