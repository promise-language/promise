// Test char equality, comparisons, and range operators
test_equality() `test {
  assert('a' == 'a', "'a' == 'a'");
  assert(!('a' == 'b'), "!('a' == 'b')");
  assert('a' != 'b', "'a' != 'b'");
  assert(!('x' != 'x'), "!('x' != 'x')");
}

test_comparisons() `test {
  assert('a' < 'b', "'a' < 'b'");
  assert('z' > 'a', "'z' > 'a'");
  assert('a' <= 'a', "'a' <= 'a'");
  assert('a' <= 'b', "'a' <= 'b'");
  assert('z' >= 'z', "'z' >= 'z'");
  assert('z' >= 'a', "'z' >= 'a'");
}

test_escape_chars() `test {
  assert('\n' != '\t', "newline != tab");
  assert('\\' == '\\', "backslash == backslash");
  assert('\'' == '\'', "quote == quote");
  assert('\0' != 'a', "null != a");
}

// --- Hash ---

test_hash() `test {
  assert('a'.hash == 'a'.hash, "char hash consistent");
  assert('a'.hash != 'b'.hash, "different chars different hash");
  assert('z'.hash != 'A'.hash, "z != A hash");
  int h = 'x'.hash;
  assert(h == 'x'.hash, "hash via variable");
}

// --- Char ranges ---

test_char_range() `test {
  int count = 0;
  for c in 'a'..'d' {
    count++;
  }
  assert(count == 3, "char range 'a'..'d' has 3 elements");
}

test_char_range_inclusive() `test {
  int count = 0;
  for c in 'a'..='d' {
    count++;
  }
  assert(count == 4, "char range 'a'..='d' has 4 elements");
}
