// B0170: String temp tracking must not double-free when temps are stored in containers.
// Push a string concatenation result into a vector — the temp ownership transfers to the vector.
push_string_concat_temp() `test {
  string[] v = string[]();
  v.push("hello " + "world");
  assert(v.len == 1, "len");
  assert(v[0] == "hello world", "value");
}

// Push a to_string() result into a vector.
push_to_string_temp() `test {
  string[] v = string[]();
  v.push(42.to_string());
  assert(v.len == 1, "len");
  assert(v[0] == "42", "value");
}

// Push multiple string temps into a vector.
push_multiple_string_temps() `test {
  string[] v = string[]();
  v.push("a" + "b");
  v.push("c" + "d");
  v.push(99.to_string());
  assert(v.len == 3, "len");
  assert(v[0] == "ab", "v0");
  assert(v[1] == "cd", "v1");
  assert(v[2] == "99", "v2");
}

// Mix of literal and temp pushes.
push_mixed_literal_and_temp() `test {
  string[] v = string[]();
  v.push("literal");
  v.push("concat" + "ed");
  assert(v.len == 2, "len");
  assert(v[0] == "literal", "v0");
  assert(v[1] == "concated", "v1");
}
