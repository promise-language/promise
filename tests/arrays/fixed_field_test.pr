// Fixed-size array as struct field
type Grid {
  int[3] data;
}

main() `test(expected: """1
2
3
42
2
3
15
3
20""") {
  // Read array field elements
  g := Grid(data: [1, 2, 3]);
  print_line("{g.data[0]}");
  print_line("{g.data[1]}");
  print_line("{g.data[2]}");

  // Write array field element
  g.data[0] = 42;
  print_line("{g.data[0]}");
  print_line("{g.data[1]}");
  print_line("{g.data[2]}");

  // Compound assign to array field element
  g.data[0] += -27;
  print_line("{g.data[0]}");

  // Field array .len
  print_line("{g.data.len}");

  // For-in over field array
  int sum = 0;
  for x in g.data {
    sum += x;
  }
  print_line("{sum}");
}
