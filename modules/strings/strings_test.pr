// Test the strings module (compiled as part of the module).
join_basic() `test(allow_leaks: true) {
  assert(join(", ", "a", "b", "c") == "a, b, c", "join basic");
}

join_empty() `test(allow_leaks: true) {
  assert(join(",") == "", "join empty");
}

join_single() `test(allow_leaks: true) {
  assert(join(",", "hello") == "hello", "join single");
}

join_vector_passthrough() `test(allow_leaks: true) {
  string[] parts = ["x", "y", "z"];
  assert(join("-", parts) == "x-y-z", "join vector passthrough");
}

join_empty_separator() `test(allow_leaks: true) {
  assert(join("", "a", "b", "c") == "abc", "join empty separator");
}

join_two_args() `test(allow_leaks: true) {
  assert(join("|", "x", "y") == "x|y", "join two args");
}

reverse_basic() `test(allow_leaks: true) {
  assert(reverse("hello") == "olleh", "reverse basic");
}

reverse_empty() `test(allow_leaks: true) {
  assert(reverse("") == "", "reverse empty");
}

reverse_single() `test(allow_leaks: true) {
  assert(reverse("x") == "x", "reverse single");
}

is_blank_spaces() `test(allow_leaks: true) {
  assert(is_blank("   "), "blank spaces");
}

is_blank_empty() `test(allow_leaks: true) {
  assert(is_blank(""), "blank empty");
}

is_blank_tabs_newlines() `test(allow_leaks: true) {
  assert(is_blank("\t\n\r "), "blank tabs newlines");
}

is_blank_false() `test(allow_leaks: true) {
  assert(!is_blank("hi"), "not blank hi");
  assert(!is_blank(" x "), "not blank x");
}

spaces_test() `test(allow_leaks: true) {
  assert(spaces(0) == "", "spaces 0");
  assert(spaces(3) == "   ", "spaces 3");
}

repeat_join_test() `test(allow_leaks: true) {
  assert(repeat_join("ab", 3, "-") == "ab-ab-ab", "repeat_join 3");
  assert(repeat_join("x", 1, ",") == "x", "repeat_join 1");
  assert(repeat_join("x", 0, ",") == "", "repeat_join 0");
}
