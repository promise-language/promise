// Select with default: no channel is ready, default case executes.
main() `test(expected: "default") {
  ch1 := channel[int](capacity: 1);
  ch2 := channel[int](capacity: 1);

  // Neither channel has data
  select {
    v := <-ch1:
    print_line(1);
    v := <-ch2:
    print_line(2);
    default:
    print_line("default");
  }
}
