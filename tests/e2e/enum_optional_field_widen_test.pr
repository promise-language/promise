// T0608: Constructing an enum variant whose field is `T?` (Optional) by
// passing a bare non-optional value (implicit `T` -> `T?` widening) or a
// `none` literal must work, mirroring the struct-constructor Optional path.
// Covers copy inner (int) and droppable inner (string, int[], map[K,V]),
// the bare-widen / none-literal / explicit-`T?` construction paths, plus a
// generic enum `Box[T]` with a `T?` field. Match-destructures each and
// asserts the value; runs under leak enforcement (must report 0 leaks).
enum MaybeInt {
  Slot(int? v),
  Empty,
}

enum MaybeStr {
  Slot(string? v),
  Empty,
}

enum MaybeVec {
  Slot(int[]? v),
  Empty,
}

enum MaybeMap {
  Slot(map[string, int]? v),
  Empty,
}

enum Box[T] {
  Full(T? v),
  Vacant,
}

type Pt {
  int x;
  int y;
}

enum Mixed {
  Pair(int? a, string b),
  Boxed(Pt? p),
  Nada,
}

// --- copy inner (int): bare-value widening ---

int_bare_widen() `test {
  MaybeInt j = MaybeInt.Slot(5);
  match j {
    MaybeInt.Slot(s) => {
      if v := s {
        assert(v == 5, "bare-widened int? holds 5");
      } else {
        assert(false, "expected present int?");
      }
    },
    MaybeInt.Empty => assert(false, "expected Slot"),
  }
}

// --- copy inner (int): none literal ---

int_none_literal() `test {
  MaybeInt j = MaybeInt.Slot(none);
  match j {
    MaybeInt.Slot(s) => {
      if v := s {
        assert(false, "expected absent int?");
      }
    },
    MaybeInt.Empty => assert(false, "expected Slot"),
  }
}

// --- copy inner (int): explicit T? arg (must stay unwrapped, no regression) ---

int_explicit_optional() `test {
  int? o = 7;
  MaybeInt j = MaybeInt.Slot(o);
  match j {
    MaybeInt.Slot(s) => {
      if v := s {
        assert(v == 7, "explicit int? holds 7");
      } else {
        assert(false, "expected present int?");
      }
    },
    MaybeInt.Empty => assert(false, "expected Slot"),
  }
}

// --- droppable inner (string): bare-value widening ---

string_bare_widen() `test {
  MaybeStr j = MaybeStr.Slot("hello");
  match j {
    MaybeStr.Slot(s) => {
      if v := s {
        assert(v == "hello", "bare-widened string? holds hello");
      } else {
        assert(false, "expected present string?");
      }
    },
    MaybeStr.Empty => assert(false, "expected Slot"),
  }
}

// --- droppable inner (string): expression temp must not leak/double-free ---

string_expr_temp() `test {
  MaybeStr j = MaybeStr.Slot("ab".to_upper());
  match j {
    MaybeStr.Slot(s) => {
      if v := s {
        assert(v == "AB", "string? holds AB");
      } else {
        assert(false, "expected present string?");
      }
    },
    MaybeStr.Empty => assert(false, "expected Slot"),
  }
}

// --- droppable inner (string): none literal ---

string_none_literal() `test {
  MaybeStr j = MaybeStr.Slot(none);
  match j {
    MaybeStr.Slot(s) => {
      if v := s {
        assert(false, "expected absent string?");
      }
    },
    MaybeStr.Empty => assert(false, "expected Slot"),
  }
}

// --- droppable inner (int[]): bare-value widening ---

vec_bare_widen() `test {
  int[] data = [1, 2, 3];
  MaybeVec j = MaybeVec.Slot(move data);
  match j {
    MaybeVec.Slot(s) => {
      if v := s {
        assert(v.len == 3, "bare-widened int[]? has 3 elements");
        assert(v[0] == 1, "first element");
        assert(v[2] == 3, "last element");
      } else {
        assert(false, "expected present int[]?");
      }
    },
    MaybeVec.Empty => assert(false, "expected Slot"),
