use propmod "./propmod";

// Test reading a module-level getter returning a constant.
test_getter_constant() `test {
  string msg = propmod.greeting;
  assert(msg == "hello from propmod", "greeting should match");
}

// Test reading a computed getter.
test_getter_computed() `test {
  int val = propmod.answer;
  assert(val == 42, "answer should be 42");
}

// Test that regular functions still work alongside getters.
test_regular_function() `test {
  int sum = propmod.add(3, 4);
  assert(sum == 7, "add(3, 4) should be 7");
}

// Test failable getter with ! unwrap (success case).
test_failable_getter_success() `test {
  string val = propmod.safe_value?!;
  assert(val == "safe", "safe_value should return 'safe'");
}

// Test failable getter that raises (error handling with ? handler).
test_failable_getter_raises() `test {
  string result = propmod.risky_value? e {
    "recovered";
  };
  assert(result == "recovered", "should recover from risky_value");
}

// Test failable getter with auto-propagation in failable function.
_check_risky!() string {
  string val = propmod.risky_value;
  return val;
}

test_failable_getter_propagation() `test {
  string result = _check_risky()? e {
    "propagated";
  };
  assert(result == "propagated", "should propagate error from risky_value");
}

// Test optional getter (present case).
test_optional_getter_present() `test {
  string? val = propmod.maybe_value;
  assert(val is present, "maybe_value should be present");
  if v := val {
    assert(v == "present", "maybe_value should be 'present'");
  }
}

// Test optional getter (absent case).
test_optional_getter_absent() `test {
  string? val = propmod.empty_value;
  assert(val is absent, "empty_value should be absent");
}

// T1240: getter returning a vector — must still bind and read correctly.
test_getter_vector() `test {
  int[] v = propmod.nums;
  assert(v.len == 3, "nums should have 3 elements");
  assert(v[0] == 1 && v[2] == 3, "nums contents");
}

// T1240: getter returning a user struct — must still bind correctly.
test_getter_struct() `test {
  p := propmod.origin;
  assert(p.x == 4 && p.y == 5, "origin should be (4, 5)");
}

// T1250: getter returning a heap user type used as a BARE TEMPORARY (result not
// bound to a variable). The owned instance allocation must be freed at statement
// end — this leaked before the fix (leak check enforces this).
test_getter_struct_temp() `test {
  assert(propmod.origin.x == 4, "origin.x should be 4");
}

// T1250: bare-discard form — the heap instance the getter allocates must be freed
// even though nothing reads it (leak check enforces this).
test_getter_struct_discard() `test {
  propmod.origin;
}

// T1250: temporary heap-user-type getter result read in a loop — each iteration
// allocates a fresh instance that must be freed at statement end (leak check
// enforces no accumulation across 100 iterations).
test_getter_struct_temp_loop() `test {
  int total = 0;
  for i in 0..100 {
    total = total + propmod.origin.x;
  }
  assert(total == 400, "100 * 4");
}

// T1250: module getter returning a HEAP-built vector used as a bare temporary
// (result not bound). The vector's heap buffer must be freed at statement end.
// Before the shared getter-result tracking, the module-getter path only handled
// heap user types, so this leaked (leak check enforces this).
test_getter_dynvec_temp() `test {
  assert(propmod.built_nums.len == 3, "built_nums should have 3 elements");
}

// T1250: bare-discard form of the heap-vector getter — buffer must be freed even
// though nothing reads it.
test_getter_dynvec_discard() `test {
  propmod.built_nums;
}

// T1250: module getter returning a buffered channel used as a bare temporary.
// The channel's heap allocation (and any buffered item) must be freed at
// statement end. Before the shared getter-result tracking this leaked.
test_getter_channel_temp() `test {
  if v := <-propmod.numbers {
    assert(v == 99, "channel should yield 99");
  }
}

// T1250: bare-discard form of the channel getter — the channel and its one
// buffered item must be freed even though nothing receives from it.
test_getter_channel_discard() `test {
  propmod.numbers;
}

// T0137/T1250: module getter returning a HEAP string used as a bare temporary
// (result not bound). The heap-allocated buffer must be freed at statement end —
// exercises the string arm of the shared getter-result tracking on the module
// path (leak check enforces this).
test_getter_string_temp() `test {
  assert(propmod.built_greeting.len == 15, "built_greeting should be 15 chars");
}

// T0137/T1250: bare-discard form of the heap-string getter — buffer must be freed
// even though nothing reads it.
test_getter_string_discard() `test {
  propmod.built_greeting;
}

// T0137/T1250: heap-string getter result read in a loop — each iteration allocates
// a fresh string that must be freed at statement end (no accumulation over 100).
test_getter_string_temp_loop() `test {
  int total = 0;
  for i in 0..100 {
    total = total + propmod.built_greeting.len;
  }
  assert(total == 1500, "100 * 15");
}

// T1240: getter whose return type is a function type, built from a CAPTURING
// closure — bind-and-call. This used to panic codegen.
test_getter_function_capturing() `test {
  f := propmod.adder;
  assert(f() == 42, "adder() should be 42");
}

// T1240: same getter, result DISCARDED — the owned closure env must be freed
// (leak check enforces this).
test_getter_function_capturing_discard() `test {
  propmod.adder;
}

// T1240: function-typed getter built from a NON-capturing closure — bind-and-call.
test_getter_function_plain() `test {
  f := propmod.plain_fn;
  assert(f() == 7, "plain_fn() should be 7");
}

// T1240: non-capturing function-typed getter, result DISCARDED.
test_getter_function_plain_discard() `test {
  propmod.plain_fn;
}

// T1240: repeatedly reading + calling a capturing function-typed getter in a
// loop. Each read allocates a fresh closure env that must be freed at the end
// of every iteration — stresses the env-temp ownership path (leak check
// enforces no accumulation across 100 iterations).
test_getter_function_loop() `test {
  int total = 0;
  for i in 0..100 {
    f := propmod.adder;
    total = total + f();
  }
  assert(total == 4200, "100 * 42");
}

// T1240: reassigning a function-typed variable that holds a getter's owned
// closure. The old capturing env must be freed at the reassignment before the
// new (non-capturing) closure is stored — single free of each env.
test_getter_function_reassign() `test {
  f := propmod.adder;
  assert(f() == 42, "capturing first");
  f = propmod.plain_fn;
  assert(f() == 7, "non-capturing after reassign");
}

// T1251: DIRECT-CALL form — `propmod.adder()` invokes the *returned* closure
// (a getter is accessed without parens; the `()` calls the closure it yields).
// This previously panicked in codegen (the `()` was treated as the getter's own
// call, producing the closure struct where its int result was expected). The
// capturing env is materialized and freed inline (leak check enforces this).
test_getter_function_direct_call_capturing() `test {
  assert(propmod.adder() == 42, "adder() should be 42");
}

// T1251: same direct-call form for the NON-capturing getter (env field is null).
test_getter_function_direct_call_plain() `test {
  assert(propmod.plain_fn() == 7, "plain_fn() should be 7");
}

// T1251: direct-call result assigned to an int — used to panic with
// `store { i8*, i8* } into i64*`.
test_getter_function_direct_call_assign() `test {
  int x = propmod.adder();
  assert(x == 42, "assigned adder() should be 42");
}

// T1251: bare direct-call discard — the closure env allocated by the getter must
// still be freed even though the int result is unused (leak check enforces this).
test_getter_function_direct_call_discard() `test {
  propmod.adder();
}

// T1251: direct-call in a loop — each call allocates a fresh capturing env that
// must be freed at statement end (leak check enforces no accumulation).
test_getter_function_direct_call_loop() `test {
  int total = 0;
  for i in 0..100 {
    total = total + propmod.adder();
  }
  assert(total == 4200, "100 * 42");
}

// T1251: direct call passing an argument to the returned closure — exercises the
// argument-coercion arm (`coerceIndirectCallArgs`) of the indirect dispatch.
test_getter_function_direct_call_with_arg() `test {
  assert(propmod.scaler(5) == 50, "scaler(5) should be 50");
  int total = 0;
  for i in 0..10 {
    total = total + propmod.scaler(i);
  }
  assert(total == 450, "sum of 10*i for i in 0..10");
}

// T1251: direct call issued from inside a generic (monomorphized) function body —
// exercises the `c.typeSubst != nil` substitution arm of the direct-call path,
// which the top-level call sites above never reach.
call_getter_in_generic[T](T dummy) int {
  return propmod.adder();
}

call_scaler_in_generic[T](T dummy, int n) int {
  return propmod.scaler(n);
}

test_getter_function_direct_call_in_generic() `test {
  assert(call_getter_in_generic[int](0) == 42, "generic-context adder() should be 42");
  assert(call_getter_in_generic[bool](true) == 42, "second monomorphization should be 42");
  assert(call_scaler_in_generic[int](0, 7) == 70, "generic-context scaler(7) should be 70");
}

// T1272: a module-level getter returning a fresh heap Builder, passed as a bare
// temporary into a `~` (MutRef) parameter. This is the `mod.prop` member form of
// the T1272 fix — it routes through isMemberGetter's `ModuleGetters` branch to
// the materialize-and-track path (a getter member is not an lvalue, so it must be
// materialized into a temp alloca and dropped at statement end). Before the fix
// the temp was materialized for the callee but never drop-registered → leak.
_emit_via_mutref!(Writer ~out, string msg) `doc("Writes msg via a coerced Writer view.") {
  out.write_line(msg);
}

test_module_getter_into_mutref() `test {
  _emit_via_mutref(propmod.fresh_builder, "x")? e {
    assert(false, "unexpected error");
    return;
  };
}

// T1272: same module-getter `~`-param temp read in a loop — each iteration
// materializes a fresh Builder that must be dropped at statement end (leak check
// enforces no accumulation across 100 iterations).
test_module_getter_into_mutref_loop() `test {
  for i in 0..100 {
    _emit_via_mutref(propmod.fresh_builder, "x")? e {
      assert(false, "unexpected error");
      return;
    };
  }
}
