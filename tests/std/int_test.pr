// Test int arithmetic, comparisons, and unary operators
//
test_addition() `test(allow_leaks: true) {
  assert(1 + 2 == 3, "1 + 2 == 3");
  assert(0 + 0 == 0, "0 + 0 == 0");
  assert(100 + 200 == 300, "100 + 200 == 300");
  assert(0 - 1 + 1 == 0, "-1 + 1 == 0");
}

test_subtraction() `test(allow_leaks: true) {
  assert(5 - 3 == 2, "5 - 3 == 2");
  assert(0 - 5 + 5 == 0, "0 - 5 + 5 == 0");
  assert(10 - 10 == 0, "10 - 10 == 0");
}

test_multiplication() `test(allow_leaks: true) {
  assert(3 * 4 == 12, "3 * 4 == 12");
  assert(0 * 100 == 0, "0 * 100 == 0");
  assert(7 * 1 == 7, "7 * 1 == 7");
  assert((0 - 2) * 3 == 0 - 6, "-2 * 3 == -6");
}

test_division() `test(allow_leaks: true) {
  assert(10 / 2 == 5, "10 / 2 == 5");
  assert(7 / 3 == 2, "7 / 3 == 2 (integer division)");
  assert(0 / 5 == 0, "0 / 5 == 0");
  assert((0 - 10) / 2 == 0 - 5, "-10 / 2 == -5");
}

test_modulo() `test(allow_leaks: true) {
  assert(10 % 3 == 1, "10 % 3 == 1");
  assert(15 % 5 == 0, "15 % 5 == 0");
  assert(7 % 2 == 1, "7 % 2 == 1");
}

test_comparisons() `test(allow_leaks: true) {
  assert(1 < 2, "1 < 2");
  assert(!(2 < 1), "!(2 < 1)");
  assert(2 > 1, "2 > 1");
  assert(!(1 > 2), "!(1 > 2)");
  assert(1 <= 1, "1 <= 1");
  assert(1 <= 2, "1 <= 2");
  assert(2 >= 2, "2 >= 2");
  assert(3 >= 1, "3 >= 1");
}

test_equality() `test(allow_leaks: true) {
  assert(42 == 42, "42 == 42");
  assert(!(1 == 2), "!(1 == 2)");
  assert(1 != 2, "1 != 2");
  assert(!(5 != 5), "!(5 != 5)");
}

test_unary_negation() `test(allow_leaks: true) {
  int x = 5;
  assert(-x == 0 - 5, "-x == -5");
  assert(-(-x) == 5, "-(-x) == 5");
  assert(-0 == 0, "-0 == 0");
}

test_increment_decrement() `test(allow_leaks: true) {
  int x = 5;
  x++;
  assert(x == 6, "x++ makes 6");
  x--;
  assert(x == 5, "x-- makes 5");
  x--;
  assert(x == 4, "x-- makes 4");
}

test_compound_assignment() `test(allow_leaks: true) {
  int x = 10;
  x += 5;
  assert(x == 15, "+= 5");
  x -= 3;
  assert(x == 12, "-= 3");
  x *= 2;
  assert(x == 24, "*= 2");
  x /= 4;
  assert(x == 6, "/= 4");
  x %= 4;
  assert(x == 2, "%= 4");
}

test_bitwise_and() `test(allow_leaks: true) {
  assert(12 & 10 == 8, "12 & 10 == 8");
  assert(0xFF & 0x0F == 0x0F, "0xFF & 0x0F == 0x0F");
  assert(0 & 100 == 0, "0 & x == 0");
  assert(7 & 7 == 7, "x & x == x");
}

test_bitwise_or() `test(allow_leaks: true) {
  assert(5 | 3 == 7, "5 | 3 == 7");
  assert(0 | 42 == 42, "0 | x == x");
  assert(0xF0 | 0x0F == 0xFF, "0xF0 | 0x0F == 0xFF");
}

test_bitwise_xor() `test(allow_leaks: true) {
  assert(12 ^ 10 == 6, "12 ^ 10 == 6");
  assert(0xFF ^ 0xFF == 0, "x ^ x == 0");
  assert(0 ^ 42 == 42, "0 ^ x == x");
}

test_left_shift() `test(allow_leaks: true) {
  assert(1 << 0 == 1, "1 << 0 == 1");
  assert(1 << 4 == 16, "1 << 4 == 16");
  assert(3 << 2 == 12, "3 << 2 == 12");
  assert(1 << 10 == 1024, "1 << 10 == 1024");
}

test_right_shift() `test(allow_leaks: true) {
  assert(16 >> 2 == 4, "16 >> 2 == 4");
  assert(1024 >> 10 == 1, "1024 >> 10 == 1");
  assert(255 >> 4 == 15, "255 >> 4 == 15");
  // Arithmetic right shift preserves sign for signed ints
  assert((0 - 8) >> 1 == 0 - 4, "-8 >> 1 == -4");
}

test_bitwise_not() `test(allow_leaks: true) {
  assert(~0 == 0 - 1, "~0 == -1");
  assert(~(0 - 1) == 0, "~(-1) == 0");
  assert(~~42 == 42, "~~x == x");
}

test_bitwise_precedence() `test(allow_leaks: true) {
  // Shift binds tighter than additive
  assert(1 + 1 << 2 == 1 + 4, "1 + (1 << 2) == 5");
  // Bitwise binds tighter than comparison
  assert(3 & 1 == 1, "(3 & 1) == 1");
  // Bitwise ops are same precedence, left-to-right
  assert((5 | 3) & 6 == 6, "(5|3) & 6 == 6");
}

// --- Range operators ---

test_range_exclusive() `test(allow_leaks: true) {
  int sum = 0;
  for i in 1..5 {
    sum += i;
  }
  assert(sum == 10, "1..5 sum == 10");
}

test_range_inclusive() `test(allow_leaks: true) {
  int sum = 0;
  for i in 1..=5 {
    sum += i;
  }
  assert(sum == 15, "1..=5 sum == 15");
}

test_range_single_element() `test(allow_leaks: true) {
  int count = 0;
  for _ in 0..1 {
    count++;
  }
  assert(count == 1, "0..1 one iteration");
}

test_range_empty() `test(allow_leaks: true) {
  int count = 0;
  for _ in 5..5 {
    count++;
  }
  assert(count == 0, "5..5 zero iterations");
}

test_range_variable_bounds() `test(allow_leaks: true) {
  int start = 3;
  int end = 6;
  int sum = 0;
  for i in start..end {
    sum += i;
  }
  assert(sum == 12, "3..6 sum == 12");
}
