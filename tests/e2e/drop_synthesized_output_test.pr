// B0158: Verify synthesized drop infrastructure exists (drop is registered but
// body is a no-op until ownership tracking enables safe field cleanup — B0160).
type Inner {
  string name;

  drop(~this) {
    print_line("drop: " + this.name);
  }
}

type Outer {
  Inner inner;
}

main() `test(expected: "value: world") {
  o := Outer(inner: Inner(name: "world"));
  print_line("value: " + o.inner.name);
}
