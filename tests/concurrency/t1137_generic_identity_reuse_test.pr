// T1137: a generic function/method that returns its borrowed (non-`move`) param,
// instantiated over a BARE single-owner handle (task/Mutex/MutexGuard), makes the
// call result an alias of the caller's source local. A SINGLE use of the result
// is sound (codegen clears the source's drop flag), but REUSING the source local
// after the aliasing call is a use-after-free — the handle was already consumed.
//
// The reuse-after-alias forms are now rejected at compile time by the ownership
// pass (covered by internal/ownership/t1137_test.go). These runtime tests prove
// the fix does NOT over-reject the still-valid paths and that they stay
// leak-free: single use of the result, reusing a NON-returned param, and
// reusing the source after reassigning it to a fresh handle.
worker() int {
  return 42;
}

identity[T](T x) T {
  return x;
}

// Wraps a positive int as a present Optional (for while-unwrap tests); a
// non-positive value yields the empty case, ending the loop.
some_positive(int v) int? {
  if (v > 0) {
    return v;
  }
  return none;
}

// Valid: single use of the aliased result — the deliberately-supported form.
t1137_single_use_task() `test {
  task[int] t = go worker();
  int r = <-identity(t);
  assert(r == 42, "single-use generic identity over task");
}

// Valid: pick_first returns `a`; reusing the NON-returned param `t2` is sound —
// t2 was never aliased into the result. Precision guard (t1 would be rejected).
pick_first[T](T a, T b) T {
  return a;
}

t1137_pick_first_reuse_non_returned() `test {
  task[int] t1 = go worker();
  task[int] t2 = go worker();
  int r = <-pick_first(t1, t2);
  int r2 = <-t2;
  assert(r == 42, "pick_first returned param");
  assert(r2 == 42, "reuse non-returned param");
}

// Valid: reassigning the source to a FRESH handle before the later use — the
// later `<-t` awaits the new handle, not the consumed one.
t1137_reassign_then_use() `test {
  task[int] t = go worker();
  int r = <-identity(t);
  t = go worker();
  int r2 = <-t;
  assert(r == 42, "aliased result");
  assert(r2 == 42, "reassigned fresh handle");
}

// Valid: single use of the aliased result over a Mutex handle — the non-task
// single-owner-handle kind. The source `m` is aliased into `m2` and never
// reused; `m2` is locked once and dropped. Confirms the Mutex path stays
// leak-free at runtime (the Go tests only assert compile-time acceptance).
t1137_single_use_mutex() `test {
  Mutex[int] m = Mutex[int](5);
  Mutex[int] m2 = identity(m);
  use g := m2.lock();
  assert(g.borrow == 5, "single-use generic identity over Mutex");
}

// T1255 (Fix A): mutually-exclusive branches each alias the handle once. Only
// one branch runs, so there is no reuse-after-alias — the flow-insensitive
// textual heuristic used to over-reject the else-branch `<-t`. Now valid.
t1255_branch_reuse_ok() `test {
  bool cond = true;
  task[int] t = go worker();
  int r = 0;
  if (cond) {
    r = <-identity(t);
  } else {
    r = <-t;
  }
  assert(r == 42, "mutually-exclusive branch alias");
}

// T1255 (Fix B precision): reassign a FRESH handle at the top of each iteration,
// then alias it once. The top-level rebind dominates the loop back-edge, so each
// iteration consumes its own handle — no cross-iteration reuse. Must stay valid
// and leak-free.
t1255_loop_reassign_per_iteration_ok() `test {
  task[int] t = go worker();
  int last = 0;
  for i in 0..3 {
    t = go worker();
    last = <-identity(t);
  }
  assert(last == 42, "fresh handle reassigned each iteration");
}

// T1255 (Fix B precision): a handle declared INSIDE the loop body is a fresh
// binding each iteration — aliasing it once per iteration is sound.
t1255_loop_declared_in_body_ok() `test {
  int last = 0;
  for i in 0..3 {
    task[int] t = go worker();
    last = <-identity(t);
  }
  assert(last == 42, "handle declared in loop body");
}

// T1256 (residual to T1255): once-eval loop positions must NOT be flagged. The
// for-in ITERABLE is evaluated exactly once before the first iteration, so
// aliasing the handle there is a single sound use — the ownership pass leaves it
// outside the loop frame. The receive joins the aliased task exactly once, so
// this stays valid and leak-free.
t1256_forin_iterable_alias_once_ok() `test {
  task[int] t = go worker();
  int sum = 0;
  for x in[<-identity(t)] {
    sum = sum + x;
  }
  assert(sum == 42, "for-in iterable aliased once (once-eval, outside frame)");
}

// T1256: a fresh handle rebound at the top of each body iteration dominates the
// back-edge, so aliasing it in the NEXT iteration's while CONDITION is sound. The
// freshBound shield covers the condition alias. Must stay valid and leak-free.
t1256_while_cond_fresh_rebind_ok() `test {
  task[int] t = go worker();
  int i = 0;
  while (<-identity(t) == 42 && i < 3) {
    i = i + 1;
    t = go worker();
  }
  assert(i == 3, "condition alias with fresh handle reassigned each iteration");
}

// NOTE: a classic-for CONDITION runtime test (`for task[int] t = go worker();
// <-identity(t) == 42 && ...; ...`) is deliberately omitted here: a single-owner
// handle *declared in the classic-for init* and consumed in the condition
// segfaults/deadlocks at runtime — a distinct codegen bug (T1257), not a
// T1256 ownership issue. The while-equivalent (handle declared before the loop)
// works and is covered by t1256_while_cond_fresh_rebind_ok above.

// T1256: fresh-rebind shield for the while-unwrap VALUE position. The unwrapped
// value re-aliases t each iteration, but the body rebinds t to a fresh handle
// that dominates the back-edge, so every alias joins a distinct task once.
t1256_while_unwrap_value_fresh_rebind_ok() `test {
  task[int] t = go worker();
  int n = 0;
  while v := some_positive(<-identity(t)) {
    n = n + 1;
    t = go worker();
    if (n >= 3) {
      break;
    }
  }
  assert(n == 3, "while-unwrap value alias with fresh handle each iteration");
}
