// T0579: Fixed-size array fields with non-primitive element types.
// Before T0579, `instanceFieldLLVMType` had no Array recursion case so any
// non-primitive element (heap user / Optional / value-type) made the field
// slot type `[N x i8*]`, mismatching the array-literal expression layout and
// crashing `NewStore` in `genConstructorCallMono`. After T0579, layouts agree
// and droppable elements are released by a new `emitFieldDropsFor` branch.
type _Box {
  int n;
  drop(~this) {
  }
}

type _HolderBox {
  _Box[2] data;
}

test_heap_box_in_array_field() `test {
  _HolderBox h = _HolderBox(data: [_Box(n: 1), _Box(n: 2)]);
  assert(h.data[0].n == 1, "first box n");
  assert(h.data[1].n == 2, "second box n");
}

type _BoxA {
  int n;
  drop(~this) {
  }
}

type _HolderOptBox {
  _BoxA?[2] data;
}

test_optional_heap_box_in_array_field() `test {
  // Direct repro from T0579.
  _BoxA? a = _BoxA(n: 7);
  _BoxA? b = _BoxA(n: 8);
  _HolderOptBox h = _HolderOptBox(data: [a, b]);
  assert(h.data[0] is present, "first slot present");
  assert(h.data[1] is present, "second slot present");
}

test_optional_heap_box_array_field_with_none() `test {
  // One slot populated, one absent — exercises both Optional branches inside
  // the drop walk.
  _BoxA? a = _BoxA(n: 11);
  _BoxA? b = none;
  _HolderOptBox h = _HolderOptBox(data: [a, b]);
  assert(h.data[0] is present, "filled slot present");
  assert(h.data[1] is absent, "empty slot absent");
}

type _HolderPoint {
  Point[int][2] data;
}

test_value_type_point_in_array_field() `test {
  _HolderPoint h = _HolderPoint(data: [Point[int](x: 1, y: 2), Point[int](x: 3, y: 4)]);
  assert(h.data[0].x == 1, "p0.x");
  assert(h.data[0].y == 2, "p0.y");
  assert(h.data[1].x == 3, "p1.x");
  assert(h.data[1].y == 4, "p1.y");
}

type _MixedFields {
  int[3] nums;
  string label;
}

test_mixed_array_and_string_fields() `test {
  // Non-droppable element type (int) in an array field on a type that ALSO has
  // a droppable string field — confirms the new Array branch doesn't crash and
  // that string drop still fires for the sibling field.
  _MixedFields m = _MixedFields(nums: [10, 20, 30], label: "test");
  assert(m.nums[0] == 10, "n0");
  assert(m.nums[2] == 30, "n2");
  assert(m.label == "test", "label");
}

type _TupArr {
  (string, int)[2] data;
}

test_tuple_element_in_array_field() `test {
  // Exercises `typeNeedsFieldDrop`'s Tuple branch — predicate must recognise
  // that the array's element tuple holds a droppable string and emit drops.
  _TupArr t = _TupArr(data: [("a", 1), ("b", 2)]);
  (s0, n0) := t.data[0];
  (s1, n1) := t.data[1];
  assert(n0 == 1, "first elem int");
  assert(n1 == 2, "second elem int");
  assert(s0 == "a", "first elem string");
  assert(s1 == "b", "second elem string");
}

type _VecArr {
  Vector[int][2] data;
}

test_vector_element_in_array_field() `test {
  // Exercises `typeNeedsFieldDrop`'s `AsVector` branch — without it the
  // predicate would return false and the inner Vector's heap buffer would leak.
  Vector[int] v0 = Vector[int]();
  v0.push(10);
  Vector[int] v1 = Vector[int]();
  v1.push(20);
  _VecArr v = _VecArr(data: [v0, v1]);
  assert(v.data[0][0] == 10, "v0[0]");
  assert(v.data[1][0] == 20, "v1[0]");
}

type _ChArr {
  channel[int][2] data;
}

test_channel_element_in_array_field() `test {
  // Exercises `typeNeedsFieldDrop`'s `AsChannel` branch.
  channel[int] c0 = channel[int]();
  channel[int] c1 = channel[int]();
  _ChArr c = _ChArr(data: [c0, c1]);
  assert(true, "channels stored in array field");
}

type _Bare {
  int x;
}

type _BareArr {
  _Bare[2] data;
}

test_heap_user_no_drop_element_in_array_field() `test {
  // _Bare has no explicit drop and isn't a value type — exercises the
  // "heap user without explicit drop" branch in `typeNeedsFieldDrop` that
  // must still return true so the per-element `pal_free` fires (otherwise
  // every _Bare instance in the array leaks).
  _BareArr b = _BareArr(data: [_Bare(x: 1), _Bare(x: 2)]);
  assert(b.data[0].x == 1, "first bare");
  assert(b.data[1].x == 2, "second bare");
}

// T0583: `arr[i] = newVal` on a fixed-size array of droppable elements must
// drop the previous slot value, not just overwrite it. Tests below exercise
// every droppable branch reached via emitVariantFieldDrop from
// genArrayIndexAssign, mirroring the drop-on-overwrite behavior already in
// place for Vector and struct field assignment.
//
// Verification strategy: the zero-tolerance leak policy (T0067) already fails
// the test if any allocation is unfreed, so the assertions only need to confirm
// observable post-state (slot present/absent, primitive contents). Reading a
// droppable element back into an owning binding (e.g. `if v := arr[i]`) would
// alias arr's slot — `genArrayIndex` has no dup-on-read — and is intentionally
// out of scope for this fix (noted in T0583's plan; would be a follow-up bug).

test_local_optional_box_array_reassign() `test {
  // Direct T0583 repro — overwrite the second slot with a fresh _BoxA.
  // Pre-fix: leaks the previous _BoxA(n: 2) allocation.
  _BoxA? a = _BoxA(n: 1);
  _BoxA? b = _BoxA(n: 2);
  _BoxA?[2] arr = [a, b];
  _BoxA? c = _BoxA(n: 3);
  arr[1] = c;
  assert(arr[1] is present, "slot 1 still present");
  assert(arr[0] is present, "slot 0 untouched");
}

test_local_optional_box_array_reassign_to_none() `test {
  // Overwrite a present slot with `none` — must drop the previous _BoxA.
  _BoxA? a = _BoxA(n: 5);
  _BoxA? b = _BoxA(n: 6);
  _BoxA?[2] arr = [a, b];
  _BoxA? empty = none;
  arr[0] = empty;
  assert(arr[0] is absent, "slot 0 cleared");
  assert(arr[1] is present, "slot 1 untouched");
}

test_local_optional_box_array_reassign_from_none() `test {
  // Overwrite an absent slot with a present value — drops `none`, no leak.
  _BoxA? a = _BoxA(n: 9);
  _BoxA? b = none;
  _BoxA?[2] arr = [a, b];
  _BoxA? c = _BoxA(n: 10);
  arr[1] = c;
  assert(arr[1] is present, "slot 1 now present");
  assert(arr[0] is present, "slot 0 untouched");
}

test_holder_optional_box_array_field_reassign() `test {
  // Field-arr path through `genArrayBasePtr`'s MemberExpr branch.
  _BoxA? a = _BoxA(n: 21);
  _BoxA? b = _BoxA(n: 22);
  _HolderOptBox h = _HolderOptBox(data: [a, b]);
  _BoxA? c = _BoxA(n: 23);
  h.data[1] = c;
  assert(h.data[1] is present, "field arr slot 1 reassigned");
  assert(h.data[0] is present, "field arr slot 0 untouched");
}

test_local_box_array_reassign() `test {
  // Plain _Box (non-Optional, explicit drop) — exercises the named.HasDrop()
  // branch of emitVariantFieldDrop (drop call + pal_free). Reading .n is safe
  // because n is a value-type field, not the heap instance pointer.
  _Box[2] arr = [_Box(n: 31), _Box(n: 32)];
  _Box c = _Box(n: 33);
  arr[1] = c;
  assert(arr[1].n == 33, "slot 1 reassigned");
  assert(arr[0].n == 31, "slot 0 untouched");
}

test_local_bare_array_reassign() `test {
  // _Bare (heap user, no explicit drop) — exercises the pal_free-only branch.
  _Bare[2] arr = [_Bare(x: 41), _Bare(x: 42)];
  _Bare c = _Bare(x: 43);
  arr[1] = c;
  assert(arr[1].x == 43, "slot 1 reassigned");
  assert(arr[0].x == 41, "slot 0 untouched");
}

test_local_string_array_reassign() `test {
  // string element — exercises promise_string_drop branch.
  string[2] arr = ["alpha", "beta"];
  arr[1] = "gamma";
  assert(arr[1] == "gamma", "slot 1 reassigned");
  assert(arr[0] == "alpha", "slot 0 untouched");
}

test_local_string_array_compound_assign() `test {
  // string compound (+=) — exercises emitStringDropOldValue path.
  string[2] arr = ["foo", "bar"];
  arr[1] += "baz";
  assert(arr[1] == "barbaz", "slot 1 concatenated");
  assert(arr[0] == "foo", "slot 0 untouched");
}

test_local_vector_array_reassign() `test {
  // Vector[int] element — exercises Vector.drop branch. The original Vector
  // at slot 1 had a heap buffer; without drop-on-overwrite, that buffer leaks.
  // No element-read assertions: the fix is verified by leak-free completion.
  Vector[int] v0 = Vector[int]();
  v0.push(100);
  Vector[int] v1 = Vector[int]();
  v1.push(200);
  Vector[int][2] arr = [v0, v1];
  Vector[int] v2 = Vector[int]();
  v2.push(300);
  arr[1] = v2;
  assert(true, "vector reassign completed without leak");
}

test_local_tuple_array_reassign() `test {
  // (string, int) element — exercises tuple-walk branch of
  // emitVariantFieldDrop (drops the old string inside the old tuple). The
  // original "second" string at slot 1 must be released by the tuple-walk
  // path before "third" is stored. Verified by leak-free completion.
  (string, int)[2] arr = [("first", 1), ("second", 2)];
  arr[1] = ("third", 3);
  assert(true, "tuple reassign completed without leak");
}

test_local_arc_array_reassign() `test {
  // Arc[T] element — exercises the AsArc branch of emitVariantFieldDrop
  // (getOrCreateArcDrop). Arc handles refcounted heap allocation; without
  // drop-on-overwrite the original Arc's refcount never reaches zero.
  Arc[int][2] arr = [Arc[int](1), Arc[int](2)];
  Arc[int] c = Arc[int](3);
  arr[1] = c;
  assert(arr[1].borrow == 3, "slot 1 reassigned");
  assert(arr[0].borrow == 1, "slot 0 untouched");
}

test_local_channel_array_reassign() `test {
  // channel[T] element — exercises the AsChannel branch (Channel.drop).
  // The replaced channel's buffer/state must be released.
  channel[int] c0 = channel[int]();
  channel[int] c1 = channel[int]();
  channel[int][2] arr = [c0, c1];
  channel[int] c2 = channel[int]();
  arr[1] = c2;
  assert(true, "channel reassign completed without leak");
}

test_local_mutex_array_reassign() `test {
  // Mutex[T] element — exercises the AsMutex branch (getOrCreateMutexDrop).
  // Mutex owns its inner value's allocation plus the mutex primitive.
  Mutex[int] m0 = Mutex[int](1);
  Mutex[int] m1 = Mutex[int](2);
  Mutex[int][2] arr = [m0, m1];
  Mutex[int] m2 = Mutex[int](3);
  arr[1] = m2;
  use g := arr[1].lock();
  assert(g.borrow == 3, "mutex reassigned, lock works");
}

test_local_mutex_array_lock_on_slot() `test {
  // T0596: positive coverage for `arr[i].lock()`. Method calls on a slot
  // borrow the value rather than moving it — IndexExpr is the receiver, not
  // the consumed value, so the ownership-pass rejection does not fire.
  Mutex[int] m0 = Mutex[int](10);
  Mutex[int] m1 = Mutex[int](20);
  Mutex[int][2] arr = [m0, m1];
  use g0 := arr[0].lock();
  assert(g0.borrow == 10, "slot 0 lock");
}

test_local_mutex_vec_lock_on_slot() `test {
  // T0596: `Vector[Mutex[T]]` slot access via method call. Confirms the
  // single-owner native handle rejection narrows to moves, not borrows.
  // Uses push() rather than a literal to avoid a separate vector-literal
  // codegen issue with Mutex elements (T0602).
  Vector[Mutex[int]] v = Vector[Mutex[int]]();
  v.push(Mutex[int](100));
  v.push(Mutex[int](200));
  use g0 := v[0].lock();
  assert(g0.borrow == 100, "vec slot 0 lock");
}

test_local_task_array_reassign_fresh() `test(exclude: wasm) {
  // T0596: Task[T] slot overwrite with a fresh `go { … }` task. The RHS is a
  // GoExpr, not an IndexExpr, so the rejection does not fire and the existing
  // drop-on-overwrite path releases the old task. Confirm subsequent slot
  // reads do not SEGV — we don't need the awaited values, just that the
  // overwritten slot's allocations stay valid through scope exit drop.
  Task[int] t0 = go {
    1
  };
  Task[int] t1 = go {
    2
  };
  Task[int][2] arr = [t0, t1];
  arr[1] = go {
    99
  };
  assert(true, "task slot 1 reassigned without SEGV");
}

test_local_nested_string_array_reassign() `test {
  // Nested fixed-size array — exercises the Array recursion branch in
  // emitVariantFieldDrop (walks each element of the old inner array and
  // drops it). The replaced row's two strings must both be released.
  string[2] row0 = ["a", "b"];
  string[2] row1 = ["c", "d"];
  string[2][2] arr = [row0, row1];
  string[2] new_row = ["e", "f"];
  arr[1] = new_row;
  assert(arr[1][0] == "e", "slot 1,0");
  assert(arr[1][1] == "f", "slot 1,1");
  assert(arr[0][0] == "a", "slot 0,0 untouched");
}

enum _Status {
  Active(string name),
  Inactive(int id),
}

test_local_enum_array_reassign_across_variants() `test {
  // Enum element with droppable variant data — exercises the enum branch in
  // emitVariantFieldDrop. The original Active("second") allocated a string;
  // overwriting with Inactive(99) must drop that string via the synthesized
  // enum drop function (switches on tag, drops per-variant data).
  _Status[2] arr = [_Status.Active("first"), _Status.Active("second")];
  _Status c = _Status.Inactive(99);
  arr[1] = c;
  string desc = match arr[1] {
    _Status.Active(name) => "active",
    _Status.Inactive(id) => "inactive",
  };
  assert(desc == "inactive", "slot 1 reassigned to inactive");
}

type _GenHolder[T] {
  T[2] data;
}

test_generic_array_field_heap_user() `test {
  // T0584: _Box is a heap user type with explicit drop. Without the Array case
  // in monoTypeHasDroppable, _GenHolder[_Box].drop is not synthesised — the two
  // _Box allocations leak when h goes out of scope.
  _GenHolder[_Box] h = _GenHolder[_Box](data: [_Box(n: 1), _Box(n: 2)]);
  assert(h.data[0].n == 1, "elem 0");
  assert(h.data[1].n == 2, "elem 1");
}

test_generic_array_field_string() `test {
  // string element with forced heap allocation (concat lifts from .rodata).
  string a = "x";
  a = a + "x";
  string b = "y";
  b = b + "y";
  _GenHolder[string] h = _GenHolder[string](data: [a, b]);
  assert(h.data[0] == "xx", "elem 0");
  assert(h.data[1] == "yy", "elem 1");
}

test_generic_array_field_vector() `test {
  // Vector[int] element — synth drop must walk the array and call Vector.drop
  // on each slot.
  Vector[int] v0 = Vector[int]();
  v0.push(1);
  Vector[int] v1 = Vector[int]();
  v1.push(2);
  _GenHolder[Vector[int]] h = _GenHolder[Vector[int]](data: [v0, v1]);
  assert(h.data[0][0] == 1, "elem 0");
  assert(h.data[1][0] == 2, "elem 1");
}

type _TupArrGen[T] {
  (T, int)[2] data;
}

test_generic_array_of_tuple_of_typeparam() `test {
  // Array of Tuple of TypeParam — exercises both the Array and Tuple recursion
  // branches of monoTypeHasDroppable. Without the Array case, the gate never
  // reaches the inner Tuple's TypeParam droppable check.
  _TupArrGen[_Box] h = _TupArrGen[_Box](data: [(_Box(n: 1), 1), (_Box(n: 2), 2)]);
  assert(true, "constructed");
}

type _OptArrGen[T] {
  T?[2] data;
}

test_generic_array_of_optional_of_typeparam() `test {
  // Array of Optional of TypeParam — exercises the Array → Optional recursion
  // chain. Sema's fieldTypeHasDrop returns false for the bare TypeParam, so
  // detection must happen at mono time and recurse through both wrappers.
  _Box? a = _Box(n: 1);
  _Box? b = _Box(n: 2);
  _OptArrGen[_Box] h = _OptArrGen[_Box](data: [a, b]);
  assert(true, "constructed");
}

type _Pair[T, U] {
  T[2] a;
  U[2] b;
}

test_generic_array_field_multi_typeparam() `test {
  // Multi-typeparam generic with two T[N] fields — confirms the gate fires
  // per-field and substitution maps for distinct type params resolve correctly.
  _Pair[_Box, string] h = _Pair[_Box, string](a: [_Box(n: 1), _Box(n: 2)],
  b: ["alpha", "beta"]);
  assert(h.a[0].n == 1, "a[0]");
  assert(h.b[0] == "alpha", "b[0]");
}

enum _GenEnum[T] {
  Pair(T[2] data),
  Empty,
}

test_generic_enum_array_variant_field() `test {
  // Generic ENUM with T[N] variant field — parallel case for the fix in
  // monoEnumInstNeedsSynthDrop, which calls into the same monoTypeHasDroppable.
  // Without the Array case, the synth enum drop is never generated and the
  // _Box allocations in the variant data leak.
  _GenEnum[_Box] e = _GenEnum[_Box].Pair([_Box(n: 1), _Box(n: 2)]);
  assert(true, "constructed");
}

test_generic_array_field_primitive_no_false_positive() `test {
  // Negative test: T = int (primitive) must NOT trigger synth drop generation.
  // The Array recursion bottoms out at the primitive Named branch, which
  // returns false. No leak, no false-positive drop emission.
  _GenHolder[int] h = _GenHolder[int](data: [10, 20]);
  assert(h.data[0] == 10, "elem 0");
  assert(h.data[1] == 20, "elem 1");
}

// T0590: `genArrayIndex` had no dup-on-read, so any read from a fixed-size
// array slot returned an alias of the slot's owned data. Combined with
// T0583's drop-on-overwrite, slot-to-slot copies / let-then-overwrite /
// let-then-scope-exit all produced double-frees on droppable element types.
// Tests below exercise each droppable element shape × {slot-to-slot,
// let-then-overwrite, let-then-scope-exit}. The zero-tolerance leak policy
// (T0067) plus PAL's double-free guard verify the fix.

// --- Slot-to-slot copies (`arr[1] = arr[0]`) ---

test_slot_to_slot_box() `test {
  // Heap user with explicit drop.
  _Box[2] arr = [_Box(n: 1), _Box(n: 2)];
  arr[1] = arr[0];
  assert(arr[0].n == 1, "slot 0 preserved");
  assert(arr[1].n == 1, "slot 1 cloned from slot 0");
}

test_slot_to_slot_optional_box() `test {
  // Primary repro from the bug — Optional<heap-user>.
  _BoxA? a = _BoxA(n: 1);
  _BoxA? b = _BoxA(n: 2);
  _BoxA?[2] arr = [a, b];
  arr[1] = arr[0];
  assert(arr[0] is present, "slot 0 preserved");
  assert(arr[1] is present, "slot 1 cloned from slot 0");
}

test_slot_to_slot_droppable_tuple() `test {
  // Tuple with droppable inner field (string).
  (_Box, int)[2] arr = [(_Box(n: 1), 10), (_Box(n: 2), 20)];
  arr[1] = arr[0];
  (b0, n0) := arr[0];
  (b1, n1) := arr[1];
  assert(b0.n == 1, "slot 0 box.n");
  assert(b1.n == 1, "slot 1 box.n (cloned)");
  assert(n0 == 10, "slot 0 int");
  assert(n1 == 10, "slot 1 int");
}

test_slot_to_slot_string() `test {
  // string — pre-fix this was a silent UAF.
  string a = "hello";
  a = a + " world";
  string b = "alpha";
  b = b + " beta";
  string[2] arr = [a, b];
  arr[1] = arr[0];
  assert(arr[0] == "hello world", "slot 0 preserved");
  assert(arr[1] == "hello world", "slot 1 cloned independently");
}

test_slot_to_slot_vector() `test {
  // Vector — pre-fix this aliased the buffer; leak-free completion verifies the
  // independent buffer allocation (each slot's drop releases its own buffer).
  // T0595 prevents direct `arr[1].push(...)`, so independence is confirmed via
  // leak-free scope exit.
  Vector[int] v0 = Vector[int]();
  v0.push(10);
  Vector[int] v1 = Vector[int]();
  v1.push(20);
  Vector[int][2] arr = [v0, v1];
  arr[1] = arr[0];
  assert(arr[0].len == 1, "slot 0 buffer intact");
  assert(arr[0][0] == 10, "slot 0 value preserved");
  assert(arr[1].len == 1, "slot 1 has its own buffer with cloned data");
  assert(arr[1][0] == 10, "slot 1 value cloned");
}

test_slot_to_slot_arc() `test {
  // Arc — slot-to-slot should incref so both slots stay valid.
  Arc[int][2] arr = [Arc[int](1), Arc[int](2)];
  arr[1] = arr[0];
  assert(arr[0].borrow == 1, "slot 0 alive");
  assert(arr[1].borrow == 1, "slot 1 alive (refcounted clone)");
}

test_slot_to_slot_bare() `test {
  // Heap user without explicit drop — exercises the pal_free-only path.
  _Bare[2] arr = [_Bare(x: 1), _Bare(x: 2)];
  arr[1] = arr[0];
  assert(arr[0].x == 1, "slot 0 preserved");
  assert(arr[1].x == 1, "slot 1 cloned");
}

test_slot_to_slot_channel() `test {
  // channel — exercises the Channel branch of the container dup.
  channel[int] c0 = channel[int]();
  channel[int] c1 = channel[int]();
  channel[int][2] arr = [c0, c1];
  arr[1] = arr[0];
  assert(true, "channel slot-to-slot completes leak-free");
}

type _CloneBox {
  int n;
  drop(~this) {
  }
  clone() _CloneBox {
    return _CloneBox(n: this.n);
  }
}

test_slot_to_slot_clone_box() `test {
  // Heap user with both `drop` and `clone` — the genMethodIndex gate
  // (`drop && !clone`) would skip the dup here, but the array path drops the
  // gate (no internal match-dup in genArrayIndex). Pre-fix this double-freed.
  _CloneBox[2] arr = [_CloneBox(n: 1), _CloneBox(n: 2)];
  arr[1] = arr[0];
  assert(arr[0].n == 1, "slot 0 preserved");
  assert(arr[1].n == 1, "slot 1 cloned");
}

test_slot_to_slot_optional_clone_box() `test {
  // Optional<heap user with drop AND clone> — same gate-relaxation as above
  // applied to the Optional path. Pre-fix this double-freed.
  _CloneBox? a = _CloneBox(n: 10);
  _CloneBox? b = _CloneBox(n: 20);
  _CloneBox?[2] arr = [a, b];
  arr[1] = arr[0];
  assert(arr[0] is present, "slot 0");
  assert(arr[1] is present, "slot 1");
}

// --- let-then-overwrite (`x := arr[0]; arr[0] = c;`) ---

test_let_then_overwrite_box() `test {
  _Box[2] arr = [_Box(n: 1), _Box(n: 2)];
  _Box x = arr[0];
  arr[0] = _Box(n: 99);
  assert(x.n == 1, "x preserved despite overwrite");
  assert(arr[0].n == 99, "slot 0 reassigned");
}

test_let_then_overwrite_optional_box() `test {
  _BoxA? a = _BoxA(n: 1);
  _BoxA? b = _BoxA(n: 2);
  _BoxA?[2] arr = [a, b];
  _BoxA? x = arr[0];
  _BoxA? newA = _BoxA(n: 99);
  arr[0] = newA;
  assert(x is present, "x preserved despite overwrite");
  assert(arr[0] is present, "slot 0 reassigned");
}

test_let_then_overwrite_droppable_tuple() `test {
  (_Box, int)[2] arr = [(_Box(n: 1), 10), (_Box(n: 2), 20)];
  (_Box, int) t = arr[0];
  arr[0] = (_Box(n: 99), 999);
  (b, n) := t;
  assert(b.n == 1, "t preserved despite overwrite");
  assert(n == 10, "t int preserved");
}

test_let_then_overwrite_string() `test {
  string a = "first";
  a = a + " value";
  string b = "second";
  b = b + " value";
  string[2] arr = [a, b];
  string x = arr[0];
  arr[0] = "new";
  assert(x == "first value", "x preserved despite overwrite");
  assert(arr[0] == "new", "slot 0 reassigned");
}

test_let_then_overwrite_vector() `test {
  Vector[int] v0 = Vector[int]();
  v0.push(10);
  Vector[int] v1 = Vector[int]();
  v1.push(20);
  Vector[int][2] arr = [v0, v1];
  Vector[int] x = arr[0];
  Vector[int] newV = Vector[int]();
  newV.push(99);
  arr[0] = newV;
  assert(x.len == 1, "x preserved despite overwrite");
  assert(x[0] == 10, "x value preserved");
  assert(arr[0].len == 1, "slot 0 reassigned");
  assert(arr[0][0] == 99, "slot 0 new value");
}

// --- let-then-scope-exit (`x := arr[0];` without overwrite) ---

test_let_then_scope_exit_box() `test {
  _Box[2] arr = [_Box(n: 1), _Box(n: 2)];
  _Box x = arr[0];
  assert(x.n == 1, "x copy intact");
  // both x and arr[0] drop at scope exit — must be independent allocations
}

test_let_then_scope_exit_optional_box() `test {
  _BoxA? a = _BoxA(n: 7);
  _BoxA? b = _BoxA(n: 8);
  _BoxA?[2] arr = [a, b];
  _BoxA? x = arr[0];
  assert(x is present, "x present");
  assert(arr[0] is present, "slot 0 still present");
}

test_let_then_scope_exit_droppable_tuple() `test {
  (_Box, int)[2] arr = [(_Box(n: 1), 10), (_Box(n: 2), 20)];
  (_Box, int) t = arr[0];
  (b, n) := t;
  assert(b.n == 1, "t.box.n");
  assert(n == 10, "t.int");
}

test_let_then_scope_exit_string() `test {
  string a = "alpha";
  a = a + "+";
  string b = "beta";
  b = b + "+";
  string[2] arr = [a, b];
  string x = arr[0];
  assert(x == "alpha+", "x independent copy");
}

// --- T0590 coverage additions: branches the original 16 regression tests
// missed. Each branch in genArrayIndex (expr.go:7681-7866) needs at least one
// slot-to-slot regression to catch future aliasing regressions.

// Optional[string] slot-to-slot — exercises the B0347 analogue branch.
test_slot_to_slot_optional_string() `test {
  string a = "hello";
  a = a + " A";
  string b = "world";
  b = b + " B";
  string? oa = a;
  string? ob = b;
  string?[2] arr = [oa, ob];
  arr[1] = arr[0];
  assert(arr[0] is present, "slot 0 preserved");
  assert(arr[1] is present, "slot 1 cloned independently");
}

// Optional[droppable tuple] slot-to-slot — exercises the T0397 analogue branch.
test_slot_to_slot_optional_tuple() `test {
  (_Box, int)? a = (_Box(n: 1), 10);
  (_Box, int)? b = (_Box(n: 2), 20);
  (_Box, int)?[2] arr = [a, b];
  arr[1] = arr[0];
  assert(arr[0] is present, "slot 0 preserved");
  assert(arr[1] is present, "slot 1 cloned");
}

// T0597: Optional[Vector] slot-to-slot — original repro for the
// genAssignStmt IndexExpr-LHS optionalContainerDup gap. Pre-fix this
// SEGV'd with a double-free on the inner Vector pointer because
// claimStringTemp(val) at the IndexExpr site sees the wrapped {i1, ptr}
// struct, not the bare inner-dup pointer that genArrayIndex registered.
test_slot_to_slot_optional_vector() `test {
  Vector[int] v0 = Vector[int]();
  v0.push(1);
  Vector[int] v1 = Vector[int]();
  v1.push(2);
  Vector[int]? a = v0;
  Vector[int]? b = v1;
  Vector[int]?[2] arr = [a, b];
  arr[1] = arr[0];
  assert(arr[0] is present, "slot 0 preserved");
  assert(arr[1] is present, "slot 1 cloned");
}

// T0597: Optional[Channel] slot-to-slot — same code path as Vector via
// the channel branch of genArrayIndex's container-dup (refcount inc).
test_slot_to_slot_optional_channel() `test {
  channel[int] c0 = channel[int](1);
  c0.send(11);
  channel[int] c1 = channel[int](1);
  c1.send(22);
  channel[int]? a = c0;
  channel[int]? b = c1;
  channel[int]?[2] arr = [a, b];
  arr[1] = arr[0];
  assert(arr[0] is present, "slot 0 preserved");
  assert(arr[1] is present, "slot 1 cloned");
}

// T0597: Optional[Arc] slot-to-slot — exercises the Arc branch of the
// container dup (atomic refcount inc).
test_slot_to_slot_optional_arc() `test {
  Arc[int] a0 = Arc[int](100);
  Arc[int] a1 = Arc[int](200);
  Arc[int]? a = a0;
  Arc[int]? b = a1;
  Arc[int]?[2] arr = [a, b];
  arr[1] = arr[0];
  assert(arr[0] is present, "slot 0 preserved");
  assert(arr[1] is present, "slot 1 cloned");
}

// Weak[T] slot-to-slot — exercises the AsWeak branch of the container dup.
test_slot_to_slot_weak() `test {
  Arc[int] keep0 = Arc[int](10);
  Arc[int] keep1 = Arc[int](20);
  Weak[int] w0 = keep0.downgrade();
  Weak[int] w1 = keep1.downgrade();
  Weak[int][2] arr = [w0, w1];
  arr[1] = arr[0];
  assert(true, "weak slot-to-slot leak-free");
}

// Field-arr slot-to-slot (`h.data[1] = h.data[0]`) — verifies that the
// genAssignStmt flag-setting also fires for MemberExpr→IndexExpr LHS.
test_field_arr_slot_to_slot_heap() `test {
  _HolderBox h = _HolderBox(data: [_Box(n: 1), _Box(n: 2)]);
  h.data[1] = h.data[0];
  assert(h.data[0].n == 1, "slot 0 preserved");
  assert(h.data[1].n == 1, "slot 1 cloned");
}

// Field-arr let-then-overwrite — exercises var-decl-site flag for MemberExpr-arr.
test_field_arr_let_then_overwrite_heap() `test {
  _HolderBox h = _HolderBox(data: [_Box(n: 1), _Box(n: 2)]);
  _Box x = h.data[0];
  // Note: data is non-optional _Box[2] (not _Box?[2]), so the T0599
  // bare→Optional wrap does not apply here; the overwrite form is covered by
  // test_field_arr_bare_to_optional_slot below for the Optional case.
  assert(x.n == 1, "x preserved");
  assert(h.data[0].n == 1, "slot 0 still present");
}

// _Bare let-then-overwrite — heap-user-no-drop pal_free-only path.
test_let_then_overwrite_bare() `test {
  _Bare[2] arr = [_Bare(x: 1), _Bare(x: 2)];
  _Bare x = arr[0];
  arr[0] = _Bare(x: 99);
  assert(x.x == 1, "x preserved");
  assert(arr[0].x == 99, "slot 0 reassigned");
}

// _Bare let-then-scope-exit — both x and arr[0] drop the same allocation pre-fix.
test_let_then_scope_exit_bare() `test {
  _Bare[2] arr = [_Bare(x: 1), _Bare(x: 2)];
  _Bare x = arr[0];
  assert(x.x == 1, "x intact");
}

// Vector let-then-scope-exit (the 16-test set covered slot-to-slot and
// let-then-overwrite but not this form).
test_let_then_scope_exit_vector() `test {
  Vector[int] v0 = Vector[int]();
  v0.push(7);
  Vector[int] v1 = Vector[int]();
  v1.push(8);
  Vector[int][2] arr = [v0, v1];
  Vector[int] x = arr[0];
  assert(x.len == 1, "x has its own buffer");
  assert(x[0] == 7, "x value preserved");
  // arr[0] and x both drop at scope exit — must be independent buffers
}

// Channel let-then-scope-exit.
test_let_then_scope_exit_channel() `test {
  channel[int] c0 = channel[int]();
  channel[int] c1 = channel[int]();
  channel[int][2] arr = [c0, c1];
  channel[int] x = arr[0];
  assert(true, "leak-free");
}

// Arc let-then-scope-exit — must refcount-clone so x and arr[0] both stay alive.
test_let_then_scope_exit_arc() `test {
  Arc[int][2] arr = [Arc[int](100), Arc[int](200)];
  Arc[int] x = arr[0];
  assert(x.borrow == 100, "x intact");
  assert(arr[0].borrow == 100, "slot 0 still alive");
}

// Arc let-then-overwrite.
test_let_then_overwrite_arc() `test {
  Arc[int][2] arr = [Arc[int](100), Arc[int](200)];
  Arc[int] x = arr[0];
  arr[0] = Arc[int](999);
  assert(x.borrow == 100, "x preserved");
  assert(arr[0].borrow == 999, "slot 0 reassigned");
}

// Channel let-then-overwrite.
test_let_then_overwrite_channel() `test {
  channel[int] c0 = channel[int]();
  channel[int] c1 = channel[int]();
  channel[int][2] arr = [c0, c1];
  channel[int] x = arr[0];
  channel[int] c2 = channel[int]();
  arr[0] = c2;
  assert(true, "leak-free");
}

// _CloneBox let-then-overwrite — clone-bearing heap user not previously tested
// in the let-then-X forms.
test_let_then_overwrite_clone_box() `test {
  _CloneBox[2] arr = [_CloneBox(n: 1), _CloneBox(n: 2)];
  _CloneBox x = arr[0];
  arr[0] = _CloneBox(n: 99);
  assert(x.n == 1, "x preserved");
  assert(arr[0].n == 99, "slot 0 reassigned");
}

// _CloneBox let-then-scope-exit.
test_let_then_scope_exit_clone_box() `test {
  _CloneBox[2] arr = [_CloneBox(n: 1), _CloneBox(n: 2)];
  _CloneBox x = arr[0];
  assert(x.n == 1, "x intact");
}

// --- T0599: bare-T RHS assigned to an Optional[T] fixed-array slot. Pre-fix
// the IndexExpr-LHS path in genAssignStmt had no Optional-wrap (the MemberExpr
// and IdentExpr paths did), so `arr[i] = bareValue` panicked at codegen with
// "store operands are not compatible: src=T; dst={i1,T}*". These exercise the
// natural form a user writes; zero-leak + PAL double-free guard verify the
// pre-wrap claimStringTemp / post-wrap claimHeapTemp ownership handoff.

// Heap user type: bare _BoxA → _BoxA? slot. Post-wrap claimHeapTemp must
// claim the ctor temp via its {i1,{vtable,instance}} struct-extraction path.
test_bare_heap_user_to_optional_slot() `test {
  _BoxA? a = _BoxA(n: 7);
  _BoxA? b = _BoxA(n: 8);
  _BoxA?[2] arr = [a, b];
  arr[0] = _BoxA(n: 99);
  assert(arr[0] is present, "slot 0 present after bare assign");
  assert(arr[1] is present, "slot 1 untouched");
}

// String: bare heap-string concat temp → string? slot. The old slot value is
// dropped via promise_string_drop; the new temp must be claimed BEFORE the
// Optional wrap (val identity changes after wrapOptional).
test_bare_string_to_optional_slot() `test {
  string sa = "al" + "pha";
  string sb = "be" + "ta";
  string? oa = sa;
  string? ob = sb;
  string?[2] arr = [oa, ob];
  arr[0] = "ne" + "w";
  assert(arr[0] is present, "slot 0 present after bare-string assign");
  assert(arr[1] is present, "slot 1 untouched");
}

// Container: bare Vector[int] → Vector[int]? slot. Exercises the container
// branch of the pre-wrap temp claim.
test_bare_vector_to_optional_slot() `test {
  Vector[int] v0 = Vector[int]();
  v0.push(1);
  Vector[int] v1 = Vector[int]();
  v1.push(2);
  Vector[int]? a = v0;
  Vector[int]? b = v1;
  Vector[int]?[2] arr = [a, b];
  Vector[int] v2 = Vector[int]();
  v2.push(42);
  arr[0] = v2;
  assert(arr[0] is present, "slot 0 present after bare-vector assign");
  assert(arr[1] is present, "slot 1 untouched");
}

// Regression guard: `arr[i] = none` must keep working (the exprType==TypNone
// guard skips the wrap; none is handled as zeroinit by genExpr).
test_none_to_optional_slot() `test {
  _BoxA? a = _BoxA(n: 1);
  _BoxA? b = _BoxA(n: 2);
  _BoxA?[2] arr = [a, b];
  arr[0] = none;
  assert(arr[0] is absent, "slot 0 cleared to none");
  assert(arr[1] is present, "slot 1 untouched");
}

// Field-array: bare _BoxA → _BoxA? slot via the MemberExpr→IndexExpr LHS form
// (h.data[0] = ...). Same IndexExpr branch; one fix covers local + field.
test_field_arr_bare_to_optional_slot() `test {
  _BoxA? a = _BoxA(n: 7);
  _BoxA? b = _BoxA(n: 8);
  _HolderOptBox h = _HolderOptBox(data: [a, b]);
  h.data[0] = _BoxA(n: 99);
  assert(h.data[0] is present, "field slot 0 present after bare assign");
  assert(h.data[1] is present, "field slot 1 untouched");
}

// Arc: bare Arc → Arc[int]? slot. Exercises the types.IsArc(exprType)
// disjunct of the T0599 pre-wrap claim (only string & Vector were covered by
// the cases above). Arc is refcounted — a missed pre-wrap claim would
// leak/double-decrement; the zero-tolerance leak policy verifies the handoff.
test_bare_arc_to_optional_slot() `test {
  Arc[int]? a = Arc[int](1);
  Arc[int]? b = Arc[int](2);
  Arc[int]?[2] arr = [a, b];
  arr[0] = Arc[int](99);
  assert(arr[0] is present, "arc slot 0 present after bare assign");
  assert(arr[0]!.borrow == 99, "arc slot 0 value");
  assert(arr[1] is present, "arc slot 1 untouched");
}

// Channel: bare channel → channel[int]? slot. Exercises the
// types.IsChannel(exprType) disjunct of the T0599 pre-wrap claim.
test_bare_channel_to_optional_slot() `test {
  channel[int]? a = channel[int]();
  channel[int]? b = channel[int]();
  channel[int]?[2] arr = [a, b];
  arr[0] = channel[int]();
  assert(arr[0] is present, "chan slot 0 present after bare assign");
  assert(arr[1] is present, "chan slot 1 untouched");
}

// Generic typeSubst path: a generic free function whose body assigns a bare
// T into a T?[N] slot — exercises the `c.typeSubst != nil` branch of the
// T0599 block (slotType/exprType types.Substitute), which no other case
// covers. Instantiated with both a primitive (int) and a heap type (string).
_set_opt_arr_first[T](~T x) bool {
  T? z0 = none;
  T? z1 = none;
  T?[2] a = [z0, z1];
  a[0] = x;
  return a[0] is present;
}

test_bare_generic_typeparam_to_optional_slot() `test {
  assert(_set_opt_arr_first[int](7), "generic int slot present");
  assert(_set_opt_arr_first[string]("hi" + "!"), "generic string slot present");
}
