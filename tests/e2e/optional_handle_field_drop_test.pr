// T0573: Optional[Arc/Weak/Mutex/MutexGuard] field drop sites — the sibling
// of T0560 (Task field drops). The two affected sites are:
//
//   1. emitOptionalValueDrop         — Optional[Handle] field at scope exit
//   2. emitOptionalFieldReassignDrop — Optional[Handle] field on reassign
//
// Both switches previously had no Arc/Weak/Mutex/MutexGuard cases and fell
// through to the heap-user-type path (gated by !isOpaqueContainerType), so
// these branches were never taken and old handles leaked.
// --- Optional[Ref[T]] field, some at scope exit ---
type T0573ArcHolder {
  Ref[int]? a;
}

test_optional_arc_field_scope_exit() `test {
  h := T0573ArcHolder(a: Ref[int](1));
}

test_optional_arc_field_scope_exit_none() `test {
  h := T0573ArcHolder(a: none);
}

// --- Optional[Ref[T]] field, reassignment some → some ---

test_optional_arc_field_reassign_some_some() `test {
  h := T0573ArcHolder(a: Ref[int](1));
  h.a = Ref[int](2);
}

// --- Optional[Ref[T]] field, reassignment some → none ---

test_optional_arc_field_reassign_some_none() `test {
  h := T0573ArcHolder(a: Ref[int](1));
  h.a = none;
}

// --- Optional[Ref[T]] field, none → some assign ---

test_optional_arc_field_assign_after_none() `test {
  h := T0573ArcHolder(a: none);
  h.a = Ref[int](42);
}

// --- Optional[Weak[T]] field, some at scope exit ---

type T0573WeakHolder {
  Weak[int]? w;
}

test_optional_weak_field_scope_exit() `test {
  a := Ref[int](1);
  h := T0573WeakHolder(w: a.downgrade());
}

test_optional_weak_field_scope_exit_none() `test {
  h := T0573WeakHolder(w: none);
}

// --- Optional[Weak[T]] field, reassignment some → some ---

test_optional_weak_field_reassign_some_some() `test {
  a := Ref[int](1);
  h := T0573WeakHolder(w: a.downgrade());
  h.w = a.downgrade();
}

// --- Optional[Weak[T]] field, reassignment some → none ---

test_optional_weak_field_reassign_some_none() `test {
  a := Ref[int](1);
  h := T0573WeakHolder(w: a.downgrade());
  h.w = none;
}

// --- Optional[Weak[T]] field, none → some assign ---

test_optional_weak_field_assign_after_none() `test {
  a := Ref[int](1);
  h := T0573WeakHolder(w: none);
  h.w = a.downgrade();
}

// --- Optional[Mutex[T]] field, some at scope exit ---

type T0573MutexHolder {
  Mutex[int]? m;
}

test_optional_mutex_field_scope_exit() `test {
  h := T0573MutexHolder(m: Mutex[int](1));
}

test_optional_mutex_field_scope_exit_none() `test {
  h := T0573MutexHolder(m: none);
}

// --- Optional[Mutex[T]] field, reassignment some → some ---

test_optional_mutex_field_reassign_some_some() `test {
  h := T0573MutexHolder(m: Mutex[int](1));
  h.m = Mutex[int](2);
}

// --- Optional[Mutex[T]] field, reassignment some → none ---

test_optional_mutex_field_reassign_some_none() `test {
  h := T0573MutexHolder(m: Mutex[int](1));
  h.m = none;
}

// --- Optional[Mutex[T]] field, none → some assign ---

test_optional_mutex_field_assign_after_none() `test {
  h := T0573MutexHolder(m: none);
  h.m = Mutex[int](7);
}

// --- Mixed-field holder: Optional handles with a sibling non-Optional field ---

type T0573MixedHolder {
  Ref[int]? a;
  Weak[int]? w;
  Mutex[int]? m;
  string label;
}

test_mixed_optional_handle_fields_scope_exit() `test {
  arc := Ref[int](10);
  h := T0573MixedHolder(a: Ref[int](1), w: arc.downgrade(), m: Mutex[int](2), label: "hello" + "");
}

test_mixed_optional_handle_fields_reassign() `test {
  arc := Ref[int](10);
  h := T0573MixedHolder(a: Ref[int](1), w: arc.downgrade(), m: Mutex[int](2), label: "hello" + "");
  h.a = Ref[int](3);
  h.w = arc.downgrade();
  h.m = Mutex[int](4);
}

// --- Generic holder over Arc/Weak/Mutex — exercises typeSubst resolution in
//     emitOptionalValueDrop and emitOptionalFieldReassignDrop ---

type T0573Box[T] {
  Ref[T]? a;
  Weak[T]? w;
  Mutex[T]? m;
}

test_generic_optional_handle_box_int() `test {
  arc := Ref[int](1);
  b := T0573Box[int](a: Ref[int](1), w: arc.downgrade(), m: Mutex[int](2));
}

test_generic_optional_handle_box_string() `test {
  arc := Ref[string]("hi" + "");
  b := T0573Box[string](a: Ref[string]("a" + ""), w: arc.downgrade(), m: Mutex[string]("m" + ""));
}

test_generic_optional_handle_box_reassign() `test {
  arc := Ref[int](1);
  b := T0573Box[int](a: Ref[int](1), w: arc.downgrade(), m: Mutex[int](2));
  b.a = Ref[int](5);
  b.w = arc.downgrade();
  b.m = Mutex[int](6);
}

// --- Synthesized-drop owner (no explicit drop): same Optional-handle paths
//     still fire via the auto-injected drop.

type T0573SynthHolder {
  Ref[int]? a;
  int extra;
}

test_synth_drop_owner_optional_arc_scope_exit() `test {
  h := T0573SynthHolder(a: Ref[int](1), extra: 7);
}

test_synth_drop_owner_optional_arc_reassign() `test {
  h := T0573SynthHolder(a: Ref[int](1), extra: 7);
  h.a = Ref[int](2);
}

// --- Droppable inner element (Ref[string] / Mutex[string] / Ref[int[]] /
//     Mutex[int[]] in a plain non-generic holder) — exercises per-instantiation
//     drop's own inner cleanup along the Optional field path. The string/vector
//     inner content was only reached through the generic Box[T] in the tests
//     above, which is a different mono path than a plain holder with a
//     concrete Ref[string]/Mutex[int[]] field.

type T0573ArcStringHolder {
  Ref[string]? a;
}

test_optional_arc_string_field_scope_exit() `test {
  h := T0573ArcStringHolder(a: Ref[string]("hi" + ""));
}

test_optional_arc_string_field_reassign() `test {
  h := T0573ArcStringHolder(a: Ref[string]("hi" + ""));
  h.a = Ref[string]("bye" + "");
}

type T0573ArcVecHolder {
  Ref[int[]]? a;
}

test_optional_arc_vec_field_scope_exit() `test {
  h := T0573ArcVecHolder(a: Ref[int[]]([1, 2, 3]));
}

test_optional_arc_vec_field_reassign() `test {
  h := T0573ArcVecHolder(a: Ref[int[]]([1, 2, 3]));
  h.a = Ref[int[]]([4, 5]);
}

type T0573MutexStringHolder {
  Mutex[string]? m;
}

test_optional_mutex_string_field_scope_exit() `test {
  h := T0573MutexStringHolder(m: Mutex[string]("locked" + ""));
}

test_optional_mutex_string_field_reassign() `test {
  h := T0573MutexStringHolder(m: Mutex[string]("first" + ""));
  h.m = Mutex[string]("second" + "");
}

type T0573MutexVecHolder {
  Mutex[int[]]? m;
}

test_optional_mutex_vec_field_scope_exit() `test {
  h := T0573MutexVecHolder(m: Mutex[int[]]([10, 20]));
}

test_optional_mutex_vec_field_reassign() `test {
  h := T0573MutexVecHolder(m: Mutex[int[]]([10, 20]));
  h.m = Mutex[int[]]([30]);
}

// --- Optional[MutexGuard[T]] field — covers the MutexGuard branch in both
//     emitOptionalValueDrop and emitOptionalFieldReassignDrop. The case in the
//     codegen was previously unexercised by any test (the original plan
//     deliberately skipped it; this fills that gap).

type T0573GuardHolder {
  MutexGuard[int]? g;
}

test_optional_mutex_guard_field_scope_exit() `test {
  m := Mutex[int](1);
  h := T0573GuardHolder(g: m.lock());
}

test_optional_mutex_guard_field_scope_exit_none() `test {
  h := T0573GuardHolder(g: none);
}

test_optional_mutex_guard_field_reassign_to_none() `test {
  m := Mutex[int](1);
  h := T0573GuardHolder(g: m.lock());
  h.g = none;
}

test_optional_mutex_guard_field_assign_after_none() `test {
  m := Mutex[int](1);
  h := T0573GuardHolder(g: none);
  h.g = m.lock();
}
