#!/bin/sh
# Trampoline: delegates to the Go-based pre-commit tool.
# All hook logic lives in bin/precommit (compiled by ./make).
root="$(git rev-parse --show-toplevel)"
hook="$root/bin/precommit"
if [ ! -x "$hook" ]; then
    echo "pre-commit: bin/precommit not found — run ./make first" >&2
    exit 1
fi
exec "$hook" "$@"
