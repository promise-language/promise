map_string_int_test() `test {
  Counters c1 = Counters(counts: map[string, int]());
  c1.counts["views"] = 100;
  c1.counts["clicks"] = 5;
  json.JsonEncoder enc = json.JsonEncoder();
  c1.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"views\":100"), "map int: views");
}

