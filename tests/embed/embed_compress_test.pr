// T0259: compile-time gzip compression of embedded data, lazy decompression
// at the first call to the getter via the auto-injected gzip module.
get small_compressed string `embed("greeting.txt", compress: true);
get large_compressed string `embed("compress_fixture.txt", compress: true);
get bin_compressed u8[] `embed("data.bin", compress: true);

embed_compressed_string_short_test() `test {
  // Round-trip should match the file contents byte-for-byte.
  assert(small_compressed == "Hello, embedded world!", "short compressed string round-trip");
  assert(small_compressed.len == 22, "short compressed string length");
}

embed_compressed_string_large_test() `test {
  // Large fixture (~11KB) must round-trip. The file is highly compressible
  // (repeated sentence) — exercises dynamic Huffman + back-references.
  string s = large_compressed;
  assert(s.len == 11300, "large compressed string length round-trip");
  assert(s.contains("The quick brown fox"), "content preserved");
  // First and last 50 chars
  string head = s[0:50];
  string want_head = "The quick brown fox jumps over the lazy dog. The q";
  assert(head == want_head, "head matches");
}

embed_compressed_bytes_test() `test {
  u8[] b = bin_compressed;
  assert(b.len > 0, "bin_compressed nonempty");
}

embed_compressed_repeat_call_test() `test {
  // Each call decompresses afresh; results must compare equal even when the
  // underlying allocations are distinct.
  string a = small_compressed;
  string b = small_compressed;
  assert(a == b, "repeat calls return equal data");
}

embed_compress_fixture_no_line_endings_test() `test {
  // T0437 regression guard: compress_fixture.txt must contain no LF (0x0A) or
  // CR (0x0D) bytes. With LFs present, Windows core.autocrlf=true converts
  // them to CRLF at smudge time, inflating the file from 11300 to 11350 and
  // breaking the round-trip length assertion. Scanning the decompressed
  // string is equivalent to scanning the source — gzip round-trips byte for
  // byte.
  string s = large_compressed;
  int i = 0;
  while i < s.len {
    int b = s.byte_at(i) as! int;
    assert(b != 10, "fixture contains LF; Windows CRLF conversion would break length round-trip");
    assert(b != 13, "fixture contains CR; Windows CRLF conversion would break length round-trip");
    i = i + 1;
  }
}
