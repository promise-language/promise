// Tests for covariant return types in structural interface satisfaction (T0065).
// A concrete method returning ConcreteType should satisfy a structural interface
// method returning StructuralInterface if ConcreteType satisfies StructuralInterface.
//
// Note: Tests that call through vtable dispatch returning structural interfaces
// are blocked by B0270 (cleanup stack overflow). The sema-level acceptance is
// verified by the fact that these assignments compile. Runtime dispatch tests
// will be added once B0270 is fixed.
type Readable `structural {
  read_data(int n) string `abstract;
}

type DataSource `structural {
  open_source(string name) Readable `abstract;
}

type MemReadable {
  string data;
  read_data(int n) string {
    return this.data;
  }
}

type MemDataSource {
  open_source(string name) MemReadable {
    return MemReadable(data: name);
  }
}

// Verify covariant return assignment compiles (sema acceptance)
test_covariant_assignment_compiles() `test {
  DataSource s = MemDataSource();
  // Direct structural satisfaction still works at runtime
  Readable r = MemReadable(data: "hello");
  assert(r.read_data(0) == "hello", "direct structural assignment works");
}

// Failable version compiles
type FailableDataSource `structural {
  open_source!(string name) Readable `abstract;
}

type FailableMemDataSource {
  open_source!(string name) MemReadable {
    return MemReadable(data: name);
  }
}

test_failable_covariant_compiles() `test {
  FailableDataSource s = FailableMemDataSource();
  assert(true, "failable covariant return compiles");
}

// Non-failable concrete satisfies failable interface with covariant return
type SafeMemDataSource {
  open_source(string name) MemReadable {
    return MemReadable(data: name);
  }
}

test_nonfailable_failable_covariant_compiles() `test {
  FailableDataSource s = SafeMemDataSource();
  assert(true, "non-failable satisfies failable with covariant return");
}
