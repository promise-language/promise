// T0322: Verify that constructors in module-defined types correctly drop
// owned heap params at scope exit. Both the "stored in field" and
// "not stored" cases should leak nothing.
use ctormod "./ctormod";

test_module_ctor_param_stored() `test {
  int[] cs = int[]();
  cs.push(1);
  cs.push(2);
  cs.push(3);
  ctormod.Holder h = ctormod.Holder(codes: move cs);
  assert(h.data.len == 3, "module ctor stored vector in field");
  assert(h.data[0] == 1, "first element");
}

test_module_ctor_param_not_stored() `test {
  int[] cs = int[]();
  cs.push(10);
  cs.push(20);
  ctormod.Sized h = ctormod.Sized(codes: move cs);
  assert(h.n == 2, "module ctor read length only — vector dropped at scope exit");
}
