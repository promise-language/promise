  assert(err is present, "invalid token should error");
}

parse_value_error_unterminated_array_test() `test {
  (v, err) := parse_value("[1,2");
  assert(err is present, "unterminated array should error");
}

parse_value_error_unterminated_object_test() `test {
  (v, err) := parse_value("\{\"a\":1");
  assert(err is present, "unterminated object should error");
}

parse_value_error_unterminated_string_test() `test {
  (v, err) := parse_value("\"hello");
  assert(err is present, "unterminated string should error");
}

parse_value_whitespace_object_test() `test {
  // Generous whitespace
  string data = "  \{  \"a\"  :  1  ,  \"b\"  :  2  }  ";
  JsonValue v = parse_value(move data)?!;
  match v {
    JsonValue.Object(fields) => assert(fields.len == 2, "whitespace obj: 2 fields"),
    _ => assert(false, "expected object"),
  }
}

parse_value_whitespace_array_test() `test {
  JsonValue v = parse_value("  [  1  ,  2  ,  3  ]  ")?!;
  match v {
    JsonValue.Array(items) => assert(items.len == 3, "whitespace array: 3 items"),
    _ => assert(false, "expected array"),
  }
}

parse_value_zero_test() `test {
  JsonValue v = parse_value("0")?!;
  match v {
    JsonValue.Number(n) => assert(n == 0.0, "zero"),
    _ => assert(false, "expected number"),
  }
}

parse_value_exponent_test() `test {
  JsonValue v = parse_value("1e3")?!;
  match v {
    JsonValue.Number(n) => assert(n == 1000.0, "1e3"),
    _ => assert(false, "expected number"),
  }
}

parse_value_negative_exponent_test() `test {
  JsonValue v = parse_value("1e-2")?!;
  match v {
    JsonValue.Number(n) => assert(n > 0.009 && n < 0.011, "1e-2"),
    _ => assert(false, "expected number"),
  }
}

format_value_number_negative_test() `test {
  string s = format_value(JsonValue.Number(-3.5))?!;
  assert(s == "-3.5", "format negative float");
}

// Type-check getters

is_null_test() `test {
  assert(JsonValue.Null.is_null, "null is_null");
  assert(!JsonValue.Bool(true).is_null, "bool not is_null");
  assert(!JsonValue.Number(1.0).is_null, "number not is_null");
}

is_bool_test() `test {
  assert(JsonValue.Bool(true).is_bool, "bool is_bool");
  assert(!JsonValue.Null.is_bool, "null not is_bool");
  assert(!JsonValue.Str("x").is_bool, "str not is_bool");
}

is_number_test() `test {
  assert(JsonValue.Number(42.0).is_number, "number is_number");
  assert(!JsonValue.Null.is_number, "null not is_number");
  assert(!JsonValue.Bool(false).is_number, "bool not is_number");
}

is_string_test() `test {
  assert(JsonValue.Str("hello").is_string, "str is_string");
  assert(!JsonValue.Null.is_string, "null not is_string");
  assert(!JsonValue.Number(0.0).is_string, "number not is_string");
}

is_array_test() `test {
  assert(JsonValue.Array(JsonValue[]()).is_array, "array is_array");
  assert(!JsonValue.Null.is_array, "null not is_array");
  assert(!JsonValue.Object(map[string, JsonValue]()).is_array, "object not is_array");
}

is_object_test() `test {
  assert(JsonValue.Object(map[string, JsonValue]()).is_object, "object is_object");
  assert(!JsonValue.Null.is_object, "null not is_object");
  assert(!JsonValue.Array(JsonValue[]()).is_object, "array not is_object");
}

// Value extraction methods

as_bool_test() `test {
  bool? b = JsonValue.Bool(true).as_bool();
  assert(b is present, "as_bool present");
  assert(b! == true, "as_bool value");

  bool? b2 = JsonValue.Null.as_bool();
  assert(b2 is absent, "as_bool absent on null");
}

as_number_test() `test {
  f64? n = JsonValue.Number(3.14).as_number();
  assert(n is present, "as_number present");
  assert(n! > 3.13 && n! < 3.15, "as_number value");

  f64? n2 = JsonValue.Str("x").as_number();
  assert(n2 is absent, "as_number absent on string");
}

as_string_test() `test {
  string? s = JsonValue.Str("hello").as_string();
  assert(s is present, "as_string present");
  assert(s! == "hello", "as_string value");

  string? s2 = JsonValue.Number(1.0).as_string();
  assert(s2 is absent, "as_string absent on number");
}

as_array_test() `test {
  JsonValue[] items = [JsonValue.Number(1.0), JsonValue.Number(2.0)];
  JsonValue[]? arr = JsonValue.Array(move items).as_array();
  assert(arr is present, "as_array present");
  assert(arr!.len == 2, "as_array len");

  JsonValue[]? arr2 = JsonValue.Null.as_array();
  assert(arr2 is absent, "as_array absent on null");
}

as_object_test() `test {
  map[string, JsonValue] fields = {
    "a": JsonValue.Number(1.0)
  };
  map[string, JsonValue]? obj = JsonValue.Object(move fields).as_object();
  assert(obj is present, "as_object present");
  assert(obj!.len == 1, "as_object len");

  map[string, JsonValue]? obj2 = JsonValue.Str("x").as_object();
  assert(obj2 is absent, "as_object absent on string");
}

// Convenience access methods

get_method_test() `test {
  map[string, JsonValue] fields = {
    "name": JsonValue.Str("Alice"),
    "age": JsonValue.Number(30.0),
  };
  JsonValue obj = JsonValue.Object(move fields);

  JsonValue? name = obj.get("name");
  assert(name is present, "get name present");
  assert(name!.as_string()! == "Alice", "get name value");

  JsonValue? missing = obj.get("missing");
  assert(missing is absent, "get missing absent");

  // get on non-object returns none
  JsonValue? bad = JsonValue.Number(1.0).get("key");
  assert(bad is absent, "get on number is none");
}

at_method_test() `test {
  JsonValue[] items = [JsonValue.Str("a"), JsonValue.Str("b"), JsonValue.Str("c")];
  JsonValue arr = JsonValue.Array(move items);

  JsonValue? first = arr.at(0);
  assert(first is present, "at 0 present");
  assert(first!.as_string()! == "a", "at 0 value");

  JsonValue? last = arr.at(2);
  assert(last is present, "at 2 present");
  assert(last!.as_string()! == "c", "at 2 value");

  JsonValue? oob = arr.at(3);
  assert(oob is absent, "at 3 absent (out of bounds)");

  JsonValue? neg = arr.at(-1);
  assert(neg is absent, "at -1 absent (negative)");

  // at on non-array returns none
  JsonValue? bad = JsonValue.Null.at(0);
  assert(bad is absent, "at on null is none");
}

// Encoding/formatting methods

encode_method_test() `test {
  JsonValue v = JsonValue.Array([JsonValue.Number(1.0), JsonValue.Bool(true)]);
  JsonEncoder enc = JsonEncoder();
  v.encode(enc)?!;
  assert(enc.to_string() == "[1,true]", "encode method");
}

format_method_test() `test {
