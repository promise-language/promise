// Select with send case: channel has capacity, send succeeds.

main() `test(expected: "sent\n99") {
  ch := channel[int](capacity: 1);

  select {
    ch.send(99):
      println("sent");
    default:
      println("default");
  }

  // Verify the value was sent
  r := <-ch;
  if v := r { print_int(v); }
}
