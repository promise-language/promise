// Mutex[T] basic tests — T0156
test_mutex_create_and_read() `test {
  m := Mutex[int](42);
  use guard := m.lock();
  assert(guard.borrow == 42, "borrow should be 42");
}

test_mutex_write_and_read() `test {
  m := Mutex[int](0);
  use guard := m.lock();
  guard.borrow = 10;
  assert(guard.borrow == 10, "borrow should be 10 after write");
}

test_mutex_compound_assign() `test {
  m := Mutex[int](5);
  use guard := m.lock();
  guard.borrow += 3;
  assert(guard.borrow == 8, "5 + 3 = 8");
  guard.borrow -= 2;
  assert(guard.borrow == 6, "8 - 2 = 6");
  guard.borrow *= 4;
  assert(guard.borrow == 24, "6 * 4 = 24");
}

test_mutex_multiple_lock_unlock() `test {
  m := Mutex[int](0);
  {
    use guard := m.lock();
    guard.borrow = 1;
  }
  {
    use guard := m.lock();
    assert(guard.borrow == 1, "should be 1 after first lock");
    guard.borrow = 2;
  }
  {
    use guard := m.lock();
    assert(guard.borrow == 2, "should be 2 after second lock");
  }
}

test_mutex_drop_without_use() `test {
  m := Mutex[int](100);
  guard := m.lock();
  assert(guard.borrow == 100, "borrow should be 100");
  guard.borrow = 200;
  assert(guard.borrow == 200, "borrow should be 200 after write");
  // guard is dropped at scope exit — automatically unlocks
}

test_mutex_bool() `test {
  m := Mutex[bool](false);
  use guard := m.lock();
  assert(guard.borrow == false, "should be false");
  guard.borrow = true;
  assert(guard.borrow == true, "should be true after write");
}

test_mutex_f64() `test {
  m := Mutex[f64](3.14);
  use guard := m.lock();
  assert(guard.borrow == 3.14, "should be 3.14");
  guard.borrow = 2.718;
  assert(guard.borrow == 2.718, "should be 2.718 after write");
}

test_mutex_string() `test {
  m := Mutex[string]("hello");
  use guard := m.lock();
  assert(guard.borrow == "hello", "should be hello");
  guard.borrow = "world";
  assert(guard.borrow == "world", "should be world after write");
}

test_mutex_string_multiple_writes() `test {
  m := Mutex[string]("a");
  {
    use guard := m.lock();
    guard.borrow = "b";
    guard.borrow = "c";
    guard.borrow = "d";
  }
  use guard := m.lock();
  assert(guard.borrow == "d", "should be d after multiple writes");
}

// Mutex with vector inner type — exercises Mutex.drop calling Vector.drop.
// T0438: keep `r` typed as `int[]&` to read through the guard without an
// implicit decay.
test_mutex_vector_inner() `test {
  v := [1, 2, 3];
  m := Mutex[int[]](move v);
  {
    use guard := m.lock();
    int[] &r = guard.borrow;
    assert(r.len == 3, "vector should have 3 elements");
  }
  // m dropped at scope exit — must drop inner vector without leak
}

// Mutex with string inner type — exercises Mutex.drop calling promise_string_drop
test_mutex_string_drop() `test {
  m := Mutex[string]("owned string");
  use guard := m.lock();
  assert(guard.borrow == "owned string", "should read inner string");
  // guard + m both dropped — no leak
}

// Multiple Mutex variables in same scope — all get drop flags
test_mutex_multiple_in_scope() `test {
  m1 := Mutex[int](1);
  m2 := Mutex[int](2);
  {
    use g1 := m1.lock();
    use g2 := m2.lock();
    assert(g1.borrow == 1, "m1 should be 1");
    assert(g2.borrow == 2, "m2 should be 2");
  }
  // Both mutexes dropped at scope exit
}

// User-defined type tests — T0272
type MutexPoint {
  int x;
  int y;
}

test_mutex_user_type() `test {
  m := Mutex[MutexPoint](MutexPoint(x: 10, y: 20));
  use guard := m.lock();
  assert(guard.borrow.x == 10, "user type x");
  assert(guard.borrow.y == 20, "user type y");
}

// Mutex with user type that has explicit drop — T0272
type MutexDroppable {
  int val;
  drop(~this) {
  }
}

test_mutex_user_type_with_drop() `test {
  m := Mutex[MutexDroppable](MutexDroppable(val: 99));
  use guard := m.lock();
  assert(guard.borrow.val == 99, "droppable user type val");
}

// Mutex with user type that has synth drop (string field)
type MutexNamed {
  string name;
  int id;
}

test_mutex_user_type_synth_drop() `test {
  m := Mutex[MutexNamed](MutexNamed(name: "hello", id: 5));
  use guard := m.lock();
  assert(guard.borrow.name == "hello", "synth drop name");
  assert(guard.borrow.id == 5, "synth drop id");
}

// T0367: Mutex[string[]] — heap container borrowed via guard.borrow. Without the
// fix, `borrowed`'s drop and Mutex.drop both free the same buffer → segfault.
test_mutex_borrow_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  m := Mutex[string[]](move v);
  use guard := m.lock();
  borrowed := guard.borrow;
  assert(borrowed.len == 1, "heap vec borrow len");
}

// T0367: Mutex[string] with a heap-allocated string borrowed via guard.borrow.
test_mutex_borrow_heap_string() `test {
  s := "hello" + "";
  m := Mutex[string](move s);
  use guard := m.lock();
  borrowed := guard.borrow;
  assert(borrowed.len == 5, "heap string borrow len");
}

// T0367: Typed var decl (`T& borrowed = guard.borrow`) for MutexGuard with heap T.
// T0438: keep the local typed as `T&` (no implicit decay).
test_mutex_borrow_typed_decl_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  m := Mutex[string[]](move v);
  use guard := m.lock();
  string[] &borrowed = guard.borrow;
  assert(borrowed.len == 1, "typed decl heap vec");
}

// T0379: Reassignment of `guard.borrow` to an existing local must clear the
// dropflag re-armed by the unconditional reset in the assignment path.
test_mutex_borrow_reassign() `test {
  v1 := string[]();
  v1.push("hello" + "");
  v2 := string[]();
  v2.push("world" + "");
  m1 := Mutex[string[]](move v1);
  m2 := Mutex[string[]](move v2);
  use g1 := m1.lock();
  use g2 := m2.lock();
  borrowed := g1.borrow;
  borrowed = g2.borrow;
  borrowed = g1.borrow;
  assert(borrowed.len == 1, "mutex borrow reassign");
}

// T0379: Borrow→owned reassignment (negative test). The fix must NOT fire when
// RHS is owned — the local must drop the new vector at scope exit. A regression
// that always cleared the dropflag would leak.
test_mutex_borrow_reassign_to_owned() `test {
  v := string[]();
  v.push("borrowed" + "");
  m := Mutex[string[]](move v);
  use g := m.lock();
  borrowed := g.borrow;
  borrowed = string[]();
  borrowed.push("owned" + "");
  assert(borrowed.len == 1, "mutex borrow reassigned to owned");
}

// T0377: Borrow on a MutexGuard laundered through an if-expression. Both arms
// must produce a borrow for the dropflag to be cleared — without the fix, scope
// cleanup double-frees with MutexGuard.drop.
test_mutex_borrow_through_if() `test {
  v := string[]();
  v.push("hello" + "");
  m := Mutex[string[]](move v);
  use g := m.lock();
  cond := true;
  borrowed := if cond {
    g.borrow
  } else {
    g.borrow
  };
  assert(borrowed.len == 1, "mutex if borrow len");
}

// T0383: `vec[i] = guard.borrow.clone()` exercises Vector.drop on the old
// element + an explicit clone of the borrowed value into the slot. T0438:
// the original `vec[0] = g.borrow` form is rejected at sema (no implicit
// `string[]& → string[]` decay); `.clone()` is the documented owned-copy
// recovery path.
test_mutex_borrow_index_assign_vector() `test {
  vec := string[][]();
  v1 := string[]();
  v1.push("init" + "");
  vec.push(move v1);

  v2 := string[]();
  v2.push("hello" + "");
  m := Mutex[string[]](move v2);
  use g := m.lock();

  vec[0] = g.borrow.clone();
  assert(vec[0].len == 1, "vec[0] len after mutex borrow assign");
}

// T0386 / T0438: MutexGuard slice-assign with an explicit clone of the
// borrowed source. The original `v1[0:3] = g.borrow` form is rejected at
// sema (no implicit `string[]& → string[]` decay); `.clone()` produces an
// owned vector whose elements are dup'd into the slice slots.
test_mutex_guard_slice_assign() `test {
  s := string[]();
  s.push("a" + "");
  s.push("b" + "");
  s.push("c" + "");
  m := Mutex[string[]](move s);
  use g := m.lock();
  v1 := string[]();
  v1.push("x" + "");
  v1.push("y" + "");
  v1.push("z" + "");
  v1[0:3] = g.borrow.clone();
  assert(v1[0] == "a", "v1[0]");
  assert(v1[1] == "b", "v1[1]");
  assert(v1[2] == "c", "v1[2]");
}
