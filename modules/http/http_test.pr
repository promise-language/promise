// ── PUT method ──────────────────────────────────────────────────────────────

test_http_put() `test(exclude: "wasm32", timeout: "10s") {
  net.TcpListener listener = net.TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;

  go {
    Request req = Request(method: Method.Put, url: "http://127.0.0.1:" + port.to_string() + "/res", headers: map[string, string](), body: "update");
    Response resp = req.send()?!;
    assert(resp.status_code == 200, "status");
  };

  string request = _serve_once(listener, "HTTP/1.1 200 OK\r\nContent-Length: 2\r\nConnection: close\r\n\r\nok")?!;
  assert(request.contains("PUT /res"), "PUT method");
  assert(request.contains("update"), "body");
  listener.close()?!;
  sleep(Duration.from_millis(100));
}

