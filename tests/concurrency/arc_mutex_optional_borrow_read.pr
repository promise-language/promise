// T0856: Binding Arc[T?]/Mutex[T?].borrow (value-type payload) to a typed
// optional var spuriously re-wrapped an already-optional value, panicking
// codegen with an insertvalue elem-type mismatch. The `.borrow` getter returns
// `T &` (a SharedRef-to-optional); for a value/Copy payload it auto-copies to a
// bare `{i1,T}` optional at the borrow site, and genTypedVarDecl must strip the
// ref before its Optional-wrap comparison or it re-wraps the already-optional
// value. These bind the borrow result back through a typed-var decl — the path
// that panicked — across value-type payloads and both the Some and None states.
type Pt {
  int x `value;
  int y `value;
}

arc_optional_value_borrow_read() `test {
  int? init = 5;
  Arc[int?] a = Arc[int?](init);
  int? av = a.borrow; // was: insertvalue panic
  assert(av! == 5, "arc borrow read");
}

mutex_optional_value_borrow_read() `test {
  int? init = 7;
  Mutex[int?] m = Mutex[int?](init);
  g := m.lock();
  int? mv = g.borrow;
  assert(mv! == 7, "mutex borrow read");
}

// None state: the borrowed optional is `{i1=false, ...}`; binding it must
// preserve none rather than re-wrap into a present {i1=true, {i1,T}} value.
arc_optional_none_borrow_read() `test {
  int? init = none;
  Arc[int?] a = Arc[int?](init);
  int? av = a.borrow;
  got := false;
  if x := av {
    got = true;
  }
  assert(!got, "arc none borrow read stays none");
}

mutex_optional_none_borrow_read() `test {
  int? init = none;
  Mutex[int?] m = Mutex[int?](init);
  g := m.lock();
  int? mv = g.borrow;
  got := false;
  if x := mv {
    got = true;
  }
  assert(!got, "mutex none borrow read stays none");
}

// Other value/Copy payload widths: f64 and bool exercise the same ref-strip
// path with differently-shaped {i1,T} structs.
arc_optional_f64_borrow_read() `test {
  f64? init = 3.5;
  Arc[f64?] a = Arc[f64?](init);
  f64? av = a.borrow;
  assert(av! == 3.5, "arc f64 borrow read");
}

arc_optional_bool_borrow_read() `test {
  bool? init = true;
  Arc[bool?] a = Arc[bool?](init);
  bool? av = a.borrow;
  assert(av! == true, "arc bool borrow read");
}

// Pure value-type struct payload (all `value fields): the {i1,T} optional
// embeds the struct by value, the widest auto-copy case.
arc_optional_struct_borrow_read() `test {
  Pt? init = Pt(x: 1, y: 2);
  Arc[Pt?] a = Arc[Pt?](init);
  Pt? av = a.borrow;
  p := av!;
  assert(p.x == 1 && p.y == 2, "arc struct borrow read");
}

mutex_optional_struct_borrow_read() `test {
  Pt? init = Pt(x: 3, y: 4);
  Mutex[Pt?] m = Mutex[Pt?](init);
  g := m.lock();
  Pt? mv = g.borrow;
  p := mv!;
  assert(p.x == 3 && p.y == 4, "mutex struct borrow read");
}
