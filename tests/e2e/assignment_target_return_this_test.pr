// T0899: T0892 added the receiver-alias-clear to the *variable* assignment path
// (`m = expr`). The MemberExpr (`obj.field = expr`) and IndexExpr (`arr[i] = expr`)
// target branches of genAssignStmt had none, so the same clear was wired in for
// field/element targets from an operator/method result that returns the borrowed
// receiver (`return this`).
//
// T1084: that clear is now a runtime no-op. T0893 clones the `return this` result
// in wrapThisReturnValue, so the "aliasing" cases below are NOT actually aliased at
// runtime — each side (the operand local and the field/element) owns an independent
// clone and drops it exactly once. There is no double-free for any leak detector to
// absorb. The maybeClearReceiverDropFlag icmp at these assignment sites compares the
// result instance pointer against the operand's; because the clone makes them differ,
// it is always false and never clears a flag. These tests therefore exercise the
// clone path, not the clear path: they verify the clone yields correct values AND
// zero leaks (both sides drop once).
//
// The *fresh-value over-fire* cases still meaningfully verify the no-op clears don't
// wrongly fire: a fresh-value RHS (`f.fresh()`) allocates a new instance, so the
// operand must be left untouched — if the clear wrongly fired, the operand would leak
// (positive alloc delta, caught by the linux zero-leak gate). All types here have a
// `drop(~this)` so the separate no-drop drop-old gap (T0908) does not contaminate the
// results.
// Heap user type with a binary operator that returns the borrowed receiver.
type BB `doc("Heap user type whose + operator returns the borrowed receiver.") {
  int v;
  +(BB o) BB {
    return this;
  }
  drop(~this) {
  }
}

// Heap user type with a method that returns the borrowed receiver, plus one that
// allocates a fresh instance.
type DD `doc("Heap user type with dup() returning `this` and fresh() allocating anew.") {
  int v;
  dup() DD {
    return this;
  }
  fresh() DD {
    return DD(v: 99);
  }
  drop(~this) {
  }
}

// Generic heap user type with a binary operator that returns the borrowed receiver.
type GB[T] `doc("Generic heap user type whose + operator returns the borrowed receiver.") {
  T v;
  +(GB[T] o) GB[T] {
    return this;
  }
  drop(~this) {
  }
}

// Holder of a droppable field, for MemberExpr-target tests.
type Holder `doc("Holds a droppable BB field for field-target assignment tests.") {
  BB f;
  drop(~this) {
  }
}

// Holder of a droppable generic field.
type GHolder `doc("Holds a droppable GB[int] field for generic field-target tests.") {
  GB[int] f;
  drop(~this) {
  }
}

// Field target, binary operator alias: `h.f = a + b` where + returns `this`.
// The operand `a` is borrowed by `+` (not moved), so reading `a.v` AFTER the
// assignment must still see 11 — this is the direct check of T1084's thesis that
// T0893's clone gives the field and the operand independent ownership. If the clone
// regressed and the field aliased `a`, this readback would observe freed/mutated
// memory (and one side would double-free or leak).
field_binary_operator() `test {
  a := BB(v: 11);
  b := BB(v: 3);
  h := Holder(f: BB(v: 0));
  h.f = a + b;
  assert(h.f.v == 11, "field binary-operator assignment result");
  assert(a.v == 11, "operand independently readable after aliasing field assign");
}

// Field target, method alias: `hd.f = d.dup()` where dup() returns `this`.
// `dup()` borrows `this`, so `d` stays valid; reading `d.v` after confirms the
// field's clone is independent of the operand (T1084).
field_method_return_this() `test {
  d := DD(v: 7);
  hd := DDHolder(f: DD(v: 0));
  hd.f = d.dup();
  assert(hd.f.v == 7, "field method return-this assignment result");
  assert(d.v == 7, "operand independently readable after aliasing field assign");
}

// Index target, binary operator alias: `v[0] = a + b`.
index_binary_operator() `test {
  a := BB(v: 11);
  b := BB(v: 3);
  v := [BB(v: 0)];
  v[0] = a + b;
  assert(v[0].v == 11, "index binary-operator assignment result");
  assert(a.v == 11, "operand independently readable after aliasing index assign");
}

// Index target, method alias: `v[0] = d.dup()`.
index_method_return_this() `test {
  d := DD(v: 7);
  v := [DD(v: 0)];
  v[0] = d.dup();
  assert(v[0].v == 7, "index method return-this assignment result");
  assert(d.v == 7, "operand independently readable after aliasing index assign");
}

// Self-alias field (`h.f = h.f + b`): the existing same-pointer drop-old guard in
// genMemberAssign must still hold with the new operand-clear present.
field_self_alias() `test {
  b := BB(v: 4);
  h := Holder(f: BB(v: 21));
  h.f = h.f + b;
  assert(h.f.v == 21, "self-alias field assignment result");
}

// Self-alias index (`v[0] = v[0] + b`).
index_self_alias() `test {
  b := BB(v: 4);
  v := [BB(v: 21)];
  v[0] = v[0] + b;
  assert(v[0].v == 21, "self-alias index assignment result");
}

// Fresh-value over-fire guard (field): `h.f = f.fresh()` allocates a NEW instance,
// so the operand `f` must be left untouched. If the alias-clear wrongly over-fires
// here, `f` leaks — caught by the linux zero-leak gate.
field_fresh_value() `test {
  f := DD(v: 1);
  hd := DDHolder(f: DD(v: 0));
  hd.f = f.fresh();
  assert(hd.f.v == 99, "fresh-value field assignment result");
  assert(f.v == 1, "operand untouched by fresh-value field assignment");
}

// Fresh-value over-fire guard (index): `v[0] = f.fresh()`.
index_fresh_value() `test {
  f := DD(v: 1);
  v := [DD(v: 0)];
  v[0] = f.fresh();
  assert(v[0].v == 99, "fresh-value index assignment result");
  assert(f.v == 1, "operand untouched by fresh-value index assignment");
}

// Generic operator, field target: `gh.f = a + b` on GB[int].
generic_operator_field() `test {
  a := GB[int](v: 17);
  b := GB[int](v: 5);
  gh := GHolder(f: GB[int](v: 0));
  gh.f = a + b;
  assert(gh.f.v == 17, "generic operator field assignment result");
  assert(a.v == 17, "generic operand independently readable after field assign");
}

// Generic operator, index target: `v[0] = a + b` on GB[int].
generic_operator_index() `test {
  a := GB[int](v: 17);
  b := GB[int](v: 5);
  v := [GB[int](v: 0)];
  v[0] = a + b;
  assert(v[0].v == 17, "generic operator index assignment result");
  assert(a.v == 17, "generic operand independently readable after index assign");
}

// Generic-function-body field target: the operator-return-this assignment lives
// INSIDE wrap[T], so monomorphization runs with c.typeSubst active and the RHS
// type (GB[T]) is substituted before the alias-clear. The above generic_* tests
// keep the assignment in a `test (no typeSubst); this is the substitution path.
// The operands `a`/`b` are droppable locals — a missing clear would double-free
// (macOS abort), an over-fire would leak (linux zero-leak gate).
type GGHolder[T] `doc("Generic holder of a droppable GB[T] field for generic-body field tests.") {
  GB[T] f;
  drop(~this) {
  }
}

generic_body_field[T](GGHolder[T] move h, T move x, T move y) `doc("Field-target assign inside a generic body.") {
  a := GB[T](v: move x);
  b := GB[T](v: move y);
  h.f = a + b;
}

generic_field_in_generic_body() `test {
  h := GGHolder[int](f: GB[int](v: 0));
  generic_body_field[int](move h, 6, 4);
  assert(true, "generic-body field assignment completes without double-free");
}

// Generic-function-body index target: `v[0] = a + b` inside a generic body.
generic_body_index[T](T move x, T move y, T move z) `doc("Index-target assign inside a generic body.") {
  a := GB[T](v: move x);
  b := GB[T](v: move y);
  v := [GB[T](v: move z)];
  v[0] = a + b;
}

generic_index_in_generic_body() `test {
  generic_body_index[int](6, 4, 1);
  assert(true, "generic-body index assignment completes without double-free");
}

// Holder of a droppable DD field, used by the method/fresh field-target tests.
type DDHolder `doc("Holds a droppable DD field for field-target assignment tests.") {
  DD f;
  drop(~this) {
  }
}
