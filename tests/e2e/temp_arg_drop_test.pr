// T0331: Temporaries (CallExpr results) passed as plain (non-`~`) args to
// free functions or non-`new` methods must be dropped at statement end.
// Previously, T0109 unconditionally claimed the stmtTemp at the call site,
// which leaked the temp because the callee borrowed but didn't drop.
//
// Regression coverage for the related cases (return-aliases-arg, ~ params,
// constructors, container ops) is included to ensure no double-free.
makes_bytes() u8[] {
  u8[] r = u8[]();
  r.push(1u8);
  r.push(2u8);
  return r;
}

makes_strings() string[] {
  string[] r = string[]();
  r.push("a");
  r.push("b");
  return r;
}

assert_vec_len(u8[] a, u8[] b, int expected) {
  assert(a.len == expected, "a.len");
  assert(b.len == expected, "b.len");
}

assert_str_eq(string a, string b) {
  assert(a == b, "str eq");
}

// =========================================================================
// T0331-A: temporary from a method call passed as plain arg
// =========================================================================

t0331_method_temp() `test {
  u8[] x = makes_bytes();
  string s = "AB";
  assert_vec_len(x, s.bytes(), 2);
}

// =========================================================================
// T0331-B: temporaries from free-function calls passed as plain args
// =========================================================================

t0331_free_function_temps() `test {
  assert_vec_len(makes_bytes(), makes_bytes(), 2);
}

// =========================================================================
// Multiple temps in one call — each must drop independently
// =========================================================================

three_lens(u8[] a, u8[] b, u8[] c) int {
  return a.len + b.len + c.len;
}

t0331_three_temps() `test {
  int total = three_lens(makes_bytes(), makes_bytes(), makes_bytes());
  assert(total == 6, "three temps total");
}

// =========================================================================
// String temp as plain arg
// =========================================================================

t0331_string_temp() `test {
  string s = "hello";
  assert_str_eq(s.to_upper(), "HELLO");
}

// =========================================================================
// Standalone CallExpr-result-discard (statement-only, no assignment)
// =========================================================================

t0331_discard_call_result() `test {
  makes_bytes();
  // If the temp wasn't tracked, this would leak. The call result is
  // discarded — cleanupStmtTemps must drop it at statement end.
  assert(true, "discard");
}

// =========================================================================
// Regression: return-aliases-arg (identity-style on a temp)
// shuffle returns its input vector pointer. Without the alias-clear branch
// in emitReturnAliasCheck, the input stmtTemp would drop AND the result
// variable's drop binding would drop the same allocation (double-free).
// =========================================================================

identity_vec[T](T[] v) T[] {
  return v;
}

t0331_identity_returns_arg() `test {
  int[] v = identity_vec[int](make_ints());
  assert(v.len == 3, "identity len");
  assert(v[0] == 1, "identity v[0]");
}

make_ints() int[] {
  int[] r = int[]();
  r.push(1);
  r.push(2);
  r.push(3);
  return r;
}

// =========================================================================
// Regression: ~ param with CallExpr arg (must not leak, must not double-free)
// genCallArgsWithMutRef explicitly claims for ~ params, so this is unaffected
// by the T0109 removal — but verifying anyway.
// =========================================================================

consume_vec(~int[] v) int {
  return v.len;
}

t0331_tilde_param_with_temp() `test {
  int n = consume_vec(make_ints());
  assert(n == 3, "tilde param temp");
}

// =========================================================================
// Regression: constructor with CallExpr heap arg (T0322 path)
// genConstructorCallMono unconditionally claims; must not leak or double-free.
// =========================================================================

type Holder {
  int[] data;
}

t0331_constructor_with_temp() `test {
  Holder h = Holder(data: make_ints());
  assert(h.data.len == 3, "ctor with temp");
}

// =========================================================================
// Regression: Vector.push with CallExpr element
// push handler claims explicitly — no leak, no double-free.
// =========================================================================

make_string() string {
  return "ab" + "cd";
}

t0331_vector_push_temp() `test {
  string[] v = string[]();
  v.push(make_string());
  assert(v.len == 1, "push temp len");
  assert(v[0] == "abcd", "push temp value");
}

// =========================================================================
// Regression: Channel send with CallExpr arg (must not leak, no double-free)
// =========================================================================

t0331_channel_send_temp() `test {
  channel[int[]] ch = channel[int[]](capacity: 1);
  ch.send(make_ints());
  if v := <-ch {
    assert(v.len == 3, "channel temp len");
  } else {
    assert(false, "channel recv");
  }
}

// =========================================================================
// Regression: lambda call with CallExpr arg, return aliases input
// genIndirectCall must run emitReturnAliasCheck (added T0331). Without it,
// the stmtTemp would drop AND the variable would drop the same allocation.
// =========================================================================

t0331_lambda_returns_arg() `test {
  alias_fn := |int[] xs| -> int[] {
    return xs;
  };
  int[] v = alias_fn(make_ints());
  assert(v.len == 3, "lambda alias len");
}

// Lambda that does NOT return its arg — temp must drop at statement end.
t0331_lambda_borrows_arg() `test {
  count_fn := |int[] xs| -> int {
    return xs.len;
  };
  int n = count_fn(make_ints());
  assert(n == 3, "lambda borrow len");
}

// =========================================================================
// Regression: container internal == with ident arg (T0085 path)
// Map.get invokes key_eq with the second arg borrowed from container storage.
// Removing T0109 must not affect this path (args are IdentExpr, not CallExpr).
// =========================================================================

t0331_map_get_no_corrupt() `test {
  map[string, int] m = map[string, int]();
  m["foo"] = 1;
  m["bar"] = 2;
  m["baz"] = 3;
  if v := m["foo"] {
    assert(v == 1, "map foo");
  } else {
    assert(false, "map foo missing");
  }
  if v := m["bar"] {
    assert(v == 2, "map bar");
  } else {
    assert(false, "map bar missing");
  }
  if v := m["baz"] {
    assert(v == 3, "map baz");
  } else {
    assert(false, "map baz missing");
  }
  assert(m.len == 3, "map len");
}

// =========================================================================
// String-vector temp as plain arg
// Exercises the string[] tracking path (Vector elem type = string).
// =========================================================================

assert_str_vec_len(string[] a, int expected) {
  assert(a.len == expected, "str vec len");
}

t0331_string_vector_temp() `test {
  assert_str_vec_len(makes_strings(), 2);
}

// =========================================================================
// Member-field lambda call with CallExpr arg (genCallExpr line 1180 path)
// Tests `obj.fn(make_temp())` where fn is a stored lambda field. Distinct
// from the local-variable lambda path covered by t0331_lambda_*.
// =========================================================================

type Counter {
  (int[]) -> int counter_fn;
}

type AliasFn {
  (int[]) -> int[] alias_fn;
}

t0331_member_lambda_borrows_arg() `test {
  Counter c = Counter(counter_fn: |int[] xs| -> xs.len);
  int n = c.counter_fn(make_ints());
  assert(n == 3, "member lambda borrow len");
}

t0331_member_lambda_returns_arg() `test {
  AliasFn af = AliasFn(alias_fn: |int[] xs| -> int[] {
    return xs;
  });
  int[] v = af.alias_fn(make_ints());
  assert(v.len == 3, "member lambda alias len");
}

// =========================================================================
// Variadic param with CallExpr args (genCallArgsWithMutRef variadic path)
// genCallArgsWithMutRef explicitly claims for variadic — must not leak
// or double-free.
// =========================================================================

sum_lens(...int[] vecs) int {
  int total = 0;
  for v in vecs {
    total = total + v.len;
  }
  return total;
}

t0331_variadic_temps() `test {
  int n = sum_lens(make_ints(), make_ints(), make_ints());
  assert(n == 9, "variadic temps total");
}

// =========================================================================
// T0341: CallExpr results returning Map / Set / heap user types must be
// dropped at statement end when discarded or passed as plain (non-`~`) args.
// Previously these leaked because expr.go only tracked string and vector
// return types — not value-struct heap user types.
// =========================================================================

t0341_make_map() map[string, int] {
  map[string, int] m = map[string, int]();
  m["a"] = 1;
  m["b"] = 2;
  return m;
}

t0341_len_check_map(map[string, int] m, int expected) {
  assert(m.len == expected, "map.len");
}

t0341_map_plain_arg() `test {
  t0341_len_check_map(t0341_make_map(), 2);
}

t0341_map_discard() `test {
  t0341_make_map();
  assert(true, "ok");
}

t0341_make_set() Set[int] {
  Set[int] s = Set[int]();
  s.add(1);
  s.add(2);
  s.add(3);
  return s;
}

t0341_len_check_set(Set[int] s, int expected) {
  assert(s.len == expected, "set.len");
}

t0341_set_plain_arg() `test {
  t0341_len_check_set(t0341_make_set(), 3);
}

t0341_set_discard() `test {
  t0341_make_set();
  assert(true, "ok");
}

type T341Holder {
  int[] data;
}

t0341_make_holder() T341Holder {
  return T341Holder(data: int[]());
}

t0341_len_check_holder(T341Holder h, int expected) {
  assert(h.data.len == expected, "holder.data.len");
}

t0341_user_heap_plain_arg() `test {
  t0341_len_check_holder(t0341_make_holder(), 0);
}

t0341_user_heap_discard() `test {
  t0341_make_holder();
  assert(true, "ok");
}

type T341Factory {
  int x;
  produce() T341Holder => T341Holder(data: int[]());
}

t0341_method_heap_discard() `test {
  T341Factory f = T341Factory(x: 1);
  f.produce();
}

t0341_method_heap_plain_arg() `test {
  T341Factory f = T341Factory(x: 1);
  t0341_len_check_holder(f.produce(), 0);
}

// T0341: Receiver alias check — a method that returns `this` aliases its
// receiver. The new tracking from T0341 must not double-free the receiver's
// allocation. emitReceiverAliasCheck handles this for IdentExpr-on-local and
// ThisExpr receivers via a runtime pointer comparison. These tests use a heap
// user type WITH a heap field (int[]) so a double-free would crash, distinct
// from the tests in return_this_test.pr which use only int fields.

type T341SelfAlias {
  int[] data;
  alias() T341SelfAlias {
    return this;
  }
}

t0341_self_returning_discard_local() `test {
  s := T341SelfAlias(data: int[]());
  s.alias();
  assert(s.data.len == 0, "s still owns data after alias() discard");
}

t0341_self_returning_plain_arg(T341SelfAlias x, int expected) {
  assert(x.data.len == expected, "alias plain arg data.len");
}

t0341_self_returning_local_plain_arg() `test {
  s := T341SelfAlias(data: int[]());
  t0341_self_returning_plain_arg(s.alias(), 0);
  assert(s.data.len == 0, "s still owns data after alias() plain-arg");
}

// ThisExpr branch: a method on `this` that returns `this`, where the result
// is bound to a local before being returned. emitReceiverAliasCheck reaches
// the *ast.ThisExpr branch when the alias call appears inside another method.
type T341SelfAlias2 {
  int[] data;
  alias() T341SelfAlias2 {
    return this;
  }
  bind_self_then_return() T341SelfAlias2 {
    r := this.alias();
    return r;
  }
}

t0341_this_alias_inside_method() `test {
  s := T341SelfAlias2(data: int[]());
  r := s.bind_self_then_return();
  assert(r.data.len == 0, "this.alias() inside method preserves data");
}

// Method on a field receiver (MemberExpr target) — emitReceiverAliasCheck
// short-circuits via the default branch (only IdentExpr/ThisExpr). claimHeapTemp
// catches any aliasing at runtime via pointer comparison.
type T341FieldOwner {
  T341Factory factory;
}

t0341_method_on_field_discard() `test {
  o := T341FieldOwner(factory: T341Factory(x: 1));
  o.factory.produce();
}

t0341_method_on_field_plain_arg() `test {
  o := T341FieldOwner(factory: T341Factory(x: 1));
  t0341_len_check_holder(o.factory.produce(), 0);
}

// =========================================================================
// T0346: A constructor expression used as a standalone discard statement
// (no LHS, no enclosing call) must free its allocation exactly once.
// Previously, two cleanup paths fired on the same allocation (the
// genConstructorCallMono heap-temp's palFree at statement end AND
// dropDiscardedHeapType's explicit free), causing a double-free segfault.
// Fix: dropDiscardedHeapType claims the constructor's heap temp before
// emitting its own free, so cleanupHeapTemps skips the now-claimed temp.
// =========================================================================

type T0346Holder {
  int x;
}

t0346_user_heap_discard() `test {
  T0346Holder(x: 5);
  assert(true, "no segfault");
}

t0346_map_discard() `test {
  map[string, int]();
  assert(true, "no segfault");
}

t0346_set_discard() `test {
  Set[int]();
  assert(true, "no segfault");
}

// =========================================================================
// T0345: Constructor inline as plain (non-`~`) arg must free transitive heap
// fields. genConstructorCallMono tracks the new instance with palFree (T0135),
// which only frees the top-level instance struct at statement end. The type's
// synthesized drop (which would free heap fields like vector buffers, map
// storage, strings) was never invoked. Fix: swap the heap-temp dropFunc from
// palFree to the full drop after construction completes successfully.
// =========================================================================

type T0345VecHolder {
  int[] data;
}

t0345_len_check_vec(T0345VecHolder h, int expected) {
  assert(h.data.len == expected, "vec.len");
}

t0345_ctor_vec_field_plain_arg() `test {
  t0345_len_check_vec(T0345VecHolder(data: int[]()), 0);
}

type T0345StrHolder {
  string name;
}

t0345_len_check_str(T0345StrHolder h, int expected) {
  assert(h.name.len == expected, "str.len");
}

t0345_ctor_str_field_plain_arg() `test {
  t0345_len_check_str(T0345StrHolder(name: "hello"), 5);
}

type T0345MapHolder {
  map[string, int] m;
}

t0345_len_check_map(T0345MapHolder h, int expected) {
  assert(h.m.len == expected, "map.len");
}

t0345_ctor_map_field_plain_arg() `test {
  t0345_len_check_map(T0345MapHolder(m: map[string, int]()), 0);
}

type T0345SetHolder {
  Set[int] s;
}

t0345_len_check_set(T0345SetHolder h, int expected) {
  assert(h.s.len == expected, "set.len");
}

t0345_ctor_set_field_plain_arg() `test {
  t0345_len_check_set(T0345SetHolder(s: Set[int]()), 0);
}

type T0345Inner {
  int[] data;
}
type T0345Outer {
  T0345Inner inner;
}

t0345_check_outer(T0345Outer h, int expected) {
  assert(h.inner.data.len == expected, "nested data.len");
}

t0345_ctor_nested_user_heap_plain_arg() `test {
  t0345_check_outer(T0345Outer(inner: T0345Inner(data: int[]())), 0);
}

type T0345MultiField {
  int[] a;
  string b;
  map[string, int] c;
}

t0345_check_multi(T0345MultiField h) {
  assert(h.a.len == 0, "a.len");
  assert(h.b.len == 5, "b.len");
  assert(h.c.len == 0, "c.len");
}

t0345_ctor_multi_field_plain_arg() `test {
  t0345_check_multi(T0345MultiField(a: int[](), b: "hello", c: map[string, int]()));
}

// Failable HasNew constructor as plain arg: the okBlock swap site is exercised
// here. The instance is allocated, fields zero-init'd, new() runs and succeeds,
// the dropFunc is swapped, and the value struct is built. The unclaimed temp
// must invoke the type's full drop at statement end, freeing the int[] field.
type T0345FailableHolder {
  int[] data;

  new!(~this, ~int[] codes) {
    if codes.len > 100 {
      raise error(message: "too long");
    }
    this.data = codes;
  }
}

t0345_len_check_failable(T0345FailableHolder h, int expected) {
  assert(h.data.len == expected, "failable.data.len");
}

t0345_use_failable!() {
  // Constructor is failable; `?!` unwraps inline and the unwrapped value
  // is passed as a plain arg. The temp must be cleaned up via the
  // okBlock-swapped full drop at statement end (freeing the int[] field).
  t0345_len_check_failable(T0345FailableHolder(codes: int[]())?!, 0);
}

t0345_failable_ctor_plain_arg_success() `test {
  t0345_use_failable()?!;
  assert(true, "failable ok-path plain-arg ok");
}

// Generic mono type as plain-arg: exercises resolveDropFuncForTemp's
// monoName lookup path (via *types.Instance branch). The synth drop for
// Box__intvec must be declared before the constructor body emits.
type T0345Box[T] {
  T[] items;
}

t0345_check_box_int(T0345Box[int] b, int expected) {
  assert(b.items.len == expected, "box.items.len");
}

t0345_generic_mono_plain_arg() `test {
  t0345_check_box_int(T0345Box[int](items: int[]()), 0);
}

// Generic mono type with multiple type parameters as plain-arg.
type T0345Pair[K, V] {
  K[] keys;
  V[] values;
}

t0345_check_pair(T0345Pair[string, int] p) {
  assert(p.keys.len == 0, "pair keys");
  assert(p.values.len == 0, "pair values");
}

t0345_generic_mono_multi_param_plain_arg() `test {
  t0345_check_pair(T0345Pair[string, int](keys: string[](), values: int[]()));
}

// Explicit user drop (HasDrop) with heap fields: exercises
// resolveDropFuncForTemp's HasDrop branch (returns the $wrap drop, which
// calls the user drop then pal_free). Without the swap, the heap field
// leaks because the original tracker only freed the instance struct.
type T0345HasDrop {
  int[] data;
  int id;

  new(~this, ~int[] data, int id) {
    this.data = data;
    this.id = id;
  }

  drop(~this) {
    // Explicit user drop. Synth drop is suppressed; the $wrap added by
    // codegen wraps this call with pal_free for the instance struct.
    // Heap fields (this.data) are dropped by the $wrap path.
  }
}

t0345_check_has_drop(T0345HasDrop r, int expected_id) {
  assert(r.id == expected_id, "has_drop.id");
}

t0345_has_drop_plain_arg() `test {
  t0345_check_has_drop(T0345HasDrop(data: int[](), id: 7), 7);
}

// Discard of constructor with heap fields: T0345 swaps dropFunc, then
// T0346's dropDiscardedHeapType claims the heap temp and emits its own
// drop call using resolveDropFuncForTemp. Both should resolve to the
// same full drop. Verifies the two fixes interact cleanly.
type T0345DiscardWithFields {
  string name;
  int[] codes;
}

t0345_discard_with_heap_fields() `test {
  T0345DiscardWithFields(name: "abc", codes: int[]());
  assert(true, "no leak/segfault");
}

// Failable HasNew err-path: when new() raises, the instance is left
// zero-initialized. cleanupHeapTemps fires the swapped fullDrop on the
// zero-init'd instance. Synth drop must null-check heap fields to avoid
// segfault. Verifies the safety claim from the T0345 fix plan.
type T0345ErrFailable {
  int[] data;

  new!(~this, ~int[] codes) {
    if codes.len > 100 {
      raise error(message: "too long");
    }
    this.data = codes;
  }
}

t0345_make_long_vec() int[] {
  int[] v = int[]();
  int i = 0;
  while i < 101 {
    v.push(i);
    i = i + 1;
  }
  return v;
}

t0345_check_err_failable(T0345ErrFailable h, int expected) {
  assert(h.data.len == expected, "err_failable.data.len");
}

t0345_err_callsite!() {
  // Failable constructor as plain-arg with `?^` propagation. On err,
  // the instance is zero-init'd and the swapped fullDrop must safely
  // walk the null heap fields without crashing.
  t0345_check_err_failable(T0345ErrFailable(codes: t0345_make_long_vec())?^, 0);
}

t0345_failable_ctor_plain_arg_failure() `test {
  int caught = 0;
  t0345_err_callsite()? e {
    caught = 1;
  };
  assert(caught == 1, "err propagated, instance dropped without crash");
}

// =========================================================================
// T0343: Heap user type results from ErrorPanicExpr (?!), OptionalUnwrapExpr
// (!), ErrorPropagateExpr (?^), and ErrorHandlerExpr (? e {}) must be dropped
// at statement end when discarded or passed as plain (non-`~`) args.
// Previously, only the i8* (string) branch tracked the result; value-struct
// heap user types fell through with no tracking, leaking 2 allocations
// (instance + transitive heap field).
// =========================================================================

type T0343Holder {
  int[] data;
}

t0343_make_failable!() T0343Holder {
  return T0343Holder(data: int[]());
}

t0343_make_optional() T0343Holder? {
  return T0343Holder(data: int[]());
}

t0343_check_holder(T0343Holder h) {
  assert(h.data.len == 0, "holder data.len");
}

// ?! (ErrorPanicExpr) discard / plain-arg
t0343_panic_discard() `test {
  t0343_make_failable()?!;
}

t0343_panic_plain_arg() `test {
  t0343_check_holder(t0343_make_failable()?!);
}

// ! (OptionalUnwrapExpr) discard / plain-arg
t0343_optional_discard() `test {
  t0343_make_optional()!;
}

t0343_optional_plain_arg() `test {
  t0343_check_holder(t0343_make_optional()!);
}

// ?^ (ErrorPropagateExpr) discard / plain-arg, in a failable wrapper
t0343_propagate_discard_inner!() {
  t0343_make_failable()?^;
}

t0343_propagate_discard() `test {
  t0343_propagate_discard_inner()?!;
}

t0343_propagate_plain_arg_inner!() {
  t0343_check_holder(t0343_make_failable()?^);
}

t0343_propagate_plain_arg() `test {
  t0343_propagate_plain_arg_inner()?!;
}

// ? e { } (ErrorHandlerExpr) discard / plain-arg
t0343_handler_discard() `test {
  t0343_make_failable()? e {
    return;
  };
}

t0343_handler_plain_arg() `test {
  t0343_check_holder(t0343_make_failable()? e {
    return;
  });
}

// Method on a local returning failable heap user type — exercises the
// receiver-alias check after peeling the ?! through findInnerCallExpr.
type T0343Factory {
  int x;
  produce!() T0343Holder {
    return T0343Holder(data: int[]());
  }
}

t0343_method_failable_discard() `test {
  f := T0343Factory(x: 1);
  f.produce()?!;
}

t0343_method_failable_plain_arg() `test {
  f := T0343Factory(x: 1);
  t0343_check_holder(f.produce()?!);
}

// Optional bound to a local then unwrapped — must NOT be tracked, otherwise
// the optional's drop binding and the unwrap tracker would double-free.
t0343_optional_ident_unwrap() `test {
  o := t0343_make_optional();
  h := o!;
  assert(h.data.len == 0, "ident-source unwrap");
}

// =========================================================================
// T0343 coverage gaps — additional cases for the unwrap/propagate/handler
// receiver-alias paths and findInnerCallExpr's ParenExpr peel.
// =========================================================================

type T0343FactoryAll {
  int x;
  produce_failable!() T0343Holder {
    return T0343Holder(data: int[]());
  }
  produce_optional() T0343Holder? {
    return T0343Holder(data: int[]());
  }
}

// Method-on-local with ! (optional) — exercises receiver-alias peel through
// OptionalUnwrapExpr in findInnerCallExpr.
t0343_method_optional_discard() `test {
  f := T0343FactoryAll(x: 1);
  f.produce_optional()!;
}

t0343_method_optional_plain_arg() `test {
  f := T0343FactoryAll(x: 1);
  t0343_check_holder(f.produce_optional()!);
}

// Method-on-local with ?^ — exercises receiver-alias peel through
// ErrorPropagateExpr inside a failable wrapper.
t0343_method_propagate_inner!() {
  f := T0343FactoryAll(x: 1);
  f.produce_failable()?^;
}

t0343_method_propagate_discard() `test {
  t0343_method_propagate_inner()?!;
}

t0343_method_propagate_plain_arg_inner!() {
  f := T0343FactoryAll(x: 1);
  t0343_check_holder(f.produce_failable()?^);
}

t0343_method_propagate_plain_arg() `test {
  t0343_method_propagate_plain_arg_inner()?!;
}

// Method-on-local with ? e {} — exercises receiver-alias peel through
// ErrorHandlerExpr.
t0343_method_handler_discard() `test {
  f := T0343FactoryAll(x: 1);
  f.produce_failable()? e {
    return;
  };
}

t0343_method_handler_plain_arg() `test {
  f := T0343FactoryAll(x: 1);
  t0343_check_holder(f.produce_failable()? e {
    return;
  });
}

// Map result through ?! — exercises trackHeapUserTypeResult on a non-user
// heap type (Map is a heap-allocated generic but not a "container" per
// isContainerType; it must still be tracked through the unwrap path).
t0343_make_map_failable!() map[string, int] {
  m := map[string, int]();
  m["a"] = 1;
  return m;
}

t0343_check_map(map[string, int] m) {
  assert(m.len == 1, "map.len");
}

t0343_map_panic_discard() `test {
  t0343_make_map_failable()?!;
}

t0343_map_panic_plain_arg() `test {
  t0343_check_map(t0343_make_map_failable()?!);
}

// Set result through ! — same path with optional.
t0343_make_set_optional() Set[int]? {
  s := Set[int]();
  s.add(42);
  return s;
}

t0343_check_set(Set[int] s) {
  assert(s.len == 1, "set.len");
}

t0343_set_optional_discard() `test {
  t0343_make_set_optional()!;
}

t0343_set_optional_plain_arg() `test {
  t0343_check_set(t0343_make_set_optional()!);
}

// Self-returning method through ?! — exercises claimHeapTemp pointer
// comparison on the unwrap result aliasing the receiver. Failable variant
// of T0341's t0341_self_returning_local_plain_arg.
type T0343SelfAlias {
  int[] data;
  alias_failable!() T0343SelfAlias {
    return this;
  }
}

t0343_self_alias_failable_discard() `test {
  s := T0343SelfAlias(data: int[]());
  s.alias_failable()?!;
  assert(s.data.len == 0, "s still owns data after alias_failable() ?!");
}

t0343_self_alias_failable_plain_arg(T0343SelfAlias x, int expected) {
  assert(x.data.len == expected, "alias failable plain arg");
}

t0343_self_alias_failable_local_plain_arg() `test {
  s := T0343SelfAlias(data: int[]());
  t0343_self_alias_failable_plain_arg(s.alias_failable()?!, 0);
  assert(s.data.len == 0, "s still owns data after alias_failable() ?! plain-arg");
}

// T0344: ?! / ! / ? e {...} returning heap user types must drop temps at
// statement end when discarded or passed as plain (non-`~`) args.

type T344Holder {
  int[] data;
}

t0344_make_holder_failable!() T344Holder {
  return T344Holder(data: int[]());
}
t0344_make_holder_optional() T344Holder? {
  return T344Holder(data: int[]());
}
t0344_make_map_failable!() map[string, int] {
  m := map[string, int]();
  m["a"] = 1;
  return m;
}
t0344_len_check_holder(T344Holder h, int expected) {
  assert(h.data.len == expected, "holder.data.len");
}

t0344_panic_unwrap_discard() `test {
  t0344_make_holder_failable()?!;
}
t0344_panic_unwrap_plain_arg() `test {
  t0344_len_check_holder(t0344_make_holder_failable()?!, 0);
}
t0344_panic_unwrap_map_discard() `test {
  t0344_make_map_failable()?!;
}
t0344_optional_unwrap_discard() `test {
  t0344_make_holder_optional()!;
}
t0344_optional_unwrap_plain_arg() `test {
  t0344_len_check_holder(t0344_make_holder_optional()!, 0);
}
t0344_handler_constructor_discard() `test {
  t0344_make_holder_failable()? e {
    T344Holder(data: int[]())
  };
}
t0344_handler_plain_arg() `test {
  t0344_len_check_holder(t0344_make_holder_failable()? e {
    T344Holder(data: int[]())
  },
  0);
}

// =========================================================================
// T0350: ?! / ! / ?^ / ? e {} returning Vector[T] (i8* result) must drop
// temps at statement end when discarded or passed as plain (non-`~`) args.
// Vector returns as bare i8* (not the {i8*, i8*} value struct of T0343),
// so the i8* branches in expr.go must explicitly check for TypVector and
// route to Vector.drop with element-type info — otherwise:
//   - ?! / ?^ leaked the entire vector buffer (no tracking).
//   - ! / ? e {} leaked element strings (string[] elements never dropped;
//     only the buffer was accidentally freed via promise_string_drop's
//     bit-63 path on the cap field).
// String-element variants are the strongest regression guard since they
// exercise Vector.drop's per-element drop loop.
// =========================================================================

t0350_make_int_vec_failable!() int[] {
  v := int[]();
  v.push(1);
  v.push(2);
  return v;
}

t0350_make_int_vec_optional() int[]? {
  v := int[]();
  v.push(1);
  v.push(2);
  return v;
}

t0350_check_int_vec(int[] v) {
  assert(v.len == 2, "int vec len");
}

t0350_make_str_vec_failable!() string[] {
  v := string[]();
  v.push("hello");
  v.push("world");
  return v;
}

t0350_make_str_vec_optional() string[]? {
  v := string[]();
  v.push("hello");
  v.push("world");
  return v;
}

t0350_check_str_vec(string[] v) {
  assert(v.len == 2, "str vec len");
}

// ?! (ErrorPanicExpr) — int[]
t0350_int_panic_discard() `test {
  t0350_make_int_vec_failable()?!;
}
t0350_int_panic_plain_arg() `test {
  t0350_check_int_vec(t0350_make_int_vec_failable()?!);
}

// ?! — string[] (string-element drop required)
t0350_str_panic_discard() `test {
  t0350_make_str_vec_failable()?!;
}
t0350_str_panic_plain_arg() `test {
  t0350_check_str_vec(t0350_make_str_vec_failable()?!);
}

// ! (OptionalUnwrapExpr) — int[]
t0350_int_optional_discard() `test {
  t0350_make_int_vec_optional()!;
}
t0350_int_optional_plain_arg() `test {
  t0350_check_int_vec(t0350_make_int_vec_optional()!);
}

// ! — string[]
t0350_str_optional_discard() `test {
  t0350_make_str_vec_optional()!;
}
t0350_str_optional_plain_arg() `test {
  t0350_check_str_vec(t0350_make_str_vec_optional()!);
}

// B0287 regression: optional bound to a local then unwrapped — must NOT be
// tracked, otherwise the optional's drop binding and the unwrap tracker
// would double-free.
t0350_int_optional_ident_unwrap() `test {
  o := t0350_make_int_vec_optional();
  v := o!;
  assert(v.len == 2, "int ident unwrap");
}
t0350_str_optional_ident_unwrap() `test {
  o := t0350_make_str_vec_optional();
  v := o!;
  assert(v.len == 2, "str ident unwrap");
}

// ?^ (ErrorPropagateExpr) — int[], wrapped because ?^ requires failable context
t0350_int_propagate_discard_inner!() {
  t0350_make_int_vec_failable()?^;
}
t0350_int_propagate_discard() `test {
  t0350_int_propagate_discard_inner()?!;
}
t0350_int_propagate_plain_arg_inner!() {
  t0350_check_int_vec(t0350_make_int_vec_failable()?^);
}
t0350_int_propagate_plain_arg() `test {
  t0350_int_propagate_plain_arg_inner()?!;
}

// ?^ — string[]
t0350_str_propagate_discard_inner!() {
  t0350_make_str_vec_failable()?^;
}
t0350_str_propagate_discard() `test {
  t0350_str_propagate_discard_inner()?!;
}
t0350_str_propagate_plain_arg_inner!() {
  t0350_check_str_vec(t0350_make_str_vec_failable()?^);
}
t0350_str_propagate_plain_arg() `test {
  t0350_str_propagate_plain_arg_inner()?!;
}

// ? e {} (ErrorHandlerExpr) — int[]
t0350_int_handler_discard() `test {
  t0350_make_int_vec_failable()? e {
    return;
  };
}
t0350_int_handler_plain_arg() `test {
  t0350_check_int_vec(t0350_make_int_vec_failable()? e {
    return;
  });
}

// ? e {} — string[] (catches the previously-broken accidental tracking)
t0350_str_handler_discard() `test {
  t0350_make_str_vec_failable()? e {
    return;
  };
}
t0350_str_handler_plain_arg() `test {
  t0350_check_str_vec(t0350_make_str_vec_failable()? e {
    return;
  });
}

// =========================================================================
// T0356: Vector[T] elements (heap user types, enums with droppable variant
// data, etc.) returned from CallExpr / ?! / ! / ?^ / ? e {} must be dropped
// when the vector is discarded or passed as a plain (non-`~`) arg.
//
// stmtTemp cleanup previously called a string-only element drop helper,
// so non-string elements leaked even after T0350 fixed the buffer leak.
// Both cleanupStmtTemps and emitStmtTempCleanupForErrorPath were affected.
// =========================================================================

type T0356Holder {
  string name;
}

t0356_make_holder_vec() T0356Holder[] {
  v := T0356Holder[]();
  v.push(T0356Holder(name: "a"));
  v.push(T0356Holder(name: "b"));
  return v;
}

t0356_make_holder_vec_failable!() T0356Holder[] {
  v := T0356Holder[]();
  v.push(T0356Holder(name: "a"));
  v.push(T0356Holder(name: "b"));
  return v;
}

t0356_make_holder_vec_optional() T0356Holder[]? {
  v := T0356Holder[]();
  v.push(T0356Holder(name: "a"));
  v.push(T0356Holder(name: "b"));
  return v;
}

t0356_check_holder_vec(T0356Holder[] v) {
  assert(v.len == 2, "T0356 holder vec len");
}

// Plain CallExpr — discard / plain-arg
t0356_call_discard() `test {
  t0356_make_holder_vec();
}
t0356_call_plain_arg() `test {
  t0356_check_holder_vec(t0356_make_holder_vec());
}

// ?! (ErrorPanicExpr) — discard / plain-arg
t0356_panic_discard() `test {
  t0356_make_holder_vec_failable()?!;
}
t0356_panic_plain_arg() `test {
  t0356_check_holder_vec(t0356_make_holder_vec_failable()?!);
}

// ! (OptionalUnwrapExpr) — discard / plain-arg
t0356_optional_discard() `test {
  t0356_make_holder_vec_optional()!;
}
t0356_optional_plain_arg() `test {
  t0356_check_holder_vec(t0356_make_holder_vec_optional()!);
}

// ? e {} (ErrorHandlerExpr) — discard / plain-arg
t0356_handler_discard() `test {
  t0356_make_holder_vec_failable()? e {
    return;
  };
}
t0356_handler_plain_arg() `test {
  t0356_check_holder_vec(t0356_make_holder_vec_failable()? e {
    return;
  });
}

// Enum element with droppable variant data — uses to_string() so the payload
// is heap-allocated (string literals live in .rodata and don't leak).
enum T0356Color {
  Named(string n),
  Rgb(int r, int g, int b),
}

t0356_mk_color_str(int n) string {
  return n.to_string();
}

t0356_make_enum_vec() T0356Color[] {
  v := T0356Color[]();
  v.push(T0356Color.Named(n: t0356_mk_color_str(1)));
  v.push(T0356Color.Named(n: t0356_mk_color_str(2)));
  return v;
}

t0356_enum_discard() `test {
  t0356_make_enum_vec();
}

// Error-propagation cleanup path — exercises emitStmtTempCleanupForErrorPath.
// make_vec() produces a stmt temp; fail()?^ then propagates an error, so the
// error-path cleanup must drop the vector elements (not just the buffer).
t0356_err_path_fail!() int {
  raise error("nope");
}

t0356_err_path_consume(T0356Holder[] ~v, int x) {
}

t0356_err_path_inner!() {
  t0356_err_path_consume(t0356_make_holder_vec(), t0356_err_path_fail()?^);
}

t0356_err_path() `test {
  t0356_err_path_inner()? e {
    return;
  };
}

// Nested-vector elements (`int[][]`) — vectors are themselves heap-allocated
// with their own synth drop, so cleanupStmtTemps must drop each inner Vector
// before freeing the outer buffer. Exercises the vecElemNeedsUserTypeDrop /
// recursive Vector.drop branch of emitVectorElementDropLoop.
t0356_make_nested_vec() int[][] {
  v := int[][]();
  inner1 := int[]();
  inner1.push(1);
  inner1.push(2);
  v.push(inner1);
  inner2 := int[]();
  inner2.push(3);
  v.push(inner2);
  return v;
}

t0356_check_nested_vec(int[][] v) {
  assert(v.len == 2, "T0356 nested vec len");
}

t0356_nested_discard() `test {
  t0356_make_nested_vec();
}

t0356_nested_plain_arg() `test {
  t0356_check_nested_vec(t0356_make_nested_vec());
}
