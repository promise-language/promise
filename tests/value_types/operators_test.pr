type Vec2 {
  int x `value;
  int y `value;

  +(Vec2 other) Vec2 {
    return Vec2(x: this.x + other.x, y: this.y + other.y);
  }

  - (Vec2 other) Vec2 {
    return Vec2(x: this.x - other.x, y: this.y - other.y);
  }

  == (Vec2 other) bool {
    return this.x == other.x && this.y == other.y;
  }

  != (Vec2 other) bool {
    return !(this == other);
  }
}

main() `test(expected: """4
6
2
2
eq
neq
diff""") {
  Vec2 a = Vec2(x: 1, y: 2);
  Vec2 b = Vec2(x: 3, y: 4);

  Vec2 c = a + b;
  print_line(c.x);
  print_line(c.y);

  Vec2 d = b - a;
  print_line(d.x);
  print_line(d.y);

  Vec2 e = Vec2(x: 1, y: 2);
  if a == e {
    print_line("eq");
  } else {
    print_line("neq");
  }
  if a == b {
    print_line("eq");
  } else {
    print_line("neq");
  }
  if a != b {
    print_line("diff");
  } else {
    print_line("same");
  }
}
