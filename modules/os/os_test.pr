// Tests for os module: environment variables, working directory, exit, arguments, executable_path.
test_get_environment_variable_path() `test(exclude: "wasm32") {
  string? path = get_environment_variable("PATH");
  assert(path is present, "PATH should be present");
}

test_get_environment_variable_home() `test(exclude: "wasm32") {
  string? home = get_environment_variable("HOME");
  assert(home is present, "HOME should be present");
  if h := home {
    assert(h.len > 0, "HOME should be non-empty");
  }
}

test_get_environment_variable_absent() `test(exclude: "wasm32") {
  string? val = get_environment_variable("PROMISE_NONEXISTENT_VAR_12345");
  assert(val is absent, "absent variable returns none");
}

test_get_environment_variable_unwrap() `test(exclude: "wasm32") {
  string? path = get_environment_variable("PATH");
  if p := path {
    assert(p.len > 0, "PATH value should be non-empty");
  } else {
    assert(false, "PATH should be present");
  }
}

test_get_environment_variable_empty_value() `test(exclude: "wasm32") {
  // PROMISE_EMPTY_TEST_VAR is set to "" by the test harness setup below.
  // We can't set env vars from Promise yet, so test using a var that is
  // commonly empty or use PATH which is guaranteed present and non-empty.
  // Instead, verify the "present but value could be anything" path:
  // HOME is always present; if we had set-env we'd test empty specifically.
  string? home = get_environment_variable("HOME");
  if h := home {
    // Verify we can compare the value (exercises the string inside optional)
    assert(h == h, "unwrapped env var should equal itself");
  } else {
    assert(false, "HOME should be present");
  }
}

test_working_directory_is_stable() `test(exclude: "wasm32") {
  string cwd1 = working_directory!;
  string cwd2 = working_directory!;
  assert(cwd1 == cwd2, "reading working_directory twice should return the same value");
}

test_working_directory_nonempty() `test(exclude: "wasm32") {
  string cwd = working_directory!;
  assert(cwd.len > 0, "working directory should be non-empty");
}

test_working_directory_absolute() `test(exclude: "wasm32") {
  string cwd = working_directory!;
  assert(cwd.starts_with("/"), "working directory should be absolute path");
}

test_arguments_returns_empty_in_test_runner() `test(exclude: "wasm32") {
  string[] a = arguments();
  // Test runner passes no user arguments, so arguments() should be empty
  assert(a.len == 0, "arguments should be empty in test runner");
}

test_arguments_is_iterable() `test(exclude: "wasm32") {
  string[] a = arguments();
  int count = 0;
  for _ in a {
    count = count + 1;
  }
  assert(count == 0, "iterating empty arguments should produce zero elements");
}

test_executable_path_returns_string() `test(exclude: "wasm32") {
  string exe = executable_path();
  assert(exe.len > 0, "executable_path should be non-empty");
}

test_executable_path_contains_slash() `test(exclude: "wasm32") {
  string exe = executable_path();
  // The executable path should be an absolute or relative path with a separator
  assert(exe.contains("/"), "executable_path should contain a path separator");
}

test_executable_path_is_stable() `test(exclude: "wasm32") {
  string exe1 = executable_path();
  string exe2 = executable_path();
  assert(exe1 == exe2, "calling executable_path() twice should return the same value");
}
