  set_env_var("PROMISE_TEST_ENV_MAP", move absent);
}

test_execute_custom_env() `test(exclude: wasm) `target(!windows) {
  map[string, string] custom_env = map[string, string]();
  custom_env["PATH"] = "/usr/bin:/bin";
  custom_env["MY_TEST_VAR"] = "custom_value";
  ProcessResult result = execute("sh", ["-c", "echo $MY_TEST_VAR"], environment: move custom_env)?!;
  assert(result.exit_code == 0, "sh should exit with 0");
  assert(result.stdout.trim() == "custom_value", "child should see custom env var");
}

test_execute_custom_env_windows() `test(exclude: wasm) `target(windows) {
  // env map fully replaces the child environment; seed from parent so cmd.exe keeps
  // SystemRoot/ComSpec, then inject our own var. Guards emitEnvpToBlock.
  map[string, string] custom_env = env;
  custom_env["PROMISE_TEST_WIN_VAR"] = "custom_value";
  ProcessResult result = execute("cmd", ["/c", "echo %PROMISE_TEST_WIN_VAR%"],
  environment: move custom_env)?!;
  assert(result.exit_code == 0, "cmd /c echo should exit 0");
  assert(result.stdout.trim() == "custom_value", "child should see injected env var");
}

test_execute_custom_cwd() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("pwd", [], working_directory: "/usr")?!;
  assert(result.exit_code == 0, "pwd should exit with 0");
  assert(result.stdout.trim() == "/usr", "child should run in /usr");
}

test_execute_env_isolation() `test(exclude: wasm) `target(!windows) {
  // Custom env does NOT inherit parent env — child should NOT see PATH from parent
  // (unless we explicitly set it)
  set_env_var("PROMISE_TEST_ISOLATION", "parent_value");
  map[string, string] custom_env = map[string, string]();
  custom_env["PATH"] = "/usr/bin:/bin";
  ProcessResult result = execute("sh", ["-c", "printenv PROMISE_TEST_ISOLATION || echo absent"], environment: move custom_env)?!;
  assert(result.stdout.trim() == "absent", "custom env should not inherit parent vars");
  // Clean up
  string? absent;
  set_env_var("PROMISE_TEST_ISOLATION", move absent);
}

test_execute_env_and_cwd() `test(exclude: wasm) `target(!windows) {
  map[string, string] custom_env = map[string, string]();
  custom_env["PATH"] = "/usr/bin:/bin";
  custom_env["COMBO_VAR"] = "combined";
  ProcessResult result = execute("sh", ["-c", "echo $COMBO_VAR $(pwd)"],
  environment: move custom_env, working_directory: "/usr")?!;
  assert(result.exit_code == 0, "sh should exit with 0");
  assert(result.stdout.contains("combined"), "should see custom env");
  assert(result.stdout.contains("/usr"), "should run in /usr");
}

