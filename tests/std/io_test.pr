// Tests for std/io.pr — Reader, Writer, Closer interfaces
// --- Writer.write_line ---
test_write_line() `test {
  Builder b = Builder();
  b.write_line("hello")!;
  string sep = Platform.line_separator;
  assert(b.to_string() == "hello" + sep, "write_line appends platform line separator");
}

test_write_line_multiple() `test {
  Builder b = Builder();
  b.write_line("first")!;
  b.write_line("second")!;
  string sep = Platform.line_separator;
  assert(b.to_string() == "first" + sep + "second" + sep, "multiple write_lines");
}

test_write_line_empty() `test {
  Builder b = Builder();
  b.write_line("")!;
  string sep = Platform.line_separator;
  assert(b.to_string() == sep, "write_line empty string");
}

// --- Closer structural interface ---

type TestCloser {
  bool closed;

  close(~this)! {
    this.closed = true;
  }
}

_do_close(Closer ~c)! {
  c.close();
}

test_closer_structural() `test {
  TestCloser tc = TestCloser(closed: false);
  _do_close(tc)!;
  assert(tc.closed, "closer was called");
}

// --- Closer error propagation ---

type FailCloser {
  close(~this)! {
    raise error(message: "close failed");
  }
}

_try_close(Closer ~c) string {
  c.close()? e {
    return e.message;
  };
  return "ok";
}

test_closer_error() `test {
  FailCloser fc = FailCloser();
  string result = _try_close(fc);
  assert(result == "close failed", "closer error propagated");
}

// --- Writer structural interface ---

_write_through_writer(Writer ~w, string s) int! {
  return w.write_string(s);
}

_write_line_through_writer(Writer ~w, string s)! {
  w.write_line(s);
}

_write_bytes_through_writer(Writer ~w, u8[]~data) int! {
  return w.write(data);
}

test_writer_structural_write_string() `test {
  Builder b = Builder();
  int n = _write_through_writer(b, "hello")!;
  assert(n == 5, "write_string returns 5");
  assert(b.to_string() == "hello", "write_string through Writer");
}

test_writer_structural_write_line() `test {
  Builder b = Builder();
  _write_line_through_writer(b, "hello")!;
  string sep = Platform.line_separator;
  assert(b.to_string() == "hello" + sep, "write_line through Writer");
}

test_writer_structural_write_bytes() `test {
  Builder b = Builder();
  u8[] data = "ABC".bytes();
  int n = _write_bytes_through_writer(b, data)!;
  assert(n == 3, "write returns 3");
  assert(b.to_string() == "ABC", "write bytes through Writer");
}

// --- Reader structural interface ---

_read_through_reader(Reader ~r, u8[]~buf) int! {
  return r.read(buf);
}

_read_byte_through_reader(Reader ~r) u8? {
  return r.read_byte();
}

test_reader_structural_read() `test {
  Scanner s = Scanner(s: "hello");
  u8[] buf = Vector[u8].filled(0u8, 10);
  int n = _read_through_reader(s, buf)!;
  assert(n == 5, "read returns 5");
  assert(buf[0] as! int == 104, "h");
  assert(buf[1] as! int == 101, "e");
  assert(buf[2] as! int == 108, "l");
  assert(buf[3] as! int == 108, "l");
  assert(buf[4] as! int == 111, "o");
}

test_reader_structural_read_eof() `test {
  Scanner s = Scanner(s: "ab");
  u8[] buf = Vector[u8].filled(0u8, 10);
  int n1 = _read_through_reader(s, buf)!;
  assert(n1 == 2, "first read returns 2");
  int n2 = _read_through_reader(s, buf)!;
  assert(n2 == 0, "second read returns 0 (EOF)");
}

test_reader_structural_read_byte() `test {
  Scanner s = Scanner(s: "XY");
  bool got1 = false;
  u8? b1 = _read_byte_through_reader(s);
  if v := b1 {
    assert(v as! int == 88, "X");
    got1 = true;
  }
  assert(got1, "byte1 present");
  bool got2 = false;
  u8? b2 = _read_byte_through_reader(s);
  if v := b2 {
    assert(v as! int == 89, "Y");
    got2 = true;
  }
  assert(got2, "byte2 present");
  bool got3 = false;
  u8? b3 = _read_byte_through_reader(s);
  if _ := b3 {
    got3 = true;
  }
  assert(!got3, "EOF returns absent");
}

// --- MutRef indexing regression (vector indexing through ~ parameter) ---

_fill_buf(u8[]~buf) {
  buf[0] = 65u8;
  buf[1] = 66u8;
  buf[2] = 67u8;
}

_check_buf(u8[]~buf) bool {
  return buf[0] == 65u8 && buf[1] == 66u8 && buf[2] == 67u8;
}

test_mutref_vector_index_write() `test {
  u8[] buf = Vector[u8].filled(0u8, 3);
  _fill_buf(buf);
  assert(buf[0] == 65u8, "A");
  assert(buf[1] == 66u8, "B");
  assert(buf[2] == 67u8, "C");
}

test_mutref_vector_index_read() `test {
  u8[] buf = Vector[u8].filled(0u8, 3);
  _fill_buf(buf);
  assert(_check_buf(buf), "read through ~buf matches");
}

// --- B0149: MutRef vector push with reallocation ---

_push_one(int[]~output) {
  output.push(42);
}

_push_three(int[]~output) {
  output.push(1);
  output.push(2);
  output.push(3);
}

_conditional_push(int cp, int[]~output) {
  if cp >= 100 {
    output.push(1);
    output.push(2);
    int t = cp % 28;
    if t > 0 {
      output.push(3);
    }
  } else {
    output.push(cp);
  }
}

_nested_push(int[]~output) {
  // Calls another function with the same MutRef param (forwarding)
  _push_one(output);
  _push_one(output);
}

test_mutref_push_empty_vector() `test `doc("B0149: push through MutRef on empty vector (triggers realloc)") {
  int[] result = [];
  _push_one(result);
  assert(result.len == 1, "expected 1, got " + result.len.to_string());
  assert(result[0] == 42, "expected 42");
}

test_mutref_push_with_capacity() `test `doc("B0149: push through MutRef with pre-allocated capacity") {
  int[] result = Vector[int](capacity: 10);
  _push_three(result);
  assert(result.len == 3, "expected 3, got " + result.len.to_string());
  assert(result[0] == 1, "r[0]");
  assert(result[1] == 2, "r[1]");
  assert(result[2] == 3, "r[2]");
}

test_mutref_push_multiple_reallocs() `test `doc("B0149: multiple pushes through MutRef on empty vector") {
  int[] result = [];
  _push_three(result);
  assert(result.len == 3, "expected 3, got " + result.len.to_string());
  assert(result[0] == 1, "r[0]");
  assert(result[1] == 2, "r[1]");
  assert(result[2] == 3, "r[2]");
}

test_mutref_conditional_push() `test `doc("B0149: conditional push through MutRef (original bug pattern)") {
  int[] result = [];
  _conditional_push(101, result);
  assert(result.len == 3, "expected 3, got " + result.len.to_string());
  assert(result[0] == 1, "r[0]");
  assert(result[1] == 2, "r[1]");
  assert(result[2] == 3, "r[2]");
}

test_mutref_nested_push() `test `doc("B0149: nested MutRef forwarding with push") {
  int[] result = [];
  _nested_push(result);
  assert(result.len == 2, "expected 2, got " + result.len.to_string());
  assert(result[0] == 42, "r[0]");
  assert(result[1] == 42, "r[1]");
}
