test_raw_socket_create_close() `test(exclude: wasm) {
  int fd = _net_socket_create(2, 1, 0);
  assert(fd >= 0, "socket created");
  int rc = _net_socket_close(fd);
  assert(rc >= 0, "socket closed");
}

test_netpoll_open_close() `test(exclude: wasm) {
  int fd = _net_socket_create(2, 1, 0);
  assert(fd >= 0, "socket created");
  int pd = _net_netpoll_open(fd);
  assert(pd != 0, "netpoll opened");
  _net_netpoll_close(pd);
  int rc = _net_socket_close(fd);
  assert(rc >= 0, "socket closed");
}

test_netpoll_multiple_open_close() `test(exclude: wasm) {
  int i = 0;
  while i < 5 {
    int fd = _net_socket_create(2, 1, 0);
    assert(fd >= 0, "socket created");
    int pd = _net_netpoll_open(fd);
    assert(pd != 0, "netpoll opened");
    _net_netpoll_close(pd);
    int rc = _net_socket_close(fd);
    assert(rc >= 0, "socket closed");
    i = i + 1;
  }
}

test_listener_bind_auto_drop() `test(exclude: wasm) {
  TcpListener listener = TcpListener.bind("127.0.0.1", 0)?!;
}

test_listener_bind_and_close() `test(exclude: wasm) {
  TcpListener listener = TcpListener.bind("127.0.0.1", 0)?!;
  listener.close()?!;
}

_try_bind_invalid!() bool {
  TcpListener listener = TcpListener.bind("not_an_ip", 0)?^;
  listener.close()?^;
  return false;
}

test_listener_bind_invalid_address() `test(exclude: wasm) {
  bool ok = _try_bind_invalid()? e {
    return; // bind failed as expected
  };
  assert(false, "bind should have failed for invalid address");
}

test_listener_local_port() `test(exclude: wasm) {
  TcpListener listener = TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;
  assert(port > 0, "local_port should be positive");
  assert(port < 65536, "local_port should be valid");
}

test_listener_drop_multiple() `test(exclude: wasm) {
  int i = 0;
  while i < 3 {
    TcpListener listener = TcpListener.bind("127.0.0.1", 0)?!;
    i = i + 1;
  }
}

// Regression test for B0340: 10 sequential open/close cycles stress the
// batch_lock acquire path in netpoll_close. With the old 10ms reactor timeout,
// this could time out under heavy load (lock starvation). With 1ms it is fast.
test_netpoll_close_batch_lock_stress() `test(exclude: wasm) {
  int i = 0;
  while i < 10 {
    int fd = _net_socket_create(2, 1, 0);
    assert(fd >= 0, "socket created");
    int pd = _net_netpoll_open(fd);
    assert(pd != 0, "netpoll opened");
    _net_netpoll_close(pd);
    int rc = _net_socket_close(fd);
    assert(rc >= 0, "socket closed");
    i = i + 1;
  }
}

// Verify _eagain() returns a valid positive errno value on the current platform.
// Linux=11 (EAGAIN), macOS=35, Windows=10035 (WSAEWOULDBLOCK).
test_eagain_is_valid_errno() `test(exclude: wasm) {
  int e = _eagain();
  assert(e > 0, "eagain is positive");
}

// Verify _net_strerror returns a human-readable message for known and unknown errno values.
test_net_strerror_known_and_unknown() `test(exclude: wasm) {
  assert(_net_strerror(9) == "bad file descriptor", "EBADF");
  assert(_net_strerror(32) == "broken pipe", "EPIPE");
  assert(_net_strerror(999999) == "network error (errno 999999)", "unknown errno");
}

// Server side uses raw blocking sockets; sequential flow — no goroutines
// needed because kernel buffers handle connect backlog and data.

test_stream_connect_and_close() `test(exclude: wasm) {
  int sfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(sfd >= 0, "server socket");
  assert(_net_socket_bind_addr(sfd, "127.0.0.1", 0) == 0, "bind");
  assert(_net_socket_listen(sfd, 128) == 0, "listen");
  int port = _net_socket_getsockname(sfd);

  TcpStream client = TcpStream.connect("127.0.0.1", port)?!;
  client.close()?!;

  int afd = _net_socket_accept_addr(sfd);
  assert(afd >= 0, "accept");
  _net_socket_close(afd);
  _net_socket_close(sfd);
}

test_stream_write() `test(exclude: wasm) {
  int sfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(sfd >= 0, "server socket");
  assert(_net_socket_bind_addr(sfd, "127.0.0.1", 0) == 0, "bind");
  assert(_net_socket_listen(sfd, 128) == 0, "listen");
  int port = _net_socket_getsockname(sfd);

  TcpStream client = TcpStream.connect("127.0.0.1", port)?!;
  int afd = _net_socket_accept_addr(sfd);
  assert(afd >= 0, "accept");

  u8[] data = "Hi".bytes();
  int written = client.write(data)?!;
  assert(written == 2, "wrote 2 bytes");
  client.close()?!;

  u8[] buf = u8[].filled(0, 64);
  int n = _net_socket_recv(afd, buf);
  assert(n == 2, "server read 2 bytes");
  assert(buf[0] == 72, "byte H");
  assert(buf[1] == 105, "byte i");

  _net_socket_close(afd);
  _net_socket_close(sfd);
}

test_stream_read() `test(exclude: wasm) {
  int sfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(sfd >= 0, "server socket");
  assert(_net_socket_bind_addr(sfd, "127.0.0.1", 0) == 0, "bind");
  assert(_net_socket_listen(sfd, 128) == 0, "listen");
  int port = _net_socket_getsockname(sfd);

  TcpStream client = TcpStream.connect("127.0.0.1", port)?!;
  int afd = _net_socket_accept_addr(sfd);
  assert(afd >= 0, "accept");

  u8[] data = "Ok".bytes();
  int sent = _net_socket_send(afd, data);
  assert(sent == 2, "server sent 2 bytes");
  _net_socket_close(afd);

  u8[] buf = u8[].filled(0, 64);
  int n = client.read(buf)?!;
  assert(n == 2, "client read 2 bytes");
  assert(buf[0] == 79, "byte O");
  assert(buf[1] == 107, "byte k");

  client.close()?!;
  _net_socket_close(sfd);
}

test_stream_shutdown_write() `test(exclude: wasm) {
  int sfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(sfd >= 0, "server socket");
  assert(_net_socket_bind_addr(sfd, "127.0.0.1", 0) == 0, "bind");
  assert(_net_socket_listen(sfd, 128) == 0, "listen");
  int port = _net_socket_getsockname(sfd);

  TcpStream client = TcpStream.connect("127.0.0.1", port)?!;
  client.shutdown(write: true)?!;

  int afd = _net_socket_accept_addr(sfd);
  assert(afd >= 0, "accept");
  u8[] buf = u8[].filled(0, 64);
  int n = _net_socket_recv(afd, buf);
  assert(n == 0, "read EOF after shutdown");

  _net_socket_close(afd);
  client.close()?!;
  _net_socket_close(sfd);
}

test_stream_shutdown_read() `test(exclude: wasm) {
  int sfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(sfd >= 0, "server socket");
  assert(_net_socket_bind_addr(sfd, "127.0.0.1", 0) == 0, "bind");
  assert(_net_socket_listen(sfd, 128) == 0, "listen");
  int port = _net_socket_getsockname(sfd);

  TcpStream client = TcpStream.connect("127.0.0.1", port)?!;
  client.shutdown(read: true)?!;

  // After SHUT_RD, client can still write
  int afd = _net_socket_accept_addr(sfd);
  assert(afd >= 0, "accept");

  u8[] data = "Hi".bytes();
  int written = client.write(data)?!;
  assert(written == 2, "wrote after shutdown read");

  u8[] buf = u8[].filled(0, 64);
  int n = _net_socket_recv(afd, buf);
  assert(n == 2, "server received data");

  _net_socket_close(afd);
  client.close()?!;
  _net_socket_close(sfd);
}

test_stream_shutdown_both() `test(exclude: wasm) {
  int sfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(sfd >= 0, "server socket");
  assert(_net_socket_bind_addr(sfd, "127.0.0.1", 0) == 0, "bind");
  assert(_net_socket_listen(sfd, 128) == 0, "listen");
  int port = _net_socket_getsockname(sfd);

  TcpStream client = TcpStream.connect("127.0.0.1", port)?!;
  client.shutdown(read: true, write: true)?!;

  int afd = _net_socket_accept_addr(sfd);
  assert(afd >= 0, "accept");
  u8[] buf = u8[].filled(0, 64);
  int n = _net_socket_recv(afd, buf);
  assert(n == 0, "server read EOF after full shutdown");

  _net_socket_close(afd);
  client.close()?!;
  _net_socket_close(sfd);
}

test_listener_accept() `test(exclude: wasm) {
  TcpListener listener = TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;

  // Connect with raw blocking socket — kernel queues it in the backlog
  int cfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(cfd >= 0, "client socket");
  int rc = _net_socket_connect_addr(cfd, "127.0.0.1", port);
  assert(rc == 0, "connect");

  // Accept should find the pending connection
  TcpStream stream = listener.accept()?!;

  // Verify data flows through the accepted stream
  u8[] msg = "ab".bytes();
  int sent = _net_socket_send(cfd, msg);
  assert(sent == 2, "raw client sent");

  u8[] buf = u8[].filled(0, 64);
  int n = stream.read(buf)?!;
  assert(n == 2, "accepted stream read");
  assert(buf[0] == 97, "byte a");
  assert(buf[1] == 98, "byte b");

  stream.close()?!;
  _net_socket_close(cfd);
  listener.close()?!;
}

_try_connect_refused!() bool {
  // Port 1 is reserved and should not have a listener — connect must fail.
  TcpStream s = TcpStream.connect("127.0.0.1", 1)?^;
  s.close()?^;
  return true;
}

test_stream_connect_refused() `test(exclude: wasm) {
  bool ok = _try_connect_refused()? e {
    assert(e.message.contains("connection refused"), "connect refused message");
    return;
  };
  // On some CI environments port 1 may unexpectedly be open; skip rather than
  // fail to avoid a flaky test.
}

test_stream_drop_without_close() `test(exclude: wasm) {
  int sfd = _net_socket_create(_af_inet(), _sock_stream(), 0);
  assert(sfd >= 0, "server socket");
  assert(_net_socket_bind_addr(sfd, "127.0.0.1", 0) == 0, "bind");
  assert(_net_socket_listen(sfd, 128) == 0, "listen");
  int port = _net_socket_getsockname(sfd);

  TcpStream client = TcpStream.connect("127.0.0.1", port)?!;
  // Drop without close — drop() should clean up fd + reactor

  int afd = _net_socket_accept_addr(sfd);
  if afd >= 0 {
    _net_socket_close(afd);
  }
  _net_socket_close(sfd);
}
