// Tests for Builder type
test_basic() `test {
  Builder b = Builder();
  b.write_string("hello")?!;
  b.write_string(" ")?!;
  b.write_string("world")?!;
  assert(b.to_string() == "hello world", "basic write_string");
}

test_empty() `test {
  Builder b = Builder();
  assert(b.to_string() == "", "empty builder");
}

test_len() `test {
  Builder b = Builder();
  assert(b.len == 0, "initial len 0");
  b.write_string("hello")?!;
  assert(b.len == 5, "after write len 5");
}

test_clear() `test {
  Builder b = Builder();
  b.write_string("hello")?!;
  assert(b.len == 5, "before clear");
  b.clear();
  assert(b.len == 0, "after clear");
}

test_write_bytes() `test {
  Builder b = Builder();
  u8[] data = "ABC".bytes();
  b.write(data)?!;
  assert(b.to_string() == "ABC", "write bytes");
}

test_capacity() `test {
  Builder b = Builder(capacity: 64);
  b.write_string("hello")?!;
  assert(b.to_string() == "hello", "with capacity");
}

test_multiple_writes() `test {
  Builder b = Builder();
  int i = 0;
  while i < 10 {
    b.write_string("x")?!;
    i = i + 1;
  }
  assert(b.to_string() == "xxxxxxxxxx", "10 x's");
  assert(b.len == 10, "len 10");
}

test_clear_then_reuse() `test {
  Builder b = Builder();
  b.write_string("first")?!;
  b.clear();
  b.write_string("second")?!;
  assert(b.to_string() == "second", "reuse after clear");
}

test_write_returns_count() `test {
  Builder b = Builder();
  int n = b.write_string("hello")?!;
  assert(n == 5, "write_string returns 5");
  u8[] data = "AB".bytes();
  int m = b.write(data)?!;
  assert(m == 2, "write returns 2");
}

// B0223: Vector slice intermediate in from_bytes must not leak.
test_write_from_bytes_loop() `test {
  Builder b = Builder();
  u8[] buf = u8[].filled(65u8, 10);
  int i = 0;
  while i < 3 {
    b.write_string(string.from_bytes(buf[0:5]))? {
    };
    i = i + 1;
  }
  assert(b.to_string() == "AAAAAAAAAAAAAAA", "3x5 A's");
}

// B0223: Vector slice passed to from_bytes as simple expression.
test_from_bytes_slice_temp() `test {
  u8[] buf = u8[].filled(66u8, 10);
  string s = string.from_bytes(buf[0:3]);
  assert(s == "BBB", "from_bytes with slice");
}
