// All fixtures generated with Python:
//   gzip.GzipFile(fileobj=buf, mode='wb', mtime=0).write(data)
gunzip_hello_test() `test {
  // gzip("hello") with mtime=0
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  raw.push(0xCB);
  raw.push(0x48);
  raw.push(0xCD);
  raw.push(0xC9);
  raw.push(0xC9);
  raw.push(0x07);
  raw.push(0x00);
  raw.push(0x86);
  raw.push(0xA6);
  raw.push(0x10);
  raw.push(0x36);
  raw.push(0x05);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  u8[] result = gunzip(data)?!;
  string s = "hello";
  u8[] want = s.bytes();
  _assert_eq(result, want, "gunzip hello");
}

