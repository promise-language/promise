// T1230: storing a heap struct that holds a capturing closure FIELD into a Map,
// then reading it back and calling the closure. The Map's `[]` returns the element
// by value; a closure-nesting aggregate cannot be deep-cloned on read (the captured
// env frame is opaque), so the read is a BORROW — the local aliases the map's stored
// instance/env, and the map retains sole ownership (single drop). Judging the struct
// dup-safe previously routed `return v` through dupHeapValueFields, which zeroes the
// closure slot (T0813) → null {fn,env} fat pointer → SEGV at 0x0 on invoke.
// See heapTypeSafeToDup (codegen/expr.go), isClosureAggregateBorrow (codegen/stmt.go),
// closureAggregateBorrowSource (ownership/expr.go), FirstFieldNestedClosure (sema).
type Fn {
  () -> int f;
}
type FnStr {
  () -> int f;
  string s;
}
type Outer {
  Fn inner;
}

// Repro A — inline read + call: `m[0]!.f()`.
probe_map_struct_closure_inline() `test {
  x := 5;
  m := Map[int, Fn]();
  m[0] = Fn(f: || -> x);
  assert(m[0]!.f() == 5, "inline read+call");
}

// Repro B — bind to local, then call: `fn := m[0]!; fn.f()`.
probe_map_struct_closure_bind() `test {
  x := 5;
  m := Map[int, Fn]();
  m[0] = Fn(f: || -> x);
  fn := m[0]!;
  assert(fn.f() == 5, "bind-then-call");
}

// Typed var-decl form: `Fn fn = m[0]!`.
probe_map_struct_closure_typed_bind() `test {
  x := 8;
  m := Map[int, Fn]();
  m[0] = Fn(f: || -> x);
  Fn fn = m[0]!;
  assert(fn.f() == 8, "typed bind");
}

// Struct nesting the closure two levels deep.
probe_map_struct_closure_nested() `test {
  x := 7;
  m := Map[int, Outer]();
  m[0] = Outer(inner: Fn(f: || -> x));
  o := m[0]!;
  assert(o.inner.f() == 7, "nested bind");
  assert(m[0]!.inner.f() == 7, "nested inline");
}

// Closure struct that ALSO owns a droppable non-closure (string) field — the borrow
// must not double-free the string, and the map's own drop frees it exactly once.
probe_map_struct_closure_with_droppable() `test {
  x := 3;
  m := Map[int, FnStr]();
  m[0] = FnStr(f: || -> x, s: "hello");
  fn := m[0]!;
  assert(fn.f() == 3, "call closure field");
  assert(fn.s == "hello", "read string field");
}

// Multiple independent reads of the same slot — each is a fresh borrow; the map is
// dropped once at scope exit.
probe_map_struct_closure_multi_read() `test {
  x := 2;
  m := Map[int, Fn]();
  m[0] = Fn(f: || -> x);
  a := m[0]!;
  b := m[0]!;
  assert(a.f() + b.f() == 4, "two reads, one owner");
}

// Regression guard: a plain (non-closure) heap struct read out of a map is an OWNED
// deep copy — mutating the copy's vector must not affect the map's stored value.
type VecBox {
  int[] xs;
}
probe_map_plain_struct_owned_copy() `test {
  m := Map[int, VecBox]();
  m[0] = VecBox(xs: [1, 2, 3]);
  b := m[0]!;
  b.xs.push(4);
  assert(b.xs.len == 4, "copy mutated");
  again := m[0]!;
  assert(again.xs.len == 3, "map value unchanged (owned copy, not alias)");
}

// Assignment (re-assign) form: `fn = m[k]!` into an already-bound local. Exercises
// the genAssignStmt borrow-suppression arm (distinct from the var-decl arms above) —
// without it the reassign deep-copies the closure-nesting struct, zeroing the env →
// SEGV on the following invoke.
type Fn2 {
  () -> int f;
}
probe_map_struct_closure_reassign() `test {
  x := 4;
  m := Map[int, Fn2]();
  m[0] = Fn2(f: || -> x);
  fn := Fn2(f: || -> 0);
  fn = m[0]!;
  assert(fn.f() == 4, "reassigned borrow calls the map's env");
}

// Generic struct nesting a closure field (`Box[int]` value). Exercises the
// Instance->Named substitution branch of FirstFieldNestedClosure — the closure is
// reached through a substituted, non-container generic type's field.
type Box[T] {
  T v;
  () -> int f;
}
probe_map_generic_struct_closure() `test {
  x := 11;
  m := Map[int, Box[int]]();
  m[0] = Box[int](v: 1, f: || -> x);
  b := m[0]!;
  assert(b.f() == 11, "generic struct closure field");
  assert(b.v == 1, "generic struct value field");
}

// Control from the bug report: the same closure-nesting struct read out of a VECTOR
// (not a map) was already correct. Guards the fix against regressing the vector path.
probe_vector_struct_closure_control() `test {
  x := 5;
  v := [Fn2(f: || -> x)];
  assert(v[0].f() == 5, "vector element closure call");
}

// The borrow's drop is suppressed on EVERY read: 100 reads in a loop must not leak
// (the map stays sole owner and frees the env exactly once at scope exit).
probe_map_struct_closure_loop_reads() `test {
  x := 3;
  m := Map[int, Fn2]();
  m[0] = Fn2(f: || -> x);
  total := 0;
  i := 0;
  while i < 100 {
    fn := m[0]!;
    total = total + fn.f();
    i = i + 1;
  }
  assert(total == 300, "100 borrows, one owner, no leak");
}

// ---------------------------------------------------------------------------
// T1260: sibling of T1230. A struct whose field is a *value-copying container*
// (Vector/Map/Set) of closures. FirstFieldNestedClosure previously treated every
// std native container as opaque (no TypeArgs recursion), so a struct holding
// `Vector[() -> int]` was judged dup-safe and the Map read deep-copied it via
// dupHeapValueFields — the per-element closure clone can't deep-copy the env
// (T0813 zeroes the slot) → null {fn,env} fat pointer → SEGV on invoke. The fix
// recurses TypeArgs of value-copying containers (isValueCopyingContainerNamed),
// so the struct is judged un-dup-safe → the Map read is a BORROW (env intact,
// map sole owner, single drop) — while genuinely refcounted handles (Ref/Weak)
// stay opaque and dup-safe.
type FnV {
  (() -> int)[] fns;
}

// Primary repro — Vector-of-closures field, read back, element invoked.
probe_map_struct_vecclosure() `test {
  x := 6;
  m := Map[int, FnV]();
  m[0] = FnV(fns: [|| -> x]);
  b := m[0]!;
  assert(b.fns[0]() == 6, "vec of closures");
}

// Inline read form: `m[0]!.fns[0]()`.
probe_map_struct_vecclosure_inline() `test {
  x := 9;
  m := Map[int, FnV]();
  m[0] = FnV(fns: [|| -> x]);
  assert(m[0]!.fns[0]() == 9, "vec of closures inline");
}

// Multi-element vector capturing different values — every element's env must
// survive the borrow (not just element 0).
probe_map_struct_vecclosure_multi() `test {
  a := 1;
  b := 2;
  c := 3;
  m := Map[int, FnV]();
  m[0] = FnV(fns: [|| -> a, || -> b, || -> c]);
  v := m[0]!;
  assert(v.fns[0]() == 1, "elem 0 env");
  assert(v.fns[1]() == 2, "elem 1 env");
  assert(v.fns[2]() == 3, "elem 2 env");
}

// Map-of-closures field variant — exercises the TypVmap value-copying origin.
type FnMap {
  map[int, () -> int] fns;
}
probe_map_struct_mapclosure() `test {
  x := 12;
  m := Map[int, FnMap]();
  fns := Map[int, () -> int]();
  fns[0] = || -> x;
  m[0] = FnMap(fns: move fns);
  b := m[0]!;
  assert(b.fns[0]!() == 12, "map of closures");
}

// Loop-reads leak guard: 100 reads of a vec-of-closures struct → one owner, no
// leak (mirrors probe_map_struct_closure_loop_reads for the container path).
probe_map_struct_vecclosure_loop_reads() `test {
  x := 4;
  m := Map[int, FnV]();
  m[0] = FnV(fns: [|| -> x]);
  total := 0;
  i := 0;
  while i < 100 {
    v := m[0]!;
    total = total + v.fns[0]();
    i = i + 1;
  }
  assert(total == 400, "100 vec-closure borrows, one owner, no leak");
}

// Regression guard for the isValueCopyingContainerNamed boundary: a struct whose
// field is a value-copying container of a NON-closure element (`Vector[int]`)
// must still be an OWNED deep copy on read — recursing TypeArgs reaches `int`
// (no closure) → nil → dup-safe. Mutating the copy's vector must not affect the
// map's stored value. (Pins that the fix's TypeArgs recursion does not
// over-reject ordinary value-copying containers.)
type IntVecBox {
  int[] xs;
}
probe_map_struct_intvec_owned_copy() `test {
  m := Map[int, IntVecBox]();
  m[0] = IntVecBox(xs: [1, 2, 3]);
  b := m[0]!;
  b.xs.push(4);
  assert(b.xs.len == 4, "owned copy mutated");
  again := m[0]!;
  assert(again.xs.len == 3, "map value unchanged (owned copy, not alias)");
}

// Regression guard for the topLevel=true branch: a BARE top-level container of
// closures read directly (`vv[0]`, not through a struct field) must STAY an owned
// value (T1045 null-dup path), NOT be flipped to a borrow. FirstFieldNestedClosure
// (the non-deep entry used by ownership/stmt borrow-suppression) returns nil for a
// value-copying container at top level, so the read keeps its owned path. Flipping
// it to a borrow would leak the duped container. This pins that the T1260 fix's
// TypeArgs recursion only fires for FIELD-nested containers, not bare reads.
probe_bare_vec_of_closures() `test {
  x := 5;
  vv := Vector[() -> int]();
  vv.push(|| -> x);
  f := vv[0];
  assert(f() == 5, "bare container-of-closures read stays owned");
}

// Leak guard for the bare-container owned path: 100 direct reads must not leak.
probe_bare_vec_of_closures_loop() `test {
  x := 4;
  vv := Vector[() -> int]();
  vv.push(|| -> x);
  total := 0;
  i := 0;
  while i < 100 {
    f := vv[0];
    total = total + f();
    i = i + 1;
  }
  assert(total == 400, "100 bare-container reads, one owner, no leak");
}

// Doubly-nested value-copying container as a struct field:
// `Vector[Vector[() -> int]]`. Exercises firstFieldNestedClosure recursing through
// two container levels before reaching the closure — the struct must be judged
// un-dup-safe (borrow), env intact on invoke.
type NestVec {
  (() -> int)[][] grid;
}
probe_map_struct_nested_vecclosure() `test {
  x := 3;
  m := Map[int, NestVec]();
  m[0] = NestVec(grid: [[|| -> x]]);
  b := m[0]!;
  assert(b.grid[0][0]() == 3, "nested vec-of-vec of closures");
}

// Generic struct whose type-arg-typed field is a value-copying container:
// `GBox[() -> int]` → field `Vector[() -> int]`. Exercises the Instance→Named
// field recursion under the type-arg subst reaching a container-of-closures — the
// closure is inside the substituted field, not a direct field, so this pins the
// subst path of firstFieldNestedClosure through a container.
type GBox[T] {
  T[] items;
}
probe_map_generic_container_closure() `test {
  x := 15;
  m := Map[int, GBox[() -> int]]();
  m[0] = GBox[() -> int](items: [|| -> x]);
  b := m[0]!;
  assert(b.items[0]() == 15, "generic container-of-closures field");
}

// Set branch of isValueCopyingContainerNamed: a struct field `Set[int]`
// (non-closure element) must still be an OWNED deep copy on read — the recursion
// classifies Set as value-copying and recurses to `int` (no closure) → nil →
// dup-safe. Mutating the copy's set must not affect the map's stored value.
// (Exercises the Set arm; a Set of closures is not constructible — closures are
// not Hashable — so the Set→closure return is unreachable from source, same as
// Ref-of-closure.)
type SetBox {
  Set[int] xs;
}
probe_map_struct_setbox_owned_copy() `test {
  s := Set[int]();
  s.add(1);
  m := Map[int, SetBox]();
  m[0] = SetBox(xs: move s);
  b := m[0]!;
  b.xs.add(2);
  assert(b.xs.len == 2, "owned copy mutated");
  again := m[0]!;
  assert(again.xs.len == 1, "map value unchanged (owned copy, not alias)");
}

// ---------------------------------------------------------------------------
// T1262: sibling of T1260. A *BARE* value-copying container of closures — e.g.
// `Vector[() -> int]` stored directly as a Map value — read back and an element
// invoked. Here the container-of-closures is the Map's value type itself (not a
// struct field). Map's `[]` deep-copied the value via dupVector's element-clone
// path, which zeroes each closure element's opaque env (T0813) → null {fn,env} →
// SEGV on invoke. The fix guards typeNeedsMatchDup with FirstFieldNestedClosureDeep
// so the value stays ALIASED (no null-dup) and the read is a true BORROW (env
// intact, map sole owner, single drop) — the two borrow gates
// (closureAggregateBorrowSource, isClosureAggregateBorrow) use the same Deep
// predicate to suppress the owning env-free/drop binding, staying in lockstep.

// Primary repro — Map value IS a Vector-of-closures; bind then invoke.
probe_bare_vec_closure_map() `test {
  x := 7;
  m := Map[int, (() -> int)[]]();
  m[0] = [|| -> x];
  b := m[0]!;
  assert(b[0]() == 7, "bare vec of closures from map");
}

// Multi-element vector of closures with distinct captures — every env survives.
probe_bare_vec_closure_map_multi() `test {
  a := 10;
  b := 20;
  c := 30;
  m := Map[int, (() -> int)[]]();
  m[0] = [|| -> a, || -> b, || -> c];
  v := m[0]!;
  assert(v[0]() == 10, "elem 0 env");
  assert(v[1]() == 20, "elem 1 env");
  assert(v[2]() == 30, "elem 2 env");
}

// Inline read form: `m[0]![0]()`.
probe_bare_vec_closure_map_inline() `test {
  x := 8;
  m := Map[int, (() -> int)[]]();
  m[0] = [|| -> x];
  assert(m[0]![0]() == 8, "bare vec of closures inline");
}

// Loop-reads leak guard: 100 reads → one owner (the map), no leak. The borrow's
// env-free/drop binding must be suppressed on every read.
probe_bare_vec_closure_map_loop_reads() `test {
  x := 3;
  m := Map[int, (() -> int)[]]();
  m[0] = [|| -> x];
  total := 0;
  i := 0;
  while i < 100 {
    v := m[0]!;
    total = total + v[0]();
    i = i + 1;
  }
  assert(total == 300, "100 bare-vec-closure borrows, one owner, no leak");
}

// Nested value-copying container as the Map value: `Map[int, map[int, () -> int]]`
// — the value is itself a map-of-closures, read back and the inner closure invoked.
probe_bare_map_closure_map() `test {
  x := 14;
  m := Map[int, map[int, () -> int]]();
  m[0] = {
    0: || -> x
  };
  b := m[0]!;
  assert(b[0]!() == 14, "bare map of closures from map");
}

// Regression: refcounted value (`Map[int, Ref[int]]`) must STILL dup on read (the
// borrow gate must NOT fire) — FirstFieldNestedClosureDeep keeps Ref opaque, so
// typeNeedsMatchDup stays true and the read is an owned refcount-increment copy.
probe_bare_map_ref_still_dups() `test {
  m := Map[int, Ref[int]]();
  m[0] = Ref[int](42);
  b := m[0]!;
  assert(b.borrow == 42, "ref value read");
  again := m[0]!;
  assert(again.borrow == 42, "second ref read (refcount dup, not env-zeroing)");
}

// Regression: non-closure vector value (`Map[int, int[]]`) must STILL deep-copy on
// read (mutation isolation) — the Deep guard reaches `int` (no closure) → nil →
// typeNeedsMatchDup stays true. Pushing to the read copy leaves the map unchanged.
probe_bare_intvec_map_owned_copy() `test {
  m := Map[int, int[]]();
  m[0] = [1, 2, 3];
  b := m[0]!;
  b.push(4);
  assert(b.len == 4, "owned copy mutated");
  again := m[0]!;
  assert(again.len == 3, "map value unchanged (owned copy, not alias)");
}
