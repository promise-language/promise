// T0613: `(this).method()` and the rest of the paren-wrapped-`this` receiver
// family used to emit `extractvalue i8* ...` (invalid IR rejected by opt),
// because ~20 AST-shape dispatch gates in codegen matched `*ast.ThisExpr`
// directly and fell through for `*ast.ParenExpr{ThisExpr}`. genExpr already
// evaluates ParenExpr transparently, so the receiver *value* was correct — only
// the gate that decides "pass raw i8* vs. extractvalue from a value struct" was
// wrong. The fix peels ParenExpr at each gate via isThisReceiver().
//
// Each test pairs a `this.X` baseline with the `(this).X` and `((this)).X`
// variants, asserting identical results. Heap/string/optional fields surface any
// missed ownership handling as a leak (zero-tolerance) or double-free segfault.
// ---------------- method call (heap type) ----------------
type MBox {
  int x;
  peek(this) int {
    return this.x;
  }
  via(this) int {
    return (this).peek();
  }
  via_nested(this) int {
    return ((this)).peek();
  }
}

test_paren_this_method_call() `test {
  b := MBox(x: 42);
  assert(b.peek() == 42, "baseline this.peek()");
  assert(b.via() == 42, "(this).peek() returns same value");
  assert(b.via_nested() == 42, "((this)).peek() returns same value");
}

// `~this` method returning `this` through a paren-wrapped self call — the
// repro from the bug report. Heap field exercises the alias-clear path.
type SelfBox {
  string s;
  self(~this) SelfBox {
    return this;
  }
  driver(~this) SelfBox {
    r := (this).self();
    return r;
  }
}

test_paren_this_self_chain() `test {
  b := SelfBox(s: "hel" + "lo");
  r := b.driver();
  assert(r.s == "hello", "(this).self() preserves heap field, no double-free");
}

// ---------------- field read (heap + value type) ----------------
type FBoxHeap {
  string s;
  read(this) string {
    return (this).s;
  }
  read_nested(this) string {
    return ((this)).s;
  }
}

test_paren_this_field_read_heap() `test {
  b := FBoxHeap(s: "wor" + "ld");
  assert(b.read() == "world", "(this).s on heap type");
  assert(b.read_nested() == "world", "((this)).s on heap type");
}

type FBoxVal {
  int x `value;
  int y `value;
  read_x(this) int {
    return (this).x;
  }
  read_y(this) int {
    return ((this)).y;
  }
}

test_paren_this_field_read_value() `test {
  p := FBoxVal(x: 3, y: 4);
  assert(p.read_x() == 3, "(this).x on value type");
  assert(p.read_y() == 4, "((this)).y on value type");
}

// ---------------- setter (direct + virtual) ----------------
type SetBox {
  int n;
  get value int {
    return this.n;
  }
  set value(int v) {
    this.n = v;
  }
  set_via(~this, int v) {
    (this).value = v;
  }
}

test_paren_this_setter_direct() `test {
  b := SetBox(n: 0);
  b.set_via(9);
  assert(b.n == 9, "(this).value = v through direct setter");
}

// Plain field assignment through paren-this (lvalue field-ptr path, not a
// custom setter).
type PlainSetBox {
  int n;
  bump(~this, int v) {
    (this).n = v;
  }
}

test_paren_this_field_assign() `test {
  b := PlainSetBox(n: 0);
  b.bump(7);
  assert(b.n == 7, "(this).n = v plain field assign");
}

// Virtual setter: base with a child makes the setter virtual; the default
// method `scale_via` calls `(this).value = v` → genVirtualSetterCall.
type VSetBase {
  int n;
  get value int {
    return this.n;
  }
  set value(int v) {
    this.n = v;
  }
  scale_via(~this, int v) {
    (this).value = v;
  }
}

type VSetDerived is VSetBase {
}

test_paren_this_setter_virtual() `test {
  d := VSetDerived(n: 0);
  d.scale_via(11);
  assert(d.n == 11, "(this).value = v through virtual setter");
}

// ---------------- getter (direct + virtual) ----------------
type GetBox {
  int n;
  get value int {
    return this.n;
  }
  get_via(this) int {
    return (this).value;
  }
}

test_paren_this_getter_direct() `test {
  b := GetBox(n: 5);
  assert(b.get_via() == 5, "(this).value through direct getter");
}

type VGetBase {
  int n;
  get value int {
    return this.n;
  }
  get_via(this) int {
    return (this).value;
  }
}

type VGetDerived is VGetBase {
}

test_paren_this_getter_virtual() `test {
  d := VGetDerived(n: 13);
  assert(d.get_via() == 13, "(this).value through virtual getter");
}

// ---------------- virtual method (abstract dispatch) ----------------
type Shape {
  area(this) int `abstract;
  area_via(this) int {
    return (this).area();
  }
}

type Square is Shape {
  int side;
  area(this) int {
    return this.side * this.side;
  }
}

test_paren_this_virtual_method() `test {
  s := Square(side: 5);
  assert(s.area_via() == 25, "(this).area() virtual dispatch");
}

// ---------------- is check (RTTI) ----------------
type Animal {
  string name;
  speak(&this) string `abstract;
  am_i_dog(this) bool {
    return (this) is Dog;
  }
}

type Dog is Animal {
  speak(&this) string {
    return "Woof";
  }
}

type Cat is Animal {
  speak(&this) string {
    return "Meow";
  }
}

test_paren_this_is_check() `test {
  Animal d = Dog(name: "Rex");
  Animal c = Cat(name: "Tom");
  assert(d.am_i_dog(), "(this) is Dog true for Dog");
  assert(!c.am_i_dog(), "(this) is Dog false for Cat");
}

// ---------------- operator (value type) ----------------
type V2 {
  int x `value;
  int y `value;
  +(V2 other) V2 {
    return V2(x: this.x + other.x, y: this.y + other.y);
  }
  add_via(this, V2 other) V2 {
    return (this) + other;
  }
}

test_paren_this_operator() `test {
  a := V2(x: 1, y: 2);
  b := V2(x: 3, y: 4);
  c := a.add_via(b);
  assert(c.x == 4, "(this) + other operator receiver x");
  assert(c.y == 6, "(this) + other operator receiver y");
}

// ---------------- generic method ----------------
// NOTE: payload is `int` (not a droppable like string) to avoid T0746, a
// pre-existing double-free when a generic method returns a `this` string field
// by value. The gate under test (genGenericMethodCall, the `(this).method()`
// dispatch) is exercised regardless of payload type.
type GBox[T] {
  T val;
  peek(this) T {
    return this.val;
  }
  via(this) T {
    return (this).peek();
  }
  via_nested(this) T {
    return ((this)).peek();
  }
}

test_paren_this_generic_method() `test {
  i := GBox[int](val: 99);
  assert(i.via() == 99, "(this).peek() in generic method");
  assert(i.via_nested() == 99, "((this)).peek() in generic method");
  b := GBox[bool](val: true);
  assert(b.via() == true, "(this).peek() generic bool");
}

// ---------------- enum method / getter ----------------
enum Color {
  Red, Green, Blue,

  describe(&this) string {
    match this {
      Color.Red => {
        return "red";
      },
      Color.Green => {
        return "green";
      },
      Color.Blue => {
        return "blue";
      },
    }
  }

  describe_via(&this) string {
    return (this).describe();
  }

  get opposite Color {
    match this {
      Color.Red => {
        return Color.Green;
      },
      Color.Green => {
        return Color.Blue;
      },
      Color.Blue => {
        return Color.Red;
      },
    }
  }

  opposite_via(&this) Color {
    return (this).opposite;
  }
}

test_paren_this_enum_method() `test {
  assert(Color.Red.describe_via() == "red", "(this).describe() enum method");
  match Color.Red.opposite_via() {
    Color.Green => {
      assert(true, "ok");
    },
    _ => {
      assert(false, "(this).opposite should be Green");
    },
  }
}

// ---------------- force unwrap of optional field (Tier-2 dup/neutralize) --------
// `~this` method owning a droppable optional field; `(this).field!` must dup or
// neutralize correctly so neither the optional's scope-exit drop nor the new
// binding double-frees, and nothing leaks.
type Inner613 {
  string s;
}

type OptHolder {
  Inner613? maybe;
  take(~this) string {
    v := (this).maybe!;
    return v.s;
  }
  take_nested(~this) string {
    v := ((this)).maybe!;
    return v.s;
  }
}

test_paren_this_force_unwrap() `test {
  h := OptHolder(maybe: Inner613(s: "in" + "ner"));
  assert(h.take() == "inner", "(this).field! on ~this owner");
  h2 := OptHolder(maybe: Inner613(s: "deep" + "er"));
  assert(h2.take_nested() == "deeper", "((this)).field! on ~this owner");
}

// ---------------- operator with `(this)` as the right-hand argument ----------
// Distinct from `(this) + other` above: here `this` is the operator *argument*,
// not the receiver, so the genBinaryExpr `e.Right` "this-as-arg" gate fires.
// Heap type (the value-type form of this gate is broken bare-or-paren — T0748).
type CmpBox {
  int x;
  < (CmpBox other) bool {
    return this.x < other.x;
  }
  // `other < (this)` -> left=other, right=(this) -> e.Right gate peels paren.
  gt_via(this, CmpBox other) bool {
    return other < (this);
  }
  gt_via_nested(this, CmpBox other) bool {
    return other < ((this));
  }
}

test_paren_this_operator_arg() `test {
  assert(CmpBox(x: 5).gt_via(CmpBox(x: 2)), "other(2) < (this)(5) == true");
  assert(!CmpBox(x: 2).gt_via(CmpBox(x: 5)), "other(5) < (this)(2) == false");
  assert(CmpBox(x: 9).gt_via_nested(CmpBox(x: 1)), "((this)) arg == true");
}

// ---------------- virtual binary operator receiver ----------------
// Base has a child, so the operator dispatches through the vtable
// (genVirtualBinaryOp), a different gate from the direct operator above.
type VOpBase {
  int n;
  +(VOpBase other) VOpBase {
    return VOpBase(n: this.n + other.n);
  }
  add_via(this, VOpBase other) VOpBase {
    return (this) + other;
  }
}

type VOpDerived is VOpBase {
}

test_paren_this_virtual_operator() `test {
  assert(VOpBase(n: 1).add_via(VOpBase(n: 2)).n == 3, "(this) + other virtual dispatch");
}

// ---------------- generic enum method / getter ----------------
// Generic enum routes method calls through genGenericEnumMethodCall — a
// separate gate from the non-generic enum method covered above.
enum GOpt[T] {
  Some(T value),
  None,

  has(&this) bool {
    match this {
      GOpt.Some(v) => {
        return true;
      },
      GOpt.None => {
        return false;
      },
    }
  }
  has_via(&this) bool {
    return (this).has();
  }
  has_via_nested(&this) bool {
    return ((this)).has();
  }
}

test_paren_this_generic_enum_method() `test {
  s := GOpt[int].Some(5);
  n := GOpt[int].None;
  assert(s.has_via(), "(this).has() generic enum Some -> true");
  assert(!n.has_via(), "(this).has() generic enum None -> false");
  assert(s.has_via_nested(), "((this)).has() generic enum -> true");
}

// ---------------- `is` against a resolved generic type ----------------
// `(this) is IBox[int]` resolves to a concrete generic instance, routing
// through genIsResolvedType (distinct from the non-generic genIsNamedType
// covered by the Dog/Cat test above).
type GShape {
  area(&this) int `abstract;
  is_intbox(&this) bool {
    return (this) is IBox[int];
  }
  is_intbox_nested(&this) bool {
    return ((this)) is IBox[int];
  }
}

type IBox[T] is GShape {
  T value;
  area(&this) int {
    return 1;
  }
}

test_paren_this_is_generic() `test {
  GShape si = IBox[int](value: 5);
  GShape ss = IBox[string](value: "x");
  assert(si.is_intbox(), "(this) is IBox[int] true for IBox[int]");
  assert(!ss.is_intbox(), "(this) is IBox[int] false for IBox[string]");
  assert(si.is_intbox_nested(), "((this)) is IBox[int] true for IBox[int]");
}

// ---------------- RTTI cast (as! / as) on a `this` receiver (T0747) ----------
// genExpr(this) yields a bare instance i8*, not a {vtable, instance} value
// struct, so the cast *result* was mishandled: `(this as! T).field` emitted
// invalid IR (extractvalue from i8*) and `d := this as! T` / `T? o = this as T`
// panicked in codegen. The fix rebuilds the cast result as a value struct
// (vtable loaded from the object's typeinfo chain) and, for a cast of a borrow
// bound to a local, clears the local's drop flag so it doesn't double-free the
// aliased instance. String fields surface any missed ownership as a leak or a
// double-free segfault. Cast methods live on the abstract base, so `this` is
// statically `CShape` and the downcast is a real RTTI query.
type CShape {
  int sides;
  kind(&this) string `abstract;
  // forced cast + inline field access (int field), bare and paren `this`.
  csq_sides(&this) int {
    return (this as! CSquare).sides;
  }
  csq_sides_p(&this) int {
    return ((this) as! CSquare).sides;
  }
  // forced cast + inline virtual method call (exercises reconstructed vtable).
  csq_kind(&this) string {
    return (this as! CSquare).kind();
  }
  // forced cast bound to a local, then method call / string-field read.
  csq_local(&this) string {
    s := this as! CSquare;
    return s.kind();
  }
  csq_paren_local(&this) string {
    s := (this) as! CSquare;
    return s.kind();
  }
  csq_local_field(&this) string {
    s := this as! CSquare;
    return s.label;
  }
  // reassign an *owned* local from a cast of `this` (the assign path, not a var
  // decl): combines the value-struct reconstruction (this is a bare i8*) with
  // genAssignStmt's drop-flag clear. The owned "init" CSquare is dropped on
  // reassignment; the new value aliases `this` and must NOT be dropped again at
  // scope exit. Missing the assign-path clear double-frees `this`'s instance.
  csq_reassign_local(&this) string {
    CSquare local = CSquare(sides: 9, label: "init");
    local = this as! CSquare;
    return local.label;
  }
  // optional cast: presence narrowing only (no unwrap).
  csq_is_square(&this) bool {
    CSquare? o = this as CSquare;
    if o {
      return true;
    }
    return false;
  }
  // T0753: unwrap a borrow-holding optional (from `this as CSquare`) via the
  // handler form and read an int field. The extracted value is a borrow of
  // `this`'s instance — must NOT be tracked as an owned temp. Present case
  // returns the real `sides`; absent case takes the handler fallback (-1).
  csq_unwrap_sides(&this) int {
    CSquare? o = this as CSquare;
    return (o? _ {
      return -1;
    }).sides;
  }
  // Same, but calling a virtual method on the unwrapped borrow value.
  csq_unwrap_kind(&this) string {
    CSquare? o = this as CSquare;
    return (o? _ {
      return "none";
    }).kind();
  }
  // T0778 no-regression: non-diverging handler returning a fresh owned
  // CSquare on a borrow-holding optional. The result is a user-type
  // value-struct (NOT i8*), so it routes through trackHeapUserTypeResult,
  // whose ident-skip still applies. The T0778 i8* tracking added inside
  // genOptionalHandlerExpr must NOT fire here (named is not string/vector).
  // Present case (CSquare): phi reads the borrow's sides (4). Absent case
  // (CTriangle): phi is the fresh CSquare(sides: -1, label: "fb"+"x"),
  // which is correctly owned and dropped at scope exit. Heap label exercises
  // the leak gate; expected `sides` value tracks the present runtime.
  csq_unwrap_sides_nondiverging(&this) int {
    CSquare? o = this as CSquare;
    return (o? _ {
      CSquare(sides: -1, label: "fb" + "x")
    }).sides;
  }
}
type CSquare is CShape {
  string label;
  kind(&this) string {
    return "square";
  }
}
type CTriangle is CShape {
  string label;
  kind(&this) string {
    return "triangle";
  }
}

test_this_cast_forced_field() `test {
  CShape s = CSquare(sides: 4, label: "sq");
  assert(s.csq_sides() == 4, "(this as! CSquare).sides");
  assert(s.csq_sides_p() == 4, "((this) as! CSquare).sides");
}

test_this_cast_forced_method() `test {
  CShape s = CSquare(sides: 4, label: "sq");
  assert(s.csq_kind() == "square", "(this as! CSquare).kind() via reconstructed vtable");
}

test_this_cast_forced_local() `test {
  CShape s = CSquare(sides: 4, label: "sq");
  assert(s.csq_local() == "square", "bare local: s := this as! CSquare; s.kind()");
  assert(s.csq_paren_local() == "square", "paren local: s := (this) as! CSquare; s.kind()");
  assert(s.csq_local_field() == "sq", "local cast then string field read, no double-free");
  assert(s.csq_reassign_local() == "sq", "reassign owned local from this-cast, no double-free");
}

test_this_cast_optional_present() `test {
  CShape s = CSquare(sides: 4, label: "sq");
  CShape t = CTriangle(sides: 3, label: "tri");
  assert(s.csq_is_square(), "this as CSquare present when this is CSquare");
  assert(!t.csq_is_square(), "this as CSquare absent when this is CTriangle");
}

// T0753: unwrapping a borrow-holding optional (from `this as CSquare`) via the
// handler form must not double-free. Present case reads the real field/method;
// absent case (CTriangle) takes the handler fallback. Both must be leak-free.
test_this_cast_optional_unwrap() `test {
  CShape s = CSquare(sides: 4, label: "sq");
  CShape t = CTriangle(sides: 3, label: "tri");
  assert(s.csq_unwrap_sides() == 4, "unwrap borrow-optional, read int field (present)");
  assert(t.csq_unwrap_sides() == -1, "unwrap borrow-optional fallback (absent)");
  assert(s.csq_unwrap_kind() == "square", "unwrap borrow-optional, virtual method (present)");
  assert(t.csq_unwrap_kind() == "none", "unwrap borrow-optional fallback method (absent)");
  // T0778 no-regression: non-diverging handler on borrow-holding optional
  // with user-type (non-i8*) recovery. Must NOT route through the new T0778
  // i8* tracking path; heap-user-type path's ident-skip applies.
  assert(s.csq_unwrap_sides_nondiverging() == 4, "non-diverging borrow-optional, present");
  assert(t.csq_unwrap_sides_nondiverging() == -1, "non-diverging borrow-optional, absent fallback");
}

// ---------------- index/slice operator on a `this` receiver (T0745) ----------
// `this[i]` (read), `this[i] = v` (write), and the slice forms `this[lo:hi]` /
// `this[lo:hi] = v` on a type's *own* user-defined `[]`/`[]=`/`[:]`/`[:]=`
// operator used to emit invalid IR (extractvalue from i8*) because
// genMethodIndex / genSliceExpr / genMethodIndexAssign / genSliceAssign gated on
// isContainerType with no `this` branch — so the raw i8* receiver fell through to
// extractInstancePtr. Both bare and paren-wrapped forms were affected. The fix
// peels ParenExpr via isThisReceiver() and uses the i8* receiver directly.
// String payloads surface any missed ownership as a leak or double-free.
type IdxBox {
  int[] xs;
  [](int i) int {
    return this.xs[i];
  }
  []=(int i, int v) {
    this.xs[i] = v;
  }
  first(this) int {
    return this[0];
  }
  first_p(this) int {
    return (this)[0];
  }
  first_pn(this) int {
    return ((this))[0];
  }
  set_bare(~this, int i, int v) {
    this[i] = v;
  }
  set_paren(~this, int i, int v) {
    (this)[i] = v;
  }
}

test_this_index_read() `test {
  b := IdxBox(xs: [10, 20]);
  assert(b.first() == 10, "bare this[0] read");
  assert(b.first_p() == 10, "(this)[0] read");
  assert(b.first_pn() == 10, "((this))[0] read");
}

test_this_index_write() `test {
  b := IdxBox(xs: [10, 20]);
  b.set_bare(0, 99);
  assert(b[0] == 99, "bare this[i] = v write");
  b.set_paren(1, 77);
  assert(b[1] == 77, "(this)[i] = v write");
}

// Generic + heap (string) repro from the report — exercises monomorphization and
// string ownership (a missed move surfaces as a leak/double-free under the
// zero-tolerance policy).
type StrGrid[T] {
  T[] cells;
  [](int i) T {
    return this.cells[i];
  }
  []=(int i, ~T v) {
    this.cells[i] = v;
  }
  at_bare(this, int i) T {
    return this[i];
  }
  set_bare(~this, int i, ~T v) {
    this[i] = v;
  }
}

test_this_index_generic_heap() `test {
  g := StrGrid[string](cells: ["a", "b", "c"]);
  assert(g.at_bare(0) == "a", "generic bare this[i] read");
  g.set_bare(1, "x" + "y");
  assert(g[1] == "xy", "generic bare this[i] = v write");
}

// Slice operators (`[:]` / `[:]=`) on a `this` receiver.
type SliceBox {
  int[] xs;
  [](int i) int {
    return this.xs[i];
  }
  [:](int? lo, int? hi) int[] {
    return this.xs[lo: hi];
  }
  [:]=(int? lo, int? hi, ~int[] v) {
    this.xs[lo: hi] = v;
  }
  head2(this) int[] {
    return this[0:2];
  }
  head2_p(this) int[] {
    return (this)[0:2];
  }
  replace01(~this, ~int[] v) {
    this[0:2] = v;
  }
  replace01_p(~this, ~int[] v) {
    (this)[0:2] = v;
  }
}

test_this_slice_read() `test {
  b := SliceBox(xs: [1, 2, 3, 4]);
  h := b.head2();
  assert(h.len == 2, "bare this[0:2] slice read len");
  assert(h[0] == 1 && h[1] == 2, "bare this[0:2] slice read values");
  hp := b.head2_p();
  assert(hp[0] == 1 && hp[1] == 2, "(this)[0:2] slice read values");
}

test_this_slice_write() `test {
  b := SliceBox(xs: [1, 2, 3, 4]);
  b.replace01([9, 8]);
  assert(b[0] == 9 && b[1] == 8, "bare this[0:2] = v slice write");
  c := SliceBox(xs: [1, 2, 3, 4]);
  c.replace01_p([7, 6]);
  assert(c[0] == 7 && c[1] == 6, "(this)[0:2] = v slice write");
}

// Value-type `this[i]` read — previously panicked in valueTypeReceiverPtr because
// the `this` receiver is a raw i8* (value-struct ptr), not a value struct.
type VPair {
  int a `value;
  int b `value;
  [](int i) int {
    if i == 0 {
      return this.a;
    }
    return this.b;
  }
  first(this) int {
    return this[0];
  }
  first_p(this) int {
    return (this)[1];
  }
}

test_this_index_value_type() `test {
  p := VPair(a: 5, b: 7);
  assert(p.first() == 5, "value-type bare this[0] read");
  assert(p.first_p() == 7, "value-type (this)[1] read");
}
//
// NOTE: `(this) as!/as T` RTTI cast on a `this` receiver — FIXED (T0747) and
// covered above by the test_this_cast_* family (forced field/method, forced
// local binding, optional presence + unwrap). Unwrapping an optional that holds
// a borrow (e.g. `(this as T)? _ { ... }`) used to double-free — fixed in T0753
// (the optional-handler unwrap on an ident source no longer tracks the extracted
// value as an owned temp) and now covered by test_this_cast_optional_unwrap.
//
// NOTE: value-type binary operator with `this` as the right-hand *argument*
// (`other < this` where `<` is on a value type) is still broken for BOTH bare
// and paren `this` — the arg-wrap stores the i8* into an embedded data field.
// Filed as T0748. (The heap-type form of this gate IS covered above by
// test_paren_this_operator_arg.) Once T0748 is fixed, add the `(this)` case here.
