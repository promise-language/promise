// T0261: Vector drop + channel/goroutine in the same function must not
// produce duplicate LLVM local names (vecdrop.idx).
vector_and_channel() `test(exclude: wasm) {
  string[] items = ["hello", "world"];
  ch := channel[int](capacity: 1);
  go {
    ch.send(42);
    ch.close();
  };
  int? received = <-ch;
  assert(received is int, "expected int");
  assert(items.len == 2, "expected 2 items");
}

multiple_vectors_and_goroutine() `test(exclude: wasm) {
  int[] nums = [1, 2, 3];
  string[] words = ["a", "b"];
  ch := channel[int](capacity: 1);
  go {
    ch.send(99);
    ch.close();
  };
  int? msg = <-ch;
  assert(msg is int, "expected int");
  assert(nums.len == 3, "expected 3 nums");
  assert(words.len == 2, "expected 2 words");
}
