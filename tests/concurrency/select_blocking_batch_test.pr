// Blocking select in batch tests (B0045 fix).
// Verifies that blocking select (no default) works correctly in batch
// test functions, which run outside coroutine context.
// Single recv case blocks until data arrives.
test_blocking_recv_single() `test(allow_leaks: true, exclude: "wasm32") {
  ch := channel[int](capacity: 1);
  go {
    ch.send(42);
  };
  int result = 0;
  select {
    v := <-ch:
      if val := v {
        result = val;
      }
  }
  assert(result == 42, "blocking recv should get 42");
}

// Multiple recv cases, one becomes ready.
test_blocking_recv_multi() `test(allow_leaks: true, exclude: "wasm32") {
  ch1 := channel[int](capacity: 1);
  ch2 := channel[int](capacity: 1);
  go {
    ch2.send(99);
  };
  int result = 0;
  select {
    v := <-ch1:
      if val := v {
        result = val;
      }
    v := <-ch2:
      if val := v {
        result = val;
      }
  }
  assert(result == 99, "blocking recv multi should get 99");
}

// Blocking send case waits for space (channel initially full).
test_blocking_send() `test(allow_leaks: true, exclude: "wasm32") {
  ch := channel[int](capacity: 1);
  ch.send(0); // fill the channel
  go {
    <-ch; // goroutine drains one slot so select can send
  };
  select {
    ch.send(77):
  }
  int result = 0;
  r := <-ch;
  if val := r {
    result = val;
  }
  assert(result == 77, "blocking send should deliver 77");
}

// Blocking select with already-ready channel proceeds immediately.
test_blocking_already_ready() `test(allow_leaks: true, exclude: "wasm32") {
  ch := channel[int](capacity: 1);
  ch.send(10);
  int result = 0;
  select {
    v := <-ch:
      if val := v {
        result = val;
      }
  }
  assert(result == 10, "already-ready channel should work");
}

// Blocking select with closed channel.
test_blocking_recv_closed() `test(allow_leaks: true, exclude: "wasm32") {
  ch := channel[int](capacity: 1);
  ch.close();
  bool got_none = false;
  select {
    v := <-ch:
      if val := v {
        got_none = false;
      } else {
        got_none = true;
      }
  }
  assert(got_none, "closed channel recv should produce none");
}
