// Tests for explicit ^ error propagation syntax (T0118).
type ParseError is error {
  int code;
}

_parse_int!(string s) int {
  if s == "bad" {
    raise ParseError(message: "parse error", code: 1)
  }
  return 42;
}

_void_fail!() void {
  raise error(message: "void fail");
}

// Helper functions for propagation tests
_propagate_assign!() int {
  int v = _parse_int("ok")?^;
  return v;
}

_propagate_return!() int {
  return _parse_int("ok")?^;
}

_propagate_error!() int {
  return _parse_int("bad")?^;
}

_propagate_void!() void {
  _void_fail()?^;
}

_level2!() int {
  return _parse_int("bad")?^;
}
_level1!() int {
  return _level2()?^;
}

_propagate_inside_handler!() int {
  int v = _parse_int("bad")? e {
    return _parse_int("ok")?^;
  };
  return v;
}

_add_parsed!(string a, string b) int {
  int x = _parse_int(a)?^;
  int y = _parse_int(b)?^;
  return x + y;
}

// Basic propagation in assignment
test_propagate_assign() `test {
  assert(_propagate_assign()?! == 42, "propagate assign");
}

// Propagation in return
test_propagate_return() `test {
  assert(_propagate_return()?! == 42, "propagate return");
}

// Propagation of error (error path)
test_propagate_error() `test {
  _propagate_error()? e {
    assert(e.message == "parse error", "propagated error message");
    return;
  };
  assert(false, "should not reach here");
}

// Propagation as statement (void)
test_propagate_void() `test {
  _propagate_void()? e {
    assert(e.message == "void fail", "propagated void error message");
    return;
  };
  assert(false, "should not reach here");
}

// Nested propagation
test_nested_propagate() `test {
  _level1()? e {
    assert(e.message == "parse error", "nested propagated error");
    return;
  };
  assert(false, "should not reach here");
}

// Propagation with XOR still working (^ is both postfix and binary)
test_xor_still_works() `test {
  assert((12 ^ 10) == 6, "12 ^ 10 == 6");
  assert((0xFF ^ 0xFF) == 0, "x ^ x == 0");
  assert((0 ^ 42) == 42, "0 ^ x == x");
}

// Propagation inside error handler body
test_propagate_inside_handler() `test {
  assert(_propagate_inside_handler()?! == 42, "propagate inside handler");
}

// Multiple propagations in same function
test_multiple_propagations() `test {
  assert(_add_parsed("ok", "ok")?! == 84, "multiple propagations");
}

// T0330: Failable call used as binary operand auto-propagates in failable function.
type _Rd {
  int x;
  new(~this) {
    this.x = 0;
  }
  read!(~this) u32 {
    return 1u32;
  }
}

type _Wrapper {
  _Rd inner;
  new(~this, ~_Rd r) {
    this.inner = r;
  }
  is_one!(~this) bool {
    return this.inner.read() != 0u32;
  }
}

test_failable_binary_operand_auto_propagate() `test {
  _Wrapper w = _Wrapper(r: _Rd());
  bool b = w.is_one()?!;
  assert(b, "expected true");
}
