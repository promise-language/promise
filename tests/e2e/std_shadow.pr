use std;

// User-defined min shadows std min
min(int a, int b) int {
  return 999;
}

// User-defined println shadows std println
println(string s) {
  std.print_int(0);
}

main() `test(expected: """999
3
0
via std
2.72
true""") {
  print_int(min(3, 7));
  print_int(std.min(3, 7));

  // User println (prints 0), then std.println (prints the string)
  println("ignored");
  std.println("via std");

  // Verify std.print_f64 and std.print_bool work via std namespace
  std.print_f64(2.72);
  std.print_bool(true);
}
