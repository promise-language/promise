// Type casting and type check tests: is expression, polymorphism.
type Shape {
  string name;
  area(&this) f64 `abstract;
}

type Circle is Shape {
  f64 radius;
  area(&this) f64 {
    return 3.14159 * this.radius * this.radius;
  }
}

type Square is Shape {
  f64 side;
  area(&this) f64 {
    return this.side * this.side;
  }
}

type Triangle is Shape {
  f64 base;
  f64 height;
  area(&this) f64 {
    return this.base * this.height / 2.0;
  }
}

// --- is expression: positive check ---

test_is_positive() `test {
  Shape s = Circle(name: "circle", radius: 5.0);
  assert(s is Circle, "Circle is Circle");
}

// --- is expression: negative check ---

test_is_negative() `test {
  Shape s = Circle(name: "circle", radius: 5.0);
  assert(!(s is Square), "Circle is not Square");
}

// --- is expression in if ---

test_is_in_if() `test {
  Shape s = Square(name: "sq", side: 4.0);
  string result = "unknown";
  if s is Circle {
    result = "circle";
  } else if s is Square {
    result = "square";
  } else if s is Triangle {
    result = "triangle";
  }
  assert(result == "square", "identified as square");
}

// --- polymorphic method dispatch ---

test_polymorphic_dispatch() `test {
  Shape c = Circle(name: "c", radius: 1.0);
  Shape s = Square(name: "s", side: 2.0);
  f64 ca = c.area();
  f64 sa = s.area();
  assert(ca > 3.0 && ca < 3.2, "circle area ~ 3.14");
  assert(sa > 3.9 && sa < 4.1, "square area = 4.0");
}

// --- is on same type ---

test_is_same_type() `test {
  Shape s1 = Circle(name: "a", radius: 1.0);
  Shape s2 = Circle(name: "b", radius: 2.0);
  assert(s1 is Circle, "s1 is Circle");
  assert(s2 is Circle, "s2 is Circle");
}

// --- parent field access via polymorphic ref ---

test_parent_field_access() `test {
  Shape s = Triangle(name: "tri", base: 6.0, height: 8.0);
  assert(s.name == "tri", "parent field accessible");
}

// --- multiple levels of type check ---

type Vehicle {
  string make;
  describe(&this) string `abstract;
}

type Car is Vehicle {
  int doors;
  describe(&this) string {
    return "car";
  }
}

type Truck is Vehicle {
  int payload;
  describe(&this) string {
    return "truck";
  }
}

test_vehicle_hierarchy() `test {
  Vehicle v1 = Car(make: "Toyota", doors: 4);
  Vehicle v2 = Truck(make: "Ford", payload: 5000);
  assert(v1 is Car, "v1 is Car");
  assert(!(v1 is Truck), "v1 is not Truck");
  assert(v2 is Truck, "v2 is Truck");
  assert(!(v2 is Car), "v2 is not Car");
  assert(v1.describe() == "car", "v1 describes as car");
  assert(v2.describe() == "truck", "v2 describes as truck");
}

// --- type check in loop with individual items ---

test_type_check_loop() `test {
  Shape s1 = Circle(name: "c", radius: 1.0);
  Shape s2 = Square(name: "s", side: 1.0);
  Shape s3 = Triangle(name: "t", base: 1.0, height: 1.0);

  int circles = 0;
  int squares = 0;
  int triangles = 0;

  // Check each shape
  if s1 is Circle {
    circles++;
  }
  if s1 is Square {
    squares++;
  }
  if s1 is Triangle {
    triangles++;
  }

  if s2 is Circle {
    circles++;
  }
  if s2 is Square {
    squares++;
  }
  if s2 is Triangle {
    triangles++;
  }

  if s3 is Circle {
    circles++;
  }
  if s3 is Square {
    squares++;
  }
  if s3 is Triangle {
    triangles++;
  }

  assert(circles == 1, "1 circle");
  assert(squares == 1, "1 square");
  assert(triangles == 1, "1 triangle");
}

// --- RTTI downcast (as! / as) binding to a local: must not double-free (T0747) ---
// `d := <borrow> as!/as T` is a non-consuming *view* — the ownership pass never
// moves the subject, so the subject keeps ownership and the cast local must NOT
// get its own drop binding. The inherited `name` string field (heap) surfaces a
// missed clear as a double-free segfault or a leak. Casting an *owned temp*
// (factory result) instead legitimately transfers ownership to the local.

helper_param_downcast(Shape s) f64 {
  // s is a borrowed parameter; the cast aliases it.
  c := s as! Circle;
  return c.radius;
}

make_circle() Shape {
  return Circle(name: "made", radius: 9.0);
}

test_downcast_local_owned_subject() `test {
  // Owned local subject, cast result bound to a local.
  Shape s = Circle(name: "circle", radius: 5.0);
  c := s as! Circle;
  assert(c.radius == 5.0, "downcast owned-local subject, bound to local");
  assert(c.name == "circle", "downcast local reads inherited heap field, no double-free");
}

test_downcast_borrowed_param_subject() `test {
  Shape s = Circle(name: "circle", radius: 2.5);
  assert(helper_param_downcast(s) == 2.5, "downcast borrowed param, bound to local");
}

test_downcast_inline_field() `test {
  Shape s = Square(name: "sq", side: 3.0);
  assert((s as! Square).side == 3.0, "inline downcast field access (no local binding)");
}

test_downcast_owned_temp_subject() `test {
  // Owned-temp subject (factory result): the local owns the freshly made value.
  c := make_circle() as! Circle;
  assert(c.radius == 9.0, "downcast owned-temp subject keeps ownership");
  assert(c.name == "made", "downcast owned-temp reads heap field, no leak");
}

test_downcast_optional_presence() `test {
  Shape s = Circle(name: "circle", radius: 1.0);
  // Presence narrowing only — unwrapping a borrow-holding optional is T0753.
  Circle? o = s as Circle;
  bool present = false;
  if o {
    present = true;
  }
  assert(present, "optional downcast present when subject matches");
  Square? sq = s as Square;
  bool absent = true;
  if sq {
    absent = false;
  }
  assert(absent, "optional downcast absent when subject does not match");
}

// --- RTTI downcast of an OWNED-returning subject: must keep ownership (T0747) ---
// A getter or user-defined `[]` that returns an owned value produces a *fresh*
// instance, not an alias. The cast result therefore OWNS it and the bound local
// must keep its drop flag — clearing it (as the borrow case does) leaks the
// freshly produced instance (the inherited `name` heap string surfaces it).

type ShapeFactory {
  // Getter returning an owned heap user-type value.
  get make Shape {
    return Circle(name: "from-getter", radius: 4.0);
  }
}

type ShapeBox {
  // User-defined `[]` operator returning an owned heap user-type value.
  [](&this, int i) Shape {
    return Circle(name: "from-index", radius: 6.0);
  }
}

test_downcast_owned_getter_subject() `test {
  f := ShapeFactory();
  c := f.make as! Circle;
  assert(c.radius == 4.0, "downcast owned getter result keeps ownership");
  assert(c.name == "from-getter", "downcast owned getter reads heap field, no leak");
}

test_downcast_owned_user_index_subject() `test {
  b := ShapeBox();
  c := b[0] as! Circle;
  assert(c.radius == 6.0, "downcast owned user-index result keeps ownership");
  assert(c.name == "from-index", "downcast owned user-index reads heap field, no leak");
}

test_downcast_reassign_local_from_borrow() `test {
  // Reassigning an existing local from a cast-of-borrow (`c = s as! T`, not a
  // var decl) is also a non-consuming view — the old value is dropped on
  // reassignment and the new aliased value must NOT be dropped again at scope
  // exit. Without clearing the target's re-armed drop flag this double-frees.
  Shape s = Circle(name: "src", radius: 7.5);
  Circle c = Circle(name: "init", radius: 0.0);
  c = s as! Circle;
  assert(c.radius == 7.5, "reassigned local from cast-of-borrow");
  assert(c.name == "src", "reassigned local reads inherited heap field, no double-free");
}

test_downcast_reassign_local_from_owned_temp() `test {
  // Contrast with the borrow case above: reassigning a local from a cast of an
  // *owned temp* (factory result) — the subject is a fresh value, so the assign
  // path must NOT clear the target's drop flag. The local owns the new value;
  // failing to keep its flag would leak it (the inherited heap `name` surfaces
  // the leak). Exercises the isRttiCastBorrow default branch in genAssignStmt.
  Circle c = Circle(name: "init", radius: 0.0);
  c = make_circle() as! Circle;
  assert(c.radius == 9.0, "reassigned local from owned-temp cast keeps ownership");
  assert(c.name == "made", "reassigned owned-temp reads heap field, no leak");
}

// --- RTTI downcast into an owning slot: must move subject (T0754) ---
// obj.field / v[i] / Holder(held: …) have no per-binding drop flag, so the
// per-local T0747 clear cannot reach them. Owning-slot stores must consume
// the cast subject, just like the equivalent non-cast assignment. Assertions
// read the inherited heap `name` field to surface a missed move as a use-
// after-free / double-free; the radius is also checked to confirm the new
// value reached the slot.

type Holder {
  Shape held;
}

test_downcast_field_target_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 2.0);
  h := Holder(held: Circle(name: "init", radius: 0.0));
  h.held = s as! Circle;
  assert((h.held as! Circle).radius == 2.0, "field target from cast-of-owned-local radius");
  assert(h.held.name == "src", "field target from cast-of-owned-local name (UAF probe)");
}

test_downcast_element_target_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 3.0);
  Shape[] v = [];
  v.push(Circle(name: "init", radius: 0.0));
  v[0] = s as! Circle;
  assert((v[0] as! Circle).radius == 3.0, "element target from cast-of-owned-local radius");
  assert(v[0].name == "src", "element target from cast-of-owned-local name (UAF probe)");
}

test_downcast_ctor_arg_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 4.0);
  h := Holder(held: s as! Circle);
  assert((h.held as! Circle).radius == 4.0, "ctor arg from cast-of-owned-local radius");
  assert(h.held.name == "src", "ctor arg from cast-of-owned-local name (UAF probe)");
}

test_downcast_field_target_from_owned_temp() `test {
  // Regression: owned-temp factory subject — must still pass after T0754.
  h := Holder(held: Circle(name: "init", radius: 0.0));
  h.held = make_circle() as! Circle;
  assert((h.held as! Circle).radius == 9.0, "field target from cast-of-owned-temp radius");
  assert(h.held.name == "made", "field target from cast-of-owned-temp name");
}

test_downcast_element_target_from_vector_index() `test {
  // Cast subject is v[i] — exercises the isIdxRhs paren/cast peel in stmt.go.
  Shape[] src = [];
  src.push(Circle(name: "src", radius: 5.0));
  Shape[] dst = [];
  dst.push(Circle(name: "init", radius: 0.0));
  dst[0] = src[0] as! Circle;
  assert((dst[0] as! Circle).radius == 5.0, "element target from cast-of-indexed radius");
  assert(dst[0].name == "src", "element target from cast-of-indexed name (UAF probe)");
}

// --- RTTI downcast as a `~` callee arg / enum-variant constructor arg (T0754) ---
// Sibling owning contexts to obj.field / v[i] / Holder(held: …) — the callee
// (`~Circle`) or the enum variant payload takes ownership of the cast result.
// Without clearing the subject's drop flag at the call site, the subject and the
// new owner both drop the same allocation → double-free at scope exit.

consume_circle(~Circle c) f64 {
  return c.radius;
}

test_downcast_tilde_param_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 2.0);
  f64 r = consume_circle(s as! Circle);
  assert(r == 2.0, "~ param from cast-of-owned-local");
}

enum DowncastVariant {
  Wrap(Circle c),
}

test_downcast_enum_variant_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 6.5);
  DowncastVariant v = DowncastVariant.Wrap(s as! Circle);
  match v {
    Wrap(c) => {
      assert(c.radius == 6.5, "enum variant from cast-of-owned-local radius");
      assert(c.name == "src", "enum variant from cast-of-owned-local name (UAF probe)");
    },
  }
}

// --- RTTI downcast into an explicit `new()` constructor / super() (T0754) ---
// The implicit-constructor sites (Holder(held: …)) above exercise the field-init
// path in genConstructorCallMono. An EXPLICIT `new()` method routes through a
// distinct codegen branch (the new-method args loop), as does `super(...)` from a
// child constructor. Both need the same cast-subject drop-flag clear or the
// inherited heap field is double-freed at scope exit.

type HolderExplicit {
  Circle held;
  new(~this, ~Circle c) {
    this.held = c;
  }
}

test_downcast_explicit_new_arg_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 4.5);
  h := HolderExplicit(c: s as! Circle);
  assert(h.held.radius == 4.5, "explicit new() arg from cast-of-owned-local radius");
  assert(h.held.name == "src", "explicit new() arg from cast-of-owned-local name (UAF probe)");
}

// Parent has explicit new() — super() call routes through the parent-has-new
// branch in genSuperCall.
type AnimalBase {
  Circle avatar;
  new(~this, ~Circle a) {
    this.avatar = a;
  }
}

type Pet is AnimalBase {
  new(~this, ~Shape s) {
    super(a: s as! Circle);
  }
}

test_downcast_super_arg_explicit_parent_new() `test {
  Shape s = Circle(name: "src", radius: 7.0);
  p := Pet(s: s);
  assert(p.avatar.radius == 7.0, "super-arg cast (explicit parent new) radius");
  assert(p.avatar.name == "src", "super-arg cast (explicit parent new) name (UAF probe)");
}

// Parent has implicit constructor — super() call routes through the
// parent-implicit-ctor branch in genSuperCall.
type SimpleHolder {
  Circle held;
}

type ChildHolder is SimpleHolder {
  new(~this, ~Shape s) {
    super(held: s as! Circle);
  }
}

test_downcast_super_arg_implicit_parent() `test {
  Shape s = Circle(name: "src", radius: 8.0);
  c := ChildHolder(s: s);
  assert(c.held.radius == 8.0, "super-arg cast (implicit parent ctor) radius");
  assert(c.held.name == "src", "super-arg cast (implicit parent ctor) name (UAF probe)");
}

// Paren-wrapped subjects exercise the unwrapDestructureParens / inner-paren-peel
// branch in both ownership/expr.go (tryMoveConsumeCastSubject) and
// codegen/stmt.go (castSubjectMovableIdent).

test_downcast_field_target_paren_wrapped_subject() `test {
  Shape s = Circle(name: "src", radius: 9.5);
  h := Holder(held: Circle(name: "init", radius: 0.0));
  h.held = (s) as! Circle;
  assert(h.held.name == "src", "paren-wrapped subject inside cast — name (UAF probe)");
}

test_downcast_field_target_paren_wrapped_cast() `test {
  Shape s = Circle(name: "src", radius: 10.5);
  h := Holder(held: Circle(name: "init", radius: 0.0));
  h.held = (s as! Circle);
  assert(h.held.name == "src", "paren-wrapped whole cast expr — name (UAF probe)");
}

// --- RTTI downcast into remaining owning slots (T0784) ---
// Siblings of T0754: array/tuple/map literals, native Arc/Mutex/channel
// constructors and ch.send, raise, and select-send. All move the cast subject
// into a new owner — without clearing the subject's drop flag the source and
// the new owner both drop the same allocation → double-free / SEGV.
// Each test asserts both the new field (functional) and the inherited heap
// `name` string (UAF probe so a missed move surfaces as a runtime crash, not
// a silently-passing test).

test_downcast_array_lit_element_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 2.0);
  Circle[] v = [s as! Circle];
  assert(v[0].radius == 2.0, "array-lit element from cast-of-owned-local radius");
  assert(v[0].name == "src", "array-lit element from cast-of-owned-local name (UAF probe)");
}

test_downcast_tuple_lit_element_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 3.5);
  (int, Circle) t = (7, s as! Circle);
  (n, c) := t;
  assert(n == 7, "tuple-lit first element");
  assert(c.radius == 3.5, "tuple-lit element from cast-of-owned-local radius");
  assert(c.name == "src", "tuple-lit element from cast-of-owned-local name (UAF probe)");
}

test_downcast_map_lit_value_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 4.25);
  map[string, Circle] m = {
    "k": s as! Circle
  };
  if c := m["k"] {
    assert(c.radius == 4.25, "map-lit value from cast-of-owned-local radius");
    assert(c.name == "src", "map-lit value from cast-of-owned-local name (UAF probe)");
  } else {
    assert(false, "map missing 'k'");
  }
}

// Map-lit *key* path — Shape doesn't satisfy Hashable + Equal, so this
// uses a dedicated Hashable + Equal hierarchy. Exercises the
// `castSubjectMovableIdent(entry.Key)` codegen branch (adjacent to the
// value branch above) end-to-end so a regression that only drops the
// key clear surfaces as a runtime double-free, not a silently-passing test.
type T0784Tag is Equal {
  int id;
  string label;
  get hash int {
    return this.id;
  }
  == (Self other) bool {
    return this.id == other.id;
  }
}
type T0784NumberedTag is T0784Tag {
  int extra;
  == (Self other) bool {
    return this.id == other.id;
  }
}

test_downcast_map_lit_key_from_owned_local() `test {
  T0784Tag t = T0784NumberedTag(id: 7, label: "src", extra: 42);
  map[T0784NumberedTag, string] m = {
    (t as! T0784NumberedTag): "v"
  };
  // Look up by an equal-but-distinct probe so the lookup exercises the
  // stored key's heap fields (label) — a UAF on the stored key would
  // misbehave on hash/equal or read garbage.
  if v := m[T0784NumberedTag(id: 7, label: "probe", extra: 999)] {
    assert(v == "v", "map-lit key from cast-of-owned-local — value");
  } else {
    assert(false, "map-lit key from cast-of-owned-local — lookup missed");
  }
  // Walk the stored keys via .keys() to read the heap label field stored
  // in the map slot (UAF probe — a freed key would crash here).
  string saw_label = "";
  for k in m.keys() {
    saw_label = k.label;
  }
  assert(saw_label == "src", "map-lit key from cast-of-owned-local — stored label (UAF probe)");
}

test_downcast_arc_ctor_arg_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 5.5);
  Arc[Circle] a = Arc[Circle](s as! Circle);
  assert(a.borrow.radius == 5.5, "arc ctor arg from cast-of-owned-local radius");
  assert(a.borrow.name == "src", "arc ctor arg from cast-of-owned-local name (UAF probe)");
}

test_downcast_mutex_ctor_arg_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 6.5);
  Mutex[Circle] m = Mutex[Circle](s as! Circle);
  use g := m.lock();
  assert(g.borrow.radius == 6.5, "mutex ctor arg from cast-of-owned-local radius");
  assert(g.borrow.name == "src", "mutex ctor arg from cast-of-owned-local name (UAF probe)");
}

test_downcast_channel_send_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 7.5);
  channel[Circle] ch = channel[Circle](capacity: 1);
  ch.send(s as! Circle);
  if c := <-ch {
    assert(c.radius == 7.5, "channel send from cast-of-owned-local radius");
    assert(c.name == "src", "channel send from cast-of-owned-local name (UAF probe)");
  } else {
    assert(false, "channel receive failed");
  }
  ch.close();
}

type T0784MyError is error {
}
type T0784SpecialError is T0784MyError {
  int code;
}

_t0784_fail!() int {
  T0784MyError e = T0784SpecialError(code: 42, message: "src-err");
  raise e as! T0784SpecialError;
}

_t0784_handle() string {
  int v = _t0784_fail()? e {
    return e.message;
  };
  return "unreached";
}

test_downcast_raise_from_owned_local() `test {
  string m = _t0784_handle();
  assert(m == "src-err", "raise cast-of-owned-local — message (UAF probe)");
}

test_downcast_select_send_from_owned_local() `test {
  Shape s = Circle(name: "src", radius: 8.5);
  channel[Circle] ch = channel[Circle](capacity: 1);
  select {
    ch.send(s as! Circle):
      {
      }
  }
  if c := <-ch {
    assert(c.radius == 8.5, "select-send from cast-of-owned-local radius");
    assert(c.name == "src", "select-send from cast-of-owned-local name (UAF probe)");
  } else {
    assert(false, "channel receive failed");
  }
  ch.close();
}

// The bug description calls `yield s as! Circle` "apparently safe" — the
// for-in-generator binding is a non-owning alias, so the consumer does not
// drop. But the ownership pass still marks the subject Moved at `yield`
// (T0784) so a future change to the generator-binding model surfaces as an
// ownership error instead of a silent UAF. This test pins down the apparent-
// safe runtime behavior so a regression in either direction (ownership-pass
// move-out + double-drop) fails loudly.
_t0784_gen_yield_cast() stream[Circle] {
  Shape s = Circle(name: "src", radius: 9.5);
  yield s as! Circle;
}

test_downcast_yield_from_owned_local() `test {
  string saw_name = "";
  f64 saw_radius = 0.0;
  int count = 0;
  for c in _t0784_gen_yield_cast() {
    saw_name = c.name;
    saw_radius = c.radius;
    count = count + 1;
  }
  assert(count == 1, "yield-of-cast — yielded exactly once");
  assert(saw_radius == 9.5, "yield-of-cast radius");
  assert(saw_name == "src", "yield-of-cast name (UAF probe)");
}

// `yield * inner` — outer delegates to an inner generator whose body uses
// `yield x as! T`. The ownership change at YieldDelegateStmt (T0784) covers
// the cast-of-stream-value case, which is unusual; this test exercises the
// more common nested case where the inner yield-of-cast site (T0784 yield)
// is reached via a yield-delegate chain.
_t0784_inner_yield_cast() stream[Circle] {
  Shape s = Circle(name: "del", radius: 11.5);
  yield s as! Circle;
}

_t0784_outer_delegate() stream[Circle] {
  yield * _t0784_inner_yield_cast();
}

test_downcast_yield_delegate_inner_cast_from_owned_local() `test {
  string saw_name = "";
  f64 saw_radius = 0.0;
  int count = 0;
  for c in _t0784_outer_delegate() {
    saw_name = c.name;
    saw_radius = c.radius;
    count = count + 1;
  }
  assert(count == 1, "yield-delegate inner-cast — yielded exactly once");
  assert(saw_radius == 11.5, "yield-delegate inner-cast radius");
  assert(saw_name == "del", "yield-delegate inner-cast name (UAF probe)");
}

// --- T0761: RTTI cast whose SUBJECT is itself an Optional ---
// `opt as! Subtype` (force) and `opt as Target` (optional). genCastExpr used to
// treat the {i1,{i8*,i8*}} optional as a bare value struct and crash; it now
// unwraps the inner value first. The `name` heap field surfaces leaks/double-frees.

// Force downcast on a present optional that matches: unwrap + downcast, no leak.
// The bound local `c` owns the inner; the source optional is neutralized.
test_optional_subject_force_match() `test {
  Shape o = Circle(name: "ofm", radius: 2.0);
  Shape? oo = o;
  c := oo as! Circle;
  assert(c.name == "ofm", "optional-subject as! name");
  assert(c.radius == 2.0, "optional-subject as! radius");
}

// Inline force downcast with no binding — the source's scope drop owns the
// inner; no double-free from a stray temp.
test_optional_subject_force_inline() `test {
  Shape o = Circle(name: "ofi", radius: 1.0);
  Shape? oo = o;
  assert((oo as! Circle).name == "ofi", "optional-subject inline as! name");
}

// Optional downcast, present + match: moves the inner into `some`; no double-free.
test_optional_subject_optional_match() `test {
  Shape o = Circle(name: "oom", radius: 3.0);
  Shape? oo = o;
  Circle? c = oo as Circle;
  bool present = false;
  if c {
    present = true;
    assert(c.radius == 3.0, "optional-subject as radius");
    assert(c.name == "oom", "optional-subject as name");
  }
  assert(present, "optional-subject as present+match");
}

// Optional downcast, present + mismatch: result is none, and the source's Circle
// is freed exactly once (no leak) — exercises the no-neutralize none path.
test_optional_subject_optional_mismatch() `test {
  Shape o = Circle(name: "oox", radius: 3.0);
  Shape? oo = o;
  Square? sq = oo as Square;
  bool present = false;
  if sq {
    present = true;
  }
  assert(!present, "optional-subject mismatch -> none");
}

// Optional downcast on a none source: result is none, no crash.
test_optional_subject_optional_none() `test {
  Shape? n = none;
  Circle? c = n as Circle;
  bool present = false;
  if c {
    present = true;
  }
  assert(!present, "optional-subject none -> none");
}

// --- T0761: non-ident Optional cast subjects (call result / index / borrowed this) ---
// genOptionalCastExpr must account for ownership of the unwrapped inner across all
// source shapes, not just local idents. Each `name` heap field surfaces leaks; the
// borrowed-`this` cases are called twice to surface use-after-free.

make_optional_shape(~string n) Shape? {
  Shape s = Circle(name: n, radius: 4.0);
  return s;
}

// Call-result temp source: the result owns the inner (no source binding). On
// mismatch the inner must be freed exactly once (no leak); on match it transfers.
test_optional_subject_temp_optional_match() `test {
  Circle? c = make_optional_shape("tom") as Circle;
  bool present = false;
  if c {
    present = true;
    assert(c.name == "tom", "temp opt name");
  }
  assert(present, "temp opt present");
}
test_optional_subject_temp_optional_mismatch() `test {
  Square? sq = make_optional_shape("tox") as Square;
  bool present = false;
  if sq {
    present = true;
  }
  assert(!present, "temp opt mismatch -> none");
}
test_optional_subject_temp_force() `test {
  c := make_optional_shape("tf") as! Circle;
  assert(c.name == "tf", "temp force name");
}

// Container-element source: indexing an Optional[Shape] element aliases the
// vector's bucket, so the cast must dup it; the vector keeps & frees the original.
test_optional_subject_index_optional_match() `test {
  Shape?[] v = [];
  Shape s = Circle(name: "iom", radius: 5.0);
  v.push(s);
  Circle? c = v[0] as Circle;
  bool present = false;
  if c {
    present = true;
    assert(c.name == "iom", "index opt name");
  }
  assert(present, "index opt present");
}
test_optional_subject_index_optional_mismatch() `test {
  Shape?[] v = [];
  Shape s = Circle(name: "iox", radius: 5.0);
  v.push(s);
  Square? sq = v[0] as Square;
  bool present = false;
  if sq {
    present = true;
  }
  assert(!present, "index opt mismatch -> none");
}
test_optional_subject_index_force() `test {
  Shape?[] v = [];
  Shape s = Circle(name: "if", radius: 5.0);
  v.push(s);
  c := v[0] as! Circle;
  assert(c.name == "if", "index force name");
}

// Borrowed-`this.field` source inside a `&this` method: the caller still owns the
// field, so the cast must dup. Called twice to surface use-after-free.
type OptHolder {
  Shape? slot;
  probe_force(&this) string {
    c := this.slot as! Circle;
    return c.name;
  }
  probe_optional(&this) bool {
    Circle? c = this.slot as Circle;
    bool present = false;
    if c {
      present = true;
    }
    return present;
  }
  probe_mismatch(&this) bool {
    Square? sq = this.slot as Square;
    bool present = false;
    if sq {
      present = true;
    }
    return present;
  }
  drop(~this) {
  }
}
test_optional_subject_borrowed_this_force() `test {
  Shape s = Circle(name: "btf", radius: 6.0);
  OptHolder h = OptHolder(slot: s);
  assert(h.probe_force() == "btf", "borrowed-this force 1");
  assert(h.probe_force() == "btf", "borrowed-this force 2");
}
test_optional_subject_borrowed_this_optional_match() `test {
  Shape s = Circle(name: "bto", radius: 6.0);
  OptHolder h = OptHolder(slot: s);
  assert(h.probe_optional(), "borrowed-this opt match 1");
  assert(h.probe_optional(), "borrowed-this opt match 2");
}
test_optional_subject_borrowed_this_optional_mismatch() `test {
  Shape s = Circle(name: "btx", radius: 6.0);
  OptHolder h = OptHolder(slot: s);
  assert(!h.probe_mismatch(), "borrowed-this opt mismatch 1");
  assert(!h.probe_mismatch(), "borrowed-this opt mismatch 2");
}

// --- T0761: SCALAR optional cast subject (`int? as f64` / `int? as! f64`) ---
// The inner is a bare scalar, not a value struct, so genOptionalCastExpr takes
// the scalar path (emitScalarCast) rather than RTTI. Scalars are `copy`/no-drop,
// so there is nothing to leak — these just verify correct unwrap + conversion.
test_optional_subject_scalar_force() `test {
  int? x = 5;
  f := x as! f64;
  assert(f == 5.0, "scalar optional as! converts inner");
}
test_optional_subject_scalar_optional_present() `test {
  int? x = 7;
  f64? f = x as f64;
  bool present = false;
  if f {
    present = true;
    assert(f == 7.0, "scalar optional as inner value");
  }
  assert(present, "scalar optional as present");
}
test_optional_subject_scalar_optional_none() `test {
  int? x = none;
  f64? f = x as f64;
  bool present = false;
  if f {
    present = true;
  }
  assert(!present, "scalar optional as none -> none");
}

// --- T0761: Optional cast in a GENERIC body + paren-wrapped source ---
// Exercises genOptionalCastExpr's `c.typeSubst != nil` substitution branches
// (active during monomorphized generic body codegen) and neutralizeOptionalCastSource's
// ParenExpr peel. The optional source is a LOCAL inside the generic body — a
// PARAMETER source hits the pre-existing T0811 segfault (out of scope here).

generic_optional_cast[T](T marker) Circle? {
  _ := marker;
  Shape s = Circle(name: "gl", radius: 2.0);
  Shape? oo = s;
  return oo as Circle;
}
generic_optional_force[T](T marker) string {
  _ := marker;
  Shape s = Circle(name: "gf", radius: 2.0);
  Shape? oo = s;
  c := oo as! Circle;
  return c.name;
}
generic_optional_mismatch[T](T marker) bool {
  _ := marker;
  Shape s = Circle(name: "gm", radius: 2.0);
  Shape? oo = s;
  Square? sq = oo as Square;
  bool present = false;
  if sq {
    present = true;
  }
  return present;
}

test_optional_subject_generic_optional_match() `test {
  Circle? c = generic_optional_cast(0);
  bool present = false;
  if c {
    present = true;
    assert(c.name == "gl", "generic-body opt cast name");
  }
  assert(present, "generic-body opt cast present");
}
test_optional_subject_generic_force() `test {
  assert(generic_optional_force(0) == "gf", "generic-body force name");
}
test_optional_subject_generic_mismatch() `test {
  assert(!generic_optional_mismatch(0), "generic-body mismatch -> none");
}

// Paren-wrapped optional source: neutralizeOptionalCastSource peels the ParenExpr
// before clearing the local's present flag (no double-free on the heap `name`).
test_optional_subject_paren_optional_match() `test {
  Shape s = Circle(name: "pom", radius: 3.0);
  Shape? oo = s;
  Circle? c = (oo) as Circle;
  bool present = false;
  if c {
    present = true;
    assert(c.name == "pom", "paren opt cast name");
  }
  assert(present, "paren opt cast present");
}
test_optional_subject_paren_force() `test {
  Shape s = Circle(name: "pf", radius: 3.0);
  Shape? oo = s;
  c := (oo) as! Circle;
  assert(c.name == "pf", "paren force name");
}

// Generic body + aliasing (index) source: exercises the dup + heap-temp
// neutralization under an active type substitution (generic × owned-source).
generic_index_cast[T](T marker) Circle? {
  _ := marker;
  Shape?[] v = [];
  Shape s = Circle(name: "gic", radius: 1.0);
  v.push(s);
  return v[0] as Circle;
}
test_optional_subject_generic_index_match() `test {
  Circle? c = generic_index_cast(0);
  bool present = false;
  if c {
    present = true;
    assert(c.name == "gic", "generic-index opt cast name");
  }
  assert(present, "generic-index opt cast present");
}

// --- T0761: owned-LOCAL member field as the Optional cast subject ---
// `h.slot as Der` where `h` is an owned local accessed directly (NOT through
// `this`). This is the MemberExpr arm that neutralizes the owner's field flag on
// match (no dup, no heap temp) — distinct from the borrowed-`this` shape, which
// dups. Only IR-covered before (Go TestOptionalSubjectOwnedMemberCast); these add
// runtime leak/double-free verification across match / mismatch / force.
type OwnedHolder {
  Shape? slot;
  drop(~this) {
  }
}
test_optional_subject_owned_member_optional_match() `test {
  Shape s = Circle(name: "omm", radius: 7.0);
  OwnedHolder h = OwnedHolder(slot: s);
  Circle? c = h.slot as Circle;
  bool present = false;
  if c {
    present = true;
    assert(c.name == "omm", "owned-member opt name");
  }
  assert(present, "owned-member opt match present");
}
test_optional_subject_owned_member_optional_mismatch() `test {
  Shape s = Circle(name: "omx", radius: 7.0);
  OwnedHolder h = OwnedHolder(slot: s);
  Square? sq = h.slot as Square;
  bool present = false;
  if sq {
    present = true;
  }
  assert(!present, "owned-member opt mismatch -> none");
}
test_optional_subject_owned_member_force() `test {
  Shape s = Circle(name: "omf", radius: 7.0);
  OwnedHolder h = OwnedHolder(slot: s);
  c := h.slot as! Circle;
  assert(c.name == "omf", "owned-member force name");
}
