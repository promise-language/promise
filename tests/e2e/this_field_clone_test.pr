// T0411: Constructor field-init / var-decl / return / consume-arg from
// `this.field` on a droppable owner must not silently shallow-copy.
//
// Auto-dup field types (string, Vector[T], Channel[T], Arc[T]) are dup'd
// by codegen, so `Type(field: this.field)` produces an independent copy.
// Non-auto-dup heap user-type fields are rejected at sema with the
// existing B0341 "use .clone()" error (covered in unit tests).
// --- Original T0411 repro (string field via Vector indexing) ---
type CloneBox {
  string label;
  drop(~this) {
  }

  clone() CloneBox {
    return CloneBox(label: this.label);
  }
}

test_t0411_clone_string_field_via_index() `test {
  v := CloneBox[]();
  v.push(CloneBox(label: "a" + "b"));
  b := v[0];
  assert(b.label == "ab", "first read");
  b2 := v[0];
  assert(b2.label == "ab", "second read");
}

// --- Vector field on a droppable owner ---

type VecHolder {
  int[] items;
  drop(~this) {
  }

  clone() VecHolder {
    return VecHolder(items: this.items);
  }
}

test_t0411_clone_vector_field() `test {
  h := VecHolder(items: [10, 20, 30]);
  h2 := h.clone();
  assert(h2.items.len == 3, "len");
  assert(h2.items[0] == 10, "0");
  assert(h2.items[1] == 20, "1");
  assert(h2.items[2] == 30, "2");
  // Independence: mutating the clone must not touch the original.
  h2.items.push(40);
  assert(h.items.len == 3, "orig len unchanged");
  assert(h2.items.len == 4, "clone len grew");
}

// --- Optional[string] field on a droppable owner ---

type OptHolder {
  string? subtitle;
  drop(~this) {
  }

  clone() OptHolder {
    return OptHolder(subtitle: this.subtitle);
  }
}

test_t0411_clone_optional_string_field_some() `test {
  h := OptHolder(subtitle: "sub");
  h2 := h.clone();
  if s := h2.subtitle {
    assert(s == "sub", "clone subtitle");
  } else {
    assert(false, "expected some");
  }
  if s := h.subtitle {
    assert(s == "sub", "orig subtitle still readable");
  } else {
    assert(false, "orig should still have value");
  }
}

test_t0411_clone_optional_string_field_none() `test {
  h := OptHolder(subtitle: none);
  h2 := h.clone();
  if _ := h2.subtitle {
    assert(false, "clone subtitle should be none");
  }
}

// --- Arc[T] field on a droppable owner (explicit .clone() required) ---
//
// Arc[T] / Weak[T] are not in `isAutoDupType` — sema requires explicit
// `.clone()` for field moves out of a droppable owner. T0411's fix doesn't
// change that; this test confirms the explicit-clone path still works.

type ArcHolder {
  Arc[string] data;
  drop(~this) {
  }

  clone() ArcHolder {
    return ArcHolder(data: this.data.clone());
  }
}

test_t0411_clone_arc_field_via_explicit_clone() `test {
  h := ArcHolder(data: Arc[string]("hello"));
  h2 := h.clone();
  // Both handles refer to the same underlying value; both must be readable.
  assert(h.data.borrow == "hello", "orig value");
  assert(h2.data.borrow == "hello", "clone value");
}

// --- Explicit `.clone()` for non-auto-dup heap user-type field ---

type Inner {
  string label;
  drop(~this) {
  }

  clone() Inner {
    return Inner(label: this.label);
  }
}

type Outer {
  Inner inner;
  drop(~this) {
  }

  // Heap user-type field requires explicit .clone() — the bare
  // `Outer(inner: this.inner)` would error at sema (B0341).
  clone() Outer {
    return Outer(inner: this.inner.clone());
  }
}

test_t0411_explicit_clone_for_user_type_field() `test {
  o := Outer(inner: Inner(label: "x" + "y"));
  o2 := o.clone();
  assert(o.inner.label == "xy", "orig label");
  assert(o2.inner.label == "xy", "clone label");
}

// --- Owned-owner regression: `Type(field: localOwner.field)` ---

test_t0411_owned_owner_constructor_field_init() `test {
  // The dup must also fire when the owner is an owned local — this is the
  // already-fixed B0345/B0351 path; the T0411 fix makes it consistent for
  // ThisExpr roots too. Belt-and-braces regression check.
  cb := CloneBox(label: "hello world");
  cb2 := CloneBox(label: cb.label);
  assert(cb.label == "hello world", "orig");
  assert(cb2.label == "hello world", "dup");
}

// --- Non-MemberExpr arg: no dup, no leak ---

test_t0411_no_field_dup_for_unrelated_constructor() `test {
  // When the constructor arg isn't a MemberExpr on a droppable owner,
  // the dup flag must NOT fire — verified by no-leak assertion.
  cb := CloneBox(label: "alpha");
  assert(cb.label == "alpha", "ok");
}

// --- var-decl from `this.field` (auto-dup type) ---

type StringRdr {
  string content;
  drop(~this) {
  }

  read_label() string {
    s := this.content;
    return s;
  }
}

test_t0411_var_decl_from_this_string_field() `test {
  r := StringRdr(content: "ab" + "c");
  s := r.read_label();
  assert(s == "abc", "ok");
  // Original is still readable — the var-decl produced an independent copy.
  assert(r.content == "abc", "orig");
}

// --- return `this.field` (auto-dup type) ---

type VecRdr {
  int[] items;
  drop(~this) {
  }

  take_items() int[] {
    return this.items;
  }
}

test_t0411_return_this_vector_field() `test {
  r := VecRdr(items: [1, 2, 3]);
  v := r.take_items();
  assert(v.len == 3, "len");
  assert(v[0] == 1, "0");
  // Original still owns its own buffer.
  assert(r.items.len == 3, "orig len");
  assert(r.items[0] == 1, "orig 0");
}

// --- consume-arg `consume(this.field)` (auto-dup type) ---

_consume_string(~string s) `public {
  // No-op — just consume.
}

type StringSrc {
  string content;
  drop(~this) {
  }

  send() {
    _consume_string(this.content);
  }
}

test_t0411_consume_arg_from_this_string_field() `test {
  s := StringSrc(content: "hello");
  s.send();
  // After consume, original must still own its content.
  assert(s.content == "hello", "orig content preserved");
}

// --- Channel field on a droppable owner ---

type ChHolder {
  channel[int] ch;
  drop(~this) {
  }

  clone() ChHolder {
    return ChHolder(ch: this.ch);
  }
}

test_t0411_clone_channel_field() `test {
  c := channel[int](1);
  c.send(42);
  h := ChHolder(ch: c);
  // h2 must hold an independent reference (incref) to the same channel.
  // Without dup, the channel ref-count stays the same and the second close
  // would underflow.
  h2 := h.clone();
  if v := <-h2.ch {
    assert(v == 42, "got value via clone");
  } else {
    assert(false, "expected value");
  }
}

// --- Map field on a droppable owner: explicit .clone() workaround ---
//
// Map[K, V] is not in isAutoDupType — sema rejects bare `Type(headers: this.headers)`
// with B0341. The user must call .clone() explicitly. This was the pattern that
// surfaced T0411 via modules/http/http.pr's response_headers getter.

type MapHolder {
  map[string, string] headers;
  drop(~this) {
  }

  clone() MapHolder {
    return MapHolder(headers: this.headers.clone());
  }
}

test_t0411_explicit_clone_for_map_field() `test {
  m := map[string, string]();
  m["a"] = "1";
  m["b"] = "2";
  h := MapHolder(headers: m);
  h2 := h.clone();
  // Both must own independent maps with the same contents.
  if a := h2.headers["a"] {
    assert(a == "1", "h2 a");
  }
  if a := h.headers["a"] {
    assert(a == "1", "h a");
  }
}

// --- Generic owner type with auto-dup field ---
//
// Verifies that maybeEnableDupForConstructorArg's c.typeSubst path works:
// the owner type is a monomorphized generic, the field type substitutes
// through TypeParam to a concrete auto-dup type.

type GenericStringHolder[T] {
  string label;
  T payload;
  drop(~this) {
  }

  clone() GenericStringHolder[T] {
    return GenericStringHolder[T](label: this.label, payload: this.payload);
  }
}

test_t0411_generic_owner_string_field_clone() `test {
  h := GenericStringHolder[int](label: "x" + "y", payload: 7);
  h2 := h.clone();
  assert(h.label == "xy", "orig label");
  assert(h2.label == "xy", "clone label");
  assert(h.payload == 7, "orig payload");
  assert(h2.payload == 7, "clone payload");
}

// --- Explicit `&this` receiver auto-dup (T0413) ---
//
// T0411's auto-dup fires whenever the owner has drop, regardless of
// whether the receiver is implicit (`clone()`) or explicit (`copy(&this)`).
// This locks the explicit-receiver path so a future change to receiver-kind
// handling doesn't silently regress field-init dup.
type _T0413Box {
  string label;
  drop(~this) {
  }

  copy(&this) _T0413Box {
    return _T0413Box(label: this.label);
  }
}

test_t0413_explicit_borrow_string_field() `test {
  b := _T0413Box(label: "a" + "b");
  c := b.copy();
  assert(c.label == "ab", "c.label");
  assert(b.label == "ab", "b.label still readable");
}

// --- Explicit `~this` (consume-self) receiver auto-dup (T0413) ---
//
// `~this` consumes the receiver — the synth drop runs at end of method,
// freeing `this.label`. Without dup, the new instance's `label` would alias
// the freed buffer and double-free at caller drop time. `genThisExpr` takes
// a different path when `thisRecvIsOwned=true` (T0428 Case 3A), so this is
// a structurally distinct codegen path from `&this`.
type _T0413ConsumeBox {
  string label;
  drop(~this) {
  }

  to_owned(~this) _T0413ConsumeBox {
    return _T0413ConsumeBox(label: this.label);
  }
}

test_t0413_consume_recv_string_field() `test {
  b := _T0413ConsumeBox(label: "p" + "q");
  b2 := b.to_owned();
  assert(b2.label == "pq", "b2.label after consume-recv");
}

// --- T0487: Optional[Vector|Channel|Arc|Weak] field on a droppable owner ---
//
// Pre-fix: `Type(items: this.items)`, `v := h.items`, `return this.items`,
// and `f(h.items)` for an `Optional[Vector|Channel|Arc|Weak]` field on a
// droppable owner shallow-copied the inner pointer. Both the original `this`
// and the new instance dropped the same buffer → segfault.
//
// Tests use heap-allocated vectors (built via `int[]() + .push`, not
// `[1,2,3]` literals) so any double-free actually crashes — `.rodata`-backed
// static vectors silently no-op on `Vector.drop`.

type _T0487OptVecHolder {
  int[]? items;
  drop(~this) {
  }

  clone() _T0487OptVecHolder {
    return _T0487OptVecHolder(items: this.items);
  }

  take_items() int[]? {
    return this.items;
  }
}

_t0487_make_dynamic_vec() int[] {
  v := int[]();
  for i := 0; i < 100; i++ {
    v.push(i);
  }
  return v;
}

test_t0487_clone_optional_vector_field_constructor_init() `test {
  // `Type(items: this.items)` — the maybeEnableDupForConstructorArg path.
  h := _T0487OptVecHolder(items: _t0487_make_dynamic_vec());
  h2 := h.clone();
  if v := h2.items {
    assert(v.len == 100, "clone len");
    assert(v[0] == 0, "clone[0]");
    assert(v[99] == 99, "clone[99]");
  } else {
    assert(false, "clone should have value");
  }
  // Independence: original still has its own buffer.
  if v := h.items {
    assert(v.len == 100, "orig len");
    assert(v[50] == 50, "orig[50]");
  } else {
    assert(false, "orig should still have value");
  }
}

test_t0487_clone_optional_vector_field_inferred_decl() `test {
  // `v := h.items` — the genInferredVarDecl path.
  h := _T0487OptVecHolder(items: _t0487_make_dynamic_vec());
  vopt := h.items;
  if v := vopt {
    assert(v.len == 100, "inferred decl len");
    assert(v[7] == 7, "inferred decl[7]");
  } else {
    assert(false, "inferred decl should have value");
  }
  // Original must still be readable.
  if v := h.items {
    assert(v.len == 100, "orig len after inferred decl");
  } else {
    assert(false, "orig should still have value");
  }
}

test_t0487_optional_vector_field_typed_decl() `test {
  // `int[]? v = h.items` — the genTypedVarDecl path (gold standard;
  // included for parity so the entire matrix is exercised in one file).
  h := _T0487OptVecHolder(items: _t0487_make_dynamic_vec());
  int[]? vopt = h.items;
  if v := vopt {
    assert(v.len == 100, "typed decl len");
  } else {
    assert(false, "typed decl should have value");
  }
}

test_t0487_optional_vector_field_return() `test {
  // `return this.items` — the genReturnStmt path.
  h := _T0487OptVecHolder(items: _t0487_make_dynamic_vec());
  ropt := h.take_items();
  if v := ropt {
    assert(v.len == 100, "return len");
    assert(v[42] == 42, "return[42]");
  } else {
    assert(false, "return should have value");
  }
  // Original still owns its own buffer.
  if v := h.items {
    assert(v.len == 100, "orig len after return");
  } else {
    assert(false, "orig should still have value");
  }
}

type _T0487OptVecHolder2 {
  int[]? primary;
  int[]? secondary;
  drop(~this) {
  }
}

test_t0487_optional_vector_field_block_result() `test {
  // Block-result expression path (stmt.go:262-272). The if-expression's last
  // statement in each arm is a field read of an Optional[Vector] — both arms
  // must be dup'd because the if's value is bound into a new variable.
  // (Two field-read arms used instead of `if/none` to dodge an unrelated
  // pre-existing block-result/none codegen mismatch.)
  h := _T0487OptVecHolder2(primary: _t0487_make_dynamic_vec(),
  secondary: _t0487_make_dynamic_vec());
  flag := true;
  vopt := if flag {
    h.primary
  } else {
    h.secondary
  };
  if v := vopt {
    assert(v.len == 100, "block result len");
    assert(v[10] == 10, "block result[10]");
  } else {
    assert(false, "block result should have value");
  }
  // Original still readable.
  if v := h.primary {
    assert(v.len == 100, "orig primary len after block result");
  } else {
    assert(false, "orig primary should still have value");
  }
}

_t0487_consume_optional_vec(~int[]? v) `public {
  // No-op — just consume.
  if x := v {
    assert(x.len == 100, "consumed len");
  }
}

test_t0487_optional_vector_field_consume_arg() `test {
  // `f(h.items)` with `~T?` param — the maybeEnableDupForMutRefArg path.
  h := _T0487OptVecHolder(items: _t0487_make_dynamic_vec());
  _t0487_consume_optional_vec(h.items);
  // After consume, original must still own its buffer.
  if v := h.items {
    assert(v.len == 100, "orig len after consume");
    assert(v[3] == 3, "orig[3] after consume");
  } else {
    assert(false, "orig should still have value");
  }
}

// --- T0487: Optional[Channel] field on a droppable owner ---

type _T0487OptChHolder {
  channel[int]? ch;
  drop(~this) {
  }

  clone() _T0487OptChHolder {
    return _T0487OptChHolder(ch: this.ch);
  }
}

test_t0487_clone_optional_channel_field_constructor() `test {
  c := channel[int](1);
  c.send(42);
  h := _T0487OptChHolder(ch: c);
  h2 := h.clone();
  // Both must hold independent refcounts to the same channel.
  if ch := h2.ch {
    if v := <-ch {
      assert(v == 42, "got value via clone");
    } else {
      assert(false, "expected value");
    }
  } else {
    assert(false, "clone should have channel");
  }
}

// --- T0487: Optional[string] consume-arg path ---
//
// Pre-fix, `maybeEnableDupForMutRefArg` set the dup flag for direct `string`
// but not `Optional[string]`. After T0487's helper switch, the Optional[string]
// consume-arg case is also covered. Verifies no double-free / no leak.

type _T0487OptStrHolder {
  string? title;
  drop(~this) {
  }
}

_t0487_consume_opt_string(~string? s) `public {
  // No-op — just consume.
  if x := s {
    assert(x == "foobar", "consumed");
  } else {
    assert(false, "consumed value should be some");
  }
}

test_t0487_optional_string_field_consume_arg() `test {
  // Heap-allocated string via concat (literal would be .rodata-flagged).
  h := _T0487OptStrHolder(title: "foo" + "bar");
  _t0487_consume_opt_string(h.title);
  // Original still owns its string.
  if x := h.title {
    assert(x == "foobar", "orig after consume");
  } else {
    assert(false, "orig should still have value");
  }
}

// (Optional[Arc] / Optional[Weak] field moves are gated by sema's B0341 —
// `isAutoDupType` only auto-dups string, Vector, Channel, and Optional of
// those. Arc/Weak require explicit `.clone()`, so the codegen dup-flag path
// for Optional[Arc|Weak] can only be reached via generics; not exercised
// here because Vector + Channel already cover the 5 broken codegen sites.)

// --- T0500: `this._arc/_weak.clone()/downgrade()/upgrade()` no double-incref ---
//
// Field-read of an Arc/Weak field on a droppable owner immediately consumed by
// .clone()/.downgrade() (or .upgrade()) was incrementing the refcount twice
// (once from the field-read dup, once from the method body) while the caller
// only registered one matching drop. The fix suppresses the receiver dup
// inside genArcMethodCall / genWeakMethodCall — the method body's own atomic
// increment provides the caller's owning reference.

type _T0500WBox {
  Weak[int] _weak;
  drop(~this) {
  }

  fresh_method() Weak[int] {
    return this._weak.clone();
  }
}

test_t0500_weak_field_method_clone() `test {
  a := Arc[int](42);
  w := _T0500WBox(_weak: a.downgrade());
  fresh := w.fresh_method();
  // Original Arc still readable; cloned Weak independently tracked.
  if up := fresh.upgrade() {
    assert(up.borrow == 42, "fresh upgrade value");
  } else {
    assert(false, "fresh should upgrade");
  }
  assert(a.borrow == 42, "orig Arc still readable");
}

type _T0500ABox {
  Arc[int] _arc;
  drop(~this) {
  }

  clone_method() Arc[int] {
    return this._arc.clone();
  }

  get downgrade_arrow Weak[int] => this._arc.downgrade();

  downgrade_method() Weak[int] {
    return this._arc.downgrade();
  }
}

test_t0500_arc_field_method_clone() `test {
  b := _T0500ABox(_arc: Arc[int](7));
  c := b.clone_method();
  assert(c.borrow == 7, "clone value");
  assert(b._arc.borrow == 7, "orig still readable");
}

test_t0500_arc_field_downgrade_getter_arrow() `test {
  // Matches the original bug repro — getter result discarded as stmt.
  // Pre-fix: LEAK 1 (weak count never decremented).
  b := _T0500ABox(_arc: Arc[int](11));
  b.downgrade_arrow;
}

test_t0500_arc_field_downgrade_getter_arrow_chain() `test {
  // Chain through to .upgrade() — intermediate getter is not bound to a
  // name so the move-check doesn't fire, but the dup-then-clone bug would
  // still leak via the chain.
  b := _T0500ABox(_arc: Arc[int](11));
  if up := b.downgrade_arrow.upgrade() {
    assert(up.borrow == 11, "arrow downgrade chain upgrade");
  } else {
    assert(false, "arrow downgrade should upgrade");
  }
}

test_t0500_arc_field_downgrade_method() `test {
  b := _T0500ABox(_arc: Arc[int](13));
  w := b.downgrade_method();
  if up := w.upgrade() {
    assert(up.borrow == 13, "method downgrade upgrade");
  } else {
    assert(false, "method downgrade should upgrade");
  }
}

type _T0500UBox {
  Weak[int] _weak;
  drop(~this) {
  }

  upgrade_method() Arc[int]? {
    return this._weak.upgrade();
  }
}

test_t0500_weak_field_upgrade_method() `test {
  // Regression-only: pre-fix this was already balanced (weak +1 dup, weak -1
  // stmt-end; conditional strong +1 from upgrade body, -1 from caller). But
  // the dup is now suppressed; verify result is still correct.
  a := Arc[int](19);
  w := _T0500UBox(_weak: a.downgrade());
  up := w.upgrade_method();
  if arc := up {
    assert(arc.borrow == 19, "upgrade value");
  } else {
    assert(false, "upgrade should succeed while a alive");
  }
}

type _T0500GenBox[T] {
  Weak[T] _weak;
  drop(~this) {
  }

  fresh_clone() Weak[T] {
    return this._weak.clone();
  }
}

test_t0500_generic_owner_weak_clone() `test {
  a := Arc[int](23);
  g := _T0500GenBox[int](_weak: a.downgrade());
  w := g.fresh_clone();
  if up := w.upgrade() {
    assert(up.borrow == 23, "generic fresh upgrade");
  } else {
    assert(false, "generic fresh should upgrade");
  }
  assert(a.borrow == 23, "generic orig Arc still readable");
}

// --- T0500 receiver-shape and outer-context coverage ---
//
// The fix in genArcMethodCall / genWeakMethodCall suppresses the receiver
// field-read dup regardless of how the receiver is reached. The original
// tests only exercise `this._arc.clone()` patterns inside method bodies.
//
// These additional tests cover two dimensions:
//   1. Non-`this` receivers — `local._arc.clone()` and `this.inner._arc.clone()`.
//      Verified to leak pre-fix (var-decl + nested-field tests).
//   2. Other outer contexts — constructor field-init and consume-arg.
//      maybeEnableDupForConstructorArg and maybeEnableDupForMutRefArg only
//      fire for MemberExpr args, not CallExpr args like `.clone()`, so these
//      paths don't activate dupContainerFieldAccess at all. The tests below
//      lock in that property — if a future change extends these helpers to
//      CallExpr args, the fix needs to remain effective.

type _T0500AWBox {
  Arc[int] _arc;
  Weak[int] _weak;
  drop(~this) {
  }
}

test_t0500_external_arc_clone_var_decl() `test {
  // `local._arc.clone()` from external code as inferred var-decl RHS.
  a := Arc[int](51);
  b := _T0500AWBox(_arc: a.clone(), _weak: a.downgrade());
  c := b._arc.clone();
  assert(c.borrow == 51, "external arc clone");
  assert(b._arc.borrow == 51, "orig still readable");
}

test_t0500_external_weak_clone_var_decl() `test {
  a := Arc[int](53);
  b := _T0500AWBox(_arc: a.clone(), _weak: a.downgrade());
  w := b._weak.clone();
  if up := w.upgrade() {
    assert(up.borrow == 53, "external weak clone upgrade");
  } else {
    assert(false, "weak clone should upgrade");
  }
}

test_t0500_external_arc_downgrade_var_decl() `test {
  a := Arc[int](57);
  b := _T0500AWBox(_arc: a.clone(), _weak: a.downgrade());
  w := b._arc.downgrade();
  if up := w.upgrade() {
    assert(up.borrow == 57, "external downgrade upgrade");
  } else {
    assert(false, "downgrade should upgrade");
  }
}

test_t0500_external_weak_upgrade_var_decl() `test {
  a := Arc[int](59);
  b := _T0500AWBox(_arc: a.clone(), _weak: a.downgrade());
  up := b._weak.upgrade();
  if c := up {
    assert(c.borrow == 59, "external upgrade");
  } else {
    assert(false, "external upgrade should succeed");
  }
}

_t0500_consume_arc(~Arc[int] a) `public {
  assert(a.borrow == 61, "consumed arc value");
}

_t0500_consume_weak(~Weak[int] w) `public {
  if up := w.upgrade() {
    assert(up.borrow == 61, "consumed weak upgraded");
  } else {
    assert(false, "consumed weak should upgrade");
  }
}

test_t0500_external_arc_clone_consume_arg() `test {
  // `consume(local._arc.clone())` — dup flag set by maybeEnableDupForMutRefArg's
  // setDupFlagsForFieldAccess(paramType=Arc[int]) call.
  a := Arc[int](61);
  b := _T0500AWBox(_arc: a.clone(), _weak: a.downgrade());
  _t0500_consume_arc(b._arc.clone());
  assert(b._arc.borrow == 61, "orig still readable after consume");
}

test_t0500_external_weak_clone_consume_arg() `test {
  a := Arc[int](61);
  b := _T0500AWBox(_arc: a.clone(), _weak: a.downgrade());
  _t0500_consume_weak(b._weak.clone());
  // Original is still tracking its handle.
  if up := b._weak.upgrade() {
    assert(up.borrow == 61, "orig weak still readable");
  } else {
    assert(false, "orig weak should upgrade");
  }
}

type _T0500Holder {
  Arc[int] a;
  Weak[int] w;
  drop(~this) {
  }
}

test_t0500_external_arc_clone_constructor_init() `test {
  // Constructor field-init from external field-method-call —
  // dup flag set by maybeEnableDupForConstructorArg.
  arc := Arc[int](67);
  b := _T0500AWBox(_arc: arc.clone(), _weak: arc.downgrade());
  h := _T0500Holder(a: b._arc.clone(), w: b._weak.clone());
  assert(h.a.borrow == 67, "holder arc");
  if up := h.w.upgrade() {
    assert(up.borrow == 67, "holder weak");
  } else {
    assert(false, "holder weak should upgrade");
  }
}

type _T0500Inner {
  Arc[int] _arc;
  Weak[int] _weak;
  drop(~this) {
  }
}

type _T0500Outer {
  _T0500Inner inner;
  drop(~this) {
  }

  // Nested receiver shape: `this.inner._arc.clone()` — the dup-flag
  // suppression must protect deep field-reads, not just `this.field`.
  nested_arc_clone() Arc[int] {
    return this.inner._arc.clone();
  }

  nested_weak_clone() Weak[int] {
    return this.inner._weak.clone();
  }

  nested_arc_downgrade() Weak[int] {
    return this.inner._arc.downgrade();
  }
}

test_t0500_nested_field_arc_clone() `test {
  a := Arc[int](71);
  o := _T0500Outer(inner: _T0500Inner(_arc: a.clone(), _weak: a.downgrade()));
  c := o.nested_arc_clone();
  assert(c.borrow == 71, "nested arc clone");
}

test_t0500_nested_field_weak_clone() `test {
  a := Arc[int](73);
  o := _T0500Outer(inner: _T0500Inner(_arc: a.clone(), _weak: a.downgrade()));
  w := o.nested_weak_clone();
  if up := w.upgrade() {
    assert(up.borrow == 73, "nested weak clone");
  } else {
    assert(false, "nested weak should upgrade");
  }
}

test_t0500_nested_field_arc_downgrade() `test {
  a := Arc[int](79);
  o := _T0500Outer(inner: _T0500Inner(_arc: a.clone(), _weak: a.downgrade()));
  w := o.nested_arc_downgrade();
  if up := w.upgrade() {
    assert(up.borrow == 79, "nested arc downgrade");
  } else {
    assert(false, "nested downgrade should upgrade");
  }
}

// --- T0498: Multi-field constructors with Optional[X] field-reads ---
// Per-field claim of optionalStringDup / optionalContainerDup. Without
// the fix, the constructor's last arg overwrites the signal, earlier
// arg's dup is never claimed, cleanupStmtTemps frees it, the new
// instance's earlier fields point at freed memory.

type _T0498StrHolder {
  string? a;
  string? b;
  drop(~this) {
  }
  swap_strs() _T0498StrHolder {
    return _T0498StrHolder(a: this.b, b: this.a);
  }
}

test_t0498_multi_optional_string_field_constructor() `test {
  // Heap-allocated strings (concat) defeat .rodata static-flag silencing.
  h := _T0498StrHolder(a: "x" + "1", b: "y" + "2");
  h2 := h.swap_strs();
  if s := h2.a {
    assert(s == "y2", "swapped a");
  } else {
    assert(false, "h2.a should have value");
  }
  if s := h2.b {
    assert(s == "x1", "swapped b");
  } else {
    assert(false, "h2.b should have value");
  }
}

type _T0498RowHolder {
  int[]? row1;
  int[]? row2;
  drop(~this) {
  }
  swap_rows() _T0498RowHolder {
    return _T0498RowHolder(row1: this.row2, row2: this.row1);
  }
}

_t0498_mkv(int seed) int[] {
  v := int[]();
  for i := 0; i < 100; i++ {
    v.push(i + seed);
  }
  return v;
}

test_t0498_multi_optional_vector_field_constructor() `test {
  // Heap vectors (via push loop) defeat .rodata static-flag silencing.
  h := _T0498RowHolder(row1: _t0498_mkv(0), row2: _t0498_mkv(1000));
  h2 := h.swap_rows();
  if v := h2.row1 {
    assert(v.len == 100, "row1 len");
    assert(v[0] == 1000, "row1[0] (was row2)");
    assert(v[50] == 1050, "row1[50]");
  } else {
    assert(false, "h2.row1 should have value");
  }
  if v := h2.row2 {
    assert(v.len == 100, "row2 len");
    assert(v[0] == 0, "row2[0] (was row1)");
  } else {
    assert(false, "h2.row2 should have value");
  }
}

// Multi-field Optional[Channel]: covers the dupChannel branch in genFieldAccess
// (expr.go:4048). Without the per-arg claim, the second field's genFieldAccess
// would overwrite the first channel's optionalContainerDup → use-after-free in
// the first field of the new instance.
type _T0498ChHolder {
  channel[int]? ch_a;
  channel[int]? ch_b;
  drop(~this) {
  }
  swap_channels() _T0498ChHolder {
    return _T0498ChHolder(ch_a: this.ch_b, ch_b: this.ch_a);
  }
}

test_t0498_multi_optional_channel_field_constructor() `test {
  ca := channel[int](1);
  ca.send(11);
  cb := channel[int](1);
  cb.send(22);
  h := _T0498ChHolder(ch_a: ca, ch_b: cb);
  h2 := h.swap_channels();
  // The new instance's ch_a should receive cb's value (22) and ch_b should
  // receive ca's value (11). Both channels must hold valid refcounts.
  if ch := h2.ch_a {
    if v := <-ch {
      assert(v == 22, "swapped ch_a got cb value");
    } else {
      assert(false, "ch_a recv should produce value");
    }
  } else {
    assert(false, "h2.ch_a should have value");
  }
  if ch := h2.ch_b {
    if v := <-ch {
      assert(v == 11, "swapped ch_b got ca value");
    } else {
      assert(false, "ch_b recv should produce value");
    }
  } else {
    assert(false, "h2.ch_b should have value");
  }
}

// Mixed Optional[string] + Optional[Vector] in same constructor: confirms the
// per-arg claim handles two distinct signals (optionalStringDup and
// optionalContainerDup) in alternating iterations without overwrite.
type _T0498MixedHolder {
  string? name;
  int[]? data;
  drop(~this) {
  }
  rebuild() _T0498MixedHolder {
    return _T0498MixedHolder(name: this.name, data: this.data);
  }
}

test_t0498_mixed_optional_string_and_vector_constructor() `test {
  // Heap-allocated values for both fields defeat .rodata static-flag silencing.
  h := _T0498MixedHolder(name: "hello" + "-world", data: _t0498_mkv(500));
  h2 := h.rebuild();
  if s := h2.name {
    assert(s == "hello-world", "rebuilt name");
  } else {
    assert(false, "h2.name should have value");
  }
  if v := h2.data {
    assert(v.len == 100, "rebuilt data len");
    assert(v[0] == 500, "rebuilt data[0]");
    assert(v[99] == 599, "rebuilt data[99]");
  } else {
    assert(false, "h2.data should have value");
  }
  // Original still owns its independent copies.
  if s := h.name {
    assert(s == "hello-world", "original name still valid");
  } else {
    assert(false, "h.name should still have value");
  }
}
