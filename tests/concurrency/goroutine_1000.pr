// Stress test: 1000 goroutines each send 1 to a shared channel.
// Tests scheduler scalability with high goroutine count.
main() `test(expected: "1000") {
  ch := channel[int](capacity: 1000);
  for idx in 0..1000 {
    go {
      ch.send(1);
    };
  }
  int sum = 0;
  for j in 0..1000 {
    r := <-ch;
    if v := r {
      sum = sum + v;
    }
  }
  print_line(sum);
}
