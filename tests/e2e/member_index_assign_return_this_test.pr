// T0898: T0890 closed the receiver-alias-clear / drop-on-overwrite gap for the
// IdentExpr-LHS assignment path (`m = a.dup()`). The MemberExpr-LHS
// (`obj.field = ...`) and IndexExpr-LHS (`arr[i] = ...`) shapes flow through
// genMemberAssign / genVectorIndexAssign, which had NO no-drop heap user-type
// drop-on-overwrite and NO dup-on-read for the matching var-decl path.
//
// For a no-drop heap user type (only methods like dup()/+, no drop()), the
// observed defect is a LEAK of the overwritten old value: `obj.field = X` /
// `arr[i] = X` stored the new pointer without freeing the field/element's
// previous instance. T0898 was filed describing the return-this case
// (`h.f = a.dup()`, dup returns `this`) as a double-free, but T0893's
// clone-on-`return this` makes a borrowing method's result an independent heap
// copy — so the result never aliases `a`, and the manifestation is the same
// leak (old value not dropped), not a double-free. The drop-on-overwrite below
// is paired with dup-on-read in genVectorIndex so the swap idiom
// (`t := v[lo]; v[lo] = v[mid]; v[mid] = t`) stays alias-free. These tests
// exercise both LHS shapes on the zero-leak gate (which, via the always-on
// debug allocator, also aborts on any double-free).
// A heap user type with a method that returns the borrowed receiver.
type BB `doc("Heap user type whose dup() returns the borrowed receiver.") {
  int v;
  dup() BB {
    return this;
  }
}

// A heap user type with a binary operator that returns the borrowed receiver.
type CC `doc("Heap user type whose + operator returns the borrowed receiver.") {
  int v;
  +(CC o) CC {
    return this;
  }
}

// A heap user type whose only method allocates a fresh instance (no return-this).
type FF `doc("Heap user type whose fresh() allocates a new instance.") {
  int v;
  fresh() FF {
    return FF(v: 99);
  }
}

// Holds a no-drop heap user-type field.
type Holder `doc("Container with a no-drop heap user-type field.") {
  BB f;
}

// MemberExpr LHS, return-this method (the filed repro). h.f aliases `a` after the
// dup; without the alias-clear both free the same instance → double-free.
member_assign_method_return_this() `test {
  a := BB(v: 11);
  h := Holder(f: BB(v: 0));
  h.f = a.dup();
  assert(h.f.v == 11, "member assign return-this method result");
}

// IndexExpr LHS, return-this operator (the filed repro).
index_assign_operator_return_this() `test {
  a := CC(v: 11);
  b := CC(v: 3);
  arr := [CC(v: 0)];
  arr[0] = a + b;
  assert(arr[0].v == 11, "index assign return-this operator result");
}

// MemberExpr LHS, fresh value — the old field value must STILL be dropped (no
// alias), and the new value owned once. The zero-leak gate catches a leak of the
// overwritten field.
member_assign_fresh_value() `test {
  f := FF(v: 1);
  h := Holder(f: BB(v: 7));
  // Overwrite the field with a fresh instance; old BB(v: 7) must be freed.
  h.f = BB(v: 42);
  assert(h.f.v == 42, "member assign fresh-value result");
  assert(f.v == 1, "fresh-value operand untouched");
}

// IndexExpr LHS, fresh value — old element must be freed, not leaked.
index_assign_fresh_value() `test {
  arr := [BB(v: 5)];
  arr[0] = BB(v: 50);
  assert(arr[0].v == 50, "index assign fresh-value result");
}

// The regression the investigation hit: a no-drop heap element swap. `t := v[0]`
// must dup-on-read so the drop-on-overwrite at `v[0] = v[2]` does not free a slot
// still aliased by t, and `v[2] = t` then stores t's independent copy.
index_swap_no_drop_heap() `test {
  v := [BB(v: 1), BB(v: 2), BB(v: 3)];
  t := v[0];
  v[0] = v[2];
  v[2] = t;
  assert(v[0].v == 3, "swap moved element 2 into slot 0");
  assert(v[2].v == 1, "swap moved element 0 into slot 2");
  assert(v[1].v == 2, "swap left middle element untouched");
}

// Read-after-overwrite via a local: `t := v[0]` then overwrite slot 0. t must
// retain the original value (independent copy), not observe the new one.
index_read_then_overwrite() `test {
  v := [BB(v: 7), BB(v: 8)];
  t := v[0];
  v[0] = BB(v: 70);
  assert(t.v == 7, "local copy retains original after overwrite");
  assert(v[0].v == 70, "slot holds the new value after overwrite");
}

// Holds a no-drop heap user-type field whose method is a binary operator.
type HolderC `doc("Container with a no-drop heap user-type field (operator type).") {
  CC f;
}

// Nests a Holder so the assignment target is a chained member (`o.h.f`).
type Outer `doc("Container nesting a Holder for chained-member assignment tests.") {
  Holder h;
}

// MemberExpr LHS, return-this OPERATOR (the existing member test uses a method;
// this exercises the same genMemberAssign drop-on-overwrite via the operator
// shape — the operand-clear is LHS-shape-agnostic but the return-this expression
// kind differs).
member_assign_operator_return_this() `test {
  a := CC(v: 11);
  b := CC(v: 3);
  h := HolderC(f: CC(v: 0));
  h.f = a + b;
  assert(h.f.v == 11, "member assign return-this operator result");
}

// IndexExpr LHS, return-this METHOD (the existing index test uses an operator;
// this exercises genVectorIndexAssign drop-on-overwrite via the method shape).
index_assign_method_return_this() `test {
  a := BB(v: 11);
  arr := [BB(v: 0)];
  arr[0] = a.dup();
  assert(arr[0].v == 11, "index assign return-this method result");
}

// Chained MemberExpr LHS (`o.h.f = ...`): the assignment target's object is
// itself a member access. The innermost field still takes the no-drop
// drop-on-overwrite; the old BB(v: 0) must be freed exactly once.
nested_member_assign_return_this() `test {
  a := BB(v: 9);
  o := Outer(h: Holder(f: BB(v: 0)));
  o.h.f = a.dup();
  assert(o.h.f.v == 9, "nested member assign return-this result");
}

// IndexExpr-object + MemberExpr LHS (`hs[0].f = ...`): the target object is a
// vector index. Combines the index-read and member-assign paths; the field's
// old value must be freed once and the cloned result owned once.
vector_element_member_assign_return_this() `test {
  a := BB(v: 7);
  hs := [Holder(f: BB(v: 0))];
  hs[0].f = a.dup();
  assert(hs[0].f.v == 7, "vector element member assign return-this result");
}

// Same IndexExpr-object + MemberExpr LHS shape with a fresh (non-aliasing)
// value: the old field value must STILL be dropped (zero-leak gate).
vector_element_member_assign_fresh_value() `test {
  hs := [Holder(f: BB(v: 1))];
  hs[0].f = BB(v: 2);
  assert(hs[0].f.v == 2, "vector element member assign fresh-value result");
}
