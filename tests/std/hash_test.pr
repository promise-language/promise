// hash_test.pr — Tests for FNV-1a hash implementation

test_int_hash_deterministic() `test {
    int x = 42;
    assert(x.hash == x.hash, "same value same hash");
    int y = 42;
    assert(x.hash == y.hash, "equal values equal hash");
}

test_int_hash_different_values() `test {
    int a = 0;
    int b = 1;
    assert(a.hash != b.hash, "0 vs 1");
    int c = 100;
    assert(a.hash != c.hash, "0 vs 100");
    assert(b.hash != c.hash, "1 vs 100");
}

test_uint_hash() `test {
    uint x = 42;
    uint y = 42;
    assert(x.hash == y.hash, "equal uint same hash");
    uint z = 99;
    assert(x.hash != z.hash, "different uint different hash");
}

test_bool_hash() `test {
    bool t = true;
    bool f = false;
    assert(t.hash == t.hash, "true deterministic");
    assert(f.hash == f.hash, "false deterministic");
    assert(t.hash != f.hash, "true vs false");
}

test_char_hash() `test {
    char a = 'a';
    char b = 'b';
    assert(a.hash == a.hash, "char deterministic");
    assert(a.hash != b.hash, "a vs b");
}

test_string_hash() `test {
    string s = "hello";
    string t = "hello";
    assert(s.hash == t.hash, "equal strings same hash");
    string u = "world";
    assert(s.hash != u.hash, "different strings different hash");
}

test_hash_as_map_key() `test {
    // Verifies hash works end-to-end with map lookups
    map[int, int] m = {:};
    m[1] = 10;
    m[2] = 20;
    m[42] = 420;
    if v1 := m[1] { assert(v1 == 10, "m[1]"); } else { assert(false, "m[1] missing"); }
    if v2 := m[2] { assert(v2 == 20, "m[2]"); } else { assert(false, "m[2] missing"); }
    if v3 := m[42] { assert(v3 == 420, "m[42]"); } else { assert(false, "m[42] missing"); }
}

test_hash_zero() `test {
    int z = 0;
    // Hash of zero should be a valid non-zero hash (FNV-1a property)
    assert(z.hash != 0, "hash of 0 is non-zero");
}

test_negative_int_hash() `test {
    int neg = -1;
    int pos = 1;
    assert(neg.hash != pos.hash, "-1 vs 1");
    assert(neg.hash == neg.hash, "-1 deterministic");
}

test_large_values() `test {
    // Max/min boundaries should produce distinct hashes
    int big = 9223372036854775807;
    int small = -9223372036854775807;
    assert(big.hash != small.hash, "max vs min");
    assert(big.hash != 0.hash, "max vs 0");
    // Adjacent values should differ
    int a = 1000000;
    int b = 1000001;
    assert(a.hash != b.hash, "adjacent values");
}

test_expected_fnv1a_values() `test {
    // Pin exact FNV-1a 64-bit output to catch algorithmic drift
    assert(0.hash == -6284781860667377211, "fnv1a(0)");
    assert(1.hash == -8517097267634966620, "fnv1a(1)");
    assert(42.hash == -55488592825689361, "fnv1a(42)");
    int neg = -1;
    assert(neg.hash == -8289690350564177859, "fnv1a(-1)");
    int max_int = 9223372036854775807;
    assert(max_int.hash == -8289549613075766851, "fnv1a(max)");
}

test_float_hash_deterministic() `test {
    f64 x = 3.14;
    assert(x.hash == x.hash, "f64 deterministic");
    f64 y = 3.14;
    assert(x.hash == y.hash, "equal f64 same hash");
}

test_float_hash_different_values() `test {
    f64 a = 1.0;
    f64 b = 2.0;
    assert(a.hash != b.hash, "1.0 vs 2.0");
    f64 c = 0.0;
    assert(a.hash != c.hash, "1.0 vs 0.0");
}

test_float_hash_as_map_key() `test {
    map[f64, string] m = {:};
    m[1.5] = "one point five";
    m[2.5] = "two point five";
    if v1 := m[1.5] { assert(v1 == "one point five", "m[1.5]"); } else { assert(false, "m[1.5] missing"); }
    if v2 := m[2.5] { assert(v2 == "two point five", "m[2.5]"); } else { assert(false, "m[2.5] missing"); }
}

test_string_hash_deterministic() `test {
    string a = "hello";
    string b = "hello";
    assert(a.hash == b.hash, "equal strings same hash");
    assert(a.hash == a.hash, "string deterministic");
}

test_string_hash_different_values() `test {
    string a = "hello";
    string b = "world";
    string c = "hello!";
    assert(a.hash != b.hash, "hello vs world");
    assert(a.hash != c.hash, "hello vs hello!");
}

test_string_hash_empty() `test {
    string empty = "";
    // Empty string should have the FNV offset basis as hash (no bytes mixed in)
    assert(empty.hash != 0, "empty string hash non-zero");
    assert(empty.hash == empty.hash, "empty string deterministic");
}

test_expected_string_hash_values() `test {
    // Pin exact FNV-1a 64-bit output for known strings to catch algorithmic drift
    string empty = "";
    assert(empty.hash == -3750763034362895579, "fnv1a(\"\")");
    string hi = "hi";
    assert(hi.hash == 628919584683901914, "fnv1a(\"hi\")");
    string hello = "hello";
    assert(hello.hash == -6615550055289275125, "fnv1a(\"hello\")");
    string world = "world";
    assert(world.hash == 5717881983045765875, "fnv1a(\"world\")");
    string a = "a";
    assert(a.hash == -5808556873153909620, "fnv1a(\"a\")");
    string abc = "abc";
    assert(abc.hash == -1792535898324117685, "fnv1a(\"abc\")");
}

test_string_hash_as_map_key() `test {
    map[string, int] m = {:};
    m["foo"] = 1;
    m["bar"] = 2;
    m["baz"] = 3;
    if v1 := m["foo"] { assert(v1 == 1, "m[foo]"); } else { assert(false, "foo missing"); }
    if v2 := m["bar"] { assert(v2 == 2, "m[bar]"); } else { assert(false, "bar missing"); }
    if v3 := m["baz"] { assert(v3 == 3, "m[baz]"); } else { assert(false, "baz missing"); }
}
