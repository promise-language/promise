// Test f64 arithmetic, comparisons, and unary operators
//
test_arithmetic() `test {
  assert(1.0 + 2.0 == 3.0, "1.0 + 2.0 == 3.0");
  assert(5.0 - 3.0 == 2.0, "5.0 - 3.0 == 2.0");
  assert(2.5 * 4.0 == 10.0, "2.5 * 4.0 == 10.0");
  assert(10.0 / 4.0 == 2.5, "10.0 / 4.0 == 2.5");
}

test_comparisons() `test {
  assert(1.0 < 2.0, "1.0 < 2.0");
  assert(2.0 > 1.0, "2.0 > 1.0");
  assert(1.0 <= 1.0, "1.0 <= 1.0");
  assert(1.0 <= 2.0, "1.0 <= 2.0");
  assert(2.0 >= 2.0, "2.0 >= 2.0");
  assert(3.0 >= 1.0, "3.0 >= 1.0");
}

test_equality() `test {
  assert(3.14 == 3.14, "3.14 == 3.14");
  assert(1.0 != 2.0, "1.0 != 2.0");
  assert(!(1.0 == 2.0), "!(1.0 == 2.0)");
}

test_unary_negation() `test {
  f64 x = 3.5;
  assert(-x == 0.0 - 3.5, "-x == -3.5");
  assert(-(-x) == 3.5, "-(-x) == 3.5");
}

test_compound_assignment() `test {
  f64 x = 10.0;
  x += 2.5;
  assert(x == 12.5, "+= 2.5");
  x -= 1.5;
  assert(x == 11.0, "-= 1.5");
  x *= 2.0;
  assert(x == 22.0, "*= 2.0");
  x /= 4.0;
  assert(x == 5.5, "/= 4.0");
}

test_modulo() `test {
  assert(7.5 % 2.0 == 1.5, "7.5 % 2.0 == 1.5");
  assert(10.0 % 3.0 == 1.0, "10.0 % 3.0 == 1.0");
  assert(5.0 % 5.0 == 0.0, "5.0 % 5.0 == 0.0");
}

test_increment_decrement() `test {
  f64 x = 1.5;
  x++;
  assert(x == 2.5, "f64 x++ == 2.5");
  x--;
  assert(x == 1.5, "f64 x-- == 1.5");
}

// --- Hash ---

test_hash() `test {
  f64 a = 3.14;
  f64 b = 3.14;
  assert(a.hash == b.hash, "same f64 same hash");
  f64 c = 2.71;
  assert(a.hash != c.hash, "different f64 different hash");
  int h = a.hash;
  assert(h == b.hash, "hash via variable");
}

// --- f32 ---

f32_double(f32 x) f32 {
  return x * 2.0;
}

test_f32_basic() `test {
  f32 a = 1.5;
  assert(f32_double(a) == 3.0, "f32 double");
  f32 b = 0.0;
  assert(a > b, "f32 comparison");
  assert(a != b, "f32 inequality");
}

test_f32_arithmetic() `test {
  f32 a = 10.0;
  f32 b = 3.0;
  assert(a + b == 13.0, "f32 addition");
  assert(a - b == 7.0, "f32 subtraction");
  assert(a / b > 3.3, "f32 division");
}

// --- NaN / Infinity ---

test_f64_nan() `test {
  f64 n = f64.nan;
  assert(n.is_nan, "f64.nan is_nan");
  assert(!n.is_infinite, "NaN is not infinite");
  assert(!n.is_finite, "NaN is not finite");
}

test_f64_infinity() `test {
  f64 inf = f64.infinity;
  assert(inf.is_infinite, "f64.infinity is_infinite");
  assert(!inf.is_nan, "infinity is not NaN");
  assert(!inf.is_finite, "infinity is not finite");

  f64 neg_inf = -f64.infinity;
  assert(neg_inf.is_infinite, "negative infinity is_infinite");
  assert(!neg_inf.is_nan, "negative infinity is not NaN");
  assert(!neg_inf.is_finite, "negative infinity is not finite");
}

test_f64_finite() `test {
  assert((0.0).is_finite, "0.0 is finite");
  assert((1.0).is_finite, "1.0 is finite");
  assert((-3.14).is_finite, "-3.14 is finite");
  assert(f64.max.is_finite, "f64.max is finite");
  assert(f64.min.is_finite, "f64.min is finite");

  assert(!(0.0).is_nan, "0.0 is not NaN");
  assert(!(0.0).is_infinite, "0.0 is not infinite");
}

test_f32_nan() `test {
  f32 n = f32.nan;
  assert(n.is_nan, "f32.nan is_nan");
  assert(!n.is_infinite, "f32 NaN is not infinite");
  assert(!n.is_finite, "f32 NaN is not finite");
}

test_f32_infinity() `test {
  f32 inf = f32.infinity;
  assert(inf.is_infinite, "f32.infinity is_infinite");
  assert(!inf.is_nan, "f32 infinity is not NaN");
  assert(!inf.is_finite, "f32 infinity is not finite");

  f32 neg_inf = -f32.infinity;
  assert(neg_inf.is_infinite, "f32 negative infinity is_infinite");
  assert(!neg_inf.is_nan, "f32 negative infinity is not NaN");
  assert(!neg_inf.is_finite, "f32 negative infinity is not finite");
}

test_f32_finite() `test {
  f32 a = 1.5;
  assert(a.is_finite, "f32 1.5 is finite");
  assert(!a.is_nan, "f32 1.5 is not NaN");
  assert(!a.is_infinite, "f32 1.5 is not infinite");
}

test_f64_negative_zero() `test {
  f64 nz = -0.0;
  assert(nz.is_finite, "negative zero is finite");
  assert(!nz.is_nan, "negative zero is not NaN");
  assert(!nz.is_infinite, "negative zero is not infinite");
}

test_f64_arithmetic_special() `test {
  f64 inf = 1.0 / 0.0;
  assert(inf.is_infinite, "1.0/0.0 is infinite");
  f64 nan = 0.0 / 0.0;
  assert(nan.is_nan, "0.0/0.0 is NaN");
  f64 nan2 = f64.infinity - f64.infinity;
  assert(nan2.is_nan, "inf - inf is NaN");
}

test_f64_nan_comparison() `test {
  f64 n = f64.nan;
  assert(n != n, "NaN != NaN is true (IEEE 754)");
  assert(!(n == n), "NaN == NaN is false");
  assert(n != 1.0, "NaN != 1.0 is true");
  assert(!(n == 1.0), "NaN == 1.0 is false");
  assert(!(n < 1.0), "NaN < 1.0 is false");
  assert(!(n > 1.0), "NaN > 1.0 is false");
  assert(!(n <= 1.0), "NaN <= 1.0 is false");
  assert(!(n >= 1.0), "NaN >= 1.0 is false");
  // NaN vs NaN ordered comparisons all return false (degenerate IEEE 754 case)
  assert(!(n < n), "NaN < NaN is false");
  assert(!(n > n), "NaN > NaN is false");
  assert(!(n <= n), "NaN <= NaN is false");
  assert(!(n >= n), "NaN >= NaN is false");
  // NaN vs +/- infinity
  f64 inf = f64.infinity;
  assert(n != inf, "NaN != +inf is true");
  assert(!(n == inf), "NaN == +inf is false");
  assert(!(n < inf), "NaN < +inf is false");
  assert(!(n > -inf), "NaN > -inf is false");
}

test_f32_nan_comparison() `test {
  f32 n = f32.nan;
  assert(n != n, "f32 NaN != NaN is true (IEEE 754)");
  assert(!(n == n), "f32 NaN == NaN is false");
  assert(n != 1.0f32, "f32 NaN != 1.0 is true");
  assert(!(n == 1.0f32), "f32 NaN == 1.0 is false");
  // f32 ordered comparisons against NaN return false (parity with f64)
  assert(!(n < 1.0f32), "f32 NaN < 1.0 is false");
  assert(!(n > 1.0f32), "f32 NaN > 1.0 is false");
  assert(!(n <= 1.0f32), "f32 NaN <= 1.0 is false");
  assert(!(n >= 1.0f32), "f32 NaN >= 1.0 is false");
  assert(!(n < n), "f32 NaN < NaN is false");
  assert(!(n >= n), "f32 NaN >= NaN is false");
}

test_f64_nan_to_bool_cast() `test {
  // Float-to-bool cast uses fcmp une (non-zero is true; NaN is non-zero) — same
  // predicate as float `!=`, so casting NaN must yield true to stay consistent
  // with `n != 0.0`.
  f64 n = f64.nan;
  bool b = n as bool;
  assert(b, "NaN as bool is true");
  assert(n != 0.0, "consistency: NaN != 0.0 is true");
  // Sanity: zero casts to false, non-zero finite casts to true.
  assert(!((0.0) as bool), "0.0 as bool is false");
  assert((1.5) as bool, "1.5 as bool is true");
  // +/- infinity also non-zero.
  assert(f64.infinity as bool, "+inf as bool is true");
  assert((-f64.infinity) as bool, "-inf as bool is true");
}

test_f32_nan_to_bool_cast() `test {
  f32 n = f32.nan;
  bool b = n as bool;
  assert(b, "f32 NaN as bool is true");
  assert(!((0.0f32) as bool), "f32 0.0 as bool is false");
  assert((1.5f32) as bool, "f32 1.5 as bool is true");
}
