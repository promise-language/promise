// Test string operations: concat, equality, comparison, methods
test_concat() `test {
  assert("hello" + " " + "world" == "hello world", "string concat");
  assert("" + "a" == "a", "empty + a");
  assert("a" + "" == "a", "a + empty");
}

test_equality() `test {
  assert("hello" == "hello", "equal strings");
  assert(!("hello" == "world"), "different strings not equal");
  assert("hello" != "world", "!= different");
  assert(!("abc" != "abc"), "!= same");
  assert("" == "", "empty strings equal");
  assert("" != "a", "empty != non-empty");
}

test_len() `test {
  assert("hello".len == 5, "hello len 5");
  assert("".len == 0, "empty len 0");
  assert("ab".len == 2, "ab len 2");
}

test_is_empty() `test {
  assert("".is_empty, "empty is_empty");
  assert(!"hello".is_empty, "hello not is_empty");
}

test_contains() `test {
  assert("hello world".contains("world"), "contains world");
  assert("hello world".contains("hello"), "contains hello");
  assert(!"hello".contains("xyz"), "not contains xyz");
  assert("abc".contains(""), "contains empty");
  assert("abc".contains("abc"), "contains full string");
  assert(!"hi".contains("longer"), "sub longer than string");
}

test_starts_with() `test {
  assert("hello world".starts_with("hello"), "starts_with hello");
  assert(!"hello world".starts_with("world"), "not starts_with world");
  assert("abc".starts_with(""), "starts_with empty");
  assert("abc".starts_with("abc"), "starts_with full string");
  assert(!"hi".starts_with("hello"), "prefix longer than string");
}

test_ends_with() `test {
  assert("hello world".ends_with("world"), "ends_with world");
  assert(!"hello world".ends_with("hello"), "not ends_with hello");
  assert("abc".ends_with(""), "ends_with empty");
  assert("abc".ends_with("abc"), "ends_with full string");
  assert(!"hi".ends_with("hello"), "suffix longer than string");
}

test_index_of() `test {
  if idx := "hello world".index_of("world") {
    assert(idx == 6, "index_of world == 6");
  } else {
    assert(false, "should find world");
  }

  assert("hello".index_of("xyz") is absent, "index_of xyz not found");

  // Empty sub returns 0
  if idx2 := "hello".index_of("") {
    assert(idx2 == 0, "index_of empty == 0");
  } else {
    assert(false, "should find empty");
  }

  // Sub at position 0
  if idx3 := "hello".index_of("hel") {
    assert(idx3 == 0, "index_of at start == 0");
  } else {
    assert(false, "should find hel at start");
  }

  // Sub equals full string
  if idx4 := "abc".index_of("abc") {
    assert(idx4 == 0, "index_of full string == 0");
  } else {
    assert(false, "should find full string");
  }

  // Sub longer than string
  assert("hi".index_of("longer") is absent, "index_of sub longer than string");
}

test_trim() `test {
  assert("  hello  ".trim() == "hello", "trim spaces");
  assert("hello".trim() == "hello", "trim no-op");
  assert("   ".trim() == "", "trim all spaces");
}

test_split() `test {
  string[] parts = "a,b,c".split(",");
  assert(parts.len == 3, "split len 3");
  assert(parts[0] == "a", "split[0] == a");
  assert(parts[1] == "b", "split[1] == b");
  assert(parts[2] == "c", "split[2] == c");
}

test_indexing() `test {
  assert("hello"[0] == 'h', "s[0] == h");
  assert("hello"[1] == 'e', "s[1] == e");
  assert("hello"[4] == 'o', "s[4] == o");
  assert("abc"[2] == 'c', "abc[2] == c");

  string s = "world";
  assert(s[0] == 'w', "var s[0] == w");
  assert(s[4] == 'd', "var s[4] == d");

  // Variable index
  int i = 2;
  assert("abcde"[i] == 'c', "variable index");

  // Last byte of string
  string t = "xyz";
  assert(t[t.len - 1] == 'z', "last byte");
}

test_interpolation() `test {
  int x = 42;
  assert("{x}" == "42", "int interpolation");
  string name = "world";
  assert("hello {name}" == "hello world", "string interpolation");
  assert("{1 + 2}" == "3", "expr interpolation");
}

// --- Slicing ---

test_slice_range() `test {
  assert("hello world"[0:5] == "hello", "slice [0:5]");
  assert("hello world"[6:11] == "world", "slice [6:11]");
  assert("abcdef"[2:4] == "cd", "slice [2:4]");
}

test_slice_from_start() `test {
  assert("hello"[:3] == "hel", "slice [:3]");
  assert("hello"[:0] == "", "slice [:0] empty");
  assert("hello"[:5] == "hello", "slice [:5] full");
}

test_slice_to_end() `test {
  assert("hello"[3:] == "lo", "slice [3:]");
  assert("hello"[0:] == "hello", "slice [0:] full");
  assert("hello"[5:] == "", "slice [5:] empty");
}

test_slice_full() `test {
  assert("hello"[:] == "hello", "slice [:] full copy");
  assert(""[:] == "", "slice [:] empty string");
}

test_slice_empty() `test {
  assert("hello"[2:2] == "", "slice [2:2] empty");
  assert("hello"[0:0] == "", "slice [0:0] empty");
}

test_slice_single_char() `test {
  assert("hello"[1:2] == "e", "slice [1:2] single char");
}

test_slice_variable() `test {
  string s = "hello world";
  int start = 6;
  string sub = s[start:];
  assert(sub == "world", "slice with variable start");
}

// --- Hash ---

test_hash_consistent() `test {
  assert("hello".hash == "hello".hash, "same string same hash");
  assert("world".hash == "world".hash, "world hash consistent");
  assert("".hash == "".hash, "empty hash consistent");
}

test_hash_different() `test {
  assert("hello".hash != "world".hash, "different strings different hash");
  assert("abc".hash != "xyz".hash, "abc != xyz hash");
  assert("".hash != "hello".hash, "empty != hello hash");
}

test_hash_variable() `test {
  string s = "hello";
  int h = s.hash;
  assert(h == "hello".hash, "variable hash matches literal hash");
}

test_hash_type() `test {
  int h = "test".hash;
  assert(h == h, "hash is int");
}

// --- Comparison operators ---

test_less_than() `test {
  assert("apple" < "banana", "apple < banana");
  assert(!("banana" < "apple"), "not banana < apple");
  assert(!("abc" < "abc"), "not abc < abc (equal)");
  assert("a" < "ab", "prefix is less");
  assert("" < "a", "empty < non-empty");
  assert(!("a" < ""), "not a < empty");
}

test_greater_than() `test {
  assert("banana" > "apple", "banana > apple");
  assert(!("apple" > "banana"), "not apple > banana");
  assert(!("abc" > "abc"), "not abc > abc (equal)");
  assert("ab" > "a", "longer > prefix");
  assert("a" > "", "non-empty > empty");
}

test_less_equal() `test {
  assert("abc" <= "abc", "equal strings <=");
  assert("abc" <= "abd", "abc <= abd");
  assert("a" <= "ab", "prefix <=");
  assert(!("abd" <= "abc"), "not abd <= abc");
}

test_greater_equal() `test {
  assert("abc" >= "abc", "equal strings >=");
  assert("abd" >= "abc", "abd >= abc");
  assert("ab" >= "a", "longer >= prefix");
  assert(!("abc" >= "abd"), "not abc >= abd");
}

test_comparison_case_sensitive() `test {
  // ASCII: uppercase letters (65-90) come before lowercase (97-122)
  assert("A" < "a", "A < a (ASCII ordering)");
  assert("Z" < "a", "Z < a (ASCII ordering)");
  assert("hello" > "Hello", "hello > Hello");
}

// --- to_upper / to_lower ---

test_to_upper() `test {
  assert("hello".to_upper() == "HELLO", "basic to_upper");
  assert("Hello World".to_upper() == "HELLO WORLD", "mixed to_upper");
  assert("ALREADY".to_upper() == "ALREADY", "already upper");
  assert("".to_upper() == "", "empty to_upper");
  assert("abc123".to_upper() == "ABC123", "digits unchanged");
  assert("a-b_c".to_upper() == "A-B_C", "special chars unchanged");
}

test_to_lower() `test {
  assert("HELLO".to_lower() == "hello", "basic to_lower");
  assert("Hello World".to_lower() == "hello world", "mixed to_lower");
  assert("already".to_lower() == "already", "already lower");
  assert("".to_lower() == "", "empty to_lower");
  assert("ABC123".to_lower() == "abc123", "digits unchanged");
}

// --- repeat ---

test_repeat() `test {
  assert("ab".repeat(3) == "ababab", "repeat 3");
  assert("x".repeat(1) == "x", "repeat 1");
  assert("hello".repeat(0) == "", "repeat 0 is empty");
  assert("abc".repeat(-1) == "", "repeat negative is empty");
  assert("".repeat(5) == "", "empty repeat is empty");
}

// --- replace ---

test_replace() `test {
  assert("hello world".replace("world", "there") == "hello there", "replace word");
  assert("aabaa".replace("a", "x") == "xxbxx", "replace all occurrences");
  assert("hello".replace("xyz", "abc") == "hello", "replace no match");
  assert("aaa".replace("a", "bb") == "bbbbbb", "replace with longer");
  assert("hello".replace("", "x") == "hello", "replace empty does nothing");
}

// --- count ---

test_count() `test {
  assert("hello world".count("l") == 3, "count l in hello world");
  assert("aabaa".count("a") == 4, "count a");
  assert("aaa".count("aa") == 1, "count non-overlapping");
  assert("hello".count("xyz") == 0, "count no match");
  assert("".count("a") == 0, "count in empty");
  assert("hello".count("") == 0, "count empty sub");
}

// --- chars ---

test_chars() `test {
  char[] cs = "hello".chars();
  assert(cs.len == 5, "chars len 5");
  assert(cs[0] == 'h', "chars[0] == h");
  assert(cs[4] == 'o', "chars[4] == o");

  char[] empty = "".chars();
  assert(empty.len == 0, "empty chars");
}

// --- pad_left / pad_right ---

test_pad_left_basic() `test {
  assert("hi".pad_left(5, ' ') == "   hi", "pad_left space");
  assert("42".pad_left(5, '0') == "00042", "pad_left zero");
}

test_pad_left_no_op() `test {
  assert("hello".pad_left(3, ' ') == "hello", "pad_left no-op longer");
  assert("abc".pad_left(3, ' ') == "abc", "pad_left no-op equal");
}

test_pad_left_empty() `test {
  assert("".pad_left(4, '*') == "****", "pad_left empty");
}

test_pad_right_basic() `test {
  assert("hi".pad_right(5, ' ') == "hi   ", "pad_right space");
  assert("42".pad_right(5, '0') == "42000", "pad_right zero");
}

test_pad_right_no_op() `test {
  assert("hello".pad_right(3, ' ') == "hello", "pad_right no-op longer");
  assert("abc".pad_right(3, ' ') == "abc", "pad_right no-op equal");
}

test_pad_right_empty() `test {
  assert("".pad_right(4, '*') == "****", "pad_right empty");
}

// T0962: the no-op path (len >= width) must return an owned clone, not the
// borrowed receiver. When the receiver is a HEAP temporary (e.g. to_string())
// returning `this` aliased the temporary, double-freeing on drop. A literal
// receiver hid the bug (its drop is a no-op via the literal flag), so these
// tests use heap-allocated receivers and then consume the result.
test_pad_left_no_op_heap_receiver() `test {
  string r = 1234.to_string().pad_left(4, '0') + "!";
  assert(r == "1234!", "pad_left no-op on heap temp does not double-free");
}

test_pad_right_no_op_heap_receiver() `test {
  string r = 1234.to_string().pad_right(4, '0') + "!";
  assert(r == "1234!", "pad_right no-op on heap temp does not double-free");
}

test_replace_no_match_heap_receiver() `test {
  string r = (10 + 5).to_string().replace("zzz", "x") + "!";
  assert(r == "15!", "replace no-match on heap temp does not double-free");
}

// T0963: the no-op `return this` result must OWN independent storage — not just
// avoid a double-free, but also not share the receiver's buffer while both are
// live. Keep a heap receiver alive, push the padded result into a vector, then
// read both. If the result aliased the receiver, one binding's drop would
// corrupt the other's contents.
test_pad_left_no_op_result_is_independent() `test {
  string recv = 987.to_string();
  string[] v = [];
  v.push(recv.pad_left(2, '0')); // len >= width → no-op path returns `this`
  assert(v[0] == "987", "padded no-op result intact");
  assert(recv == "987", "receiver intact after pushing padded result");
}

// T0963: same independence guarantee for the pad_right no-op site (the second
// of the three fixed `return this` sites in string.pr). Codegen must auto-clone
// the borrowed receiver so the vector-stored result owns independent storage.
test_pad_right_no_op_result_is_independent() `test {
  string recv = 654.to_string();
  string[] v = [];
  v.push(recv.pad_right(2, '0')); // len >= width → no-op path returns `this`
  assert(v[0] == "654", "padded no-op result intact");
  assert(recv == "654", "receiver intact after pushing padded result");
}

// T0963: same independence guarantee for the replace empty-old site (the third
// fixed `return this` site: `if old.len == 0 { return this; }`). The no-op
// result and the still-live heap receiver must not share a buffer.
test_replace_empty_old_result_is_independent() `test {
  string recv = 321.to_string();
  string[] v = [];
  v.push(recv.replace("", "X")); // empty old → no-op path returns `this`
  assert(v[0] == "321", "replace no-op result intact");
  assert(recv == "321", "receiver intact after pushing replace result");
}

// T0963: user operator returning a borrowed string operand as an owned value
// must clone (cloneOwnedReturnAlias / T0897 path). Push the operator result and
// keep the operand live; both must remain intact.
type PickSecond {
  int z;
  % (string other) string {
    return other;
  }
}

test_operator_returns_borrowed_string_operand() `test {
  string base = 100.to_string();
  PickSecond p = PickSecond(z: 1);
  string[] v = [];
  v.push(p % base);
  assert(v[0] == "100", "operator-returned string operand intact");
  assert(base == "100", "operand intact after operator returned it as owned");
}

// T0963: an operator returning a borrowed string operand while a Vector[string]
// binding is live in its own body must dup exactly once. The op-param clone
// (cloneOwnedReturnAlias) and the B0189 vector-string return guard would both
// fire on the same `return other`, double-dup'ing and orphaning the first copy
// (leak). The B0189 guard must skip idents already handled as operator params.
type PickWithVec {
  int z;
  % (string other) string {
    string[] scratch = [];
    scratch.push("junk");
    return other;
  }
}

test_operator_returns_operand_with_live_vector() `test {
  string base = 200.to_string();
  PickWithVec p = PickWithVec(z: 1);
  string[] v = [];
  v.push(p % base);
  assert(v[0] == "200", "operator result intact with live vector binding");
  assert(base == "200", "operand intact after operator returned it as owned");
}
