gunzip_a100_test() `test {
  // gzip("A" * 100) — exercises back-reference compression.
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  raw.push(0x73);
  raw.push(0x74);
  raw.push(0xA4);
  raw.push(0x3D);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x8D);
  raw.push(0xBC);
  raw.push(0x97);
  raw.push(0x95);
  raw.push(0x64);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  u8[] result = gunzip(data)?!;
  assert(result.len == 100, "100 bytes out");
  int i = 0;
  while i < 100 {
    assert(result[i] == 0x41u8, "byte " + i.to_string() + " is 'A'");
    i = i + 1;
  }
}

