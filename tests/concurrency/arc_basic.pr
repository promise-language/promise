// Arc[T] basic tests — T0155
arc_new_borrow_int() `test {
  a := Arc[int](42);
  assert(a.borrow == 42, "int borrow");
}

arc_new_borrow_string() `test {
  a := Arc[string]("hello");
  assert(a.borrow == "hello", "string borrow");
}

arc_new_borrow_bool() `test {
  a := Arc[bool](true);
  assert(a.borrow == true, "bool borrow");
}

arc_new_borrow_f64() `test {
  a := Arc[f64](3.14);
  assert(a.borrow == 3.14, "f64 borrow");
}

arc_clone_shares_value() `test {
  a := Arc[int](100);
  b := a.clone();
  assert(a.borrow == 100, "original after clone");
  assert(b.borrow == 100, "clone value");
}

arc_clone_string() `test {
  a := Arc[string]("shared");
  b := a.clone();
  assert(a.borrow == "shared", "original string");
  assert(b.borrow == "shared", "cloned string");
}

arc_multiple_clones() `test {
  a := Arc[int](7);
  b := a.clone();
  c := a.clone();
  d := b.clone();
  assert(a.borrow == 7, "a");
  assert(b.borrow == 7, "b");
  assert(c.borrow == 7, "c");
  assert(d.borrow == 7, "d");
}

arc_cross_goroutine() `test {
  a := Arc[int](42);
  ch := channel[int]();
  go {
    ch.send(a.borrow);
  };
  r := <-ch;
  assert(r! == 42, "cross-goroutine value");
}

arc_clone_cross_goroutine() `test {
  a := Arc[int](123);
  ch := channel[int]();
  b := a.clone();
  go {
    ch.send(b.borrow);
  };
  assert(a.borrow == 123, "original intact");
  r := <-ch;
  assert(r! == 123, "clone cross-goroutine");
}

// User-defined type tests — T0272
type ArcPoint {
  int x;
}

arc_borrow_user_type() `test {
  a := Arc[ArcPoint](ArcPoint(x: 5));
  assert(a.borrow.x == 5, "user type borrow");
}

type ArcPair {
  int x;
  int y;
}

arc_borrow_user_type_two_fields() `test {
  a := Arc[ArcPair](ArcPair(x: 3, y: 7));
  assert(a.borrow.x == 3, "field x");
  assert(a.borrow.y == 7, "field y");
}

type ArcDroppable {
  int val;
  drop(~this) {
  }
}

arc_borrow_user_type_with_drop() `test {
  a := Arc[ArcDroppable](ArcDroppable(val: 99));
  assert(a.borrow.val == 99, "droppable borrow");
  b := a.clone();
  assert(b.borrow.val == 99, "droppable clone borrow");
}

type ArcWithString {
  string name;
  int id;
}

arc_borrow_user_type_synth_drop() `test {
  a := Arc[ArcWithString](ArcWithString(name: "test", id: 7));
  assert(a.borrow.name == "test", "synth drop name");
  assert(a.borrow.id == 7, "synth drop id");
}

// Arc[int[]] — vector inner drop path
arc_vector_element() `test {
  v := [10, 20, 30];
  a := Arc[int[]](v);
  int[] borrowed = a.borrow;
  assert(borrowed.len == 3, "vector len");
  assert(borrowed[0] == 10, "vector[0]");
  assert(borrowed[2] == 30, "vector[2]");
}

// T0367: Arc[string[]] — heap container with heap elements. Without the fix,
// `borrowed`'s drop and Arc's inner drop both free the same buffer → segfault
// when the second drop reads scribbled string pointers from the freed buffer.
arc_borrow_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  borrowed := a.borrow;
  assert(borrowed.len == 1, "heap vec len");
}

// T0367: Arc[string] with a heap-allocated string — silently double-frees
// without the fix (string drop's bit-63 check happens to mask it).
arc_borrow_heap_string() `test {
  s := "hello" + "";
  a := Arc[string](s);
  borrowed := a.borrow;
  assert(borrowed.len == 5, "heap string len");
}

// T0367: Optional-chained borrow via Weak.upgrade!.
arc_borrow_optional_chain() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  w := a.downgrade();
  if strong := w.upgrade() {
    borrowed := strong.borrow;
    assert(borrowed.len == 1, "weak upgrade borrow len");
  }
}

// T0367: Typed var decl path (`T borrowed = a.borrow`) with heap T.
// `arc_vector_element` exercises this syntax with a static literal that masks
// the bug via Vector.drop's bit-63 check; this variant pushes a heap-allocated
// element so the static-flag short-circuit cannot hide a double-free.
arc_borrow_typed_decl_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  string[] borrowed = a.borrow;
  assert(borrowed.len == 1, "typed decl heap vec");
}

// T0367: `.borrow` inside a generic function — monomorphization preserves
// the dropflag-clear when T is heap.
arc_borrow_len[T](Arc[Vector[T]] arc) int {
  borrowed := arc.borrow;
  return borrowed.len;
}

arc_borrow_in_generic_fn() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  assert(arc_borrow_len[string](a) == 1, "generic borrow len");
}

// T0379: Reassignment of `.borrow` to an existing local must clear the dropflag
// re-armed by the unconditional reset in the assignment path. Without the fix,
// `borrowed`'s drop frees the inner buffer that Arc still owns → segfault.
arc_borrow_reassign_after_borrow() `test {
  v1 := string[]();
  v1.push("hello" + "");
  v2 := string[]();
  v2.push("world" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "reassigned borrow len");
}

// T0379: Owned→borrow reassignment. The original local owns its vector; the
// reassignment must drop the owned vec, store the borrow pointer, and clear
// the dropflag so scope cleanup doesn't free the parent's buffer.
arc_borrow_reassign_after_owned() `test {
  owned := string[]();
  owned.push("owned" + "");
  v := string[]();
  v.push("borrowed" + "");
  a := Arc[string[]](v);
  owned = a.borrow;
  assert(owned.len == 1, "owned reassigned to borrow");
}

// T0379: Arc[string] analog. Exercises the string-drop alias-check branch
// (bindingDropString) in the reassignment path.
arc_borrow_reassign_heap_string() `test {
  s1 := "hello" + "";
  s2 := "world" + "";
  a1 := Arc[string](s1);
  a2 := Arc[string](s2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 5, "reassigned string borrow");
}

// T0379: Multiple alternating reassignments — each must override the dropflag
// re-arm so cleanup never double-frees.
arc_borrow_reassign_alternating() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  borrowed = a1.borrow;
  assert(borrowed.len == 1, "alternating reassign");
}

// T0379: Borrow→owned reassignment (negative test). The fix must NOT fire when
// RHS is an owned constructor — the local now owns the new value and its drop
// must run at scope exit. A regression that always cleared the dropflag would
// leak the new vector here.
arc_borrow_reassign_to_owned() `test {
  v := string[]();
  v.push("borrowed" + "");
  a := Arc[string[]](v);
  borrowed := a.borrow;
  borrowed = string[]();
  borrowed.push("owned" + "");
  assert(borrowed.len == 1, "borrow reassigned to owned");
}

// T0379: Typed-decl path (T0367) followed by reassignment (T0379). Verifies
// integration between the two fixes — the typed decl clears the flag, then the
// reassignment correctly re-clears it after the unconditional re-arm.
arc_borrow_typed_decl_reassign() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);
  string[] borrowed = a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "typed decl + reassign");
}

// T0379: Reassign inside a loop body. Each iteration re-arms the flag at the
// reassignment site and the fix must clear it; cleanup at scope exit must see
// flag=0. A bug here would surface as cumulative leaks across iterations.
arc_borrow_reassign_in_loop() `test {
  v := string[]();
  v.push("loop" + "");
  a := Arc[string[]](v);
  borrowed := a.borrow;
  i := 0;
  while i < 4 {
    borrowed = a.borrow;
    i = i + 1;
  }
  assert(borrowed.len == 1, "reassign in loop");
}

// T0377: Borrow laundered through an if-expression. Both arms produce a
// borrow, so the merged variable must clear its dropflag — without the fix,
// scope cleanup double-frees with Arc.drop.
arc_borrow_through_if() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  cond := true;
  borrowed := if cond {
    a.borrow
  } else {
    a.borrow
  };
  assert(borrowed.len == 1, "if borrow len");
}

// T0377: Borrow laundered through a match expression with all arms producing
// the same borrow.
arc_borrow_through_match() `test {
  v := string[]();
  v.push("hi" + "");
  a := Arc[string[]](v);
  k := 1;
  borrowed := match k {
    1 => a.borrow, _ => a.borrow,
  };
  assert(borrowed.len == 1, "match borrow len");
}

// T0377: Recursion through nested if-expressions — outer if has an inner
// (parenthesized) if-expression in one arm; every leaf produces a borrow.
arc_borrow_through_nested_if() `test {
  v := string[]();
  v.push("nest" + "");
  a := Arc[string[]](v);
  cond := true;
  cond2 := false;
  borrowed := if cond {
    (if cond2 {
      a.borrow
    } else {
      a.borrow
    })
  } else {
    a.borrow
  };
  assert(borrowed.len == 1, "nested if borrow len");
}

// T0377: Plain parenthesized borrow (`(a.borrow)`) is also a laundering form —
// must clear the dropflag like the bare borrow does.
arc_borrow_through_parens() `test {
  v := string[]();
  v.push("paren" + "");
  a := Arc[string[]](v);
  borrowed := (a.borrow);
  assert(borrowed.len == 1, "paren borrow len");
}

// T0377: Block-bodied match arms (`=> { a.borrow }`) hit the `arm.Block`
// path in `matchArmIsBorrowGetter`. Must still clear the dropflag when every
// block result is a borrow — without the fix, this would double-free.
arc_borrow_through_match_blocks() `test {
  v := string[]();
  v.push("blk" + "");
  a := Arc[string[]](v);
  k := 1;
  borrowed := match k {
    1 => {
      a.borrow
    },
    _ => {
      a.borrow
    },
  };
  assert(borrowed.len == 1, "match block-arm borrow len");
}

// T0381: explicit `T&` annotation on a borrowed local — the new principled
// way to bind a borrow. Replaces the implicit decay path that T0367 had to
// detect via heuristics.
arc_borrow_explicit_ref_type() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  string[] &borrowed = a.borrow;
  assert(borrowed.len == 1, "explicit ref type borrow");
}

// T0381: chained `.borrow.method` — auto-deref through `T&` finds methods
// on the underlying type. This is the syntax that nested-Arc tests already
// exercise; pinned here as an explicit T0381 regression check.
arc_borrow_chained_method() `test {
  v := [10, 20, 30];
  a := Arc[int[]](v);
  string r = a.borrow[1].to_string();
  assert(r == "20", "chained .borrow[i].method");
}

// T0381: reassigning a `T&`-typed local from one borrow to another
// continues to suppress the dropflag (codegen looks at the RHS type, not
// the AST shape).
arc_borrow_reassign_via_explicit_ref_type() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);
  string[] &borrowed = a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "explicit ref reassign");
}

// T0383: `vec[i] = a.borrow` for non-string heap element types must dup the
// borrowed value so the vector owns an independent copy. Without the dup,
// Vector.drop and Arc.drop both free the same inner buffer → double-free.
// The dup at the call site + drop-old-element in genVectorIndexAssign +
// dup-on-read in genVectorIndex together prevent double-free, leak, and UAF.
arc_borrow_index_assign_vector() `test {
  vec := string[][]();
  v1 := string[]();
  v1.push("init" + "");
  vec.push(v1);

  v2 := string[]();
  v2.push("hello" + "");
  a := Arc[string[]](v2);

  vec[0] = a.borrow;
  assert(vec[0].len == 1, "vec[0] len after borrow assign");
}

// T0383: Channel element analog. Borrow assignment must increment refcount
// (dupChannel) so the vector owns its own ref.
arc_borrow_index_assign_channel() `test {
  ch1 := channel[int](capacity: 1);
  ch1.send(1);
  vec := channel[int][]();
  vec.push(ch1);

  ch2 := channel[int](capacity: 1);
  ch2.send(42);
  a := Arc[channel[int]](ch2);

  vec[0] = a.borrow;
  assert(true, "no double-free on borrow channel assign");
}

// T0383: Owned move into vec[i] must still work — dup only fires for borrows.
arc_borrow_index_assign_owned_unaffected() `test {
  vec := string[][]();
  v1 := string[]();
  v1.push("init" + "");
  vec.push(v1);

  v2 := string[]();
  v2.push("hello" + "");
  vec[0] = v2;
  assert(vec[0].len == 1, "owned move still works");
}

// T0383: Repeated borrow assignments — old element drop fires correctly,
// no double-free, no leak.
arc_borrow_index_assign_repeat_borrows() `test {
  vec := string[][]();
  v0 := string[]();
  v0.push("v0" + "");
  vec.push(v0);

  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  v2.push("c" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);

  vec[0] = a1.borrow;
  vec[0] = a2.borrow;
  assert(vec[0].len == 2, "second borrow assign");
}

// T0383: `t := vec[i]` for nested heap element dups (B0219 analog) so that
// drop-on-write on vec[i] does NOT cause UAF through t. Mirrors the field
// pattern T0095/B0219.
arc_borrow_index_assign_alias_safe() `test {
  vec := string[][]();
  v1 := string[]();
  v1.push("hi" + "");
  vec.push(v1);

  // t dups vec[0] — independent owned copy
  t := vec[0];

  // overwrite vec[0] — drops old (which was vec[0]'s buffer), but t owns its dup
  v2 := string[]();
  v2.push("ok" + "");
  vec[0] = v2;

  // t is still valid
  assert(t.len == 1, "t still valid after overwrite");
}

// T0402: pinning the documented fix path — `.borrow.clone()` produces an
// owned copy that can safely cross a return boundary. Without the fix in
// T0402 the unsafe `return a.borrow;` pattern crashed with `fatal: invalid
// free (bad header magic)` after a few iterations; the type-based ownership
// check now rejects the unsafe pattern at compile time and this test pins
// the runtime correctness of the .clone() workaround.
get_inner_str_clone(Arc[string] a) string {
  return a.borrow.clone();
}

arc_borrow_clone_returned_owned() `test {
  i := 0;
  while i < 50 {
    s := "hello" + i.to_string();
    a := Arc[string](s);
    result := get_inner_str_clone(a);
    assert(result.starts_with("hello"), "starts with hello");
    i = i + 1;
  }
}
