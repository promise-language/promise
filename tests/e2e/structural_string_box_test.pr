// T1280: A string coerced to a structural interface is heap-boxed as
// { i8* typeinfo, i8* string_ptr } holding an OWNED deep clone. The box must survive
// escape (return/binding, moved param, struct/enum field) and drop cleanly without a
// segfault ("field 0 misread as typeinfo") or leaks. Field 0 carries a dedicated
// typeinfo (@promise_typeinfo_stringbox) whose drop_fn (@__promise_string_box_drop)
// drops the cloned string via promise_string_drop then frees the box.
type Showable `structural {
  to_string() string `abstract;
}

// Returns a string boxed as a structural interface (escaping box).
show_str(string s) Showable {
  return s;
}

// The exact repro: returned literal boxed as Showable, bound to a local, survives an
// intervening allocation, method reads correct value, drops cleanly at scope exit.
test_returned_literal_string_survives_frame() `test {
  Showable s = show_str("hi");
  int[] junk = [9, 8, 7, 6, 5];
  assert(s.to_string() == "hi", "boxed string survives returned frame");
  assert(junk.len == 5, "intervening allocation intact");
}

// Returned HEAP string (concatenation, not a rodata literal): exercises the clone/escape
// fix and the non-literal branch of promise_string_drop (must actually free, no leak).
test_returned_heap_string_box_drop() `test {
  string a = "foo";
  string b = "bar";
  Showable s = show_str(a + b);
  assert(s.to_string() == "foobar", "boxed heap string method + drop");
}

// Local box drop path for a string literal.
test_local_string_box() `test {
  Showable s = "local";
  assert(s.to_string() == "local", "local string box");
}

// Local-to-local move: the box moves out of `a` into `b`; `a`'s drop flag must be cleared
// so only `b` frees the box at scope exit — no double free, no leak of the moved box.
test_string_box_local_move() `test {
  Showable a = show_str("deep");
  Showable b = a;
  assert(b.to_string() == "deep", "box moved through a second local");
}

// Move a string box into a callee that consumes (frees) it — moved-param free path.
describe(Showable move s) string {
  return s.to_string();
}
test_string_move_arg() `test {
  assert(describe(show_str("moved")) == "moved", "moved string box freed by callee");
  assert(describe("direct") == "direct", "moved string literal box freed by callee");
}

// Reassignment: the old string box must be dropped (freed) before the new box is
// claimed — no leak of the old, no double-free. Covers both a literal RHS and a call RHS.
test_string_reassign_drops_old_box() `test {
  Showable s = "one";
  assert(s.to_string() == "one", "initial string box");
  s = "two";
  assert(s.to_string() == "two", "reassigned from literal");
  s = show_str("three");
  assert(s.to_string() == "three", "reassigned from call");
}

// Loop stability: box + drop a string each iteration (no-leak assertion).
test_string_loop_box_drop() `test {
  int count = 0;
  for i in 0..50 {
    Showable s = show_str(i.to_string());
    if s.to_string().len > 0 {
      count = count + 1;
    }
  }
  assert(count == 50, "string boxes freed each iteration");
}

// Empty string boxed and dropped.
test_empty_string_box() `test {
  Showable s = show_str("");
  assert(s.to_string() == "", "empty string box");
  assert(s.to_string().len == 0, "empty string box length");
}

// Struct-field escape: a string box stored in a struct field must drop with the struct
// (the RTTI drop site the fix's comment claims works uniformly). No leak, correct read.
type StrHolder {
  Showable item;
}
test_string_box_in_struct_field() `test {
  StrHolder h = StrHolder(item: show_str("field"));
  assert(h.item.to_string() == "field", "boxed string survives in a struct field");
}

// Enum-field escape: a string box carried in an enum variant payload must drop when the
// enum drops (the enum-field RTTI drop site). No leak, correct read after match.
enum StrWrap {
  One(Showable s), Two,
}
test_string_box_in_enum_field() `test {
  StrWrap w = StrWrap.One(show_str("variant"));
  match w {
    StrWrap.One(s) => assert(s.to_string() == "variant", "boxed string in an enum field"),
    StrWrap.Two => assert(false, "unreachable"),
  }
}

// T1282: A string boxed to a structural interface at a MOVE position (return of an
// owned move-param / owned var, an owned frame temp, or a `move`-param call arg) must
// take ownership of the source pointer instead of cloning it. At a move site the
// ownership pass clears the source's drop flag; cloning would orphan the original heap
// string (leak 1 allocation). Borrowed sources (literal, borrow param) keep cloning.

// return of a `string move` param boxed to a structural interface (the item repro).
show_owned(string move s) Showable {
  return s;
}
test_owned_moveparam_box() `test {
  string a = "foo";
  string b = "bar";
  Showable s = show_owned(a + b); // a+b (heap) moved into s, then boxed + returned
  assert(s.to_string() == "foobar", "owned moved string box");
}

// return of an owned string local boxed to a structural interface.
show_owned_local() Showable {
  string x = "hello";
  string y = "world";
  string joined = x + y;
  return joined; // owned local, moved out via return
}
test_owned_local_box() `test {
  Showable s = show_owned_local();
  assert(s.to_string() == "helloworld", "owned local string box");
}

// return of an owned temp (concatenation escaping directly via return).
show_owned_temp(string a, string b) Showable {
  return a + b; // owned frame temp, moved out via return
}
test_owned_temp_box() `test {
  Showable s = show_owned_temp("ab", "cd");
  assert(s.to_string() == "abcd", "owned temp string box");
}

// move-param call arg: box a string into a `Showable move` param.
take_owned(Showable move s) string {
  return s.to_string();
}
test_moveparam_callarg_box() `test {
  // owned temp as the boxed source
  assert(take_owned("xy" + "zw") == "xyzw", "owned temp boxed to move param");
  // owned named binding moved explicitly into the move param
  string c = "pq" + "rs";
  assert(take_owned(move c) == "pqrs", "owned var moved + boxed to move param");
}

// Regression guard: borrow-param return must STAY on the clone path (caller owns the
// borrowed source; the box owns an independent clone) — leak-free.
show_borrow(string s) Showable {
  return s;
}
test_borrowparam_box_still_clones() `test {
  string a = "bo" + "rr"; // owned in the caller
  Showable s = show_borrow(a);
  assert(s.to_string() == "borr", "borrow param stays clone-based");
  assert(a == "borr", "borrowed source still owned by caller after box");
}

// Regression guard: literal return stays clone-based, leak-free.
test_literal_return_box_still_clones() `test {
  Showable s = show_borrow("lit");
  assert(s.to_string() == "lit", "literal box stays clone-based");
}

// T1282 (optional-return sub-case): boxing into an OPTIONAL structural return
// (`Showable?`) routes through coerceReturnToOptionalElem, not the trailing
// coerceToView, so the owned/borrowed box decision must apply there too.

// owned `string move` param boxed into an optional structural return.
show_opt_owned(string move s) Showable? {
  return s;
}
test_opt_owned_moveparam_box() `test {
  string a = "foo";
  string b = "bar";
  Showable? s = show_opt_owned(a + b); // owned temp moved in, boxed into Optional
  assert(s!.to_string() == "foobar", "owned moved string box into optional");
}

// owned local boxed into an optional structural return.
show_opt_local() Showable? {
  string x = "aa";
  string y = "bb";
  return x + y;
}
test_opt_owned_local_box() `test {
  Showable? s = show_opt_local();
  assert(s!.to_string() == "aabb", "owned local string box into optional");
}

// Regression guard: borrow param boxed into an optional return STAYS clone-based.
show_opt_borrow(string s) Showable? {
  return s;
}
test_opt_borrowparam_box_still_clones() `test {
  string a = "bo" + "rr"; // owned in the caller
  Showable? s = show_opt_borrow(a);
  assert(s!.to_string() == "borr", "opt borrow param stays clone-based");
  assert(a == "borr", "borrowed source still owned by caller after opt box");
}

// T1282 (optional-param call-arg sub-case): boxing a string into an OPTIONAL
// structural `move` PARAM (`Showable? move`) routes through coerceToOptionalElem in
// coerceCallArgs, not the trailing coerceToView, so the owned/borrowed box decision
// must apply there too. Without it the owned source leaks (box clones + orphaned original).
take_opt_owned(Showable? move s) string {
  return s!.to_string();
}
test_opt_moveparam_callarg_box() `test {
  // owned temp as the boxed source
  assert(take_opt_owned("mn" + "op") == "mnop", "owned temp boxed to optional move param");
  // owned named binding moved explicitly into the optional move param
  string c = "qr" + "st";
  assert(take_opt_owned(move c) == "qrst", "owned var moved + boxed to optional move param");
}

// Regression guard: a borrow-param optional (`Showable?`) box STAYS clone-based — the
// caller keeps ownership of the source, the box owns an independent clone. Leak-free.
take_opt_borrow(Showable? s) string {
  return s!.to_string();
}
test_opt_borrowparam_callarg_box() `test {
  string a = "uv" + "wx"; // owned in the caller
  assert(take_opt_borrow(a) == "uvwx", "owned var boxed to optional borrow param");
  assert(a == "uvwx", "borrowed source still owned by caller after opt-param box");
}

// T1282 (failable-return sub-case): the box clone-vs-move decision is computed once
// (retBoxSrcOwned) and applied in BOTH the failable and non-failable return branches of
// genReturnStmt. A failable function returning a boxed owned string exercises the
// failable branch (wrapOk-wrapped result) — owned sources must still move, not clone.
show_fail!(string move s) Showable {
  return s;
}
test_owned_moveparam_box_failable() `test {
  string a = "foo";
  string b = "bar";
  Showable s = show_fail(a + b)?!; // owned temp moved in, boxed + returned through failable
  assert(s.to_string() == "foobar", "owned moved string box, failable return");
}

// failable + optional structural return: owned source moved through coerceReturnToOptionalElem.
show_fail_opt!(string move s) Showable? {
  return s;
}
test_owned_moveparam_box_failable_opt() `test {
  string a = "foo";
  string b = "bar";
  Showable? s = show_fail_opt(a + b)?!;
  assert(s!.to_string() == "foobar", "owned moved string box, failable optional return");
}

// Regression guard: failable borrow-param return STAYS clone-based (caller keeps the source).
show_fail_borrow!(string s) Showable {
  return s;
}
test_borrowparam_box_failable_clones() `test {
  string a = "bo" + "rr"; // owned in the caller
  Showable s = show_fail_borrow(a)?!;
  assert(s.to_string() == "borr", "borrow param failable stays clone-based");
  assert(a == "borr", "borrowed source still owned by caller after failable box");
}

// T1316: An owned named string moved into a structural-interface STRUCT FIELD
// (`Type(field: move s)`) must take ownership of the source pointer rather than
// clone it. The constructor field-init path boxes the string via a SEPARATE
// coerceToView / coerceToOptionalElem call (genConstructorCallMono) that never set
// c.boxSrcOwned, so the box cloned while the owning-slot store cleared the source's
// drop flag → the original heap string was orphaned (leak 1 allocation). Sibling of
// T1282 at the constructor field-init coercion site.

type Holder {
  Showable item;
}
type OptHolder {
  Showable? item;
}

// The item repro: owned var moved into a bare structural field. Was LEAK.
test_field_move_var() `test {
  string a = "he" + "llo"; // owned heap string in the caller
  Holder h = Holder(item: move a); // moved into the structural field
  assert(h.item.to_string() == "hello", "owned var moved into structural field");
}

// Owned var moved into an OPTIONAL structural field (coerceToOptionalElem path). Was LEAK.
test_field_move_var_optional() `test {
  string a = "wor" + "ld";
  OptHolder h = OptHolder(item: move a);
  assert(h.item!.to_string() == "world", "owned var moved into optional structural field");
}

// Owned frame temp into a structural field: now takes the pointer (no redundant clone),
// leak-free (previously a wasteful clone, freed at statement end).
test_field_owned_temp() `test {
  Holder h = Holder(item: "a" + "b");
  assert(h.item.to_string() == "ab", "owned temp into structural field");
}

// Owned var moved into a structural field alongside a plain field, surviving an
// intervening allocation before the read — exercises the box + struct drop together.
type LabeledHolder {
  string label;
  Showable item;
}
test_field_move_var_mixed() `test {
  string a = "gr" + "eeting";
  LabeledHolder h = LabeledHolder(label: "tag", item: move a);
  int[] junk = [3, 2, 1];
  assert(h.item.to_string() == "greeting", "moved var in a structural field survives frame");
  assert(h.label == "tag", "plain string field intact");
  assert(junk.len == 3, "intervening allocation intact");
}

// Pure rodata literal into a structural field: a borrowed source — NOT a drop-flag
// ident and NOT a tracked frame temp — so ctorBoxSrcOwned stays false, the box clones,
// and nothing is claimed. Guards against the fix over-claiming a non-owned source.
test_field_literal() `test {
  Holder h = Holder(item: "lit");
  assert(h.item.to_string() == "lit", "literal into structural field clones, no claim");
}

// Literal into an OPTIONAL structural field: same borrowed-clone path through
// coerceToOptionalElem (ctorBoxSrcOwned false).
test_field_literal_optional() `test {
  OptHolder h = OptHolder(item: "lit2");
  assert(h.item!.to_string() == "lit2", "literal into optional structural field");
}

// Owned frame temp into an OPTIONAL structural field: exercises the claim path
// (claimStringTemp) combined with coerceToOptionalElem — the temp is taken (no clone),
// and claimed so statement-end cleanup doesn't double-free the boxed pointer.
test_field_owned_temp_optional() `test {
  OptHolder h = OptHolder(item: "x" + "y");
  assert(h.item!.to_string() == "xy", "owned temp into optional structural field");
}

// Rebind the moved var's name afterward: the move cleared a's drop flag, so the new
// binding to the same name must not resurrect a stale flag → no double-free at scope exit.
test_field_move_var_rebind() `test {
  string a = "fo" + "o";
  Holder h = Holder(item: move a);
  string a2 = "ba" + "r";
  assert(h.item.to_string() == "foo", "moved box reads right after rebinding the name");
  assert(a2 == "bar", "rebound name intact");
}

// Generic owner whose concrete field type resolves to a structural interface: the box
// runs inside genConstructorCallMono with c.typeSubst active (ctorFieldType is the
// substituted `Showable`). Confirms the move-vs-clone decision reads the substituted
// field type correctly.
type GenBox[T] {
  T item;
}
test_field_move_var_generic_owner() `test {
  string a = "ge" + "neric";
  GenBox[Showable] b = GenBox[Showable](item: move a);
  assert(b.item.to_string() == "generic", "moved string into a generic structural field");
}

enum BoxCmd {
  First(int n),
  Second,
}

// Regression for the cleanupHeapTemps double-free (found via T1280 verify):
// print_line(Format) heap-boxes its string argument as a statement-end temp. Inside a
// match in a loop, the box temp alloca/drop-flag are function-entry allocas that persist
// across iterations and are only refreshed by the *taken* arm. cleanupHeapTemps used to
// drop the temp without resetting its flag, so after arm First boxes+drops (flag stays
// true), a later iteration taking arm Second would re-drop arm First's stale (freed)
// pointer via the shared post-match cleanup → double free / segfault. Dispatching both
// arms (in either order) across iterations must not crash and must not leak.
test_match_arm_box_no_double_free() `test {
  BoxCmd[] cmds = [BoxCmd.First(1), BoxCmd.Second, BoxCmd.First(2), BoxCmd.Second];
  int hits = 0;
  for cmd in cmds {
    match cmd {
      BoxCmd.First(n) => {
        print_line("first: {n}");
        hits = hits + 1;
      },
      BoxCmd.Second => {
        print_line("second");
        hits = hits + 1;
      },
    }
  }
  assert(hits == 4, "all arms dispatched without a double-free crash");
}
