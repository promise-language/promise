// ── Malformed response (missing header terminator) ──────────────────────────

test_malformed_response() `test(exclude: "wasm32", timeout: "10s") {
  net.TcpListener listener = net.TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;

  go {
    net.TcpStream conn = listener.accept()?!;
    u8[] buf = u8[].filled(0, 8192);
    conn.read(buf)?!;
    // Send data without \r\n\r\n header terminator, then close
    u8[] rd = "HTTP/1.1 200 OK\r\nContent-Length: 2\r\n".bytes();
    conn.write(rd)?!;
    conn.close()?!;
  };

  Response resp = http_get("http://127.0.0.1:" + port.to_string() + "/")? e {
    return; // expected: malformed HTTP response
  };
  assert(false, "should have raised an error");
  listener.close()?!;
}

// ── http_post! convenience function (empty headers — B0343 blocks non-empty) ─

test_http_post_function() `test(exclude: "wasm32", timeout: "10s") {
  net.TcpListener listener = net.TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;

  go {
    map[string, string] h = map[string, string]();
    Response resp = http_post("http://127.0.0.1:" + port.to_string() + "/api", "payload", h)?!;
    assert(resp.status_code == 200, "status 200");
    assert(resp.body == "ok", "body");
  };

  string request = _serve_once(listener, "HTTP/1.1 200 OK\r\nContent-Length: 2\r\nConnection: close\r\n\r\nok")?!;
  assert(request.contains("POST /api"), "POST method");
  assert(request.contains("payload"), "body sent");
  listener.close()?!;
  sleep(Duration.from_millis(100));
}

// ── Response.json[T] (B0344: cross-module generic method→function) ─────────

test_response_json_int() `test(exclude: "wasm32", timeout: "10s") {
  net.TcpListener listener = net.TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;

  go {
    Response resp = http_get("http://127.0.0.1:" + port.to_string() + "/")?!;
    assert(resp.status_code == 200, "status");
    int val = resp.json[int]()?!;
    assert(val == 42, "json int");
  };

  _serve_once(listener, "HTTP/1.1 200 OK\r\nContent-Length: 2\r\nConnection: close\r\n\r\n42")?!;
  listener.close()?!;
  sleep(Duration.from_millis(100));
}

