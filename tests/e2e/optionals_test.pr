// Test functions for optional values.

// --- Truthiness narrowing ---

truthiness_string_present() `test {
    string? cc = "hello";
    if cc {
        string s = cc;
        assert(s == "hello", "truthiness narrows string? to string");
    } else {
        assert(false, "should enter then branch");
    }
}

truthiness_string_none() `test {
    string? cc = none;
    if cc {
        assert(false, "should not enter then branch");
    }
}

truthiness_int_present() `test {
    int? x = 42;
    if x {
        int n = x;
        assert(n == 42, "truthiness narrows int? to int");
    } else {
        assert(false, "should enter then branch");
    }
}

truthiness_int_none() `test {
    int? x = none;
    if x {
        assert(false, "should not enter then branch");
    }
}

// --- is present narrowing ---

is_present_string() `test {
    string? s = "world";
    if s is present {
        string v = s;
        assert(v == "world", "is present narrows string?");
    } else {
        assert(false, "should enter then branch");
    }
}

is_present_bool() `test {
    bool? verbose = true;
    if verbose is present {
        bool b = verbose;
        assert(b == true, "is present narrows bool?");
    } else {
        assert(false, "should enter then branch");
    }
}

is_present_none() `test {
    int? x = none;
    if x is present {
        assert(false, "should not enter then branch");
    }
}

// --- is absent ---

is_absent_none() `test {
    int? x = none;
    if x is absent {
        assert(true, "is absent detects none");
    } else {
        assert(false, "should enter then branch");
    }
}

is_absent_value() `test {
    int? x = 42;
    if x is absent {
        assert(false, "should not enter then branch");
    }
}

// --- if-unwrap ---

if_unwrap_present() `test {
    string? name = "Alice";
    if n := name {
        assert(n == "Alice", "if-unwrap binds value");
    } else {
        assert(false, "should enter then branch");
    }
}

if_unwrap_absent() `test {
    string? name = none;
    if n := name {
        assert(false, "should not enter then branch");
    }
}

// --- Elvis operator ---

elvis_none_default() `test {
    string? x = none;
    string result = x ?: "default";
    assert(result == "default", "elvis gives default for none");
}

elvis_value_kept() `test {
    string? x = "actual";
    string result = x ?: "default";
    assert(result == "actual", "elvis keeps present value");
}

// --- String interpolation with optionals ---

interp_present_int() `test {
    int? x = 42;
    string s = "{x}";
    assert(s == "42", "interpolate present int?");
}

interp_none_int() `test {
    int? x = none;
    string s = "{x}";
    assert(s == "none", "interpolate none int?");
}

interp_present_string() `test {
    string? name = "Bob";
    string s = "hello {name}";
    assert(s == "hello Bob", "interpolate present string?");
}

interp_none_string() `test {
    string? name = none;
    string s = "hello {name}";
    assert(s == "hello none", "interpolate none string?");
}

interp_present_bool() `test {
    bool? b = true;
    string s = "{b}";
    assert(s == "true", "interpolate present bool?");
}

interp_none_bool() `test {
    bool? b = none;
    string s = "{b}";
    assert(s == "none", "interpolate none bool?");
}

// --- Optional user-defined types ---

type Point {
    int x;
    int y;
}

narrowing_type_present() `test {
    Point p = Point(x: 3, y: 4);
    Point? mp = p;
    if mp {
        assert(mp.x == 3, "narrowed type field x");
        assert(mp.y == 4, "narrowed type field y");
    } else {
        assert(false, "should enter then branch");
    }
}

narrowing_type_none() `test {
    Point? mp = none;
    if mp {
        assert(false, "should not enter then branch");
    }
}

is_present_type() `test {
    Point p = Point(x: 5, y: 6);
    Point? mp = p;
    if mp is present {
        Point inner = mp;
        assert(inner.x == 5, "is present narrows type");
    } else {
        assert(false, "should enter then branch");
    }
}

// --- Narrowing with else ---

narrowing_with_else() `test {
    string? cc = none;
    bool entered_else = false;
    if cc {
        assert(false, "should not enter then branch");
    } else {
        entered_else = true;
    }
    assert(entered_else, "else branch executes for none");
}

// --- Multiple narrowings in sequence ---

multiple_narrowings() `test {
    string? a = "first";
    string? b = none;
    bool a_ok = false;
    bool b_absent = false;
    if a {
        a_ok = true;
    }
    if b {
        assert(false, "b should not be present");
    } else {
        b_absent = true;
    }
    assert(a_ok, "a was present");
    assert(b_absent, "b was absent");
}

// --- Shadowing: same var name in inner scope after narrowing ---

shadowing_after_narrowing() `test {
    int? x = 42;
    if x {
        int n = x;
        assert(n == 42, "narrowed x inside if");
    }
    // x is still int? here
    string s = "{x}";
    assert(s == "42", "x still usable as int? after narrowing block");
}

// --- Uninitialized optional vars ---

uninit_optional_int() `test {
    int? x;
    assert("{x}" == "none", "uninitialized int? is none");
}

uninit_optional_string() `test {
    string? s;
    assert("{s}" == "none", "uninitialized string? is none");
}

uninit_optional_then_assign() `test {
    int? x;
    x = 42;
    if x {
        int n = x;
        assert(n == 42, "assigned after init narrows correctly");
    }
}

// --- Negated narrowing (!cc) ---

negated_narrowing_none() `test {
    string? cc = none;
    if !cc {
        assert(true, "!cc enters then when cc is none");
    } else {
        assert(false, "should not enter else");
    }
}

negated_narrowing_present() `test {
    string? cc = "hello";
    if !cc {
        assert(false, "should not enter then when cc is present");
    } else {
        string s = cc;
        assert(s == "hello", "!cc narrows in else branch");
    }
}

negated_narrowing_no_else() `test {
    int? x = none;
    bool entered = false;
    if !x {
        entered = true;
    }
    assert(entered, "!x enters then when x is none");
}

// --- Compound narrowing (&&) ---

compound_narrowing_both_present() `test {
    int? a = 10;
    string? b = "world";
    if a && b {
        int x = a;
        string y = b;
        assert(x == 10, "compound narrows a");
        assert(y == "world", "compound narrows b");
    } else {
        assert(false, "should enter then when both present");
    }
}

compound_narrowing_first_absent() `test {
    int? a = none;
    string? b = "hello";
    if a && b {
        assert(false, "should not enter then when a is none");
    }
}

compound_narrowing_second_absent() `test {
    int? a = 42;
    string? b = none;
    if a && b {
        assert(false, "should not enter then when b is none");
    }
}

compound_narrowing_both_absent() `test {
    int? a = none;
    string? b = none;
    if a && b {
        assert(false, "should not enter then when both none");
    }
}

compound_narrowing_with_else() `test {
    int? a = none;
    string? b = "hi";
    bool entered_else = false;
    if a && b {
        assert(false, "should not enter then");
    } else {
        entered_else = true;
    }
    assert(entered_else, "else entered when compound fails");
}

// --- Optional chaining on user-defined types ---

optional_chain_present() `test {
    Point p = Point(x: 7, y: 8);
    Point? mp = p;
    int? px = mp?.x;
    int? py = mp?.y;
    if px is present {
        assert(px == 7, "optional chain extracts field x");
    } else {
        assert(false, "px should be present");
    }
    if py is present {
        assert(py == 8, "optional chain extracts field y");
    } else {
        assert(false, "py should be present");
    }
}

optional_chain_none() `test {
    Point? mp = none;
    int? px = mp?.x;
    assert("{px}" == "none", "optional chain on none gives none");
}

