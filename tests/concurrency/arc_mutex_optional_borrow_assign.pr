mutex_optional_vec_assign_none() `test {
  int? init = none;
  Mutex[int?] m = Mutex[int?](init);
  g := m.lock();
  int? z = 33;
  vec := [z, z];
  vec[0] = g.borrow;
  got := false;
  if x := vec[0] {
    got = true;
  }
  assert(!got, "mutex vec assign none");
}

// ─── Value-type struct payload ──────────────────────────────────────────────
// Covers the widest auto-copy case: {i1, {int, int}} embedded-by-value optional.

arc_optional_struct_plain_assign() `test {
  Pt? init = Pt(x: 1, y: 2);
  Ref[Pt?] a = Ref[Pt?](init);
  Pt? pv = none;
  pv = a.borrow;
  p := pv!;
  assert(p.x == 1 && p.y == 2, "arc struct plain assign");
}

mutex_optional_struct_plain_assign() `test {
  Pt? init = Pt(x: 3, y: 4);
  Mutex[Pt?] m = Mutex[Pt?](init);
  g := m.lock();
  Pt? pv = none;
  pv = g.borrow;
  p := pv!;
  assert(p.x == 3 && p.y == 4, "mutex struct plain assign");
}
