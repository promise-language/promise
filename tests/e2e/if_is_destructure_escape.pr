// T1012: `if x is V(field) { … }` destructure binding of a heap variant field
// must not use-after-free when the binding escapes the narrowing scope. The
// bound heap payload is deep-cloned so it escapes safely, while in-scope
// bindings remain correct and numeric/value payloads stay zero-copy.
enum Msg {
  Text(string body), Code(int n),
}
enum Items {
  List(int[] xs), Empty,
}
enum Pair {
  Both(string s, int n), None,
}

// --- Return escape (the reported repro) ---

return_escape_impl() string {
  Msg m = Msg.Text(body: "a" + "b"); // m owns the heap string
  if m is Text(body) {
    return body;
  }
  // body escapes; m dropped at scope exit
  return "";
}

return_escape() `test {
  assert(return_escape_impl() == "ab", "returned heap payload survives");
}

// --- Store-to-outer escape ---

store_to_outer() `test {
  Msg m = Msg.Text(body: "x" + "y");
  string out = "";
  if m is Text(body) {
    out = body;
  }
  assert(out == "xy", "stored-to-outer payload survives");
}

// --- Consuming-arg escape (~string param) ---

consume(string move s) string {
  return s + "!";
}

consuming_arg() `test {
  Msg m = Msg.Text(body: "h" + "i");
  string r = "";
  if m is Text(body) {
    r = consume(move body);
  }
  assert(r == "hi!", "payload moved into consuming param");
}

// --- Constructor-field escape ---

type Wrapper {
  string held;
}

constructor_field() `test {
  Msg m = Msg.Text(body: "w" + "z");
  string r = "";
  if m is Text(body) {
    Wrapper w = Wrapper(held: move body);
    r = w.held;
  }
  assert(r == "wz", "payload moved into constructor field");
}

// --- Vector payload escape by return ---

vec_escape_impl() int[] {
  int[] base = [1, 2, 3];
  Items it = Items.List(xs: move base);
  if it is List(xs) {
    return xs;
  }
  return[];
}

vec_escape() `test {
  int[] v = vec_escape_impl();
  assert(v.len == 3, "vector length preserved");
  assert(v[0] == 1 && v[1] == 2 && v[2] == 3, "vector contents preserved");
}

// --- In-scope only: subject stays intact (not nulled) after the `if` ---

in_scope_no_escape() `test {
  Msg m = Msg.Text(body: "a" + "bc");
  if m is Text(body) {
    assert(body.len == 3, "in-scope read");
  }
  // Subject must still be usable after the borrow-narrowing `if`.
  if m is Text(again) {
    assert(again == "abc", "subject intact after if");
  }
}

// --- Multi-field variant: per-field dup selection (heap + numeric) ---

multi_field_impl() string {
  Pair p = Pair.Both(s: "k" + "v", n: 42);
  if p is Both(s, n) {
    assert(n == 42, "numeric field zero-copy");
    return s;
  }
  return "";
}

multi_field() `test {
  assert(multi_field_impl() == "kv", "heap field of multi-field variant escapes");
}

// --- Numeric-only payload: no clone, correct value ---

code_escape_impl() int {
  Msg m = Msg.Code(n: 7);
  if m is Code(n) {
    return n;
  }
  return 0;
}

code_escape() `test {
  assert(code_escape_impl() == 7, "numeric payload correct");
}

// --- Optional / fixed-array heap payloads: T0485 borrow-mark path ---
// A variant field whose type is Optional-of-heap or fixed-Array-of-heap is
// NOT dup'd by T1012; instead bindIsDestructureEnum marks the binding
// match-borrowed (matchBindingIsBorrow / borrowInnerHasDrop). The binding
// aliases the subject's payload, which is sound as long as the read stays
// in-scope (the subject outlives the `if`). These pin that in-scope path.
// T1170 (fixed): escaping such a binding (return / store-to-escaping-outer /
// consuming arg / constructor field) now deep-clones on the read/escape side
// (genIdentExpr / genArrayIndex, gated on matchBorrowedIdents + the dup flag the
// owning sink sets), so the escaped value is independently owned and the subject's
// synth enum drop still frees the original exactly once. The escape cases live in
// the "T1170 escape" section below. In-scope reads (no dup flag) stay zero-copy.
// Optional[heap-user-type] escape (e.g. `Row?`) is the sibling fix T1174 — see
// the T1174 section at the end of this file. Out-of-scope (tracked separately):
// whole fixed-array-VALUE escape `return a`/`x = a` (T1173).

enum OptBox {
  Has(string? maybe), Nothing,
}
enum ArrHolder {
  Pair(string[2] a), Empty,
}

// Optional heap payload unwrapped in-scope (subject still alive).
opt_payload_unwrap() `test {
  OptBox b = OptBox.Has(maybe: "x" + "y");
  if b is Has(maybe) {
    if s := maybe {
      assert(s == "xy", "unwrapped optional payload in scope");
    } else {
      assert(false, "expected some");
    }
  }
}

// Optional heap payload copied to a same-scope local, read while subject alive.
opt_payload_store_inscope() `test {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  string? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  // `b` (the subject) is still alive here, so the alias is valid.
  if s := out {
    assert(s == "pq", "optional payload readable while subject alive");
  } else {
    assert(false, "expected some");
  }
}

// none-valued optional payload: elvis fallback, no unwrap.
opt_payload_none() `test {
  string? empty = none;
  OptBox b = OptBox.Has(maybe: move empty);
  if b is Has(maybe) {
    string got = maybe ?: "fallback";
    assert(got == "fallback", "none optional payload uses fallback");
  }
}

// Fixed-array heap payload read in-scope.
arr_payload_inscope() `test {
  ArrHolder h = ArrHolder.Pair(a: ["p" + "1", "q" + "2"]);
  if h is Pair(a) {
    assert(a[0] == "p1" && a[1] == "q2", "fixed-array heap payload in-scope read");
  }
}

// ============================================================================
// T1170: ESCAPING an Optional-of-heap or fixed-array-element match-borrowed
// payload out of the narrowing scope. The read/escape-side dup deep-clones so
// the escaped value survives the subject's synth enum drop. Covers BOTH `if is`
// and `match` (shared matchBorrowedIdents path). Each impl drops the subject at
// function exit; the caller reads the escaped value AFTER, so an un-cloned alias
// would be a use-after-free. Zero leaks are enforced by the batch-test policy.
// ============================================================================

type OptWrapper {
  string? held;
}
enum VecBox {
  Has(int[]? maybe), Nothing,
}

opt_unwrap(string? move s) string {
  if x := s {
    return x;
  }
  return "<none>";
}
opt_consume(string? move s) string {
  if x := s {
    return x + "!";
  }
  return "!";
}
vec_len(int[]? move v) int {
  if xs := v {
    return xs.len;
  }
  return -1;
}

// --- Optional[string] escape: store-to-outer, if is ---
opt_store_is_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  string? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  return out; // b dropped here; out must own an independent clone
}
opt_store_is() `test {
  assert(opt_unwrap(opt_store_is_impl()) == "pq", "opt[string] store-to-outer escape (if is)");
}

// --- Optional[string] escape: return, if is ---
opt_ret_is_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  if b is Has(maybe) {
    return maybe;
  }
  return none;
}
opt_ret_is() `test {
  assert(opt_unwrap(opt_ret_is_impl()) == "pq", "opt[string] return escape (if is)");
}

// --- Optional[string] escape: return + store, match ---
opt_ret_match_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  match b {
    Has(maybe) => {
      return maybe;
    }, Nothing => {
      return none;
    },
  }
}
opt_ret_match() `test {
  assert(opt_unwrap(opt_ret_match_impl()) == "pq", "opt[string] return escape (match)");
}
opt_store_match_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  string? out = none;
  match b {
    Has(maybe) => {
      out = maybe;
    }, Nothing => {
    },
  }
  return out;
}
opt_store_match() `test {
  assert(opt_unwrap(opt_store_match_impl()) == "pq", "opt[string] store-to-outer escape (match)");
}

// --- Optional[string] escape: consuming (~) arg ---
opt_consume_impl() string {
  OptBox b = OptBox.Has(maybe: "h" + "i");
  string r = "";
  if b is Has(maybe) {
    r = opt_consume(move maybe);
  }
  return r;
}
opt_consume_escape() `test {
  assert(opt_consume_impl() == "hi!", "opt[string] moved into consuming param");
}

// --- Optional[string] escape: constructor field (escapes via returned wrapper) ---
opt_ctor_impl() OptWrapper {
  OptBox b = OptBox.Has(maybe: "w" + "z");
  OptWrapper result = OptWrapper(held: none);
  if b is Has(maybe) {
    result = OptWrapper(held: maybe);
  }
  return result; // b dropped; result.held must be an independent clone
}
opt_ctor_escape() `test {
  OptWrapper w = opt_ctor_impl();
  if x := w.held {
    assert(x == "wz", "opt[string] moved into constructor field");
  } else {
    assert(false, "expected some");
  }
}

// --- fixed-array element escape: store-to-outer + return, if is ---
arr_elem_store_impl() string {
  ArrHolder h = ArrHolder.Pair(a: ["x" + "1", "y" + "2"]);
  string out = "";
  if h is Pair(a) {
    out = a[0];
  }
  return out; // h dropped; out must own an independent clone of a[0]
}
arr_elem_store() `test {
  assert(arr_elem_store_impl() == "x1", "string[N] element store-to-outer escape (if is)");
}
arr_elem_ret_impl() string {
  ArrHolder h = ArrHolder.Pair(a: ["x" + "1", "y" + "2"]);
  if h is Pair(a) {
    return a[1];
  }
  return "";
}
arr_elem_ret() `test {
  assert(arr_elem_ret_impl() == "y2", "string[N] element return escape (if is)");
}

// --- fixed-array element escape: match ---
arr_elem_match_impl() string {
  ArrHolder h = ArrHolder.Pair(a: ["x" + "1", "y" + "2"]);
  string out = "";
  match h {
    Pair(a) => {
      out = a[0];
    }, Empty => {
    },
  }
  return out;
}
arr_elem_match() `test {
  assert(arr_elem_match_impl() == "x1", "string[N] element store-to-outer escape (match)");
}

// --- Optional[Vector] escape: store-to-outer + return ---
vec_store_impl() int[]? {
  VecBox b = VecBox.Has(maybe: [1, 2, 3]);
  int[]? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  return out;
}
vec_store_escape() `test {
  assert(vec_len(vec_store_impl()) == 3, "opt[Vector] store-to-outer escape");
}
vec_ret_impl() int[]? {
  VecBox b = VecBox.Has(maybe: [4, 5]);
  match b {
    Has(maybe) => {
      return maybe;
    }, Nothing => {
      return none;
    },
  }
}
vec_ret_escape() `test {
  assert(vec_len(vec_ret_impl()) == 2, "opt[Vector] return escape (match)");
}

// --- T1174: Optional[heap-user-type] variant payload escaping if-is / match ---
// Sibling to T1170 (string?/Array). An `Optional[heap-user]` variant field (e.g.
// `Row?`) bound via `if is`/`match` is match-borrowed (matchBindingIsBorrow →
// borrowInnerHasDrop): it aliases the subject's variant payload. In-scope reads
// are sound (subject outlives the narrowing), but escaping the binding out of the
// scope was a use-after-free (SIGSEGV) — the subject's synth enum drop freed the
// payload at scope exit. The fix (dupBorrowedHeapUserPayload) deep-clones the
// inner heap value at each escape site so the destination owns an independent
// copy while the subject's drop still frees the original exactly once. In-scope
// bindings stay zero-copy (the dup is gated to explicit escape sites, not a
// read-side flag — preserving the T0512 nested-Optional invariant).
type T1174Row {
  string name;
}
enum T1174Box {
  Has(T1174Row? maybe), Nothing,
}
type T1174Wrap {
  T1174Row? held;
}

t1174_name(T1174Row? move r) string {
  if row := r {
    return row.name;
  }
  return "none";
}

// if-is: return escape (the reported repro).
t1174_ret_ifis_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "a" + "b"));
  if b is Has(maybe) {
    return maybe; // out aliases b's payload; b dropped at scope exit
  }
  return none;
}
t1174_ret_ifis() `test {
  assert(t1174_name(t1174_ret_ifis_impl()) == "ab", "if-is return escape survives");
}

// if-is: store-to-escaping-outer.
t1174_store_ifis_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "c" + "d"));
  T1174Row? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  return out;
}
t1174_store_ifis() `test {
  assert(t1174_name(t1174_store_ifis_impl()) == "cd", "if-is store-to-outer escape survives");
}

// match: return escape.
t1174_ret_match_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "e" + "f"));
  match b {
    Has(maybe) => {
      return maybe;
    },
    Nothing => {
      return none;
    },
  }
}
t1174_ret_match() `test {
  assert(t1174_name(t1174_ret_match_impl()) == "ef", "match return escape survives");
}

// match: store-to-escaping-outer.
t1174_store_match_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "g" + "h"));
  T1174Row? out = none;
  match b {
    Has(maybe) => {
      out = maybe;
    },
    Nothing => {
    },
  }
  return out;
}
t1174_store_match() `test {
  assert(t1174_name(t1174_store_match_impl()) == "gh", "match store-to-outer escape survives");
}

// Consuming-arg escape (~ move param).
t1174_consume(T1174Row? move r) string {
  if row := r {
    return row.name;
  }
  return "none";
}
t1174_consume_arg_impl() string {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "i" + "j"));
  if b is Has(maybe) {
    return t1174_consume(move maybe);
  }
  return "none";
}
t1174_consuming_arg() `test {
  assert(t1174_consume_arg_impl() == "ij", "payload moved into consuming param");
}

// Constructor-field escape: the borrowed payload is stored into an owned field.
// Reading an Optional[heap-user] field back out is a partial-move (rejected by
// sema), so the assertion here is drop-safety: the wrapper's field drop and the
// subject's synth enum drop must not free the same allocation (double-free /
// leak). Without the constructor-arg dup this SIGSEGVs; the leak checker also
// guards against an aliasing regression.
t1174_ctor_field_impl() bool {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "k" + "l"));
  bool ok = false;
  if b is Has(maybe) {
    T1174Wrap w = T1174Wrap(held: maybe);
    ok = true;
    // w and b both drop at scope exit — must be independent copies.
  }
  return ok;
}
t1174_constructor_field() `test {
  assert(t1174_ctor_field_impl(), "payload copied into constructor field (drop-safe)");
}

// In-scope guard: no escape → zero-copy borrow, correct value, no leak. An
// over-eager dup here would be caught by the leak checker.
t1174_inscope() `test {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "m" + "n"));
  if b is Has(maybe) {
    if r := maybe {
      assert(r.name == "mn", "in-scope Optional[heap-user] read");
    } else {
      assert(false, "expected some");
    }
  }
  // Subject still usable after the borrow-narrowing `if`.
  if b is Has(again) {
    if r := again {
      assert(r.name == "mn", "subject intact after if");
    }
  }
}

// Vector-push escape: `v.push(maybe)` moves the borrowed Optional[heap-user]
// payload into a vector (sema treats the destructure binding as owned, so the
// push type-checks). The push path is a native special-case that bypasses the
// escape-site dups above — it must deep-clone the Optional[heap-user] element
// itself (maybeDupPushElement's Optional branch) or the vector slot aliases the
// subject's payload → double-free when both drop.
t1174_push_ifis_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "o" + "p"));
  T1174Row?[] v = [];
  if b is Has(maybe) {
    v.push(maybe);
  }
  T1174Row? out = none;
  if v.len > 0 {
    out = v[0];
  }
  return out;
}
t1174_push_ifis() `test {
  assert(t1174_name(t1174_push_ifis_impl()) == "op", "vec push escape survives");
}

// Vector[Optional[heap-user]] slice: `v[a:b]` copies each element slot. Without
// the same Optional[heap-user] element dup, the sliced vector's slot aliases the
// source vector's payload → double-free at drop. (Pre-existing, independent of
// if-is; shares maybeDupPushElement's Optional branch.)
t1174_slice_impl() T1174Row?[] {
  T1174Row?[] v = [];
  v.push(T1174Row(name: "q" + "r"));
  v.push(T1174Row(name: "s" + "t"));
  return v[0:1];
}
t1174_slice() `test {
  T1174Row?[] s = t1174_slice_impl();
  assert(s.len == 1, "sliced length");
  if r := s[0] {
    assert(r.name == "qr", "sliced Optional[heap-user] element intact");
  } else {
    assert(false, "expected some in slice");
  }
}

// --- T1174 coverage gaps: member/index assign targets + no-drop heap-user ---
// The escape-site dup in genAssignStmt runs on `val` before dispatch to
// genMemberAssign / genIndexAssign, so a member- or index-target assignment of a
// match-borrowed Optional[heap-user] payload must be as drop-safe as the plain
// ident-target case above. And optionalHeapDupElem admits BOTH droppable heap
// user types (T1174Row, via isDroppableHeapUserType) AND no-drop-but-heap types
// (via isHeapUserNoDropPalFree); the tests above only exercise the droppable
// branch. These pin the remaining branches.

// no-drop heap user type: all-scalar field → heap-allocated but no drop/synth-drop
// (isHeapUserNoDropPalFree). Escaping `P?` must still deep-clone (pal_free path),
// else the returned alias is freed by the subject's synth enum drop → UAF.
type T1174P {
  int x;
}
enum T1174PBox {
  Has(T1174P? maybe), Nothing,
}
t1174_p_value(T1174P? move r) int {
  if p := r {
    return p.x;
  }
  return -1;
}
t1174_nodrop_ret_impl() T1174P? {
  T1174PBox b = T1174PBox.Has(maybe: T1174P(x: 41 + 1));
  if b is Has(maybe) {
    return maybe;
  }
  return none;
}
t1174_nodrop_ret() `test {
  assert(t1174_p_value(t1174_nodrop_ret_impl()) == 42, "no-drop heap-user return escape survives");
}

// member-target assign: `hold.h = maybe` stores the borrowed payload into an owned
// field. genMemberAssign drops the old field value and takes the fresh clone; the
// subject's synth enum drop still frees the original once. Drop-safety (no
// double-free / leak) is the invariant — reading an Optional[heap-user] field back
// out is a partial move (sema-rejected), so we assert via a scalar sibling field.
type T1174Hold {
  T1174Row? h;
  int tag;
}
t1174_member_impl() int {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "u" + "v"));
  T1174Hold hold = T1174Hold(h: none, tag: 0);
  if b is Has(maybe) {
    hold.h = maybe; // drops old `none`, takes independent clone
    hold.tag = 7;
  }
  return hold.tag;
}
t1174_member_target() `test {
  assert(t1174_member_impl() == 7, "member-target Optional[heap-user] assign escape drop-safe");
}

// index-target assign: `v[0] = maybe` overwrites a vector slot. genIndexAssign
// drops the old slot value and stores the fresh clone; the sliced/read-back value
// is an independent copy, and both the vector and subject drop exactly once.
t1174_index_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "w" + "x"));
  T1174Row?[] v = [];
  v.push(none);
  if b is Has(maybe) {
    v[0] = maybe;
  }
  T1174Row? out = none;
  if v.len > 0 {
    out = v[0];
  }
  return out;
}
t1174_index_target() `test {
  assert(t1174_name(t1174_index_impl()) == "wx", "index-target Optional[heap-user] assign escape survives");
}

// --- T1171: whole fixed-Array-of-heap-user variant payload escaping if-is / match ---
// Sibling to T1174 (Optional[heap-user]) and T1170/T1173 (string[N]/container arrays).
// A `Row[N]` variant field bound via `if is`/`match` is match-borrowed: the
// [N x {vtable,instance}] aggregate merely ALIASES the subject's N inner heap
// instances. In-scope reads are sound, but escaping the whole array out of the
// scope was a use-after-free (SIGSEGV) — the subject's synth enum drop freed each
// element at scope exit while the escaped copy still pointed into it. The fix
// (dupBorrowedHeapUserPayload's Array branch → arrayHeapDupElem) element-wise
// deep-clones the aggregate at each escape site so the destination owns
// independent instances; the subject's drop still frees the originals once.
// In-scope bindings stay zero-copy (gated to explicit escape sites).
type T1171Row {
  string name;
}
enum T1171Box {
  Some(T1171Row[2] value), Empty,
}
type T1171Wrap {
  T1171Row[2] rows;
  int tag;
}

// if-is: return escape (the reported repro).
t1171_ret_ifis_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  if w is Some(value) {
    return value; // value aliases w's payload; w dropped at scope exit
  }
  return[T1171Row(name: "BAD"), T1171Row(name: "BAD2")];
}
t1171_ret_ifis() `test {
  T1171Row[2] r = t1171_ret_ifis_impl();
  assert(r[0].name == "deep", "if-is return escape survives (elem 0)");
  assert(r[1].name == "xx", "if-is return escape survives (elem 1)");
}

// match: return escape.
t1171_ret_match_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  match w {
    Some(value) => {
      return value;
    },
    Empty => {
      return[T1171Row(name: "BAD"), T1171Row(name: "BAD2")];
    },
  }
}
t1171_ret_match() `test {
  T1171Row[2] r = t1171_ret_match_impl();
  assert(r[0].name == "deep", "match return escape survives (elem 0)");
  assert(r[1].name == "xx", "match return escape survives (elem 1)");
}

// if-is: store-to-escaping-outer.
t1171_store_ifis_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] out = [T1171Row(name: "D0"), T1171Row(name: "D1")];
  if w is Some(value) {
    out = value; // drops old default array, takes independent clone
  }
  return out;
}
t1171_store_ifis() `test {
  T1171Row[2] r = t1171_store_ifis_impl();
  assert(r[0].name == "deep", "if-is store-to-outer escape survives");
}

// match: store-to-escaping-outer.
t1171_store_match_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] out = [T1171Row(name: "D0"), T1171Row(name: "D1")];
  match w {
    Some(value) => {
      out = value;
    },
    Empty => {
    },
  }
  return out;
}
t1171_store_match() `test {
  T1171Row[2] r = t1171_store_match_impl();
  assert(r[0].name == "deep", "match store-to-outer escape survives");
}

// Consuming-arg escape (~ move param): the whole array is moved into a consuming
// param after the store escape.
t1171_consume(T1171Row[2] move r) string {
  return r[0].name;
}
t1171_consume_arg_impl() string {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] out = [T1171Row(name: "D0"), T1171Row(name: "D1")];
  if w is Some(value) {
    out = value;
  }
  return t1171_consume(move out);
}
t1171_consuming_arg() `test {
  assert(t1171_consume_arg_impl() == "deep", "array moved into consuming param");
}

// Constructor-field escape: the borrowed array is stored into an owned field.
// Reading a whole heap-user array field back out is a separate escape sink
// (field-access-of-array, out of scope for T1171), so — as with T1174's
// constructor-field test — the invariant here is drop-safety: the wrapper's
// field drop and the subject's synth enum drop must not free the same
// allocation (double-free / leak). We assert via a scalar sibling field.
t1171_ctor_field_impl() int {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  int tag = 0;
  if w is Some(value) {
    T1171Wrap wr = T1171Wrap(rows: value, tag: 9); // wr and w both drop — independent copies
    tag = wr.tag;
  }
  return tag;
}
t1171_constructor_field() `test {
  assert(t1171_ctor_field_impl() == 9, "array copied into constructor field (drop-safe)");
}

// In-scope guard: no escape → zero-copy borrow, correct value, no leak. An
// over-eager dup here would be caught by the leak checker.
t1171_inscope() `test {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "m" + "n"), T1171Row(name: "o" + "p")]);
  if w is Some(value) {
    assert(value[0].name == "mn", "in-scope Array[heap-user] read");
  }
  // Subject still usable after the borrow-narrowing `if`.
  if w is Some(again) {
    assert(again[1].name == "op", "subject intact after if");
  }
}

// no-drop element parity: arrayHeapDupElem admits BOTH droppable heap-user
// elements (T1171Row, via isDroppableHeapUserType) AND no-drop-but-heap elements
// (via isHeapUserNoDropPalFree) — the tests above only exercise the droppable
// branch. An all-scalar-field element type is heap-allocated but has no
// drop/synth-drop, so it takes the pal_free clone path (the T0484-caveated one).
// Escaping the array must still element-wise deep-clone, else the returned
// aggregate aliases the subject's payload → freed by the subject's synth enum
// drop → UAF. Mirror of t1174_nodrop_ret for the fixed-Array shape.
type T1171P {
  int x;
}
enum T1171PBox {
  Has(T1171P[2] cells), Nothing,
}
t1171_nodrop_ret_impl() T1171P[2] {
  T1171PBox b = T1171PBox.Has(cells: [T1171P(x: 41 + 1), T1171P(x: 7)]);
  if b is Has(cells) {
    return cells;
  }
  return[T1171P(x: -1), T1171P(x: -2)];
}
t1171_nodrop_ret() `test {
  T1171P[2] r = t1171_nodrop_ret_impl();
  assert(r[0].x == 42, "no-drop heap-user array return escape survives (elem 0)");
  assert(r[1].x == 7, "no-drop heap-user array return escape survives (elem 1)");
}

// Generic / monomorphized context: the array-of-heap-user payload lives in a
// GENERIC enum `GBox[T]` whose variant field type is `T[2]`. Inside the
// monomorphized `gesc[Row]`, the escape sink resolves the element type through
// c.typeSubst (T → Row) — both in dupBorrowedHeapUserPayload (t = Substitute(...))
// and in arrayHeapDupElem (elem = Substitute(arr.Elem(), ...)). Without those
// substitutions the recognizer would miss the array shape and the escaped
// aggregate would alias the moved-in subject's payload → UAF. This is the only
// case that exercises the typeSubst branches of both helpers.
enum T1171GBox[T] {
  Some(T[2] value), Empty,
}
t1171_gesc[T](T1171GBox[T] move b, T[2] fallback) T[2] {
  if b is Some(value) {
    return value;
  }
  return fallback;
}
t1171_generic() `test {
  T1171GBox[T1171Row] b = T1171GBox[T1171Row].Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] fb = [T1171Row(name: "BAD"), T1171Row(name: "BAD2")];
  T1171Row[2] r = t1171_gesc(move b, fb);
  assert(r[0].name == "deep", "generic array-of-heap-user escape survives (elem 0)");
  assert(r[1].name == "xx", "generic array-of-heap-user escape survives (elem 1)");
}
