// propmod — test module for module-level getters and setters.
type PropError is error `public {
  int code;
}

// Module-level getter returning a constant.
get greeting string `public `doc("Returns a greeting.") {
  return "hello from propmod";
}

// Module-level getter returning a computed value.
get answer int `public `doc("Returns the answer.") {
  return 6 * 7;
}

// Failable getter — returns string! (success case).
get safe_value! string `public `doc("Returns a value or raises.") {
  return "safe";
}

// Failable getter that always raises.
get risky_value! string `public `doc("Always raises an error.") {
  raise PropError(code: 42, message: "risky error");
}

// Optional getter — returns string? (present case).
get maybe_value string? `public `doc("Returns an optional value.") {
  return "present";
}

// Optional getter that returns none.
get empty_value string? `public `doc("Returns none.") {
  return none;
}

// Regular function for comparison.
add(int a, int b) int `public `doc("Adds two integers.") {
  return a + b;
}

// A small value-carrying type for the struct-getter coverage below.
type Pt `public `doc("A 2D point.") {
  int x;
  int y;
}

// Getter returning a vector — must still bind correctly (T1240 regression).
get nums int[] `public `doc("Returns a vector of ints.") {
  return[1, 2, 3];
}

// Getter returning a user struct — must still bind correctly (T1240 regression).
get origin Pt `public `doc("Returns a point.") {
  return Pt(x: 4, y: 5);
}

// Getter returning a HEAP string (concatenation, not a .rodata literal) — used
// as a bare temporary this exercises the string arm of the shared getter-result
// tracking on the module-getter path (T0137/T1250). A literal string would carry
// the .rodata flag and free to a no-op, so the concatenation forces a real malloc.
get built_greeting string `public `doc("Returns a heap-built greeting string.") {
  return "hello " + "from " + "heap";
}

// Getter returning a HEAP vector (built dynamically, not a static literal) —
// used as a bare temporary this leaked before T1250 (the module-getter path
// only tracked heap user types, not vectors/channels). Regression guard.
get built_nums int[] `public `doc("Returns a heap-built vector of ints.") {
  v := [10];
  v.push(20);
  v.push(30);
  return v;
}

// Getter returning a buffered channel — used as a bare temporary this leaked
// before T1250 (module-getter path did not track channel results). Regression
// guard for the Channel arm of the shared getter-result tracking.
get numbers channel[int] `public `doc("Returns a buffered channel with one value.") {
  c := channel[int](2);
  c.send(99);
  return c;
}

// Getter whose return type is itself a function type, built from a CAPTURING
// closure. Reading it (`propmod.adder`) used to panic codegen: the Signature
// result type was misclassified as a function reference (T1240).
get adder() -> int `public `doc("Returns a closure capturing a local.") {
  base := 41;
  return move || -> base + 1;
}

// Function-typed getter built from a NON-capturing closure (T1240 regression).
get plain_fn() -> int `public `doc("Returns a non-capturing closure.") {
  return || -> 7;
}

// Getter returning a CAPTURING closure that takes an argument — exercises the
// argument-coercion arm of the T1251 direct-call path (`propmod.scaler(x)`).
get scaler(int) -> int `public `doc("Returns a closure that scales its argument.") {
  factor := 10;
  return move |int x| -> x * factor;
}

// T1272: getter returning a fresh heap Builder — used as a bare-temporary
// argument to a `~` (MutRef) parameter (`emit(propmod.fresh_builder, …)`) this
// exercises the `ModuleGetters` branch of isMemberGetter's materialize-and-track
// path. The owned Builder must be dropped at statement end (leak check enforces).
get fresh_builder Builder `public `doc("Returns a fresh heap Builder.") {
  return Builder();
}
