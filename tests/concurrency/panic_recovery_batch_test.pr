// B0130: Goroutine panic recovery in batch test mode.
// Previously, the first goroutine in a batch test got G.id=0 (reserved for main),
// so promise_panic treated it as a main-goroutine panic and exited the process
// instead of recovering via the scheduler.
// Fire-and-forget goroutine panic should be silently recovered.
test_goroutine_panic_fire_forget() `test(exclude: "wasm32") {
  go {
    assert(false, "boom ff");
  };
  // Give the goroutine time to run and panic
  x := 0;
  i := 0;
  while i < 10000000 {
    x = x + 1;
    i = i + 1;
  }
  assert(x == 10000000, "main continued after goroutine panic");
}

// Goroutine that sends to channel then panics: receiver should still get the value.
test_goroutine_panic_after_send() `test(allow_leaks: true, exclude: "wasm32") {
  ch := channel[int](capacity: 2);
  go {
    ch.send(42);
    assert(false, "boom after send");
  };
  r := <-ch;
  if v := r {
    assert(v == 42, "got 42");
  }
}

// Multiple goroutines: one panics, others succeed.
test_goroutine_panic_one_of_many() `test(allow_leaks: true, exclude: "wasm32") {
  ch := channel[int](capacity: 4);
  go {
    ch.send(1);
  };
  go {
    ch.send(2);
    assert(false, "boom");
  };
  go {
    ch.send(3);
  };

  results := int[]();
  i := 0;
  while i < 3 {
    r := <-ch;
    if v := r {
      results.push(v);
    }
    i = i + 1;
  }
  assert(results.len == 3, "all three sends received");
}
