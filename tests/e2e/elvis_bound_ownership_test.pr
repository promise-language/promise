// T0940 (subsumes T0981): a BOUND elvis `m := a ?: b` whose result is a Map/Set,
// droppable heap user type, string, vector, or single-owner native handle must give
// the bound variable a PER-PATH owning drop — it owns the selected operand only on a
// path where that operand was orphaned (some-path inner) or neutralized (none-path
// owned-local / fresh-temp default), and BORROWS an operand that keeps a real owner
// (borrowed param / container member). Pre-fix, the bound variable took an
// unconditional owning drop, double-freeing a caller-/container-owned operand on the
// none-path (Map/heap-user/Mutex: SEGV / invalid free) and leaking nothing — and an
// orphaned some-path inner was untracked → leak.
//
// All operands here are HEAP-allocated (no `.rodata` literals) so a double-free is a
// real second free, not a no-op on a static buffer (the masking T0936 warned about).
// Every test asserts the expected value (proving single-free / no SEGV) and the whole
// file runs under the zero-leak gate.
type HeapBox {
  int[] data;
}
type Holder {
  HeapBox h;
}

// --- Map: bound none-path ---

t_map_none_owned_local() `test {
  map[string, int]? a = none;
  map[string, int] b = map[string, int]();
  b["k"] = 9;
  m := a ?: b;
  assert(m.len == 1, "map none owned-local");
}

t_map_none_fresh_temp() `test {
  map[string, int]? a = none;
  m := a ?: map[string, int]();
  assert(m.len == 0, "map none fresh-temp");
}

type MapHolder {
  map[string, int] m;
}
t_map_none_member_alias() `test {
  map[string, int]? a = none;
  MapHolder bx = MapHolder(m: map[string, int]());
  bx.m["x"] = 1;
  bx.m["y"] = 2;
  m := a ?: bx.m; // default aliases bx.m (struct-owned) → m borrows
  assert(m.len == 2, "map none member-alias");
  assert(bx.m.len == 2, "holder map still valid");
}

map_none_param(map[string, int]? a, map[string, int] b) int {
  m := a ?: b; // borrowed-param default → m borrows on none-path
  return m.len;
}
t_map_none_borrowed_param() `test {
  map[string, int] b = map[string, int]();
  b["k"] = 9;
  b["j"] = 8;
  r := map_none_param(none, b);
  assert(r == 2, "map none borrowed-param");
  assert(b.len == 2, "b still valid after call");
}

// --- Map: bound some-path ---

t_map_some_owned_local() `test {
  map[string, int] av = map[string, int]();
  av["x"] = 1;
  av["y"] = 2;
  av["z"] = 3;
  map[string, int]? a = av;
  map[string, int] b = map[string, int]();
  b["k"] = 9;
  m := a ?: b;
  assert(m.len == 3, "map some owned-local");
}

map_some_param(map[string, int]? a, map[string, int] b) int {
  m := a ?: b; // borrowed-param SOURCE on some-path → m borrows
  return m.len;
}
t_map_some_borrowed_param() `test {
  map[string, int] sv = map[string, int]();
  sv["x"] = 1;
  sv["y"] = 2;
  map[string, int]? src = sv; // moves sv into src
  map[string, int] def = map[string, int]();
  r := map_some_param(src, def); // borrows src and def — neither is freed in callee
  assert(r == 2, "map some borrowed-param");
  // src and def remain owned here; each freed exactly once at scope exit (the
  // zero-leak gate proves the callee did not also free the borrowed source).
}

// --- Set ---

t_set_none_owned_local() `test {
  Set[int]? a = none;
  Set[int] b = Set[int]();
  b.add(1);
  b.add(2);
  m := a ?: b;
  assert(m.len == 2, "set none owned-local");
}

t_set_some_owned_local() `test {
  Set[int] av = Set[int]();
  av.add(1);
  av.add(2);
  av.add(3);
  Set[int]? a = av;
  Set[int] b = Set[int]();
  b.add(9);
  m := a ?: b;
  assert(m.len == 3, "set some owned-local");
}

set_none_param(Set[int]? a, Set[int] b) int {
  m := a ?: b;
  return m.len;
}
t_set_none_borrowed_param() `test {
  Set[int] b = Set[int]();
  b.add(1);
  b.add(2);
  b.add(3);
  r := set_none_param(none, b);
  assert(r == 3, "set none borrowed-param");
  assert(b.len == 3, "set b still valid");
}

// --- Heap user type ---

t_heapuser_none_owned_local() `test {
  HeapBox? a = none;
  HeapBox b = HeapBox(data: []);
  b.data.push(7);
  m := a ?: b;
  assert(m.data.len == 1, "heapuser none owned-local");
}

t_heapuser_none_fresh_temp() `test {
  HeapBox? a = none;
  m := a ?: HeapBox(data: []);
  assert(m.data.len == 0, "heapuser none fresh-temp");
}

t_heapuser_none_member_alias() `test {
  HeapBox? a = none;
  Holder bx = Holder(h: HeapBox(data: []));
  bx.h.data.push(5);
  m := a ?: bx.h; // default aliases bx.h (struct-owned) → m borrows
  assert(m.data.len == 1, "heapuser none member-alias");
}

heapuser_none_param(HeapBox? a, HeapBox b) int {
  m := a ?: b;
  return m.data.len;
}
t_heapuser_none_borrowed_param() `test {
  HeapBox b = HeapBox(data: []);
  b.data.push(1);
  b.data.push(2);
  r := heapuser_none_param(none, b);
  assert(r == 2, "heapuser none borrowed-param");
  assert(b.data.len == 2, "heapuser b still valid");
}

t_heapuser_some_owned_local() `test {
  HeapBox av = HeapBox(data: []);
  av.data.push(1);
  av.data.push(2);
  HeapBox? a = av;
  HeapBox b = HeapBox(data: []);
  m := a ?: b;
  assert(m.data.len == 2, "heapuser some owned-local");
}

heapuser_some_param(HeapBox? a, HeapBox b) int {
  m := a ?: b; // borrowed-param SOURCE on some-path → m borrows
  return m.data.len;
}
t_heapuser_some_borrowed_param() `test {
  HeapBox sv = HeapBox(data: []);
  sv.data.push(7);
  HeapBox? src = sv; // moves sv into src
  HeapBox def = HeapBox(data: []);
  r := heapuser_some_param(src, def); // borrows src and def — neither is freed in callee
  assert(r == 1, "heapuser some borrowed-param");
  // src and def remain owned here; freed once each at scope exit (zero-leak gate).
}

// --- string (heap via repeat) ---

t_string_none_owned_local() `test {
  string? a = none;
  string b = "ab".repeat(3);
  m := a ?: b;
  assert(m.len == 6, "string none owned-local");
}

string_none_param(string? a, string b) int {
  m := a ?: b;
  return m.len;
}
t_string_none_borrowed_param() `test {
  string b = "xy".repeat(4);
  r := string_none_param(none, b);
  assert(r == 8, "string none borrowed-param");
  assert(b.len == 8, "string b still valid");
}

// --- int[] (heap via push) ---

t_vec_none_owned_local() `test {
  int[]? a = none;
  int[] b = [];
  b.push(1);
  b.push(2);
  b.push(3);
  m := a ?: b;
  assert(m.len == 3, "vec none owned-local");
}

vec_none_param(int[]? a, int[] b) int {
  m := a ?: b;
  return m.len;
}
t_vec_none_borrowed_param() `test {
  int[] b = [];
  b.push(1);
  b.push(2);
  r := vec_none_param(none, b);
  assert(r == 2, "vec none borrowed-param");
  assert(b.len == 2, "vec b still valid");
}

// --- Mutex handle (T0981 subsumption) ---

t_mutex_none_owned_local() `test {
  Mutex[int]? a = none;
  Mutex[int] b = Mutex[int](5);
  m := a ?: b;
  g := m.lock();
  assert(g.borrow == 5, "mutex none owned-local");
}

mutex_none_param(Mutex[int]? a, Mutex[int] b) int {
  m := a ?: b; // borrowed-param default → m borrows on none-path
  g := m.lock();
  return g.borrow;
}
t_mutex_none_borrowed_param() `test {
  Mutex[int] b = Mutex[int](7);
  r := mutex_none_param(none, b);
  assert(r == 7, "mutex none borrowed-param");
  g := b.lock();
  assert(g.borrow == 7, "mutex b still valid");
}

// --- Member-source on some-path: the bound binding dup-clones the field, so the
// bound variable OWNS the fresh clone (T0940 regression guard for the dup-on-read
// path). For Vector/string fields a clone happens (binding owns it); the container
// keeps the original — exactly one free of each.

type VecBox {
  int[]? v;
}
t_vec_some_member_source() `test {
  VecBox bx = VecBox(v: none);
  int[] inner = [];
  inner.push(1);
  inner.push(2);
  bx.v = inner;
  int[] x = (bx.v ?: [0]); // some-path: bx.v dup-cloned → x owns the clone
  assert(x.len == 2, "vec some member-source");
  assert(bx.v!.len == 2, "vecbox field still valid");
}

type StrBox {
  string? s;
}
t_string_some_member_source() `test {
  StrBox bx = StrBox(s: none);
  bx.s = "ab".repeat(3);
  string x = (bx.s ?: ""); // some-path: bx.s dup-cloned → x owns the clone
  assert(x.len == 6, "string some member-source");
  assert(bx.s!.len == 6, "strbox field still valid");
}

// --- Member-source on some-path, 2-word value-struct reprs (Map / heap-user): unlike
// Vector/string, setDupFlagsForFieldAccess does NOT dup-clone these, so the bound
// binding BORROWS the field's inner on the some-path (someOwnsInner stays false). This
// exercises the MemberExpr arm of genElvis's boundSourceDupCloned snapshot resolving to
// false. The holder still owns and frees the field exactly once at its own scope exit
// (it outlives the borrow), so there is no double-free and no leak — the bound variable
// must NOT take a second owning drop. (Companion of the Vector/string dup-clone tests
// above, which take the OWNED path.)

type MapBox {
  map[string, int]? m;
}
t_map_some_member_source() `test {
  MapBox bx = MapBox(m: none);
  map[string, int] inner = map[string, int]();
  inner["a"] = 1;
  inner["b"] = 2;
  bx.m = inner;
  map[string, int] def = map[string, int]();
  map[string, int] x = (bx.m ?: def); // some-path: x borrows bx.m (2-word, not cloned)
  assert(x.len == 2, "map some member-source");
  assert(bx.m!.len == 2, "mapbox field still valid");
}

type HBoxOpt {
  HeapBox? hb;
}
t_heapuser_some_member_source() `test {
  HBoxOpt bx = HBoxOpt(hb: none);
  HeapBox inner = HeapBox(data: []);
  inner.data.push(1);
  inner.data.push(2);
  bx.hb = inner;
  HeapBox def = HeapBox(data: []);
  HeapBox m = (bx.hb ?: def); // some-path: m borrows bx.hb (heap-user, not cloned)
  assert(m.data.len == 2, "heapuser some member-source");
  assert(bx.hb!.data.len == 2, "hboxopt field still valid");
}

// --- Mixed: borrowed-param SOURCE on some + owned-local default neutralized on none

mix_heapuser(HeapBox? a, HeapBox b) int {
  m := a ?: b;
  return m.data.len;
}
t_mixed_some_param_source() `test {
  HeapBox sv = HeapBox(data: []);
  sv.data.push(1);
  sv.data.push(2);
  HeapBox? src = sv; // moves sv into src
  HeapBox def = HeapBox(data: []);
  r := mix_heapuser(src, def); // borrows src and def
  assert(r == 2, "mixed some param-source");
  // src and def remain owned here; freed once each at scope exit (zero-leak gate).
}
t_mixed_none() `test {
  HeapBox def = HeapBox(data: []);
  def.data.push(9);
  r := mix_heapuser(none, def);
  assert(r == 1, "mixed none");
}

// ===========================================================================
// T1014: the ASSIGNMENT counterpart `m = a ?: b`. genAssignStmt used to discard
// the per-path bound flag genElvis produced (the some-path borrowed-param case
// double-freed the caller-owned inner). The fix stores the phi into the target's
// drop flag, mirroring consumeElvisBoundDropFlag on the var-decl path. All cases
// run under the zero-leak gate; a some-path double-free would be `fatal: double
// free`, a none-path over-drop a SEGV/invalid-free, and an under-drop a leak.
// ===========================================================================

// --- some-path, borrowed-param source (the repro): target aliases the caller-
// owned inner; must NOT take a second owning drop at scope exit.
heapuser_assign_some(HeapBox? a, HeapBox b) int {
  m := HeapBox(data: []);
  m = a ?: b; // some-path: m aliases borrowed a's inner
  return m.data.len;
}
t_assign_heapuser_some_borrowed_param() `test {
  HeapBox sv = HeapBox(data: []);
  sv.data.push(7);
  HeapBox? src = sv; // moves sv into src
  HeapBox def = HeapBox(data: []);
  r := heapuser_assign_some(src, def); // borrows src and def
  assert(r == 1, "assign heapuser some borrowed-param");
  // src and def remain owned here; freed once each at scope exit (zero-leak gate).
}

// --- none-path, borrowed-param default: target borrows b; no double-free, no leak.
heapuser_assign_none(HeapBox? a, HeapBox b) int {
  m := HeapBox(data: []);
  m = a ?: b; // none-path: m borrows b
  return m.data.len;
}
t_assign_heapuser_none_borrowed_param() `test {
  HeapBox b = HeapBox(data: []);
  b.data.push(1);
  b.data.push(2);
  r := heapuser_assign_none(none, b);
  assert(r == 2, "assign heapuser none borrowed-param");
  assert(b.data.len == 2, "assign heapuser b still valid");
}

// --- some-path, owned-local source: target owns the moved-out inner; the phi's
// `1` branch must be honored (source's flag cleared) → no leak, no double-free.
t_assign_heapuser_some_owned_local() `test {
  HeapBox av = HeapBox(data: []);
  av.data.push(1);
  av.data.push(2);
  HeapBox? a = av;
  HeapBox b = HeapBox(data: []);
  m := HeapBox(data: []);
  m = a ?: b; // some-path: m owns a's moved-out inner
  assert(m.data.len == 2, "assign heapuser some owned-local");
}

// --- Map variant (2-word value struct), exercising elvisResultHeapDrop on the
// assignment path.
map_assign_some(map[string, int]? a, map[string, int] b) int {
  m := map[string, int]();
  m = a ?: b; // some-path: m borrows a's inner
  return m.len;
}
t_assign_map_some_borrowed_param() `test {
  map[string, int] sv = map[string, int]();
  sv["x"] = 1;
  sv["y"] = 2;
  map[string, int]? src = sv;
  map[string, int] def = map[string, int]();
  r := map_assign_some(src, def);
  assert(r == 2, "assign map some borrowed-param");
}

map_assign_none(map[string, int]? a, map[string, int] b) int {
  m := map[string, int]();
  m = a ?: b; // none-path: m borrows b
  return m.len;
}
t_assign_map_none_borrowed_param() `test {
  map[string, int] b = map[string, int]();
  b["k"] = 9;
  b["j"] = 8;
  r := map_assign_none(none, b);
  assert(r == 2, "assign map none borrowed-param");
  assert(b.len == 2, "assign map b still valid");
}

// --- Set variant.
t_assign_set_some_owned_local() `test {
  Set[int] av = Set[int]();
  av.add(1);
  av.add(2);
  av.add(3);
  Set[int]? a = av;
  Set[int] b = Set[int]();
  m := Set[int]();
  m = a ?: b; // some-path: m owns a's moved-out inner
  assert(m.len == 3, "assign set some owned-local");
}

// --- string variant (instance-ptr repr): the flag store must coexist with the
// string drop-old of the target's prior value. some/none borrowed-param.
string_assign_some(string? a, string b) int {
  m := "init";
  m = a ?: b; // some-path: m aliases borrowed a's inner
  return m.len;
}
t_assign_string_some_borrowed_param() `test {
  string sv = "ab".repeat(4); // heap (non-literal)
  string? src = sv;
  string def = "xyz".repeat(2);
  r := string_assign_some(src, def);
  assert(r == 8, "assign string some borrowed-param");
}

string_assign_none(string? a, string b) int {
  m := "init";
  m = a ?: b; // none-path: m borrows b
  return m.len;
}
t_assign_string_none_borrowed_param() `test {
  string b = "hello".repeat(2);
  r := string_assign_none(none, b);
  assert(r == 10, "assign string none borrowed-param");
  assert(b.len == 10, "assign string b still valid");
}

// --- vector variant (3-word struct, COW drop-old): some/none borrowed-param.
vec_assign_some(int[]? a, int[] b) int {
  m := [99];
  m = a ?: b; // some-path: m aliases borrowed a's inner
  return m.len;
}
t_assign_vec_some_borrowed_param() `test {
  int[] sv = [];
  sv.push(1);
  sv.push(2);
  sv.push(3);
  int[]? src = sv;
  int[] def = [];
  def.push(0);
  r := vec_assign_some(src, def);
  assert(r == 3, "assign vec some borrowed-param");
}

vec_assign_none(int[]? a, int[] b) int {
  m := [99];
  m = a ?: b; // none-path: m borrows b
  return m.len;
}
t_assign_vec_none_borrowed_param() `test {
  int[] b = [];
  b.push(1);
  b.push(2);
  r := vec_assign_none(none, b);
  assert(r == 2, "assign vec none borrowed-param");
  assert(b.len == 2, "assign vec b still valid");
}

// --- none-path owned-local default on the assignment path: the none dimension is
// hardcoded `1` (m owns the moved-in default b). Complements the borrowed-param
// none tests above.
t_assign_heapuser_none_owned_local() `test {
  HeapBox? a = none;
  HeapBox b = HeapBox(data: []);
  b.data.push(1);
  b.data.push(2);
  m := HeapBox(data: []);
  m = a ?: b; // none-path owned-local: m owns b (moved into elvis default)
  assert(m.data.len == 2, "assign heapuser none owned-local");
}

// --- member-source on the some-path, assignment target: the elvis phi's
// some-branch value flows from the source's dup-clone/borrow classification into
// the reassigned target's drop flag. Vector/string fields are dup-cloned → target
// OWNS the clone (phi some-branch = 1); Map/heap-user fields are not cloned →
// target BORROWS the field's inner (phi some-branch = 0). Both must free exactly
// once — the target on the owned path, the holder on the borrowed path.
t_assign_vec_some_member_source() `test {
  VecBox bx = VecBox(v: none);
  int[] inner = [];
  inner.push(1);
  inner.push(2);
  bx.v = inner;
  int[] x = [7]; // pre-existing owned value, dropped on reassign
  x = (bx.v ?: [0]); // some-path: bx.v dup-cloned → x owns the clone
  assert(x.len == 2, "assign vec some member-source");
  assert(bx.v!.len == 2, "vecbox field still valid");
}
t_assign_map_some_member_source() `test {
  MapBox bx = MapBox(m: none);
  map[string, int] inner = map[string, int]();
  inner["a"] = 1;
  inner["b"] = 2;
  bx.m = inner;
  map[string, int] def = map[string, int]();
  map[string, int] x = map[string, int]();
  x["z"] = 9; // pre-existing owned value, dropped on reassign
  x = (bx.m ?: def); // some-path: x borrows bx.m (2-word, not cloned)
  assert(x.len == 2, "assign map some member-source");
  assert(bx.m!.len == 2, "mapbox field still valid");
}

// ===========================================================================
// T1166: member/index-TARGET bound elvis `hold.h = a ?: b`, `v[i] = a ?: b`.
// A field/element is an OWNED slot with no per-path drop flag — it is dropped
// unconditionally by the container's synthesized drop. So on a borrowed some/
// none path the field/element cannot hold a borrow-alias; genElvis force-clones
// the borrowed operand so the slot owns an independent copy (the caller/container
// keeps the original). Pre-fix these double-freed the caller-owned inner → SEGV.
// All operands are heap-allocated, so a double-free is a real second free; the
// whole file runs under the zero-leak gate.
// ===========================================================================

// --- member target, heap-user field ---

t1166_member_none_borrowed_param(HeapBox? a, HeapBox b) int {
  Holder hold = Holder(h: HeapBox(data: []));
  hold.h = a ?: b; // none-path aliases borrowed b → clone
  return hold.h.data.len;
}
t_t1166_member_none_borrowed_param() `test {
  HeapBox b = HeapBox(data: []);
  b.data.push(1);
  b.data.push(2);
  r := t1166_member_none_borrowed_param(none, b);
  assert(r == 2, "member none borrowed-param");
  assert(b.data.len == 2, "b still owned by caller");
}

t1166_member_some_borrowed_param(HeapBox? a, HeapBox b) int {
  Holder hold = Holder(h: HeapBox(data: []));
  hold.h = a ?: b; // some-path aliases borrowed a's inner → clone
  return hold.h.data.len;
}
t_t1166_member_some_borrowed_param() `test {
  HeapBox inner = HeapBox(data: []);
  inner.data.push(1);
  inner.data.push(2);
  inner.data.push(3);
  HeapBox? a = inner; // moves inner into a
  HeapBox b = HeapBox(data: []);
  b.data.push(9);
  r := t1166_member_some_borrowed_param(a, b); // borrows a and b
  assert(r == 3, "member some borrowed-param");
  assert(a!.data.len == 3, "a's inner still owned by caller");
  assert(b.data.len == 1, "b still owned by caller");
}

t_t1166_member_some_owned_local() `test {
  // regression: some owned-local source — was already passing (phi's owned path moves).
  HeapBox inner = HeapBox(data: []);
  inner.data.push(7);
  HeapBox? a = inner; // owned local optional (moved from inner)
  HeapBox b = HeapBox(data: []);
  Holder hold = Holder(h: HeapBox(data: []));
  hold.h = a ?: b; // some-path: a's inner orphaned → moved into field, no clone
  assert(hold.h.data.len == 1, "member some owned-local");
}

t_t1166_member_none_owned_local_default() `test {
  // none-path default is an owned local → moved into field (owner neutralized), no clone.
  HeapBox? a = none;
  HeapBox def = HeapBox(data: []);
  def.data.push(5);
  def.data.push(6);
  Holder hold = Holder(h: HeapBox(data: []));
  hold.h = a ?: def; // none-path: def moved into field
  assert(hold.h.data.len == 2, "member none owned-local default");
}

// --- index target, heap-user element ---

t1166_index_none_borrowed_param(HeapBox? a, HeapBox b) int {
  HeapBox[] v = [];
  v.push(HeapBox(data: []));
  v[0] = a ?: b; // none-path aliases borrowed b → clone
  return v[0].data.len;
}
t_t1166_index_none_borrowed_param() `test {
  HeapBox b = HeapBox(data: []);
  b.data.push(1);
  b.data.push(2);
  r := t1166_index_none_borrowed_param(none, b);
  assert(r == 2, "index none borrowed-param");
  assert(b.data.len == 2, "b still owned by caller");
}

t1166_index_some_borrowed_param(HeapBox? a, HeapBox b) int {
  HeapBox[] v = [];
  v.push(HeapBox(data: []));
  v[0] = a ?: b; // some-path aliases borrowed a's inner → clone
  return v[0].data.len;
}
t_t1166_index_some_borrowed_param() `test {
  HeapBox inner = HeapBox(data: []);
  inner.data.push(4);
  inner.data.push(5);
  HeapBox? a = inner; // moves inner into a
  HeapBox b = HeapBox(data: []);
  r := t1166_index_some_borrowed_param(a, b); // borrows a and b
  assert(r == 2, "index some borrowed-param");
  assert(a!.data.len == 2, "a's inner still owned by caller");
}

// --- string field variant (dupString representation) ---

type StrHolder {
  string s;
}
t1166_string_none_borrowed_param(string? a, string b) int {
  StrHolder h = StrHolder(s: "");
  h.s = a ?: b; // none-path aliases borrowed b → dupString clone
  return h.s.len;
}
t_t1166_string_field_none_borrowed_param() `test {
  string b = "hello".repeat(3); // heap-allocated (not .rodata)
  r := t1166_string_none_borrowed_param(none, b);
  assert(r == 15, "string field none borrowed-param");
  assert(b.len == 15, "b still owned by caller");
}

// --- vector field variant (dupVector + element clone) ---

type VecHolder {
  int[] v;
}
t1166_vec_none_borrowed_param(int[]? a, int[] b) int {
  VecHolder h = VecHolder(v: []);
  h.v = a ?: b; // none-path aliases borrowed b → dupVector clone
  return h.v.len;
}
t_t1166_vec_field_none_borrowed_param() `test {
  int[] b = [];
  b.push(1);
  b.push(2);
  b.push(3);
  r := t1166_vec_none_borrowed_param(none, b);
  assert(r == 3, "vec field none borrowed-param");
  assert(b.len == 3, "b still owned by caller");
}

// --- string/vec some-path borrowed param (some-branch clone of the vecOrStr
// representation — the none-path tests above only exercise the none-branch clone) ---

t1166_string_some_borrowed_param(string? a, string b) int {
  StrHolder h = StrHolder(s: "");
  h.s = a ?: b; // some-path aliases borrowed a's inner → dupString clone
  return h.s.len;
}
t_t1166_string_field_some_borrowed_param() `test {
  string? a = "world".repeat(2); // heap-allocated some-inner (10 chars)
  string b = "";
  r := t1166_string_some_borrowed_param(a, b); // borrows a and b
  assert(r == 10, "string field some borrowed-param");
  assert(a!.len == 10, "a's inner still owned by caller");
}

t1166_vec_some_borrowed_param(int[]? a, int[] b) int {
  VecHolder h = VecHolder(v: []);
  h.v = a ?: b; // some-path aliases borrowed a's inner → dupVector clone
  return h.v.len;
}
t_t1166_vec_field_some_borrowed_param() `test {
  int[] inner = [];
  inner.push(1);
  inner.push(2);
  int[]? a = inner; // moves inner into a
  int[] b = [];
  r := t1166_vec_some_borrowed_param(a, b); // borrows a and b
  assert(r == 2, "vec field some borrowed-param");
  assert(a!.len == 2, "a's inner still owned by caller");
}

// --- index target, string element (index arm × dupString representation) ---

t1166_index_string_none_borrowed_param(string? a, string b) int {
  string[] v = [];
  v.push("");
  v[0] = a ?: b; // none-path aliases borrowed b → dupString clone into element
  return v[0].len;
}
t_t1166_index_string_none_borrowed_param() `test {
  string b = "abc".repeat(4); // 12 chars, heap-allocated
  r := t1166_index_string_none_borrowed_param(none, b);
  assert(r == 12, "index string none borrowed-param");
  assert(b.len == 12, "b still owned by caller");
}

// --- gate-false: non-droppable (int) field target. `ownsForced` is signalled by
// the member-target assign, but forceOwnClone is false (int is neither vecOrStr nor
// heapDrop), so genElvis must NOT force-clone — a plain scalar select, no crash. ---

type IntHolder {
  int n;
}
t1166_intfield_none(int? a, int b) int {
  IntHolder h = IntHolder(n: 0);
  h.n = a ?: b; // int result: no drop, no clone
  return h.n;
}
t_t1166_intfield_none_and_some() `test {
  assert(t1166_intfield_none(none, 7) == 7, "int field none");
  assert(t1166_intfield_none(42, 7) == 42, "int field some");
}

// NOTE: a Map/Set FIELD variant (`h.m = a ?: b`) would exercise the same
// elvisResultHeapDrop → cloneResolvedValue path the heap-user variants above
// already cover, but it currently trips a SEPARATE pre-existing leak — Map/Set
// field reassignment does not drop the old container value in genMemberAssign
// (reproducible with a plain `h.m = ownedMap`, no elvis). Tracked as T1167; a
// Map/Set field elvis variant should be added there once the old-value drop lands.
