// ── Edge cases: Dir.list with subdirectories ─────────────────────────────────

dir_list_mixed() `test(allow_leaks: true, exclude: "wasm32") {
  // Dir with both files and subdirectories
  Dir.make_all("/tmp/pr_iot_dlm/sub")!;
  File.write_content("/tmp/pr_iot_dlm/file.txt", "x")!;

  string[] entries = Dir.list("/tmp/pr_iot_dlm")!;
  assert(entries.len == 2, "two entries (sub + file.txt)");

  bool found_sub = false;
  bool found_file = false;
  int i = 0;
  while i < entries.len {
    if entries[i] == "sub" {
      found_sub = true;
    }
    if entries[i] == "file.txt" {
      found_file = true;
    }
    i += 1;
  }
  assert(found_sub, "subdirectory in listing");
  assert(found_file, "file in listing");

  File.remove("/tmp/pr_iot_dlm/file.txt")!;
  Dir.remove("/tmp/pr_iot_dlm/sub")!;
  Dir.remove("/tmp/pr_iot_dlm")!;
}

