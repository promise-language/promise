// Stress test: rapid channel creation, send, receive, and close cycles.
// 100 goroutines each create a channel, send a value, receive, and close.
// Tests scheduler under rapid lifecycle churn.

main() `test(expected: "100") {
  done := channel[int](capacity: 100);

  for idx in 0..100 {
    go {
      ch := channel[int](capacity: 1);
      ch.send(1);
      r := <-ch;
      if v := r {
        ch.close();
        done.send(v);
      }
    };
  }

  int total = 0;
  for j in 0..100 {
    r := <-done;
    if v := r { total = total + v; }
  }
  print_int(total);
}
