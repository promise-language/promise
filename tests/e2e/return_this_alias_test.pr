// T0893: a borrowing method/operator whose body is `return this` must hand back
// an independent clone, not a value struct aliasing the receiver's heap instance.
// Before the fix, the result and the receiver shared one allocation: reading the
// result then the source printed 0 (early free of the shared instance).
type Box {
  int v;
  dup() Box {
    return this;
  }
}

// Method `return this` — result and source must be independent (both read 11).
return_this_method() `test {
  d := Box(v: 11);
  m := d.dup();
  assert(m.v == 11, "m.v == 11");
  assert(d.v == 11, "d.v == 11");
}

// Reversed read order — locks the regression from both directions.
return_this_method_reversed() `test {
  d := Box(v: 11);
  m := d.dup();
  assert(d.v == 11, "d.v == 11");
  assert(m.v == 11, "m.v == 11");
}

type OpBox {
  int v;
  +(OpBox other) OpBox {
    return this;
  }
}

// Operator `return this` — also covers the `fatal: invalid free` repro.
return_this_operator() `test {
  d := OpBox(v: 11);
  m := d + OpBox(v: 5);
  assert(m.v == 11, "m.v == 11");
  assert(d.v == 11, "d.v == 11");
}

type Chain {
  int v;
  self() Chain {
    return this;
  }
  via() Chain {
    return this.self();
  }
}

// Chained `return this.self()` — the leaf clone makes the whole chain independent.
return_this_chained() `test {
  d := Chain(v: 11);
  m := d.via();
  assert(m.v == 11, "m.v == 11");
  assert(d.v == 11, "d.v == 11");
}

type StrBox {
  string s;
  dup() StrBox {
    return this;
  }
}

// Heap type with a droppable field — exercises deep clone (no shared sub-alloc,
// no double-free). Mutating one copy's view must not disturb the other.
return_this_droppable_field() `test {
  d := StrBox(s: "hello");
  m := d.dup();
  assert(m.s == "hello", "m.s == hello");
  assert(d.s == "hello", "d.s == hello");
}

type Consumable {
  int v;
  consume(~this) Consumable {
    return this;
  }
}

// `~this` consuming method — genuine move, no clone, still leak-free.
return_this_consume_moves() `test {
  d := Consumable(v: 11);
  m := d.consume();
  assert(m.v == 11, "m.v == 11");
}

// Structural-interface operator `return this` — the operator result is typed as
// the structural interface, so cleanup goes through the structural-free path
// (not the normal drop path). The clone must still be registered for free, or it
// leaks. Operators desugar to method calls and must be treated identically.
type SNeg `structural {
  int v;
  -() SNeg {
    return this;
  }
}
type SNegItem is SNeg {
  int v;
}

return_this_structural_operator() `test {
  it := SNegItem(v: 8);
  m := -it;
  assert(m.v == 8, "m.v == 8");
  assert(it.v == 8, "it.v == 8");
}

// Polymorphic `return this` — typeinfo clone dispatch must copy the concrete
// subtype, not the abstract base.
type Animal {
  int legs;
  clone_me() Animal {
    return this;
  }
}
type Dog is Animal {
}

return_this_polymorphic() `test {
  d := Dog(legs: 4);
  a := d.clone_me();
  assert(a.legs == 4, "a.legs == 4");
  assert(d.legs == 4, "d.legs == 4");
}

// Generic `return this` — the clone must be emitted in the monomorphized method
// body (defineMonoMethods path), so each instantiation produces an independent copy.
type GBox[T] {
  T v;
  dup() GBox[T] {
    return this;
  }
}

return_this_generic() `test {
  d := GBox[int](v: 11);
  m := d.dup();
  assert(m.v == 11, "m.v == 11");
  assert(d.v == 11, "d.v == 11");
}

type SAdd `structural {
  int v;
  +(SAdd other) SAdd {
    return this;
  }
}
type SAddItem is SAdd {
  int v;
}

// Structural BINARY operator `return this` — exercises the BinaryExpr branch of
// maybeRegisterStructuralFree (the structural-free path) alongside the unary case
// above. The cloned operator result is owned and must be freed (no leak), while the
// receiver stays intact.
return_this_structural_binary_operator() `test {
  a := SAddItem(v: 7);
  m := a + SAddItem(v: 3);
  assert(m.v == 7, "m.v == 7");
  assert(a.v == 7, "a.v == 7");
}

type PBox {
  int v;
  dup() PBox {
    return (this);
  }
}

// `return (this)` — the parenthesized form (unwrapDestructureParens, T0582) must
// take the same clone-on-return path as bare `return this`.
return_this_parenthesized() `test {
  d := PBox(v: 11);
  m := d.dup();
  assert(m.v == 11, "m.v == 11");
  assert(d.v == 11, "d.v == 11");
}

type SConsumable {
  string s;
  consume(~this) SConsumable {
    return this;
  }
}

// `~this` consume with a droppable (heap) field — the move path (no clone) must
// transfer ownership of the backing string exactly once: no double-free, no leak.
return_this_consume_droppable_field() `test {
  d := SConsumable(s: "hello");
  m := d.consume();
  assert(m.s == "hello", "m.s == hello");
}

// T0906: a method whose return type is an optional of its own receiver type
// (`OB?`) with body `return this` previously crashed codegen ("insertvalue elem
// type mismatch, expected { i8*, i8* }, got i8*") — wrapThisReturnValue bailed
// because extractNamed does not peel Optional, so the bare i8* instance pointer
// flowed into the optional wrap. The clone-on-return (T0893) must still fire so
// the unwrapped optional owns an independent instance, leaving the receiver
// usable (guards the alias/double-free regression in the optional path).
type OB {
  int v;
  dup() OB? {
    return this;
  }
}

return_this_optional_heap() `test {
  d := OB(v: 1);
  m := d.dup()!;
  assert(m.v == 1, "m.v == 1");
  assert(d.v == 1, "d.v == 1");
}

type OGBox[T] {
  T v;
  dup() OGBox[T]? {
    return this;
  }
}

// Generic heap type — exercises monomorphization + typeSubst through the optional
// element type.
return_this_optional_generic() `test {
  d := OGBox[int](v: 42);
  m := d.dup()!;
  assert(m.v == 42, "m.v == 42");
  assert(d.v == 42, "d.v == 42");
}

type VT {
  int x `value;
  int y `value;
  dup() VT? {
    return this;
  }
}

// Pure value type — wrapThisReturnValue must load the full value struct from the
// `this` pointer using the optional's element type before the optional wrap.
return_this_optional_value() `test {
  d := VT(x: 3, y: 4);
  m := d.dup()!;
  assert(m.x == 3, "m.x == 3");
  assert(m.y == 4, "m.y == 4");
}

// T0906: enum receiver. `this` in an enum method is an i8* pointer, but the
// method returns the enum by value ({i32 tag, [N x i8] data}). wrapThisReturnValue
// must load the value struct via enumThisSubject — both for `E` and the optional
// `E?` form — instead of letting the bare i8* flow into the result/optional wrap
// (panic: insertvalue elem type mismatch). The droppable-payload variant
// additionally exercises the T0893-analog deep clone (no double-free/leak).
enum OE {
  None,
  Some(string s),
  dup() OE? {
    return this;
  }
  same() OE {
    return this;
  }
}

return_this_optional_enum() `test {
  d := OE.Some("hello");
  m := d.dup()!;
  match m {
    OE.Some(s) => assert(s == "hello", "m hello"),
    OE.None => assert(false, "expected Some (m)"),
  }
  // Receiver must remain intact and independently droppable (deep clone fired).
  match d {
    OE.Some(s) => assert(s == "hello", "d hello"),
    OE.None => assert(false, "expected Some (d)"),
  }
}

return_this_enum_nonoptional() `test {
  d := OE.Some("world");
  m := d.same();
  match m {
    OE.Some(s) => assert(s == "world", "m world"),
    OE.None => assert(false, "expected Some"),
  }
}

enum OGEnum[T] {
  Empty,
  Full(T val),
  dup() OGEnum[T]? {
    return this;
  }
}

// Generic enum — exercises monomorphization + self-instance interchangeability
// (equal.go Rule 2) through the optional element type.
return_this_optional_generic_enum() `test {
  d := OGEnum[int].Full(99);
  m := d.dup()!;
  match m {
    OGEnum.Full(v) => assert(v == 99, "m.v == 99"),
    OGEnum.Empty => assert(false, "expected Full"),
  }
}

// T0906: enum with an EXPLICIT `clone` method + droppable payload. The optional
// return-this deep-clone (wrapThisReturnValue) must route through cloneEnumValue
// (call @CEClone.clone) rather than the in-place strdup fallback used by OE — both
// produce an independent owned value, but this exercises the clone-method branch.
enum CEClone {
  None,
  Some(string s),
  clone(this) CEClone {
    return match this {
      CEClone.Some(s) => CEClone.Some(s.clone()),
      CEClone.None => CEClone.None,
    };
  }
  dup() CEClone? {
    return this;
  }
}

return_this_optional_enum_clone_method() `test {
  d := CEClone.Some("hi");
  m := d.dup()!;
  match m {
    CEClone.Some(s) => assert(s == "hi", "m hi"),
    CEClone.None => assert(false, "expected Some (m)"),
  }
  // Receiver remains intact and independently droppable (deep clone fired).
  match d {
    CEClone.Some(s) => assert(s == "hi", "d hi"),
    CEClone.None => assert(false, "expected Some (d)"),
  }
}
