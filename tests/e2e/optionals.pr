// E2E tests for optional values: narrowing, interpolation, elvis.
type Config {
  int port;
  string host;
}

main() `test(expected: """Alice
none
42
hi
true
3.14
hello
noVal is none
100
true
missing is absent
Bob
localhost
8080
99
first
b is none
8080
localhost
noCfg is none
none
negated
100
both
8080""") {
  // --- Implicit T to T? conversion ---
  string name = "Alice";
  string? maybeName = name;
  print_line("{maybeName}");

  // --- Optional with none ---
  int? absent = none;
  print_line("{absent}");

  // --- String interpolation with optional types ---
  int? x = 42;
  print_line("{x}");

  string? greeting = "hi";
  print_line("{greeting}");

  bool? flag = true;
  print_line("{flag}");

  f64? pi = 3.14;
  print_line("{pi}");

  // --- Truthiness narrowing: if cc { ... } ---
  string? cc = "hello";
  if cc {
    // cc is narrowed to string here
    print_line(cc);
  }

  string? noVal = none;
  if noVal {
    print_line("should not print");
  } else {
    print_line("noVal is none");
  }

  // --- is present narrowing ---
  int? num = 100;
  if num is present {
    // num is narrowed to int here
    int n = num;
    print_line(n);
  }

  // --- is present with bool? (truthiness is ambiguous, is present works) ---
  bool? verbose = true;
  if verbose is present {
    bool b = verbose;
    print_line(b);
  }

  // --- is absent ---
  int? missing = none;
  if missing is absent {
    print_line("missing is absent");
  }

  // --- if-unwrap binding ---
  string? user = "Bob";
  if u := user {
    print_line(u);
  }

  // --- Elvis operator ---
  string? maybeHost = none;
  string host = maybeHost ?: "localhost";
  print_line(host);

  string? maybePort = "8080";
  string port = maybePort ?: "3000";
  print_line(port);

  // --- Narrowing with int ---
  int? score = 99;
  if score {
    int s = score;
    print_line(s);
  }

  // --- Multiple narrowings ---
  string? a = "first";
  string? b = none;
  if a {
    print_line(a);
  }
  if b {
    print_line("should not print");
  } else {
    print_line("b is none");
  }

  // --- Narrowing user-defined types ---
  Config cfg = Config(port: 8080, host: "localhost");
  Config? maybeCfg = cfg;
  if maybeCfg {
    print_line("{maybeCfg.port}");
    print_line(maybeCfg.host);
  }

  Config? noCfg = none;
  if noCfg {
    print_line("should not print");
  } else {
    print_line("noCfg is none");
  }

  // --- Uninitialized optional var ---
  int? uninit;
  print_line("{uninit}");

  // --- Negated narrowing ---
  string? neg = "negated";
  if !neg {
    print_line("should not print");
  } else {
    print_line(neg);
  }

  // --- Compound narrowing ---
  int? ca = 100;
  string? cb = "both";
  if ca && cb {
    print_line(ca);
    print_line(cb);
  }

  // --- Optional chaining ---
  Config cfg2 = Config(port: 8080, host: "localhost");
  Config? maybeCfg2 = cfg2;
  int? p = maybeCfg2?.port;
  print_line("{p}");
}
