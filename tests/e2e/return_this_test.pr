// Regression tests for B0122: returning `this` from a method must wrap
// the i8* instance pointer back into a value struct { vtable_ptr, instance_ptr }.
type Counter {
  int count;
  int max_val;

  next(~this) int? {
    if this.count < this.max_val {
      c := this.count;
      this.count = this.count + 1;
      return c;
    }
    return none;
  }

  iter() Counter {
    return this;
  }
}

type Wrapper {
  int value;

  self() Wrapper {
    return this;
  }
}

// Basic return this
test_return_this() `test {
  w := Wrapper(value: 42);
  w2 := w.self();
  assert(w2.value == 42, "return this should preserve field values");
}

// Return this with custom iter()
test_custom_iter() `test {
  c := Counter(count: 0, max_val: 3);
  sum := 0;
  for n in c.iter() {
    sum = sum + n;
  }
  assert(sum == 3, "custom iter() returning this should work: expected 3, got " + sum.to_string());
}

// Custom iter() combined with vector iter() in same function (original B0122 trigger)
test_custom_and_vector_iter() `test {
  c := Counter(count: 0, max_val: 3);
  sum := 0;
  for n in c.iter() {
    sum = sum + n;
  }

  nums := [10, 20, 30];
  for n in nums.iter() {
    sum = sum + n;
  }
  assert(sum == 63, "combined custom + vector iter should work: expected 63, got " + sum.to_string());
}

// Chained return this
test_chained_return_this() `test {
  w := Wrapper(value: 99).self().self().self();
  assert(w.value == 99, "chained self() should preserve value");
}

// T0347: chained self() rooted at a local (not an inline constructor)
test_chained_self_on_local() `test {
  w := Wrapper(value: 7);
  r := w.self().self();
  assert(r.value == 7, "chained self() on local should preserve value");
}

// T0347: deeper chain rooted at a local
test_chained_self_three_deep() `test {
  c := Counter(count: 0, max_val: 5);
  r := c.iter().iter().iter();
  assert(r.max_val == 5, "three-deep chain should preserve field");
}

type Inner {
  int n;

  iter() Inner {
    return this;
  }

  use_self_field() int {
    r := this.iter();
    return r.n;
  }

  use_self_chain() int {
    r := this.iter().iter();
    return r.n;
  }
}

// T0347: `r := this.iter()` inside a method, then field access on r
test_method_internal_iter_then_field() `test {
  i := Inner(n: 11);
  v := i.use_self_field();
  assert(v == 11, "this.iter() then field access should work");
}

// T0347: `r := this.iter().iter()` inside a method
test_method_internal_chained_iter() `test {
  i := Inner(n: 13);
  v := i.use_self_chain();
  assert(v == 13, "chained this.iter() inside a method should work");
}

// T0347: alias clear must not double-free heap fields.
type StringHolder {
  string name;
  self() StringHolder {
    return this;
  }
}

test_chained_self_with_string_field() `test {
  s := StringHolder(name: "hello world");
  r := s.self().self();
  assert(r.name == "hello world", "string field preserved through chain");
}

type VecHolder {
  int[] nums;
  self() VecHolder {
    return this;
  }
}

test_chained_self_with_vector_field() `test {
  v := VecHolder(nums: [10, 20, 30]);
  r := v.self().self();
  assert(r.nums.len == 3, "vector field preserved through chain");
}

type InnerHeap {
  string name;

  iter() InnerHeap {
    return this;
  }

  use_self_string() string {
    r := this.iter();
    return r.name;
  }

  use_chain_string() string {
    r := this.iter().iter();
    return r.name;
  }
}

// T0347: `r := this.iter()` inside a method with heap field — must not double-free.
test_method_internal_this_iter_heap() `test {
  i := InnerHeap(name: "promise");
  v := i.use_self_string();
  assert(v == "promise", "this.iter() preserves heap field");
}

// T0347: chained `r := this.iter().iter()` inside a method with heap field.
test_method_internal_chained_this_iter_heap() `test {
  i := InnerHeap(name: "world");
  v := i.use_chain_string();
  assert(v == "world", "chained this.iter() preserves heap field");
}

// T0582: `return (this);` (paren-wrapped) from a `~this` method must wrap
// the i8* into the { vtable_ptr, instance_ptr } value struct, same as
// `return this;`. Without the paren-peel, opt rejects the IR.
type ParenBoxT0582 {
  int x;
}
type ParenHolderT0582 {
  ParenBoxT0582 b;
  eat(~this) ParenHolderT0582 {
    return (this);
  }
  eat_nested(~this) ParenHolderT0582 {
    return ((this));
  }
}

test_return_paren_this() `test {
  h := ParenHolderT0582(b: ParenBoxT0582(x: 7));
  x := h.eat();
  assert(x.b.x == 7, "paren-wrapped return this preserves field");
}

test_return_double_paren_this() `test {
  h := ParenHolderT0582(b: ParenBoxT0582(x: 9));
  x := h.eat_nested();
  assert(x.b.x == 9, "double-paren return this preserves field");
}

// T0582 audit: paren-wrapped receiver `(w).self()` must walk chainOriginExpr
// through the ParenExpr to the IdentExpr root and clear the receiver's drop
// flag (B0250). Otherwise both w and w2 own the same instance → double-free.
type ParenWrapperT0582 {
  int v;
  self() ParenWrapperT0582 {
    return this;
  }
}

test_paren_receiver_self_call() `test {
  w := ParenWrapperT0582(v: 1);
  w2 := (w).self();
  assert(w2.v == 1, "paren-wrapped receiver self() preserves value");
}

// T0582 audit: paren-wrapped receiver under chain.
test_paren_receiver_chained() `test {
  w := ParenWrapperT0582(v: 2);
  r := (w).self().self();
  assert(r.v == 2, "paren-wrapped receiver chained preserves value");
}

// T0582 audit: paren around inner call — chain walks back through the paren.
test_chained_paren_inner_call() `test {
  w := ParenWrapperT0582(v: 3);
  r := (w.self()).self();
  assert(r.v == 3, "paren-wrapped inner call chained preserves value");
}

// T0582 audit: discard statement `(w).self();` — the receiver alias check in
// trackHeapUserTypeResult must peel the ParenExpr, otherwise the temp's drop
// flag never gets cleared at runtime → double-free at statement end.
test_discard_paren_receiver_call() `test {
  w := ParenWrapperT0582(v: 5);
  (w).self();
  assert(w.v == 5, "w preserved after discard of (w).self()");
}

// T0582 coverage: `return (this);` from a value-type method exercises the
// value-type branch of wrapThisReturnValue (load value struct from i8*),
// not the heap-type insertvalue branch covered above. Existing T0582 tests
// only used heap types.
type ParenPtT0582 {
  int x `value;
  int y `value;

  echo(this) ParenPtT0582 {
    return (this);
  }
  echo_nested(this) ParenPtT0582 {
    return ((this));
  }
}

test_return_paren_this_value_type() `test {
  p := ParenPtT0582(x: 3, y: 4);
  q := p.echo();
  assert(q.x == 3, "value-type paren this preserves x");
  assert(q.y == 4, "value-type paren this preserves y");
}

test_return_double_paren_this_value_type() `test {
  p := ParenPtT0582(x: 7, y: 11);
  q := p.echo_nested();
  assert(q.x == 7, "value-type double-paren this preserves x");
  assert(q.y == 11, "value-type double-paren this preserves y");
}

// T0891: reading the aliased result first and the source second after a
// return-this bind (`m := d.dup()`) must NOT corrupt the source. The
// receiver-alias-clear makes `m` the sole owner; NLL early-drop of `m` (whose
// last use precedes the final statement) would free the shared instance and
// leave `d`'s subsequent field read a use-after-free. Suppressing the early
// drop defers the single free to scope exit, where both aliases are dead.
type T0891Box {
  int v;
  dup() T0891Box {
    return this;
  }
}

t0891_result_then_source() `test {
  d := T0891Box(v: 11);
  m := d.dup();
  assert(m.v == 11, "result reads 11");
  assert(d.v == 11, "source still reads 11 after result"); // was 0 — the bug
}

t0891_source_then_result() `test {
  d := T0891Box(v: 22);
  m := d.dup();
  assert(d.v == 22, "source reads 22");
  assert(m.v == 22, "result reads 22");
}

// Heap-field variant — exercises a real free of the shared instance, so a
// use-after-free or double-free crashes rather than merely reading zero. `m`'s
// last use (line 3) precedes the final statement (the `d` read), so the
// early-drop path would fire absent the suppression.
type T0891Heap {
  string name;
  dup() T0891Heap {
    return this;
  }
}

t0891_heap_result_then_source() `test {
  d := T0891Heap(name: "hello world");
  m := d.dup();
  assert(m.name == "hello world", "result name");
  assert(d.name == "hello world", "source name after result");
}

// Chained return-this: `r := c.dup().dup()` roots the chain at the live local
// `c`; reading both `c` and `r` afterwards must stay consistent.
t0891_chained_result_then_source() `test {
  c := T0891Box(v: 33);
  r := c.dup().dup();
  assert(r.v == 33, "chained result reads 33");
  assert(c.v == 33, "chained source still reads 33 after result");
}

// ~this-consuming return this — the receiver is moved into the call, so there
// is no live source alias; confirm no regression and no double-free.
type T0891Consume {
  int v;
  eat(~this) T0891Consume {
    return this;
  }
}

t0891_consume_return_this() `test {
  d := T0891Consume(v: 44);
  m := d.eat();
  assert(m.v == 44, "consumed return this preserves value");
}

// `this`-rooted return-this bind: a method binds the result of `this.dup()`,
// reads it, then the still-live receiver. Exercises the ThisExpr origin of the
// alias-clear (pendingThisAliasClear) at runtime — the borrowed receiver and the
// result alias the same instance, so a mis-fired free here would corrupt or
// double-free. Heap field forces a real free of the shared instance.
type T0891ThisOrigin {
  string name;
  dup() T0891ThisOrigin {
    return this;
  }
  via_this() string {
    m := this.dup();
    n := m.name; // read result (last use of m before final stmt)
    return n; // returns the receiver's still-live field
  }
}

t0891_this_origin_bind() `test {
  d := T0891ThisOrigin(name: "hello world");
  s := d.via_this();
  assert(s == "hello world", "this-origin bind returns the live field");
  assert(d.name == "hello world", "source intact after this.dup() bind");
}

// NOTE: the failable-wrapped return-this forms `m := d.dup()?!` and `m := d.dup()?^`
// double-free at runtime (T0907 — codegen alias-clear dispatch does not peel the
// error wrappers), and the optional form `m := d.dup()!` crashes codegen (T0906).
// The ownership-level early-drop suppression for those wrapper forms is covered by
// unit tests in compiler/internal/ownership/ownership_test.go
// (TestNLLNoEarlyDropReturnThisAliasThroughErrorWrappers). Runtime e2e tests for
// them should be added once T0907/T0906 are fixed.
