  raw.push(0x08);
  raw.push(0x02);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  // FHCRC: 2 bytes (not verified by implementation)
  raw.push(0x00);
  raw.push(0x00);
  // DEFLATE body for "hello"
  raw.push(0xCB);
  raw.push(0x48);
  raw.push(0xCD);
  raw.push(0xC9);
  raw.push(0xC9);
  raw.push(0x07);
  raw.push(0x00);
  // CRC32("hello")=0x3610A686, ISIZE=5
  raw.push(0x86);
  raw.push(0xA6);
  raw.push(0x10);
  raw.push(0x36);
  raw.push(0x05);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  u8[] result = gunzip(data)?!;
  string s = "hello";
  u8[] want = s.bytes();
  _assert_eq(result, want, "gunzip with FHCRC");
}

gunzip_isize_mismatch_test() `test {
  // Same as gunzip_hello_test but ISIZE patched to 6 (actual is 5).
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  raw.push(0xCB);
  raw.push(0x48);
  raw.push(0xCD);
  raw.push(0xC9);
  raw.push(0xC9);
  raw.push(0x07);
  raw.push(0x00);
  // CRC32 correct, but ISIZE=6 instead of 5
  raw.push(0x86);
  raw.push(0xA6);
  raw.push(0x10);
  raw.push(0x36);
  raw.push(0x06);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "ISIZE mismatch raises");
}
