use propmod "./propmod";

// Test reading a module-level getter returning a constant.
test_getter_constant() `test {
  string msg = propmod.greeting;
  assert(msg == "hello from propmod", "greeting should match");
}

// Test reading a computed getter.
test_getter_computed() `test {
  int val = propmod.answer;
  assert(val == 42, "answer should be 42");
}

// Test that regular functions still work alongside getters.
test_regular_function() `test {
  int sum = propmod.add(3, 4);
  assert(sum == 7, "add(3, 4) should be 7");
}

// Test failable getter with ! unwrap (success case).
test_failable_getter_success() `test {
  string val = propmod.safe_value?!;
  assert(val == "safe", "safe_value should return 'safe'");
}

// Test failable getter that raises (error handling with ? handler).
test_failable_getter_raises() `test {
  string result = propmod.risky_value? e {
    "recovered";
  };
  assert(result == "recovered", "should recover from risky_value");
}

// Test failable getter with auto-propagation in failable function.
_check_risky!() string {
  string val = propmod.risky_value;
  return val;
}

test_failable_getter_propagation() `test {
  string result = _check_risky()? e {
    "propagated";
  };
  assert(result == "propagated", "should propagate error from risky_value");
}

// Test optional getter (present case).
test_optional_getter_present() `test {
  string? val = propmod.maybe_value;
  assert(val is present, "maybe_value should be present");
  if v := val {
    assert(v == "present", "maybe_value should be 'present'");
  }
}

// Test optional getter (absent case).
test_optional_getter_absent() `test {
  string? val = propmod.empty_value;
  assert(val is absent, "empty_value should be absent");
}

// T1240: getter returning a vector — must still bind and read correctly.
test_getter_vector() `test {
  int[] v = propmod.nums;
  assert(v.len == 3, "nums should have 3 elements");
  assert(v[0] == 1 && v[2] == 3, "nums contents");
}

// T1240: getter returning a user struct — must still bind correctly.
test_getter_struct() `test {
  p := propmod.origin;
  assert(p.x == 4 && p.y == 5, "origin should be (4, 5)");
}

// T1240: getter whose return type is a function type, built from a CAPTURING
// closure — bind-and-call. This used to panic codegen.
test_getter_function_capturing() `test {
  f := propmod.adder;
  assert(f() == 42, "adder() should be 42");
}

// T1240: same getter, result DISCARDED — the owned closure env must be freed
// (leak check enforces this).
test_getter_function_capturing_discard() `test {
  propmod.adder;
}

// T1240: function-typed getter built from a NON-capturing closure — bind-and-call.
test_getter_function_plain() `test {
  f := propmod.plain_fn;
  assert(f() == 7, "plain_fn() should be 7");
}

// T1240: non-capturing function-typed getter, result DISCARDED.
test_getter_function_plain_discard() `test {
  propmod.plain_fn;
}

// T1240: repeatedly reading + calling a capturing function-typed getter in a
// loop. Each read allocates a fresh closure env that must be freed at the end
// of every iteration — stresses the env-temp ownership path (leak check
// enforces no accumulation across 100 iterations).
test_getter_function_loop() `test {
  int total = 0;
  for i in 0..100 {
    f := propmod.adder;
    total = total + f();
  }
  assert(total == 4200, "100 * 42");
}

// T1240: reassigning a function-typed variable that holds a getter's owned
// closure. The old capturing env must be freed at the reassignment before the
// new (non-capturing) closure is stored — single free of each env.
test_getter_function_reassign() `test {
  f := propmod.adder;
  assert(f() == 42, "capturing first");
  f = propmod.plain_fn;
  assert(f() == 7, "non-capturing after reassign");
}
