// Scheduler stats: verify counters track goroutine creation and completion.
//
// goroutines_completed() may lag behind channel receives because gs_completed
// is incremented in goroutine_exit (after the coroutine finishes), so we
// spin-wait briefly for the counter to catch up.
main() `test(expected: "ok") {
  // Snapshot before spawning
  created_before := goroutines_created();
  completed_before := goroutines_completed();

  ch := channel[int](capacity: 5);
  for i in 0..5 {
    go {
      ch.send(1);
    };
  }

  // Wait for all goroutines to finish sending
  for j in 0..5 {
    <-ch;
  }

  // Check created counter (incremented synchronously during go expression)
  created_after := goroutines_created();
  new_created := created_after - created_before;
  assert(new_created >= 5, "should have created at least 5 goroutines");

  // Spin-wait for completed counter (goroutine_exit runs asynchronously
  // after the coroutine body finishes, so there's a small lag)
  int target = completed_before + 5;
  for spin in 0..10000000 {
    if goroutines_completed() >= target {
      break;
    }
  }

  completed_after := goroutines_completed();
  new_completed := completed_after - completed_before;
  assert(new_completed >= 5, "should have completed at least 5 goroutines");
  assert(context_switches() > 0, "should have context switches");

  println("ok");
}
