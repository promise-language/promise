// B0158: Verify synthesized drop calls emitFieldDrops on droppable fields.
// Outer has no explicit drop() but contains Inner which does — synthesized
// drop cascades: Outer.drop → Inner.drop (prints) → pal_free(Inner) → pal_free(Outer).
type Inner {
  string name;

  drop(~this) {
    print_line("drop: " + this.name);
  }
}

type Outer {
  Inner inner;
}

main() `test(expected: "value: world\ndrop: world") {
  o := Outer(inner: Inner(name: "world"));
  print_line("value: " + o.inner.name);
}
