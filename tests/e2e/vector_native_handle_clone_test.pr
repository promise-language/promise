// T0559 / T0545: Vector.clone() on single-owner native handle elements.
//
// T0545 supersedes T0559's user-facing behavior: Vector[Task|Mutex|
// MutexGuard].clone() (and nested Vector[Vector[Mutex]]) is now a clean
// *sema error*, not a runtime panic — T0559's own summary flagged sema-time
// rejection as the intended follow-up. Those compile-fail cases moved to
// sema_test.go (TestT0545_*) since a compile error cannot be a batch/snapshot
// test. T0559's runtime-panic codegen is retained as the backstop for the
// residual generic-indirection path (sema checks generic bodies with unbound
// T, so dup[T](Vector[T]) with T=Mutex still reaches codegen — T0616).
//
// This file keeps the still-valid T0559 cases: refcounted handles (Arc/Weak/
// Channel) ARE duplicable and must NOT be gated, plus generic indirection
// over an empty Vector[Mutex] — the one path that still reaches the retained
// T0559 codegen backstop, which must clone safely without a Go/runtime panic.
// Zero leaks (T0067).
test_arc_clone_nonempty() `test {
  v := Vector[Arc[int]]();
  v.push(Arc[int](1));
  v.push(Arc[int](2));
  v2 := v.clone();
  assert(v2.len == 2, "arc clone len");
}

test_weak_clone_nonempty() `test {
  a := Arc[int](7);
  v := Vector[Weak[int]]();
  v.push(a.downgrade());
  v2 := v.clone();
  assert(v2.len == 1, "weak clone len");
}

test_channel_clone_nonempty() `test {
  v := Vector[Channel[int]]();
  v.push(Channel[int]());
  v2 := v.clone();
  assert(v2.len == 1, "channel clone len");
}

// (A `clone struct with a Vector[Mutex[T]] field is itself non-cloneable
// under T0545 — the synthesized clone would call the gated
// Vector[Mutex].clone() — so the former struct-field clone test is removed;
// that rejection is the coherent extension of the non-cloneable rule.)

// Generic indirection (T0616): the generic body is sema-checked with unbound
// T, so v.clone() is not gated; monomorphization with T = Mutex[int] reaches
// emitVectorElementCloneLoop. With an empty vector the retained T0559
// length-guard skips the panic and clones cleanly — this pins that the kept
// T0559 backstop degrades safely on the residual path T0545 cannot gate.
dup_vec_t0559[T](Vector[T] &v) Vector[T] {
  return v.clone();
}

test_generic_indirection_empty_mutex_vec() `test {
  v := Vector[Mutex[int]]();
  v2 := dup_vec_t0559[Mutex[int]](v);
  assert(v2.len == 0, "empty mutex vec via generic indirection");
}
