// guard.pr — Claude Code PreToolUse hook for blocking dangerous Bash commands.
//
// Reads hook JSON from stdin, checks the command against a set of dangerous
// patterns, and outputs a JSON allow/deny decision to stdout.
//
// Usage (via hook config):
//   "command": "bin/promise run tools/guard/guard.pr || exit 2"
//
// The || exit 2 provides fail-closed behavior: if the compiler or guard
// crashes, exit 2 tells the hook system to block the command.
use io;
use os;

// ── Entry point ─────────────────────────────────────────────────────────────

main!() {
  string input = io.read_stdin();

  // Extract tool_input.command using string search instead of JSON parsing
  // to avoid double-free crash in JsonValue enum/map drop (compiler bug).
  string command = extract_command_raw(input);
  if command.len == 0 {
    print_deny("guard: could not extract command from hook input");
    os.exit_process(0);
  }

  // Split on shell operators and check each sub-command.
  string reason = check_all(command);
  if reason.len > 0 {
    print_deny(reason);
  } else {
    print_line("\{}");
  }
  os.exit_process(0);
}

// ── Input helpers ──────────────────────────────────────────────────────────

// Extract "command" value from hook JSON using string search.
// Avoids JSON parsing to sidestep JsonValue enum/map double-free (compiler bug).
// The hook JSON has a fixed shape: {"tool_input":{"command":"<value>"},...}
extract_command_raw(string input) string {
  // "command":"  = 11 chars, "command": " = 12 chars
  int start = 0;
  if idx := input.index_of("\"command\":\"") {
    start = idx + 11;
  } else if idx2 := input.index_of("\"command\": \"") {
    start = idx2 + 12;
  } else {
    return "";
  }
  // Find the closing quote, handling escaped quotes.
  int i = start;
  while i < input.len {
    char c = input[i];
    if c == '\\' {
      i = i + 2; // skip escaped char
    } else if c == '"' {
      return input[start: i];
    } else {
      i = i + 1;
    }
  }
  return "";
}

print_deny(string reason) {
  // Hand-build JSON to avoid JsonValue enum/map double-free (compiler bug).
  string escaped = escape_json_string(reason);
  print_line("\{\"hookSpecificOutput\":\{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"{escaped}\"}}");
}

// Minimal JSON string escaping for deny reasons.
escape_json_string(string s) string {
  string result = "";
  int i = 0;
  while i < s.len {
    char c = s[i];
    if c == '"' {
      result = result + "\\\"";
    } else if c == '\\' {
      result = result + "\\\\";
    } else if c == '\n' {
      result = result + "\\n";
    } else if c == '\r' {
      result = result + "\\r";
    } else if c == '\t' {
      result = result + "\\t";
    } else {
      result = result + c.to_string();
    }
    i = i + 1;
  }
  return result;
}

// ── Command splitting ───────────────────────────────────────────────────────

// Split a command string on shell operators (&&, ||, ;, |) into sub-commands.
split_commands(string cmd) string[] {
  // Replace operators with a sentinel, then split.
  // Use spaces around operators to avoid false matches inside strings.
  string s = cmd;
  s = s.replace(" && ", "\n");
  s = s.replace(" || ", "\n");
  s = s.replace("; ", "\n");
  s = s.replace(" | ", "\n");
  return s.split("\n");
}

// Check all sub-commands in a command string. Returns the first deny reason,
// or empty string if all sub-commands are allowed.
check_all(string cmd) string {
  string[] parts = split_commands(cmd);
  for part in parts {
    string trimmed = part.trim();
    if trimmed.len > 0 {
      string reason = check_single(trimmed);
      if reason.len > 0 {
        return reason;
      }
    }
  }
  return "";
}

// ── Single command check ────────────────────────────────────────────────────

// Check a single command (no shell operators) for dangerous patterns.
check_single(string cmd) string {
  string[] tokens = tokenize(cmd);
  if tokens.len == 0 {
    return "";
  }

  // Strip wrappers (env, sudo, command) and VAR=val prefixes.
  string[] args = strip_wrappers(tokens);
  if args.len == 0 {
    return "";
  }

  string program = args[0];

  // bash -c / sh -c: extract inner command and recurse.
  if (program == "bash" || program == "sh") && args.len >= 3 && args[1] == "-c" {
    string inner = join_from(args, 2);
    inner = strip_quotes(inner);
    return check_all(inner);
  }

  // git checks
  if program == "git" {
    return check_git(args);
  }

  // rm -rf check
  if program == "rm" {
    return check_rm(args);
  }

  // curl / wget
  if program == "curl" || program == "wget" {
    return "blocked: '{program}' (unreviewed network access)";
  }

  // Package installers
  if program == "npm" || program == "pip" || program == "pip3" {
    if has_subcommand(args, "install") {
      return "blocked: '{program} install' (unreviewed package installation)";
    }
  }
  if program == "cargo" {
    if has_subcommand(args, "install") {
      return "blocked: 'cargo install' (unreviewed package installation)";
    }
  }
  if program == "go" {
    if has_subcommand(args, "install") {
      return "blocked: 'go install' (unreviewed package installation)";
    }
  }
  if program == "apt" || program == "apt-get" {
    if has_subcommand(args, "install") {
      return "blocked: '{program} install' (unreviewed package installation)";
    }
  }

  return "";
}

// ── Git checks ──────────────────────────────────────────────────────────────

// Check git commands for dangerous patterns. Finds the subcommand by skipping
// global flags (like -c, -C which take arguments).
check_git(string[] & tokens) string {
  string subcommand = find_git_subcommand(tokens);
  bool has_force = false;
  bool has_hard = false;
  bool has_short_f = false;

  // Scan all tokens for dangerous flags.
  int i = 1;
  while i < tokens.len {
    string t = tokens[i];
    if t == "--force" || t == "--force-with-lease" {
      has_force = true;
    } else if t == "--hard" {
      has_hard = true;
    } else if t == "-f" {
      has_short_f = true;
    }
    i = i + 1;
  }

  if subcommand == "push" {
    if has_force || has_short_f {
      return "blocked: 'git push --force' (can destroy remote history)";
    }
    return "blocked: 'git push' (requires explicit user approval)";
  }
  if subcommand == "reset" && has_hard {
    return "blocked: 'git reset --hard' (can destroy uncommitted work)";
  }

  return "";
}

// Find the git subcommand by skipping global flags that take arguments.
find_git_subcommand(string[] & tokens) string {
  int i = 1;
  while i < tokens.len {
    string t = tokens[i];
    // Git global options that consume the next argument.
    if t == "-c" || t == "-C" || t == "--git-dir" || t == "--work-tree" {
      i = i + 2;
    } else if t.starts_with("-") {
      i = i + 1;
    } else {
      return t;
    }
  }
  return "";
}

// ── rm checks ───────────────────────────────────────────────────────────────

// Check rm for combined -r and -f flags (handles -rf, -r -f, -fr, etc.)
check_rm(string[] & tokens) string {
  bool has_r = false;
  bool has_f = false;
  int i = 1;
  while i < tokens.len {
    string t = tokens[i];
    if t == "-r" || t == "-R" || t == "--recursive" {
      has_r = true;
    } else if t == "-f" || t == "--force" {
      has_f = true;
    } else if t.starts_with("-") && !t.starts_with("--") {
      // Combined short flags like -rf, -fr, -rfi, etc.
      int j = 1;
      while j < t.len {
        char c = t[j];
        if c == 'r' || c == 'R' {
          has_r = true;
        } else if c == 'f' {
          has_f = true;
        }
        j = j + 1;
      }
    }
    i = i + 1;
  }
  if has_r && has_f {
    return "blocked: 'rm -rf' (recursive force delete)";
  }
  return "";
}

// ── Token helpers ───────────────────────────────────────────────────────────

// Split a command into tokens on whitespace, filtering empty strings.
tokenize(string cmd) string[] {
  string[] raw = cmd.split(" ");
  string[] result = string[]();
  for token in raw {
    if token.len > 0 {
      result.push(token);
    }
  }
  return result;
}

// Strip leading env-var assignments (VAR=val) and wrapper commands
// (env, sudo, command) from a token list.
strip_wrappers(string[] & tokens) string[] {
  int i = 0;
  while i < tokens.len {
    string t = tokens[i];
    if t.contains("=") && !t.starts_with("-") {
      i = i + 1;
    } else if t == "env" || t == "sudo" || t == "command" {
      i = i + 1;
    } else {
      break;
    }
  }
  string[] result = string[]();
  while i < tokens.len {
    result.push(tokens[i]);
    i = i + 1;
  }
  return result;
}

// Check if any token after the program name matches the given subcommand.
has_subcommand(string[] & tokens, string sub) bool {
  int i = 1;
  while i < tokens.len {
    if tokens[i] == sub {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Join tokens from index `start` with spaces.
join_from(string[] & tokens, int start) string {
  string result = "";
  int i = start;
  while i < tokens.len {
    if i > start {
      result = result + " ";
    }
    result = result + tokens[i];
    i = i + 1;
  }
  return result;
}

// Strip surrounding quotes (single or double) from a string.
strip_quotes(string s) string {
  if s.len >= 2 {
    string first = s[0:1];
    string last = s[s.len - 1:s.len];
    if (first == "\"" && last == "\"") || (first == "'" && last == "'") {
      return s[1:s.len - 1];
    }
  }
  return s;
}

// ── Tests ───────────────────────────────────────────────────────────────────

tokenize_basic_test() `test {
  string[] t = tokenize("git status");
  assert(t.len == 2, "basic len");
  assert(t[0] == "git", "basic[0]");
  assert(t[1] == "status", "basic[1]");
}

tokenize_extra_spaces_test() `test {
  string[] t = tokenize("git  status   -v");
  assert(t.len == 3, "extra spaces len");
  assert(t[0] == "git", "extra[0]");
  assert(t[1] == "status", "extra[1]");
  assert(t[2] == "-v", "extra[2]");
}

tokenize_empty_test() `test {
  string[] t = tokenize("");
  assert(t.len == 0, "empty");
}

split_and_test() `test {
  string[] parts = split_commands("echo hi && git push");
  assert(parts.len == 2, "and len");
  assert(parts[0] == "echo hi", "and[0]");
  assert(parts[1] == "git push", "and[1]");
}

split_or_test() `test {
  string[] parts = split_commands("cmd1 || cmd2");
  assert(parts.len == 2, "or len");
}

split_semicolon_test() `test {
  string[] parts = split_commands("cmd1; cmd2");
  assert(parts.len == 2, "semi len");
}

split_pipe_test() `test {
  string[] parts = split_commands("echo x | grep y");
  assert(parts.len == 2, "pipe len");
}

split_none_test() `test {
  string[] parts = split_commands("git status");
  assert(parts.len == 1, "no split");
  assert(parts[0] == "git status", "no split val");
}

strip_env_test() `test(allow_leaks: true) {
  string[] tokens = ["env", "git", "push"];
  string[] result = strip_wrappers(tokens);
  assert(result.len == 2, "env len");
  assert(result[0] == "git", "env[0]");
}

strip_sudo_test() `test(allow_leaks: true) {
  string[] tokens = ["sudo", "rm", "-rf", "/"];
  string[] result = strip_wrappers(tokens);
  assert(result.len == 3, "sudo len");
  assert(result[0] == "rm", "sudo[0]");
}

strip_var_assignment_test() `test(allow_leaks: true) {
  string[] tokens = ["VAR=1", "FOO=bar", "git", "push"];
  string[] result = strip_wrappers(tokens);
  assert(result.len == 2, "var len");
  assert(result[0] == "git", "var[0]");
}

strip_combined_test() `test(allow_leaks: true) {
  string[] tokens = ["env", "VAR=1", "sudo", "git", "push"];
  string[] result = strip_wrappers(tokens);
  assert(result.len == 2, "combined len");
  assert(result[0] == "git", "combined[0]");
}

git_subcmd_simple_test() `test {
  string[] tokens = ["git", "push"];
  assert(find_git_subcommand(tokens) == "push", "simple");
}

git_subcmd_with_c_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "-c", "x=y", "push"];
  assert(find_git_subcommand(tokens) == "push", "with -c");
}

git_subcmd_with_C_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "-C", "/path", "status"];
  assert(find_git_subcommand(tokens) == "status", "with -C");
}

git_subcmd_with_flags_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "--no-pager", "log"];
  assert(find_git_subcommand(tokens) == "log", "with flags");
}

git_push_blocked_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "push"];
  assert(check_git(tokens).len > 0, "push blocked");
}

git_push_force_blocked_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "push", "--force"];
  string reason = check_git(tokens);
  assert(reason.contains("--force"), "force reason");
}

git_push_short_f_blocked_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "push", "-f", "origin", "main"];
  string reason = check_git(tokens);
  assert(reason.contains("--force"), "short f reason");
}

git_reset_hard_blocked_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "reset", "--hard", "HEAD"];
  assert(check_git(tokens).len > 0, "reset hard blocked");
}

git_status_allowed_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "status"];
  assert(check_git(tokens) == "", "status allowed");
}

git_reset_soft_allowed_test() `test(allow_leaks: true) {
  string[] tokens = ["git", "reset", "--soft", "HEAD~1"];
  assert(check_git(tokens) == "", "reset soft allowed");
}

rm_rf_blocked_test() `test(allow_leaks: true) {
  string[] tokens = ["rm", "-rf", "/"];
  assert(check_rm(tokens).len > 0, "rf blocked");
}

rm_r_f_separate_test() `test(allow_leaks: true) {
  string[] tokens = ["rm", "-r", "-f", "/"];
  assert(check_rm(tokens).len > 0, "r f blocked");
}

rm_fr_blocked_test() `test(allow_leaks: true) {
  string[] tokens = ["rm", "-fr", "/tmp/x"];
  assert(check_rm(tokens).len > 0, "fr blocked");
}

rm_r_only_allowed_test() `test(allow_leaks: true) {
  string[] tokens = ["rm", "-r", "dir/"];
  assert(check_rm(tokens) == "", "r only allowed");
}

rm_simple_allowed_test() `test(allow_leaks: true) {
  string[] tokens = ["rm", "file.txt"];
  assert(check_rm(tokens) == "", "simple allowed");
}

single_git_push_test() `test(allow_leaks: true) {
  assert(check_single("git push").len > 0, "git push");
}

single_git_c_push_test() `test(allow_leaks: true) {
  assert(check_single("git -c x push").len > 0, "git -c push");
}

single_env_git_push_test() `test(allow_leaks: true) {
  assert(check_single("env git push").len > 0, "env git push");
}

single_curl_test() `test(allow_leaks: true) {
  assert(check_single("curl http://x").len > 0, "curl");
}

single_wget_test() `test(allow_leaks: true) {
  assert(check_single("wget http://x").len > 0, "wget");
}

single_npm_install_test() `test(allow_leaks: true) {
  assert(check_single("npm install foo").len > 0, "npm install");
}

single_go_install_test() `test(allow_leaks: true) {
  assert(check_single("go install github.com/x").len > 0, "go install");
}

single_apt_install_test() `test(allow_leaks: true) {
  assert(check_single("apt install vim").len > 0, "apt install");
}

single_allowed_test() `test(allow_leaks: true) {
  assert(check_single("git status") == "", "git status");
  assert(check_single("ls -la") == "", "ls");
  assert(check_single("go test ./...") == "", "go test");
  assert(check_single("rm file.txt") == "", "rm file");
}

all_chain_blocked_test() `test(allow_leaks: true) {
  assert(check_all("echo hi && git push").len > 0, "chain blocked");
}

all_chain_allowed_test() `test(allow_leaks: true) {
  assert(check_all("git status && echo ok") == "", "chain allowed");
}

strip_double_quotes_test() `test {
  assert(strip_quotes("\"hello\"") == "hello", "double");
}

strip_single_quotes_test() `test {
  assert(strip_quotes("'hello'") == "hello", "single");
}

strip_no_quotes_test() `test {
  assert(strip_quotes("hello") == "hello", "none");
}

has_sub_found_test() `test {
  string[] tokens = ["npm", "install", "foo"];
  assert(has_subcommand(tokens, "install") == true, "found");
}

has_sub_not_found_test() `test {
  string[] tokens = ["npm", "run", "build"];
  assert(has_subcommand(tokens, "install") == false, "not found");
}

// ── extract_command_raw tests ───────────────────────────────────────────────

extract_command_raw_basic_test() `test {
  string input = "\{\"tool_name\":\"Bash\",\"tool_input\":\{\"command\":\"echo hello\"}}";
  assert(extract_command_raw(input) == "echo hello", "basic");
}

extract_command_raw_spaced_test() `test {
  string input = "\{\"tool_name\": \"Bash\", \"tool_input\": \{\"command\": \"git status\"}}";
  assert(extract_command_raw(input) == "git status", "spaced");
}

extract_command_raw_missing_test() `test {
  string input = "\{\"tool_name\":\"Read\"}";
  assert(extract_command_raw(input) == "", "missing");
}

extract_command_raw_escaped_test() `test {
  string input = "\{\"tool_input\":\{\"command\":\"echo \\\"hi\\\"\"}}";
  assert(extract_command_raw(input) == "echo \\\"hi\\\"", "escaped");
}
