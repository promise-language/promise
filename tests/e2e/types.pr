type Point {
  int x;
  int y;

  sum(&this) int {
    return this.x + this.y;
  }
}

type Animal {
  string name;
  speak(&this) string `abstract;
}

type Dog is Animal {
  speak(&this) string {
    return "woof";
  }
}

type Cat is Animal {
  speak(&this) string {
    return "meow";
  }
}

main() {
  // Constructor + field access
  p := Point(x: 3, y: 4);
  print_int(p.x);
  print_int(p.y);

  // Method call
  print_int(p.sum());

  // Inheritance + virtual dispatch
  Dog d = Dog(name: "Rex");
  println(d.name);
  println(d.speak());

  Cat c = Cat(name: "Whiskers");
  println(c.name);
  println(c.speak());

  // Polymorphic: Animal variable holding Dog
  Animal a = Dog(name: "Buddy");
  println(a.name);
  println(a.speak());

  // Polymorphic: Animal variable holding Cat
  Animal a2 = Cat(name: "Luna");
  println(a2.name);
  println(a2.speak());
}
