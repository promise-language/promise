// T0918: A heap user-type value produced by a user-defined operator and used
// inline (not bound to a local) must be dropped at statement end, exactly like
// an ordinary method-call result. Before the fix these cases leaked one
// allocation each (the operator-dispatch paths in genExpr did not register the
// heap result as a drop temp). Leak enforcement is automatic — these fail as
// LEAK pre-fix and pass clean after.
type Vec {
  int x;
  // Method counterpart — already worked, kept as the control reference.
  neg(this) Vec {
    return Vec(x: -this.x);
  }
  // Unary prefix operator (direct dispatch).
  - () Vec {
    return Vec(x: -this.x);
  }
  // Binary operator (direct dispatch).
  - (Vec o) Vec {
    return Vec(x: this.x - o.x);
  }
}

// Control: method-call result used inline never leaked.
method_inline() `test {
  a := Vec(x: 5);
  assert(a.neg().x == -5, "method inline");
}

// Control: binding the operator result to a local never leaked.
op_bound() `test {
  a := Vec(x: 5);
  m := -a;
  assert(m.x == -5, "op bound");
}

// Regression: unary operator result used inline.
unary_inline() `test {
  a := Vec(x: 5);
  assert((-a).x == -5, "unary inline");
}

// Regression: binary operator result used inline.
binary_inline() `test {
  a := Vec(x: 5);
  b := Vec(x: 3);
  assert((a - b).x == 2, "binary inline");
}

// Virtual dispatch: the operator is declared on the parent; the child inherits
// it. Result used inline exercises genVirtualUnaryOp / genVirtualBinaryOp.
type Shape {
  int v;
  -() Shape {
    return Circle(v: -this.v);
  }
  - (Shape o) Shape {
    return Circle(v: this.v - o.v);
  }
}
type Circle is Shape {
  int v;
}

virtual_unary_inline() `test {
  Shape s = Circle(v: 7);
  assert((-s).v == -7, "virtual unary inline");
}

virtual_binary_inline() `test {
  Shape a = Circle(v: 7);
  Shape b = Circle(v: 2);
  assert((a - b).v == 5, "virtual binary inline");
}

// Enum-declared operator returning a heap user type, used inline. Exercises
// genEnumUnaryOp / genEnumBinaryOp dispatch.
type Boxed {
  int n;
}
enum Sign {
  positive,
  negative,

  -() Boxed {
    return Boxed(n: -1);
  }
  - (Sign o) Boxed {
    return Boxed(n: 2);
  }
}

enum_unary_inline() `test {
  s := Sign.positive;
  assert((-s).n == -1, "enum unary inline");
}

enum_binary_inline() `test {
  a := Sign.positive;
  b := Sign.negative;
  assert((a - b).n == 2, "enum binary inline");
}

// Generic heap type whose operator returns a heap generic instance, used inline.
// Exercises the typeSubst substitution branch in trackOperatorResult /
// trackHeapUserTypeResult (the concrete-type tests above never set typeSubst).
// All existing generic-operator tests return a scalar (bool), so this is the
// only coverage of a generic operator producing a droppable heap temp inline.
type GBox[T] {
  T v;
  -() GBox[T] {
    return GBox[T](v: this.v);
  }
  - (GBox[T] o) GBox[T] {
    return GBox[T](v: this.v);
  }
}

generic_unary_inline() `test {
  a := GBox[int](v: 7);
  assert((-a).v == 7, "generic unary inline");
}

generic_binary_inline() `test {
  a := GBox[int](v: 5);
  b := GBox[int](v: 3);
  assert((a - b).v == 5, "generic binary inline");
}

// Operator result consumed by MOVE inline (not just read). The newly-tracked
// temp must have its drop flag cleared at the move site, otherwise it would
// double-free. Confirms the T0918 tracking composes with move-tracking.
type Wrap {
  Vec inner;
}

take_vec(Vec move v) int {
  return v.x;
}

op_result_moved_into_ctor() `test {
  a := Vec(x: 5);
  w := Wrap(inner: -a);
  assert(w.inner.x == -5, "op result moved into constructor");
}

op_result_moved_into_fn() `test {
  a := Vec(x: 9);
  b := Vec(x: 2);
  assert(take_vec(a - b) == 7, "op result moved into function");
}

// Borrow-returning operator: the result aliases an owned local (`this`), so it
// must NOT be registered as an owned temp — the isRefType guard in
// trackOperatorResult skips it. Without that guard the borrowed `this` would be
// dropped at statement end AND when `a` leaves scope → double free.
type Borrowed {
  int v;
  -(Borrowed o) Borrowed & {
    return this;
  }
}

borrow_returning_op_inline() `test {
  a := Borrowed(v: 11);
  b := Borrowed(v: 4);
  assert((a - b).v == 11, "borrow-returning op inline");
}

// Operator inherited as a default method from a structural parent, returning a
// heap user type, used inline. A separate inheritance shape from Shape/Circle
// above (structural `is` rather than concrete subclassing) routing through the
// virtual dispatch path. Leaked pre-fix.
type Heapy {
  int v;
}
type Negatable {
  get magnitude int {
    return 0;
  }
  - () Heapy {
    return Heapy(v: -this.magnitude);
  }
}
type Mag is Negatable {
  int n;
  get magnitude int {
    return this.n;
  }
}

structural_default_op_inline() `test {
  Mag x = Mag(n: 3);
  assert((-x).v == -3, "structural default op inline");
}

// T0958: A HEAP user type whose operator consumes `this` by MOVE (`~this`) and
// returns it yields an inline result that ALIASES the left operand's allocation
// (no dup — the moved-in receiver is returned directly). The T0918 temp must have
// its drop flag cleared when it aliases the operand; otherwise the temp frees the
// allocation at statement end AND the operand's scope binding frees it again →
// double free (SEGV at runtime; silent under leak-only detection). The value-type
// operators above never reach this — trackHeapUserTypeResult skips value types,
// so a heap field (`string tag`) is required to exercise the drop path.
type HeapAcc {
  string tag;
  int v;
  +(~this, HeapAcc o) HeapAcc {
    return this;
  }
  - (~this) HeapAcc {
    return this;
  }
}

// Inline binary move-return-this with a field access: result aliases `a`, `.v`
// reads through it, temp drops at statement end. Double-frees (SEGV) pre-fix.
move_binary_return_this_field_inline() `test {
  a := HeapAcc(tag: "a", v: 10);
  b := HeapAcc(tag: "b", v: 5);
  assert((a + b).v == 10, "move binary return-this field inline");
}

// Inline unary move-return-this with a field access.
move_unary_return_this_field_inline() `test {
  a := HeapAcc(tag: "a", v: 7);
  assert((-a).v == 7, "move unary return-this field inline");
}

// Heap operator returning a FRESH instance used inline: the result does NOT alias
// the operand (pointers differ), so the runtime alias-clear is a no-op and the
// owned temp is still dropped (no leak, no over-suppression).
type HeapFresh {
  string tag;
  int v;
  +(HeapFresh o) HeapFresh {
    return HeapFresh(tag: "sum", v: this.v + o.v);
  }
}

heap_fresh_op_inline_drops_temp() `test {
  a := HeapFresh(tag: "a", v: 4);
  b := HeapFresh(tag: "b", v: 3);
  assert((a + b).v == 7, "heap fresh op inline");
}

// T0958: CHAINED return-this operators (`a + b + c`). The outer operator's left
// operand is itself the `a + b` BinaryExpr, so operatorReceiverOrigin must descend
// through it to reach the ultimate `a` leaf — otherwise the alias-clear is skipped
// (origin is a BinaryExpr, not Ident/This) and both `a`'s scope binding and the
// chained result free the same allocation → double-free (SEGV). Covers both the
// inline-temp path and the bound (`m := ...`) path. The pointer-equality guard
// keeps mixed chains (a `-` returning a fresh instance) correct.
type HeapChain {
  string tag;
  int v;
  +(~this, HeapChain o) HeapChain {
    return this;
  }
  - (~this, HeapChain o) HeapChain {
    return HeapChain(tag: "fresh", v: this.v - o.v);
  }
  drop(~this) {
  }
}

chained_return_this_inline() `test {
  a := HeapChain(tag: "a", v: 1);
  b := HeapChain(tag: "b", v: 2);
  c := HeapChain(tag: "c", v: 3);
  assert((a + b + c).v == 1, "chained return-this inline (aliases leftmost)");
}

chained_return_this_bound() `test {
  a := HeapChain(tag: "a", v: 1);
  b := HeapChain(tag: "b", v: 2);
  c := HeapChain(tag: "c", v: 3);
  m := a + b + c;
  assert(m.v == 1, "chained return-this bound");
}

chained_mixed_fresh_then_this() `test {
  a := HeapChain(tag: "a", v: 10);
  b := HeapChain(tag: "b", v: 2);
  c := HeapChain(tag: "c", v: 1);
  // (a - b) -> fresh F; F + c -> this == F. Result aliases the F temp, not `a`.
  assert(((a - b) + c).v == 8, "chained mixed: inner fresh, outer this");
}

chained_mixed_this_then_fresh() `test {
  a := HeapChain(tag: "a", v: 10);
  b := HeapChain(tag: "b", v: 2);
  c := HeapChain(tag: "c", v: 1);
  // (a + b) -> this == a; then `- c` -> fresh. Result is fresh; `a` freed by binding.
  assert(((a + b) - c).v == 9, "chained mixed: inner this, outer fresh");
}

// T0958: the return-this-move double-free was only exercised through DIRECT
// dispatch above (HeapAcc/HeapChain are concrete, non-generic). The alias-clear
// runs on the operand origin (Ident/This) and is dispatch-agnostic, but the
// result instancePtr that trackHeapUserTypeResult compares against is structured
// differently per dispatch kind — so the GENERIC (typeSubst active) and VIRTUAL
// (inherited operator) paths need their own return-this-move coverage to confirm
// the temp's drop flag is cleared (no double-free) and nothing leaks. The T0918
// generic/virtual tests only return FRESH instances, which can never alias.

// Generic heap type (heap `tag` field → droppable; T=int alone would be a value
// type and skipped by trackHeapUserTypeResult). Operator moves `this` and returns
// it: the inline result aliases the operand's allocation under an active typeSubst.
type GHeap[T] {
  string tag;
  T v;
  +(~this, GHeap[T] o) GHeap[T] {
    return this;
  }
  - (~this) GHeap[T] {
    return this;
  }
  drop(~this) {
  }
}

generic_binary_return_this_inline() `test {
  a := GHeap[int](tag: "a", v: 10);
  b := GHeap[int](tag: "b", v: 5);
  assert((a + b).v == 10, "generic binary return-this inline");
}

generic_unary_return_this_inline() `test {
  a := GHeap[int](tag: "a", v: 7);
  assert((-a).v == 7, "generic unary return-this inline");
}

// Virtual/inherited return-this-move: operator declared on the heap parent, child
// inherits it; called on a child instance used inline. Exercises the alias-clear
// reaching the operand origin through the virtual dispatch result.
type PHeap {
  string tag;
  int v;
  +(~this, PHeap o) PHeap {
    return this;
  }
  - (~this) PHeap {
    return this;
  }
  drop(~this) {
  }
}
type CHeap is PHeap {
  string tag;
  int v;
}

virtual_binary_return_this_inline() `test {
  PHeap a = CHeap(tag: "a", v: 4);
  PHeap b = CHeap(tag: "b", v: 1);
  assert((a + b).v == 4, "virtual binary return-this inline");
}

virtual_unary_return_this_inline() `test {
  PHeap a = CHeap(tag: "a", v: 6);
  assert((-a).v == 6, "virtual unary return-this inline");
}
