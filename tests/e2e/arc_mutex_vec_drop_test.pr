// T0358: Arc[T[]] and Mutex[T[]] inner-Vector drop must iterate elements and
// drop heap data per element before freeing the buffer. Sibling fix to T0354
// at the `emitInnerDrop` site (was calling `Vector.drop` on the buffer pointer
// without iterating).
//
// Tests use inline `.borrow.<field>` access rather than `b := a.borrow` to
// avoid B0367 (Arc.borrow assignment registers a stray drop binding for
// Vector inner T, double-freeing the buffer).
type T0358Item {
  int id;
  string name;
}

// --- Site 2a: Arc[string[]] drops on last strong ref ---

test_arc_string_vec_drop() `test {
  v := string[]();
  v.push("hello" + "");
  v.push("world" + "");
  a := Arc[string[]](v);
  // Confirm Arc holds the vector. Drop fires on scope exit when refcount → 0.
  assert(a.borrow.len == 2, "arc string vec len");
}

// --- Site 2b: Arc[string[]] with multiple clones ---

test_arc_string_vec_drop_clones() `test {
  v := string[]();
  v.push("a" + "");
  v.push("b" + "");
  v.push("c" + "");
  a := Arc[string[]](v);
  b := a.clone();
  c := a.clone();
  assert(a.borrow.len == 3, "arc len before drops");
  assert(b.borrow.len == 3, "clone1 len");
  assert(c.borrow.len == 3, "clone2 len");
}

// --- Site 2c: Mutex[string[]] drop ---

test_mutex_string_vec_drop() `test {
  v := string[]();
  v.push("foo" + "");
  v.push("bar" + "");
  m := Mutex[string[]](v);
  use guard := m.lock();
  assert(guard.borrow.len == 2, "mutex string vec len");
}

// --- Site 2d: Arc[Item[]] with user-type elements containing strings ---

test_arc_user_type_vec_drop() `test {
  items := T0358Item[]();
  items.push(T0358Item(id: 1, name: "alpha" + ""));
  items.push(T0358Item(id: 2, name: "beta" + ""));
  a := Arc[T0358Item[]](items);
  assert(a.borrow.len == 2, "arc user vec len");
}

// --- Site 2e: Mutex[int[][]] nested vector drop ---

test_mutex_nested_vec_drop() `test {
  outer := int[][]();
  inner1 := int[]();
  inner1.push(1);
  inner1.push(2);
  outer.push(inner1);

  inner2 := int[]();
  inner2.push(3);
  inner2.push(4);
  outer.push(inner2);

  m := Mutex[int[][]](outer);
  use guard := m.lock();
  assert(guard.borrow.len == 2, "mutex nested len");
}

// --- Site 2f: Arc[string[]] dropped without any borrow access (pure drop path) ---

test_arc_string_vec_no_borrow() `test {
  v := string[]();
  v.push("alpha" + "");
  v.push("beta" + "");
  a := Arc[string[]](v);
  // a goes out of scope without any read; pure Arc.drop path exercised.
}

// --- Site 2g: Mutex[string[]] dropped without any lock (pure drop path) ---

test_mutex_string_vec_no_lock() `test {
  v := string[]();
  v.push("p" + "");
  v.push("q" + "");
  m := Mutex[string[]](v);
  // m goes out of scope without lock; pure Mutex.drop path exercised.
}
