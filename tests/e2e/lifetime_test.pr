// Tests for explicit lifetime annotations (B0033).
// Elision rule 2: single ref param — lifetime is unambiguous.
get_first(string & s) string & {
  return s;
}

single_ref_elision() `test {
  string s = "hello";
  string & r = get_first(s);
  assert(r.len == 5, "single ref elision: len");
}

// Elision rule 3: &this receiver — return borrows from this.
type Named {
  string name;

  get_name(&this) string & {
    return this.name;
  }
}

this_receiver_elision() `test {
  Named n = Named(name: "world");
  string & r = n.get_name();
  assert(r.len == 5, "this receiver elision: len");
}

// Explicit lifetime: longest pattern — both params share the same lifetime.
longest(string & a `lifetime(x), string & b `lifetime(x)) string & `lifetime(x) {
  if a.len > b.len {
    return a;
  }
  return b;
}

explicit_same_lifetime() `test {
  string a = "short";
  string b = "longer string";
  string & r = longest(a, b);
  assert(r.len == 13, "explicit same lifetime: longest");
}

// Explicit lifetime: distinct lifetimes, pick one.
pick_first(string & a `lifetime(x), string & b `lifetime(y)) string & `lifetime(x) {
  return a;
}

explicit_distinct_lifetimes() `test {
  string a = "first";
  string b = "second";
  string & r = pick_first(a, b);
  assert(r.len == 5, "explicit distinct lifetimes: pick first");
}
