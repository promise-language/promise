// std/char.pr — Character type with equality and comparison operators
type char `native {
    ==(char other) bool `native;
    !=(char other) bool `native;
    <(char other) bool `native;
    >(char other) bool `native;
    <=(char other) bool `native;
    >=(char other) bool `native;
    ..(char end) range `native;
    ..=(char end) range `native;
}
