// Advanced error handling tests: propagation chains, bang unwrap, failable functions.
// --- basic raise and propagate ---
parse_int(string s) int! {
  if s == "42" {
    return 42;
  }
  if s == "0" {
    return 0;
  }
  if s == "-1" {
    return -1;
  }
  raise error(message: "invalid number: " + s);
}

test_propagate_success() `test(allow_leaks: true) {
  int r = parse_int("42")!;
  assert(r == 42, "parse_int 42 succeeds");
}

// --- propagation chain: 3 levels deep ---

level3() int! {
  raise error(message: "deep error");
}

level2() int! {
  int v = level3()?;
  return v + 1;
}

level1() int! {
  int v = level2()?;
  return v + 1;
}

// Test that error propagates through chain using wrapper function
try_level1() bool {
  int v = level1()? e {
    return true;
  };
  return false;
}

test_propagation_chain() `test(allow_leaks: true) {
  assert(try_level1(), "error propagated through 3 levels");
}

// --- multiple failable calls ---

add_parsed(string a, string b) int! {
  int x = parse_int(a)?;
  int y = parse_int(b)?;
  return x + y;
}

test_multiple_failable_success() `test(allow_leaks: true) {
  int r = add_parsed("42", "0")!;
  assert(r == 42, "42 + 0 = 42");
}

test_multiple_failable_negative() `test(allow_leaks: true) {
  int r = add_parsed("42", "-1")!;
  assert(r == 41, "42 + (-1) = 41");
}

// Test first fails using wrapper
try_add_bad_first() bool {
  int r = add_parsed("bad", "42")? e {
    return true;
  };
  return false;
}

test_first_failable_fails() `test(allow_leaks: true) {
  assert(try_add_bad_first(), "first failable raised");
}

// Test second fails using wrapper
try_add_bad_second() bool {
  int r = add_parsed("42", "bad")? e {
    return true;
  };
  return false;
}

test_second_failable_fails() `test(allow_leaks: true) {
  assert(try_add_bad_second(), "second failable raised");
}

// --- bang unwrap on success ---

test_bang_unwrap_success() `test(allow_leaks: true) {
  int r = parse_int("0")!;
  assert(r == 0, "bang unwrap on success gives 0");
}

// --- conditional error handling ---

safe_get(int[] arr, int idx) int! {
  if idx < 0 {
    raise error(message: "negative index");
  }
  if idx >= arr.len {
    raise error(message: "index out of bounds");
  }
  return arr[idx];
}

test_safe_get_valid() `test(allow_leaks: true) {
  int[] nums = [10, 20, 30];
  int v = safe_get(nums, 1)!;
  assert(v == 20, "safe_get at index 1 returns 20");
}

// Wrapper to check safe_get errors
try_safe_get(int[] arr, int idx) bool {
  int v = safe_get(arr, idx)? e {
    return true;
  };
  return false;
}

test_safe_get_negative() `test(allow_leaks: true) {
  int[] nums = [10, 20, 30];
  assert(try_safe_get(nums, -1), "negative index raises");
}

test_safe_get_out_of_bounds() `test(allow_leaks: true) {
  int[] nums = [10, 20, 30];
  assert(try_safe_get(nums, 5), "out of bounds raises");
}

// --- failable returning zero ---

test_failable_returning_zero() `test(allow_leaks: true) {
  int r = parse_int("0")!;
  assert(r == 0, "failable can return 0 (not confused with error)");
}

// --- failable returning negative ---

test_failable_returning_negative() `test(allow_leaks: true) {
  int r = parse_int("-1")!;
  assert(r == -1, "failable can return -1");
}

// --- propagation in loop ---

parse_and_sum(string[] inputs) int! {
  int sum = 0;
  for s in inputs {
    int v = parse_int(s)?;
    sum += v;
  }
  return sum;
}

test_propagation_in_loop_success() `test(allow_leaks: true) {
  string[] inputs = ["42", "0", "-1"];
  int r = parse_and_sum(inputs)!;
  assert(r == 41, "42 + 0 + (-1) = 41");
}

try_parse_and_sum_bad() bool {
  string[] inputs = ["42", "bad", "0"];
  int r = parse_and_sum(inputs)? e {
    return true;
  };
  return false;
}

test_propagation_in_loop_fail() `test(allow_leaks: true) {
  assert(try_parse_and_sum_bad(), "bad input causes propagation");
}

// --- untyped handler with field access ---

get_error_message() string {
  int v = parse_int("bad")? e {
    return e.message;
  };
  return "no error";
}

test_untyped_handler_field_access() `test(allow_leaks: true) {
  string msg = get_error_message();
  assert(msg == "invalid number: bad", "untyped handler can access e.message");
}

// --- typed error handler ---

type IoError is error {
  int code;
}

fail_io() void! {
  raise IoError(message: "disk full", code: 28);
}

get_io_error_code() int! {
  fail_io()? e is IoError {
    return e.code;
  };
  return 0;
}

test_typed_handler_catches() `test(allow_leaks: true) {
  int code = get_io_error_code()!;
  assert(code == 28, "typed handler catches IoError and accesses code");
}

// --- typed handler propagates non-matching ---

type ParseError is error {
  int line;
}

fail_parse() void! {
  raise ParseError(message: "syntax error", line: 42);
}

try_typed_propagation() bool! {
  // IoError handler won't match ParseError, should propagate
  fail_parse()? e is IoError {
    return false;
  };
  return false;
}

test_typed_handler_propagates_nonmatch() `test(allow_leaks: true) {
  // try_typed_propagation is failable, nomatch propagates
  // Can't easily test panic in e2e, but we can test matching path
  int code = get_io_error_code()!;
  assert(code == 28, "typed handler match path works");
}

// --- typed handler in failable function propagates ---

try_io_in_failable() void! {
  fail_parse()? e is IoError {
    return;
  };
}

try_propagation_wrapper() bool {
  try_io_in_failable()? e {
    return true;
  };
  return false;
}

test_typed_handler_propagates_in_failable() `test(allow_leaks: true) {
  assert(try_propagation_wrapper(), "typed handler propagates non-matching error in failable fn");
}

// --- untyped handler catches all error subtypes ---

get_io_message() string {
  fail_io()? e {
    return e.message;
  };
  return "no error";
}

test_untyped_handler_catches_subtype() `test(allow_leaks: true) {
  string msg = get_io_message();
  assert(msg == "disk full", "untyped handler catches IoError via error base");
}
