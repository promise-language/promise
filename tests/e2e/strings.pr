main() `test(expected: """true
false
true
true
false
6
false
hi
3
a
b
c""") {
  string s = "hello world";

  // contains
  print_line(s.contains("world")); // true
  print_line(s.contains("xyz")); // false

  // starts_with / ends_with
  print_line(s.starts_with("hello")); // true
  print_line(s.ends_with("world")); // true
  print_line(s.starts_with("world")); // false

  // index_of
  if idx := s.index_of("world") {
    print_line(idx); // 6
  }

  bool found = false;
  if idx2 := s.index_of("xyz") {
    found = true;
  }
  print_line(found); // false

  // trim
  string padded = "  hi  ";
  print_line(padded.trim()); // hi

  // split
  string csv = "a,b,c";
  string[] parts = csv.split(",");
  print_line(parts.len); // 3
  print_line(parts[0]); // a
  print_line(parts[1]); // b
  print_line(parts[2]); // c
}
