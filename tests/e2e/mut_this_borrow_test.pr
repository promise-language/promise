// T0569 regression guard: `~this` is a mutable borrow, not an ownership
// transfer. The method body may mutate fields and chain into other `~this`
// methods on the same receiver, but it cannot move `this` into a `~T`
// consume slot (that case is rejected at compile time — see the Go-level
// ownership tests).
type Counter {
  int n;
  string label;

  bump(~this) {
    this.n = this.n + 1;
  }

  bump_twice(~this) {
    this.bump();
    this.bump();
  }

  relabel(~this, string move s) {
    this.label = s;
  }
}

// `~this` body mutates a primitive field — caller still owns the value.
test_mut_this_field_int() `test {
  Counter c = Counter(n: 0, label: "init");
  c.bump();
  assert(c.n == 1, "n incremented once");
  c.bump();
  c.bump();
  assert(c.n == 3, "n incremented twice more");
}

// `~this` method chaining: bump_twice calls bump twice on `this` as receiver.
test_mut_this_receiver_chain() `test {
  Counter c = Counter(n: 5, label: "x");
  c.bump_twice();
  assert(c.n == 7, "chained bumps applied");
}

// `~this` body mutates a heap-allocated string field — caller's drop still
// frees the new value, not a freed one.
test_mut_this_field_string() `test {
  Counter c = Counter(n: 0, label: "old".to_upper());
  c.relabel("new" + "label");
  assert(c.label == "newlabel", "label replaced");
}

// T0980: calling a `~this` method through a `~` mutable-borrow parameter must
// compile and mutate the caller's value end-to-end. (The shared-borrow form of
// the same call is rejected at compile time — see the Go-level sema tests.)
via_mut_borrow(Counter ~c) {
  c.bump();
}

test_mut_method_through_mut_borrow_param() `test {
  Counter c = Counter(n: 10, label: "x");
  via_mut_borrow(c);
  assert(c.n == 11, "mutated through `~` borrow param");
}

// T0980: calling a `~this` method on an element reached through a `~` mutable
// borrow of a Vector must compile, mutate in place, and leave no leak (the
// shared-borrow form `Counter[] v` is rejected — see the Go-level sema tests).
bump_first(Counter[] ~v) {
  v[0].bump();
}

test_mut_method_through_indexed_mut_borrow() `test {
  Counter[] v = Counter[]();
  v.push(Counter(n: 5, label: "a"));
  v.push(Counter(n: 7, label: "b"));
  bump_first(v);
  assert(v[0].n == 6, "first element mutated through `~` vector borrow");
  assert(v[1].n == 7, "second element untouched");
}
