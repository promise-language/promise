// ============================================================
// Section 18: Failable arg to outer failable function (both propagate)
// ============================================================

outer_failable(int x) int! {
  if x > 100 {
    raise error(message: "too big");
  }
  return x;
}

both_failable() int! {
  return outer_failable(parse_int("42"));
}

test_both_failable_success() `test(allow_leaks: true) {
  int r = both_failable()!;
  assert(r == 42, "failable arg to failable function, both succeed");
}

both_failable_inner_fails() int! {
  return outer_failable(parse_int("bad"));
}

try_both_inner_fails() bool {
  both_failable_inner_fails()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_both_failable_inner_fails() `test(allow_leaks: true) {
  assert(try_both_inner_fails(), "inner failable arg fails, propagated");
}

// ============================================================
// Section 19: Custom error type preserved through arg propagation
// ============================================================

type AppError is error {
  int code;
}

get_code() int! {
  raise AppError(code: 99, message: "app error");
}

use_code(int c) int {
  return c;
}

auto_prop_custom_error() int! {
  return use_code(get_code());
}

test_custom_error_preserved() `test(allow_leaks: true) {
  auto_prop_custom_error()? e is AppError {
    assert(e.code == 99, "custom error code preserved");
    assert(e.message == "app error", "custom error message preserved");
    return;
  }!;
  assert(false, "should have caught AppError");
}

// ============================================================
// Section 20: Scope cleanup when arg fails (droppable in scope)
// ============================================================

type Tracked {
  int id;
  drop(~this) {
    // drop runs — test just verifies no crash/leak
  }
}

auto_prop_with_scope_cleanup() int! {
  Tracked t = Tracked(id: 1);
  // t is in scope; if parse_int fails, scope cleanup must drop t
  return use_int(parse_int("bad"));
}

test_scope_cleanup_on_arg_fail() `test(allow_leaks: true) {
  bool caught = false;
  auto_prop_with_scope_cleanup()? e {
    caught = true;
  };
  assert(caught, "droppable in scope cleaned up when failable arg fails");
}

// ============================================================
// Section 21: Super call argument
// ============================================================

type Base {
  int value;
  new(~this, int value) {
    this.value = value;
  }
}

type Child is Base {
  new(~this, int v) {
    super(value: v);
  }
}

auto_prop_super() int! {
  c := Child(v: parse_int("42"));
  return c.value;
}

test_super_arg_success() `test(allow_leaks: true) {
  int r = auto_prop_super()!;
  assert(r == 42, "failable arg to super() call succeeds");
}

auto_prop_super_fail() int! {
  c := Child(v: parse_int("bad"));
  return c.value;
}

try_super_fail() bool {
  auto_prop_super_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_super_arg_fail() `test(allow_leaks: true) {
  assert(try_super_fail(), "failable arg to super() propagates");
}
