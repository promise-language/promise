{
  "permissions": {
    "deny": [
      "Read(.tracker/**)",
      "Edit(.tracker/**)",
      "Write(.tracker/**)"
    ],
    "allow": [
      "Bash(make generate:*)",
      "Bash(make resources:*)",
      "Bash(make test:*)",
      "Bash(make clean:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go fmt:*)",
      "Bash(gofmt:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git stash list:*)",
      "Bash(git config core.hooksPath .githooks)",
      "Bash(sed:*)",
      "Bash(wc:*)",
      "Bash(./build:*)",
      "Bash(bin/test.sh:*)",
      "Bash(bin/verify.sh:*)",
      "Bash(bin/promise:*)",
      "Read(~.promise/cache/llvm/darwin-arm64/**)",
      "Bash(otool -L ~/.promise/cache/llvm/darwin-arm64/lld)",
      "Bash(~/.promise/cache/llvm/darwin-arm64/lld --version)",
      "Bash(rm -rf ~/.promise/cache/:*)",
      "Bash(bin/promise exec:*)",
      "Bash(codesign -v ~/.promise/cache/llvm/darwin-arm64/opt)",
      "Bash(codesign -v ~/.promise/cache/llvm/darwin-arm64/lld)",
      "Bash(codesign -v ~/.promise/cache/llvm/darwin-arm64/libLLVM.dylib)",
      "Bash(xattr ~/.promise/cache/llvm/darwin-arm64/opt)",
      "Bash(xattr -cr ~/.promise/cache/llvm/darwin-arm64/)",
      "Bash(~/.promise/cache/llvm/darwin-arm64/opt --version)",
      "Bash(bin/promise test:*)",
      "Bash(promise format:*)",
      "Bash(xxd:*)",
      "Bash(PROMISE_CACHE_DEBUG=1 bin/promise test tests/std/test_sort.pr)",
      "Read(~/go/pkg/mod/github.com/llir/llvm@v0.3.6/ir/**)",
      "Bash(PROMISE_HOME=/tmp/nocache_$$ bin/promise test:*)",
      "Bash(for d:*)",
      "Bash(do echo:*)",
      "Read(~/prog/promise_lang/**)",
      "Bash(brew --prefix llvm)",
      "Bash(/opt/homebrew/opt/llvm/bin/opt:*)"
    ],
    "additionalDirectories": [
      "/tmp",
      "~/.promise"
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Processing"
    ]
  }
}
