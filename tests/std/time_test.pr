// Tests for std/time.pr — Duration, Instant, sleep
// --- Duration factories ---
test_duration_from_nanos() `test {
  Duration d = Duration.from_nanos(500);
  assert(d.as_nanos == 500, "from_nanos 500");
}

test_duration_from_micros() `test {
  Duration d = Duration.from_micros(100);
  assert(d.as_nanos == 100000, "from_micros nanos");
  assert(d.as_micros == 100, "from_micros roundtrip");
}

test_duration_from_millis() `test {
  Duration d = Duration.from_millis(250);
  assert(d.as_nanos == 250000000, "from_millis nanos");
  assert(d.as_millis == 250, "from_millis roundtrip");
}

test_duration_from_secs() `test {
  Duration d = Duration.from_secs(3);
  assert(d.as_nanos == 3000000000, "from_secs nanos");
  assert(d.as_secs == 3, "from_secs roundtrip");
}

test_duration_zero() `test {
  Duration d = Duration.zero();
  assert(d.as_nanos == 0, "zero nanos");
  assert(d.is_zero, "is_zero");
  assert(!Duration.from_nanos(1).is_zero, "not is_zero");
}

// --- Duration accessors ---

test_duration_accessors() `test {
  Duration d = Duration.from_nanos(2500000000);
  assert(d.as_nanos == 2500000000, "as_nanos");
  assert(d.as_micros == 2500000, "as_micros");
  assert(d.as_millis == 2500, "as_millis");
  assert(d.as_secs == 2, "as_secs truncated");
}

// --- Duration arithmetic ---

test_duration_add() `test {
  Duration a = Duration.from_millis(100);
  Duration b = Duration.from_millis(200);
  Duration c = a + b;
  assert(c.as_millis == 300, "add");
}

test_duration_sub() `test {
  Duration a = Duration.from_millis(500);
  Duration b = Duration.from_millis(200);
  Duration c = a - b;
  assert(c.as_millis == 300, "sub");
}

test_duration_mul() `test {
  Duration d = Duration.from_millis(100);
  Duration r = d * 3;
  assert(r.as_millis == 300, "mul");
  assert((d * 0).is_zero, "mul zero");
}

// --- Duration comparison ---

test_duration_eq() `test {
  Duration a = Duration.from_millis(100);
  Duration b = Duration.from_millis(100);
  assert(a == b, "eq");
  assert(!(a != b), "not neq");
}

test_duration_lt_gt() `test {
  Duration a = Duration.from_millis(100);
  Duration b = Duration.from_millis(200);
  assert(a < b, "lt");
  assert(b > a, "gt");
  assert(a <= b, "le");
  assert(b >= a, "ge");
  assert(a <= a, "le eq");
  assert(a >= a, "ge eq");
}

// --- Duration to_string ---

test_duration_to_string_zero() `test {
  assert(Duration.zero().to_string() == "0ns", "zero");
}

test_duration_to_string_nanos() `test {
  assert(Duration.from_nanos(42).to_string() == "42ns", "42ns");
  assert(Duration.from_nanos(999).to_string() == "999ns", "999ns");
}

test_duration_to_string_negative() `test {
  Duration neg = Duration.from_millis(100) - Duration.from_millis(1600);
  assert(neg.to_string() == "-1.5s", "negative duration");
  Duration neg_ms = Duration.from_millis(10) - Duration.from_millis(52);
  assert(neg_ms.to_string() == "-42ms", "negative millis");
}

test_duration_to_string_micros() `test {
  assert(Duration.from_micros(5).to_string() == "5us", "5us");
  assert(Duration.from_nanos(1500).to_string() == "1.5us", "1.5us");
}

test_duration_to_string_millis() `test {
  assert(Duration.from_millis(42).to_string() == "42ms", "42ms");
  assert(Duration.from_nanos(1500000).to_string() == "1.5ms", "1.5ms");
}

test_duration_to_string_secs() `test {
  assert(Duration.from_secs(3).to_string() == "3s", "3s");
  assert(Duration.from_millis(1500).to_string() == "1.5s", "1.5s");
}

test_duration_to_string_boundaries() `test {
  // Exact boundary transitions: ns→us, us→ms, ms→s
  assert(Duration.from_nanos(999).to_string() == "999ns", "just under 1us");
  assert(Duration.from_nanos(1000).to_string() == "1us", "exactly 1us");
  assert(Duration.from_nanos(999999).to_string() == "999.9us", "just under 1ms");
  assert(Duration.from_nanos(1000000).to_string() == "1ms", "exactly 1ms");
  assert(Duration.from_nanos(999999999).to_string() == "999.9ms", "just under 1s");
  assert(Duration.from_nanos(1000000000).to_string() == "1s", "exactly 1s");
}

// --- Duration format ---

test_duration_format() `test {
  Builder b = Builder();
  Duration.from_millis(42).format(b)?!;
  assert(b.to_string() == "42ms", "format 42ms");
}

// --- Instant ---

test_instant_now() `test(exclude: "wasm32") {
  Instant t = Instant.now();
  assert(t.nanos > 0, "now returns positive nanos");
}

test_instant_elapsed() `test {
  Instant start = Instant.now();
  // Do some trivial work
  int x = 0;
  while x < 1000 {
    x = x + 1;
  }
  Duration elapsed = start.elapsed();
  assert(elapsed.as_nanos >= 0, "elapsed non-negative");
}

test_instant_duration_since() `test {
  Instant a = Instant.now();
  int x = 0;
  while x < 1000 {
    x = x + 1;
  }
  Instant b = Instant.now();
  Duration d = b.duration_since(a);
  assert(d.as_nanos >= 0, "duration_since non-negative");
}

test_instant_comparison() `test {
  Instant a = Instant.now();
  int x = 0;
  while x < 100 {
    x = x + 1;
  }
  Instant b = Instant.now();
  assert(a <= b, "a <= b");
  assert(b >= a, "b >= a");
  assert(a != b || a == b, "!= or ==");
}

// --- sleep ---

test_sleep() `test(exclude: "wasm32") {
  Instant start = Instant.now();
  sleep(Duration.from_millis(15));
  Duration elapsed = start.elapsed();
  assert(elapsed.as_millis >= 10, "sleep at least 10ms");
}
