// Select with default when no channels ready: should not block.
main() `test(expected: "default taken") {
  ch1 := channel[int](capacity: 1);
  ch2 := channel[int](capacity: 1);

  // No data in either channel
  select {
    v := <-ch1:
    print_line("from ch1");
    v := <-ch2:
    print_line("from ch2");
    default:
    print_line("default taken");
  }
}
