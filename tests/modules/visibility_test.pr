use vis "./visibility";

// flaky leak — sometimes leaks depending on timing
test_public_value() `test {
  assert(vis.public_value() == 42, "public_value() == 42");
}

test_public_greet() `test(allow_leaks: true) {
  assert(vis.public_greet("tester") == "hi tester (via 7)", "public_greet uses private helper internally");
}
