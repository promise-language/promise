// T0405: Field reassignment must drop elements of the old vector before freeing the buffer.
// Repro: overwriting a string[] field leaked the old vector's string elements.
type Holder {
  string[] field;
}

type OptHolder {
  string[]? field;
  drop(~this) {
  }
}

type GenHolder[T] {
  T[] field;
  set_field(~this, ~T[] val) {
    this.field = val;
  }
}

type NestedHolder {
  string[][] field;
}

type HeapElem {
  string name;
}

type HeapHolder {
  HeapElem[] field;
}

type SelfHolder {
  string[] field;
  read_field(this) string[] {
    return this.field;
  }
}

test_string_vec_field_reassign() `test {
  v1 := string[]();
  v1.push("init" + "");
  h := Holder(v1);
  v2 := string[]();
  v2.push("hello" + "");
  h.field = v2;
  assert(h.field.len == 1, "field has 1 element after reassign");
}

test_multi_elem_string_vec_field_reassign() `test {
  v1 := string[]();
  v1.push("a" + "");
  v1.push("b" + "");
  v1.push("c" + "");
  h := Holder(v1);
  v2 := string[]();
  v2.push("x" + "");
  h.field = v2;
  assert(h.field.len == 1, "field has 1 element after reassign");
  assert(h.field[0] == "x", "field element correct after reassign");
}

test_repeated_field_reassign() `test {
  v1 := string[]();
  v1.push("first" + "");
  h := Holder(v1);
  v2 := string[]();
  v2.push("second" + "");
  h.field = v2;
  v3 := string[]();
  v3.push("third" + "");
  h.field = v3;
  assert(h.field.len == 1, "field has 1 element after double reassign");
  assert(h.field[0] == "third", "field element correct after double reassign");
}

// T0405: Generic type with T[]=string[] field — reassignment must drop string elements (no leak).
test_generic_string_vec_field_reassign() `test {
  v1 := string[]();
  v1.push("init" + "");
  h := GenHolder[string](v1);
  v2 := string[]();
  v2.push("hello" + "");
  h.set_field(v2);
  assert(h.field.len == 1, "generic field has 1 element after reassign");
  assert(h.field[0] == "hello", "generic field element correct after reassign");
}

// T0516: After a B0219 dup of `h.field`, a subsequent `h.field = w` must skip
// the element drop loop because the original elements are now owned by the dup.
// Without skip-on-wasDuped, the original elements would be double-freed (dropped
// here AND when the duped local is dropped at scope end).
test_t0516_was_duped_path() `test {
  v1 := string[]();
  v1.push("init" + "");
  h := Holder(v1);
  v := h.field;
  w := string[]();
  w.push("new" + "");
  h.field = w;
  assert(v[0] == "init", "v retains original element");
  assert(h.field[0] == "new", "h.field has new value");
  assert(h.field.len == 1, "h.field has 1 element");
}

// T0516: B0219 dup tracking must be per-receiver. A dup of `h1.field` must not
// cause the wasDuped=TRUE skip to fire on a different instance like `h2.field`,
// otherwise h2's old elements leak. Without the fix this either leaks "b"
// (h2's old element skipped) or double-frees "a" (h1 not marked, emits element
// drop on the buffer still aliased with v).
test_t0516_cross_instance() `test {
  va := string[]();
  va.push("a" + "");
  h1 := Holder(va);
  vb := string[]();
  vb.push("b" + "");
  h2 := Holder(vb);
  v := h1.field;
  w := string[]();
  w.push("c" + "");
  h2.field = w;
  x := string[]();
  x.push("d" + "");
  h1.field = x;
  assert(v[0] == "a", "v retains h1's original element");
  assert(h1.field[0] == "d", "h1.field has d");
  assert(h2.field[0] == "c", "h2.field has c");
}

// T0516: Non-canonicalizable receivers (index exprs, call results) must use a
// per-type fallback key so self-reassign on the same indexed element correctly
// skips the element drop. Without the fallback, the dup'd local aliases the
// element pointers and `arr[0].field = w` would double-free at the next drop.
test_t0516_index_recv_self_reassign() `test {
  v1 := string[]();
  v1.push("init" + "");
  arr := Holder[]();
  arr.push(Holder(v1));
  v := arr[0].field;
  w := string[]();
  w.push("new" + "");
  arr[0].field = w;
  assert(v[0] == "init", "v retains init");
  assert(arr[0].field[0] == "new", "arr[0].field is new");
}

// T0516: B0219 dup tracking must distinguish generic instantiations. The dup
// marker for `hi.field` (GenHolder[int]) must not cause `hs.field = w`
// (GenHolder[string]) to wrongly skip its element drop, otherwise "hello" leaks.
test_t0516_cross_generic_instantiation() `test {
  v1 := int[]();
  v1.push(42);
  hi := GenHolder[int](v1);
  v2 := string[]();
  v2.push("hello" + "");
  hs := GenHolder[string](v2);
  vs := hi.field;
  w := string[]();
  w.push("new" + "");
  hs.field = w;
  x := int[]();
  x.push(7);
  hi.field = x;
  assert(vs[0] == 42, "vs retains hi's original element");
  assert(hs.field[0] == "new", "hs.field has new");
  assert(hi.field[0] == 7, "hi.field has 7");
}

// T0540: `v := h.field` on a droppable owner with a droppable-element vector field
// produces a deep dup. Without the fix, the shallow memcpy aliases element pointers
// between v and h.field; at scope end both vectors would call promise_string_drop
// on the same "init" pointer → `bad header magic`.
test_t0540_dup_only_no_reassign() `test {
  v1 := string[]();
  v1.push("init" + "");
  h := Holder(v1);
  v := h.field;
  assert(v[0] == "init", "dup'd vector reads element");
  assert(h.field[0] == "init", "original field still readable");
}

// T0540: Multi-element variant exercises the per-element clone loop boundary.
test_t0540_dup_only_multi_element() `test {
  v1 := string[]();
  v1.push("a" + "");
  v1.push("b" + "");
  v1.push("c" + "");
  h := Holder(v1);
  v := h.field;
  assert(v.len == 3, "dup len");
  assert(v[0] == "a" && v[1] == "b" && v[2] == "c", "dup elements");
  assert(h.field[0] == "a" && h.field[1] == "b" && h.field[2] == "c", "original elements");
}

// T0540: Optional[Vector] field — the deep-dup must apply to the inner vector
// extracted from the Optional payload.
test_t0540_optional_vec_field() `test {
  v1 := string[]();
  v1.push("opt" + "");
  h := OptHolder(field: v1);
  if v := h.field {
    assert(v[0] == "opt", "optional dup'd vector reads element");
  } else {
    assert(false, "field should be present");
  }
}

// T0541: branch-mutation pattern — `v := h.field` then a conditionally-skipped
// reassign followed by an unconditional reassign. Pre-T0540 this double-freed
// "init" on the cond=true path because the wasDuped consume in the else branch
// caused the unconditional reassign's element drop loop to see no mark.
// With deep-dup, both branches are safe.
test_t0541_branch_mutation_cond_true() `test {
  v1 := string[]();
  v1.push("init" + "");
  h := Holder(v1);
  cond := true;
  v := h.field;
  if cond {
    // no reassign
  } else {
    x := string[]();
    x.push("x" + "");
    h.field = x;
  }
  z := string[]();
  z.push("z" + "");
  h.field = z;
  assert(v[0] == "init", "v retains original after branch + reassign");
  assert(h.field[0] == "z", "h.field reflects final reassign");
}

test_t0541_branch_mutation_cond_false() `test {
  v1 := string[]();
  v1.push("init" + "");
  h := Holder(v1);
  cond := false;
  v := h.field;
  if cond {
    // no reassign
  } else {
    x := string[]();
    x.push("x" + "");
    h.field = x;
  }
  z := string[]();
  z.push("z" + "");
  h.field = z;
  assert(v[0] == "init", "v retains original after branch + reassign");
  assert(h.field[0] == "z", "h.field reflects final reassign");
}

// T0540: dup + reassign — after the fix, the originals must still be dropped
// unconditionally at reassign (no skip path), and the dup retains its own
// independent copy. This is the simple correct behavior the workaround used
// to obscure.
test_t0540_dup_plus_reassign_still_drops_originals() `test {
  v1 := string[]();
  v1.push("orig" + "");
  h := Holder(v1);
  v := h.field;
  w := string[]();
  w.push("new" + "");
  h.field = w;
  assert(v[0] == "orig", "v retains deep-cloned original");
  assert(h.field[0] == "new", "h.field has new");
}

// T0540: nested Vector[Vector[string]] field — exercises the recursive
// emitVectorElementCloneLoop path (inner vectors must also deep-clone their
// string elements, otherwise the inner buffers alias and double-free at scope end).
test_t0540_nested_vec_field_dup() `test {
  inner1 := string[]();
  inner1.push("a" + "");
  inner1.push("b" + "");
  inner2 := string[]();
  inner2.push("c" + "");
  outer := string[][]();
  outer.push(inner1);
  outer.push(inner2);
  h := NestedHolder(outer);
  v := h.field;
  assert(v.len == 2, "outer len");
  assert(v[0].len == 2 && v[1].len == 1, "inner lens");
  assert(v[0][0] == "a" && v[0][1] == "b" && v[1][0] == "c", "v elements");
  assert(h.field[0][0] == "a" && h.field[1][0] == "c", "original elements");
}

// T0540: Vector[HeapUserType] field — exercises the isHeapUser branch in
// emitVectorElementCloneLoop (each element is deep-cloned via dupHeapValue;
// without it, both v and h.field alias the same heap instance pointers).
test_t0540_heap_user_vec_field_dup() `test {
  e1 := HeapElem(name: "alice" + "");
  e2 := HeapElem(name: "bob" + "");
  v1 := HeapElem[]();
  v1.push(e1);
  v1.push(e2);
  h := HeapHolder(v1);
  v := h.field;
  assert(v.len == 2, "len");
  assert(v[0].name == "alice" && v[1].name == "bob", "v elements");
  assert(h.field[0].name == "alice" && h.field[1].name == "bob", "original elements");
}

// T0540: `this.field` access from a method — exercises the deep-dup path
// when the receiver is ThisExpr (vs. IdentExpr or MemberExpr in other tests).
// SelfHolder.read_field returns this.field, which auto-dups via the B0219 path.
test_t0540_this_field_dup_via_method() `test {
  v1 := string[]();
  v1.push("self" + "");
  v1.push("ish" + "");
  h := SelfHolder(v1);
  v := h.read_field();
  assert(v.len == 2 && v[0] == "self" && v[1] == "ish", "v elements");
  assert(h.field[0] == "self" && h.field[1] == "ish", "h.field elements");
}

// T0540: empty vector field auto-dup — exercises the len=0 boundary in the
// element clone loop (the `idx < length` guard must skip the body, no crash).
test_t0540_empty_vec_field_dup() `test {
  v1 := string[]();
  h := Holder(v1);
  v := h.field;
  assert(v.len == 0, "v empty");
  assert(h.field.len == 0, "h.field empty");
}
