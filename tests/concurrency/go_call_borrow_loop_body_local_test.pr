// T1151: borrowing an owned droppable local *declared inside a loop body* into a
// `go` call let the borrow escape into a goroutine that can outlive the loop
// iteration → silent use-after-free when handles are awaited after the loop.
// Sibling of T1147 (the for-in loop-*binding* shape): here the borrowed root is a
// `string y = x.clone();` local declared in the body, whose scope still ends at
// the iteration boundary. The compiler now REJECTS that shape at compile time
// (see the Go ownership tests `TestT1151*` for the rejection coverage). These
// batch tests confirm the sound rewrites the diagnostic points at — `.clone()`
// into a fresh temp, and `move` of the owned local into a consuming `move` param —
// compile and produce correct, deterministic output across many spawns.
type Box {
  string s;
}

keep(string p) Box {
  return Box(s: p.clone());
}

store(string move s) Box {
  return Box(s: move s);
}

// Sound rewrite #1: clone the loop-body local into a fresh temp at the call site.
// The temp is owned by the goroutine frame — no borrow of the per-iteration local.
go_call_local_clone_temp_after_loop() `test {
  string[] xs = ["alpha".clone(), "bravo".clone(), "charlie".clone()];
  task[Box][] ts = [];
  for x in xs {
    string y = x.clone();
    ts.push(go keep(y.clone()));
  }
  string[] out = [];
  for t in ts {
    Box b = <-t;
    out.push(move b.s);
  }
  assert(out.len == 3, "clone temp: count");
  assert(out[0] == "alpha", "clone temp: first");
  assert(out[1] == "bravo", "clone temp: second");
  assert(out[2] == "charlie", "clone temp: third");
}

// Sound rewrite #2: move the owned loop-body local into a consuming `move` param.
// Ownership transfers into the goroutine frame (T1148), so there is no dangling
// borrow even when the handles are awaited after the loop.
go_call_local_move_after_loop() `test {
  string[] xs = ["aa".clone(), "bb".clone(), "cc".clone()];
  task[Box][] ts = [];
  for x in xs {
    string y = x.clone();
    ts.push(go store(move y));
  }
  string[] out = [];
  for t in ts {
    Box b = <-t;
    out.push(move b.s);
  }
  assert(out.len == 3, "move: count");
  assert(out[0] == "aa", "move: first");
  assert(out[1] == "bb", "move: second");
  assert(out[2] == "cc", "move: third");
}

// Scale up the spawn count so any residual aliasing/use-after-free would surface
// as a non-deterministic corrupted field across the many goroutines.
go_call_local_clone_temp_many() `test {
  string[] xs = [];
  for i in 0..64 {
    xs.push("item-{i}");
  }
  task[Box][] ts = [];
  for x in xs {
    string y = x.clone();
    ts.push(go keep(y.clone()));
  }
  int idx = 0;
  for t in ts {
    Box b = <-t;
    assert(b.s == "item-{idx}", "many: element {idx}");
    idx = idx + 1;
  }
  assert(idx == 64, "many: count");
}
