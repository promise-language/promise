gunzip_isize_mismatch_test() `test {
  // Same as gunzip_hello_test but ISIZE patched to 6 (actual is 5).
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  raw.push(0xCB);
  raw.push(0x48);
  raw.push(0xCD);
  raw.push(0xC9);
  raw.push(0xC9);
  raw.push(0x07);
  raw.push(0x00);
  // CRC32 correct, but ISIZE=6 instead of 5
  raw.push(0x86);
  raw.push(0xA6);
  raw.push(0x10);
  raw.push(0x36);
  raw.push(0x06);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "ISIZE mismatch raises");
}

// ---------------------------------------------------------------------------
// gzip() encoder tests — round-trip through gunzip().
// ---------------------------------------------------------------------------

_gzip_roundtrip(u8[] data, string label) {
  u8[] cloned = data.clone();
  u8[] compressed = gzip_encode(cloned);
  // Magic header sanity check.
  assert(compressed.len >= 18, label + ": minimum 18-byte frame");
  assert(compressed[0] == 0x1Fu8, label + ": magic 0x1F");
  assert(compressed[1] == 0x8Bu8, label + ": magic 0x8B");
  assert(compressed[2] == 0x08u8, label + ": CM=8 (DEFLATE)");
  u8[] decoded = gunzip(compressed)?!;
  _assert_eq(decoded, data, label + ": round-trip");
}

gzip_empty_test() `test {
  u8[] data = u8[]();
  _gzip_roundtrip(data, "empty");
}

gzip_hello_test() `test {
  string s = "hello";
  u8[] bytes = s.bytes();
  _gzip_roundtrip(bytes, "hello");
}

gzip_hello_world_test() `test {
  string s = "Hello, World!\n";
  u8[] bytes = s.bytes();
  _gzip_roundtrip(bytes, "Hello, World!");
}

gzip_repeated_a_test() `test {
  // 100 'A' bytes — exercises a payload that the original Python fixture
  // (gunzip_a100_test) compresses heavily; our stored-block encoder produces
  // a different but still valid bytestream.
  u8[] data = u8[]();
  int i = 0;
  while i < 100 {
    data.push(0x41u8);
    i = i + 1;
  }
  _gzip_roundtrip(data, "100 As");
}

gzip_all_byte_values_test() `test {
  u8[] data = u8[]();
  int i = 0;
  while i < 256 {
    data.push(i as! u8);
    i = i + 1;
  }
  _gzip_roundtrip(data, "all 256 byte values");
}

gzip_large_binary_test() `test {
  // 100KB of pseudo-random bytes — exercises CRC32 over a realistic size and
  // forces the encoder across the 65535-byte stored-block boundary.
  u8[] data = u8[]();
  u32 state = 0xDEADBEEFu32;
  int i = 0;
  while i < 100000 {
    state = (state * 1664525u32 + 1013904223u32) & 0xFFFFFFFFu32;
    data.push((state >> 16u32) as! u8);
    i = i + 1;
  }
  _gzip_roundtrip(data, "100KB binary");
}

gunzip_fextra_overflow_test() `test {
  // FEXTRA with XLEN=7 but only 18 bytes total → pos overruns data.len.
  // After reading XLEN=7, pos = 10 + 2 + 7 = 19 > data.len (18).
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x04); // FLG = FEXTRA
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  raw.push(0x07); // XLEN lo = 7
  raw.push(0x00); // XLEN hi = 0
  raw.push(0x00); // padding to reach 18 bytes
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "FEXTRA overflow raises");
}

gunzip_fname_unterminated_test() `test {
  // FNAME field with no NUL terminator — _skip_cstring raises.
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x08); // FLG = FNAME
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  // 8 non-NUL bytes — no terminator within the stream
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "FNAME without NUL raises");
}

gunzip_fhcrc_truncated_test() `test {
  // FNAME consumes all 8 bytes after the header (pos=18), then FHCRC needs 2 more
  // bytes (pos+2=20 > data.len=18) → raises.
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x0A); // FLG = FNAME | FHCRC
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  // FNAME = "AAAAAAA\0" (7 chars + NUL = 8 bytes): pos advances from 10 to 18
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "FHCRC truncated raises");
}

gunzip_header_overruns_trailer_test() `test {
  // FNAME of 10 bytes pushes pos to 20; trailer_pos = 25-8 = 17; pos (20) > trailer_pos.
  int[] raw = int[]();
  raw.push(0x1F);
  raw.push(0x8B);
  raw.push(0x08);
  raw.push(0x08); // FLG = FNAME
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x02);
  raw.push(0xFF);
  // FNAME = "AAAAAAAAA\0" (9 chars + NUL = 10 bytes): pos goes from 10 to 20
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x41);
  raw.push(0x00);
  // 5 filler bytes → data.len=25, trailer_pos=17, pos=20 > 17
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  raw.push(0x00);
  u8[] data = _bytes(raw);
  assert(_try_gunzip(data), "header overruns trailer raises");
}

gzip_trailer_isize_test() `test {
  // Verify ISIZE matches input length for a known-size payload.
  string s = "Promise";
  u8[] bytes = s.bytes();
  u8[] cloned = bytes.clone();
  u8[] compressed = gzip_encode(cloned);
  int trailer = compressed.len - 8;
  // ISIZE is bytes 4..7 of the trailer (after CRC32).
  u32 isize = (compressed[trailer + 4] as! u32) | ((compressed[trailer + 5] as! u32) << 8u32) | ((compressed[trailer + 6] as! u32) << 16u32) | ((compressed[trailer + 7] as! u32) << 24u32);
  assert(isize == 7u32, "ISIZE = 7 for 'Promise'");
}
