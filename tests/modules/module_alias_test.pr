use m "./mathlib";

test_alias_function() `test {
  assert(m.add(5, 5) == 10, "m.add(5, 5) == 10");
  assert(m.square(4) == 16, "m.square(4) == 16");
}

test_alias_type() `test(allow_leaks: true) {
  v := m.Vec2(x: 7, y: 8);
  assert(v.sum() == 15, "m.Vec2 sum == 15");
}

test_alias_enum() `test {
  c := m.Color.Blue;
  assert(m.color_name(c) == "blue", "m.Color.Blue name");
}

// --- Aliased module generic function calls (B0100) ---

test_alias_generic_explicit() `test {
  int r = m.identity[int](7);
  assert(r == 7, "aliased explicit generic");
}

test_alias_generic_inferred() `test {
  int r = m.identity(7);
  assert(r == 7, "aliased inferred generic");
}
