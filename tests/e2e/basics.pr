main() `test(expected: """42
-7
3.14
true
false
hello world
30
foobar
x < y
10
45
5
7""", exclude: "wasm32") {
  // Integers
  print_int(42);
  print_int(-7);

  // Float
  print_f64(3.14);

  // Bool
  print_bool(true);
  print_bool(false);

  // String
  println("hello world");

  // Variables and arithmetic
  int x = 10;
  int y = 20;
  print_int(x + y);

  // String concat
  string a = "foo";
  string b = "bar";
  println(a + b);

  // If/else
  if x < y {
    println("x < y");
  } else {
    println("x >= y");
  }

  // While loop
  int i = 0;
  int sum = 0;
  while i < 5 {
    sum += i;
    i += 1;
  }
  print_int(sum);

  // For range
  int total = 0;
  for n in 0..10 {
    total += n;
  }
  print_int(total);

  // Increment/decrement
  int c = 0;
  for j := 0; j < 5; j++ {
    c++;
  }
  print_int(c);

  int d = 10;
  d--;
  d--;
  d--;
  print_int(d);
}
