// T0853: constructing a generic `Ref[T?]` / `Mutex[T?]` by passing a BARE
// non-optional value of type `T` (or a bare `none`) used to panic in codegen —
// the constructor stored the `T` value struct directly into the `T?` payload
// slot without widening it to an optional (`store operands are not compatible:
// src=T; dst={i1,T}*`). The fix mirrors Vector.push (T0658): set targetType so
// a bare `none` lowers to a zero {i1,T} struct, and wrap a bare `T` arg via
// wrapReturnOptional after temp-claiming. Already-optional args still take the
// existing matching-shape path (regression guards below).
type Shape {
  string name;
  area(&this) f64 `abstract;
}
type Circle is Shape {
  f64 radius;
  area(&this) f64 {
    return this.radius;
  }
}

// Ref[Circle?] from a bare Circle — the reported repro. Read back via RTTI cast
// to confirm the wrapped payload is a valid `Some`.
arc_bare_value() `test {
  Ref[Circle?] a = Ref[Circle?](Circle(name: "x", radius: 1.0));
  Circle? cc = a.borrow as Circle;
  f64 r = 0.0;
  if cc {
    r = cc.radius;
  }
  assert(r == 1.0, "bare-value Ref[Circle?] should hold a Some(Circle)");
}

// Ref[Circle?] from a bare `none` — exercises the genNoneLit targetType path.
arc_bare_none() `test {
  Ref[Circle?] a = Ref[Circle?](none);
  Circle? cc = a.borrow as Circle;
  bool present = false;
  if cc {
    present = true;
  }
  assert(!present, "bare-none Ref[Circle?] should hold None");
}

// Mutex[Circle?] from a bare Circle — the analogous Mutex constructor path.
mutex_bare_value() `test {
  Mutex[Circle?] m = Mutex[Circle?](Circle(name: "m", radius: 3.5));
  MutexGuard[Circle?] g = m.lock();
  Circle? cc = g.borrow as Circle;
  f64 r = 0.0;
  if cc {
    r = cc.area();
  }
  assert(r == 3.5, "bare-value Mutex[Circle?] should hold a Some(Circle)");
}

// Mutex[Circle?] from a bare `none`.
mutex_bare_none() `test {
  Mutex[Circle?] m = Mutex[Circle?](none);
  MutexGuard[Circle?] g = m.lock();
  Circle? cc = g.borrow as Circle;
  bool present = false;
  if cc {
    present = true;
  }
  assert(!present, "bare-none Mutex[Circle?] should hold None");
}

// Primitive element — exercises the non-struct-elem / value-type-payload variant
// (the wrapped payload is a value-type `{i1,i64}` slot) for both Arc and Mutex.
// Read back via if-unwrap; the typed-var bind `int? av = a.borrow` hits a
// separate pre-existing borrow-read codegen bug (T0856), not this constructor.
arc_mutex_bare_primitive() `test {
  Ref[int?] a = Ref[int?](5);
  bool arc_ok = false;
  if x := a.borrow {
    arc_ok = (x == 5);
  }
  assert(arc_ok, "bare-int Ref[int?] should hold Some(5)");

  Mutex[int?] m = Mutex[int?](7);
  MutexGuard[int?] g = m.lock();
  bool mtx_ok = false;
  if x := g.borrow {
    mtx_ok = (x == 7);
  }
  assert(mtx_ok, "bare-int Mutex[int?] should hold Some(7)");
}

// Primitive bare-none for both Arc and Mutex — value-type payload zeroed slot.
arc_mutex_bare_primitive_none() `test {
  Ref[int?] a = Ref[int?](none);
  bool arc_present = false;
  if x := a.borrow {
    arc_present = true;
  }
  assert(!arc_present, "bare-none Ref[int?] should hold None");

  Mutex[int?] m = Mutex[int?](none);
  MutexGuard[int?] g = m.lock();
  bool mtx_present = false;
  if x := g.borrow {
    mtx_present = true;
  }
  assert(!mtx_present, "bare-none Mutex[int?] should hold None");
}

// Regression guard: an already-optional arg still takes the matching-shape path
// (wrapReturnOptional's types.Identical short-circuit skips re-wrapping).
arc_already_optional() `test {
  Circle? init = Circle(name: "c", radius: 9.0);
  Ref[Circle?] a = Ref[Circle?](init);
  Circle? cc = a.borrow as Circle;
  f64 r = 0.0;
  if cc {
    r = cc.radius;
  }
  assert(r == 9.0, "already-optional Ref[Circle?] arg should still work");
}

// Regression guard (Mutex): an already-optional arg takes the matching-shape
// path through the independent genMutexConstructor call site.
mutex_already_optional() `test {
  Circle? init = Circle(name: "c", radius: 4.0);
  Mutex[Circle?] m = Mutex[Circle?](init);
  MutexGuard[Circle?] g = m.lock();
  Circle? cc = g.borrow as Circle;
  f64 r = 0.0;
  if cc {
    r = cc.radius;
  }
  assert(r == 4.0, "already-optional Mutex[Circle?] arg should still work");
}
