// Ref[T] basic tests — T0155
arc_new_borrow_int() `test {
  a := Ref[int](42);
  assert(a.borrow == 42, "int borrow");
}

arc_new_borrow_string() `test {
  a := Ref[string]("hello");
  assert(a.borrow == "hello", "string borrow");
}

arc_new_borrow_bool() `test {
  a := Ref[bool](true);
  assert(a.borrow == true, "bool borrow");
}

arc_new_borrow_f64() `test {
  a := Ref[f64](3.14);
  assert(a.borrow == 3.14, "f64 borrow");
}

arc_clone_shares_value() `test {
  a := Ref[int](100);
  b := a.clone();
  assert(a.borrow == 100, "original after clone");
  assert(b.borrow == 100, "clone value");
}

arc_clone_string() `test {
  a := Ref[string]("shared");
  b := a.clone();
  assert(a.borrow == "shared", "original string");
  assert(b.borrow == "shared", "cloned string");
}

arc_multiple_clones() `test {
  a := Ref[int](7);
  b := a.clone();
  c := a.clone();
  d := b.clone();
  assert(a.borrow == 7, "a");
  assert(b.borrow == 7, "b");
  assert(c.borrow == 7, "c");
  assert(d.borrow == 7, "d");
}

arc_cross_goroutine() `test {
  a := Ref[int](42);
  ch := channel[int]();
  go {
    ch.send(a.borrow);
  };
  r := <-ch;
  assert(r! == 42, "cross-goroutine value");
}

arc_clone_cross_goroutine() `test {
  a := Ref[int](123);
  ch := channel[int]();
  b := a.clone();
  go {
    ch.send(b.borrow);
  };
  assert(a.borrow == 123, "original intact");
  r := <-ch;
  assert(r! == 123, "clone cross-goroutine");
}

// User-defined type tests — T0272
type ArcPoint {
  int x;
}

arc_borrow_user_type() `test {
  a := Ref[ArcPoint](ArcPoint(x: 5));
  assert(a.borrow.x == 5, "user type borrow");
}

type ArcPair {
  int x;
  int y;
}

arc_borrow_user_type_two_fields() `test {
  a := Ref[ArcPair](ArcPair(x: 3, y: 7));
  assert(a.borrow.x == 3, "field x");
  assert(a.borrow.y == 7, "field y");
}

type ArcDroppable {
  int val;
  drop(~this) {
  }
}

arc_borrow_user_type_with_drop() `test {
  a := Ref[ArcDroppable](ArcDroppable(val: 99));
  assert(a.borrow.val == 99, "droppable borrow");
  b := a.clone();
  assert(b.borrow.val == 99, "droppable clone borrow");
}

type ArcWithString {
  string name;
  int id;
}

arc_borrow_user_type_synth_drop() `test {
  a := Ref[ArcWithString](ArcWithString(name: "test", id: 7));
  assert(a.borrow.name == "test", "synth drop name");
  assert(a.borrow.id == 7, "synth drop id");
}

// Ref[int[]] — vector inner drop path. T0438: keep `borrowed` typed as
// `int[]&` so we read from the Arc-owned buffer without an implicit decay.
arc_vector_element() `test {
  v := [10, 20, 30];
  a := Ref[int[]](v);
  int[] &borrowed = a.borrow;
  assert(borrowed.len == 3, "vector len");
  assert(borrowed[0] == 10, "vector[0]");
  assert(borrowed[2] == 30, "vector[2]");
}

// T0367: Ref[string[]] — heap container with heap elements. Without the fix,
// `borrowed`'s drop and Arc's inner drop both free the same buffer → segfault
// when the second drop reads scribbled string pointers from the freed buffer.
arc_borrow_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  a := Ref[string[]](v);
  borrowed := a.borrow;
  assert(borrowed.len == 1, "heap vec len");
}

// T0367: Ref[string] with a heap-allocated string — silently double-frees
// without the fix (string drop's bit-63 check happens to mask it).
arc_borrow_heap_string() `test {
  s := "hello" + "";
  a := Ref[string](s);
  borrowed := a.borrow;
  assert(borrowed.len == 5, "heap string len");
}

// T0367: Optional-chained borrow via Weak.upgrade!.
arc_borrow_optional_chain() `test {
  v := string[]();
  v.push("hello" + "");
  a := Ref[string[]](v);
  w := a.downgrade();
  if strong := w.upgrade() {
    borrowed := strong.borrow;
    assert(borrowed.len == 1, "weak upgrade borrow len");
  }
}

// T0367: Typed var decl path (`T& borrowed = a.borrow`) with heap T.
// T0438 restricted the implicit `T& → T` decay to Copy types, so the test
// keeps the borrow type explicitly. The dropflag-clear codegen path for
// the borrow-typed local is the regression check.
arc_borrow_typed_decl_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  a := Ref[string[]](v);
  string[] &borrowed = a.borrow;
  assert(borrowed.len == 1, "typed decl heap vec");
}

// T0367: `.borrow` inside a generic function — monomorphization preserves
// the dropflag-clear when T is heap.
arc_borrow_len[T](Ref[Vector[T]] arc) int {
  borrowed := arc.borrow;
  return borrowed.len;
}

arc_borrow_in_generic_fn() `test {
  v := string[]();
  v.push("hello" + "");
  a := Ref[string[]](v);
  assert(arc_borrow_len[string](a) == 1, "generic borrow len");
}

// T0379: Reassignment of `.borrow` to an existing local must clear the dropflag
// re-armed by the unconditional reset in the assignment path. Without the fix,
// `borrowed`'s drop frees the inner buffer that Arc still owns → segfault.
arc_borrow_reassign_after_borrow() `test {
  v1 := string[]();
  v1.push("hello" + "");
  v2 := string[]();
  v2.push("world" + "");
  a1 := Ref[string[]](v1);
  a2 := Ref[string[]](v2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "reassigned borrow len");
}

// T0379: Owned-local reassignment with cloned-borrow RHS. Original test
// reassigned to `a.borrow` directly, but T0438 now rejects implicit
// `T& → T` decay; explicit `.clone()` is the documented owned-value
// recovery path. The reassignment-drop codegen path being verified
// (drop old owned vector, store new owned vector) is unchanged.
arc_borrow_reassign_after_owned() `test {
  owned := string[]();
  owned.push("owned" + "");
  v := string[]();
  v.push("borrowed" + "");
  a := Ref[string[]](v);
  owned = a.borrow.clone();
  assert(owned.len == 1, "owned reassigned to cloned borrow");
}

// T0379: Ref[string] analog. Exercises the string-drop alias-check branch
// (bindingDropString) in the reassignment path.
arc_borrow_reassign_heap_string() `test {
  s1 := "hello" + "";
  s2 := "world" + "";
  a1 := Ref[string](s1);
  a2 := Ref[string](s2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 5, "reassigned string borrow");
}

// T0379: Multiple alternating reassignments — each must override the dropflag
// re-arm so cleanup never double-frees.
arc_borrow_reassign_alternating() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Ref[string[]](v1);
  a2 := Ref[string[]](v2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  borrowed = a1.borrow;
  assert(borrowed.len == 1, "alternating reassign");
}

// T0379: Borrow→owned reassignment (negative test). The fix must NOT fire when
// RHS is an owned constructor — the local now owns the new value and its drop
// must run at scope exit. A regression that always cleared the dropflag would
// leak the new vector here.
arc_borrow_reassign_to_owned() `test {
  v := string[]();
  v.push("borrowed" + "");
  a := Ref[string[]](v);
  borrowed := a.borrow;
  borrowed = string[]();
  borrowed.push("owned" + "");
  assert(borrowed.len == 1, "borrow reassigned to owned");
}

// T0379: Typed-decl path (T0367) followed by reassignment (T0379). Verifies
// integration between the two fixes — the typed decl clears the flag, then the
// reassignment correctly re-clears it after the unconditional re-arm. T0438:
// keep the local typed as `T&` (no implicit decay).
arc_borrow_typed_decl_reassign() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Ref[string[]](v1);
  a2 := Ref[string[]](v2);
  string[] &borrowed = a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "typed decl + reassign");
}

// T0379: Reassign inside a loop body. Each iteration re-arms the flag at the
// reassignment site and the fix must clear it; cleanup at scope exit must see
// flag=0. A bug here would surface as cumulative leaks across iterations.
arc_borrow_reassign_in_loop() `test {
  v := string[]();
  v.push("loop" + "");
  a := Ref[string[]](v);
  borrowed := a.borrow;
  i := 0;
  while i < 4 {
    borrowed = a.borrow;
    i = i + 1;
  }
  assert(borrowed.len == 1, "reassign in loop");
}

// T0377: Borrow laundered through an if-expression. Both arms produce a
// borrow, so the merged variable must clear its dropflag — without the fix,
// scope cleanup double-frees with Arc.drop.
arc_borrow_through_if() `test {
  v := string[]();
  v.push("hello" + "");
  a := Ref[string[]](v);
  cond := true;
  borrowed := if cond {
    a.borrow
  } else {
    a.borrow
  };
  assert(borrowed.len == 1, "if borrow len");
}

// T0377: Borrow laundered through a match expression with all arms producing
// the same borrow.
arc_borrow_through_match() `test {
  v := string[]();
  v.push("hi" + "");
  a := Ref[string[]](v);
  k := 1;
  borrowed := match k {
    1 => a.borrow, _ => a.borrow,
  };
  assert(borrowed.len == 1, "match borrow len");
}

// T0377: Recursion through nested if-expressions — outer if has an inner
// (parenthesized) if-expression in one arm; every leaf produces a borrow.
arc_borrow_through_nested_if() `test {
  v := string[]();
  v.push("nest" + "");
  a := Ref[string[]](v);
  cond := true;
  cond2 := false;
  borrowed := if cond {
    (if cond2 {
      a.borrow
    } else {
      a.borrow
    })
  } else {
    a.borrow
  };
  assert(borrowed.len == 1, "nested if borrow len");
}

// T0377: Plain parenthesized borrow (`(a.borrow)`) is also a laundering form —
// must clear the dropflag like the bare borrow does.
arc_borrow_through_parens() `test {
  v := string[]();
  v.push("paren" + "");
  a := Ref[string[]](v);
  borrowed := (a.borrow);
  assert(borrowed.len == 1, "paren borrow len");
}

// T0377: Block-bodied match arms (`=> { a.borrow }`) hit the `arm.Block`
// path in `matchArmIsBorrowGetter`. Must still clear the dropflag when every
// block result is a borrow — without the fix, this would double-free.
arc_borrow_through_match_blocks() `test {
  v := string[]();
  v.push("blk" + "");
  a := Ref[string[]](v);
  k := 1;
  borrowed := match k {
    1 => {
      a.borrow
    },
    _ => {
      a.borrow
    },
  };
  assert(borrowed.len == 1, "match block-arm borrow len");
}

// T0381: explicit `T&` annotation on a borrowed local — the new principled
// way to bind a borrow. Replaces the implicit decay path that T0367 had to
// detect via heuristics.
arc_borrow_explicit_ref_type() `test {
  v := string[]();
  v.push("hello" + "");
  a := Ref[string[]](v);
  string[] &borrowed = a.borrow;
  assert(borrowed.len == 1, "explicit ref type borrow");
}

// T0381: chained `.borrow.method` — auto-deref through `T&` finds methods
// on the underlying type. This is the syntax that nested-Arc tests already
// exercise; pinned here as an explicit T0381 regression check.
arc_borrow_chained_method() `test {
  v := [10, 20, 30];
  a := Ref[int[]](v);
  string r = a.borrow[1].to_string();
  assert(r == "20", "chained .borrow[i].method");
}

// T0381: reassigning a `T&`-typed local from one borrow to another
// continues to suppress the dropflag (codegen looks at the RHS type, not
// the AST shape).
arc_borrow_reassign_via_explicit_ref_type() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Ref[string[]](v1);
  a2 := Ref[string[]](v2);
  string[] &borrowed = a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "explicit ref reassign");
}

// T0383 / T0438: `vec[i] = a.borrow.clone()` — explicit clone is the
// documented owned-copy recovery path now that implicit `T& → T` decay
// is rejected. The codegen drop-old-element + store-new path is still
// the regression check.
arc_borrow_index_assign_vector() `test {
  vec := string[][]();
  v1 := string[]();
  v1.push("init" + "");
  vec.push(v1);

  v2 := string[]();
  v2.push("hello" + "");
  a := Ref[string[]](v2);

  vec[0] = a.borrow.clone();
  assert(vec[0].len == 1, "vec[0] len after clone assign");
}

// T0383 / T0438: original `vec[0] = a.borrow` Channel test relied on
// implicit `Channel[T]& → Channel[T]` decay, which T0438 rejects. The
// documented sharing path for Channels is `Ref[Channel[T]].clone()` at
// the Arc level — atomic refcount handles the shared lifetime so each
// owner can drop independently. Both `a1` and `a2` share the same
// underlying Channel and both Arc drops must run without double-freeing
// the inner Channel.
arc_channel_share_via_arc_clone() `test {
  ch := channel[int](capacity: 4);
  a1 := Ref[channel[int]](ch);
  a2 := a1.clone();
  a1.borrow.send(1);
  a2.borrow.send(2);
  assert(true, "Ref[Channel] shared via Arc.clone — no double-free");
}

// T0383: Owned move into vec[i] must still work — dup only fires for borrows.
arc_borrow_index_assign_owned_unaffected() `test {
  vec := string[][]();
  v1 := string[]();
  v1.push("init" + "");
  vec.push(v1);

  v2 := string[]();
  v2.push("hello" + "");
  vec[0] = v2;
  assert(vec[0].len == 1, "owned move still works");
}

// T0383 / T0438: Repeated cloned-borrow assignments — old element drop
// fires correctly between assignments, no double-free, no leak. Original
// `vec[0] = a.borrow` form is rejected at sema; explicit `.clone()` is
// the documented owned-copy recovery path.
arc_borrow_index_assign_repeat_borrows() `test {
  vec := string[][]();
  v0 := string[]();
  v0.push("v0" + "");
  vec.push(v0);

  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  v2.push("c" + "");
  a1 := Ref[string[]](v1);
  a2 := Ref[string[]](v2);

  vec[0] = a1.borrow.clone();
  vec[0] = a2.borrow.clone();
  assert(vec[0].len == 2, "second clone assign");
}

// T0383: `t := vec[i]` for nested heap element dups (B0219 analog) so that
// drop-on-write on vec[i] does NOT cause UAF through t. Mirrors the field
// pattern T0095/B0219.
arc_borrow_index_assign_alias_safe() `test {
  vec := string[][]();
  v1 := string[]();
  v1.push("hi" + "");
  vec.push(v1);

  // t dups vec[0] — independent owned copy
  t := vec[0];

  // overwrite vec[0] — drops old (which was vec[0]'s buffer), but t owns its dup
  v2 := string[]();
  v2.push("ok" + "");
  vec[0] = v2;

  // t is still valid
  assert(t.len == 1, "t still valid after overwrite");
}

// T0402: pinning the documented fix path — `.borrow.clone()` produces an
// owned copy that can safely cross a return boundary. Without the fix in
// T0402 the unsafe `return a.borrow;` pattern crashed with `fatal: invalid
// free (bad header magic)` after a few iterations; the type-based ownership
// check now rejects the unsafe pattern at compile time and this test pins
// the runtime correctness of the .clone() workaround.
get_inner_str_clone(Ref[string] a) string {
  return a.borrow.clone();
}

arc_borrow_clone_returned_owned() `test {
  i := 0;
  while i < 50 {
    s := "hello" + i.to_string();
    a := Ref[string](s);
    result := get_inner_str_clone(a);
    assert(result.starts_with("hello"), "starts with hello");
    i = i + 1;
  }
}

// T0382: `Holder(a.borrow.clone())` deep-copies the Arc's inner buffer at
// construction. Field is then independently owned — both Holder and Arc can
// drop without aliasing the buffer.
type _ArcBorrowHolder {
  string[] field;
}

arc_borrow_into_field_via_clone() `test {
  v2 := string[]();
  v2.push("hello" + "");
  a := Ref[string[]](v2);
  h := _ArcBorrowHolder(a.borrow.clone());
  assert(h.field.len == 1, "clone into field via constructor");
}

// T0386 / T0438: Slice-assign with explicit `.clone()` — full-range. The
// original `v1[0:3] = a.borrow` form is rejected at sema (no implicit
// `string[]& → string[]` decay); `.clone()` produces an owned source whose
// elements are dup'd into the target slice slots.
arc_borrow_slice_assign() `test {
  s := string[]();
  s.push("a" + "");
  s.push("b" + "");
  s.push("c" + "");
  a := Ref[string[]](s);
  v1 := string[]();
  v1.push("x" + "");
  v1.push("y" + "");
  v1.push("z" + "");
  v1[0:3] = a.borrow.clone();
  assert(v1[0] == "a", "v1[0]");
  assert(v1[1] == "b", "v1[1]");
  assert(v1[2] == "c", "v1[2]");
}

// T0386 / T0438: Partial-range slice assignment with explicit `.clone()`.
arc_borrow_slice_assign_partial() `test {
  s := string[]();
  s.push("a" + "");
  a := Ref[string[]](s);
  v1 := string[]();
  v1.push("x" + "");
  v1.push("y" + "");
  v1.push("z" + "");
  v1[0:1] = a.borrow.clone();
  assert(v1[0] == "a", "v1[0]");
  assert(v1[1] == "y", "v1[1]");
  assert(v1[2] == "z", "v1[2]");
}

// T0386 / T0438: Two Arcs alternating with explicit `.clone()`.
arc_borrow_slice_assign_alternating() `test {
  s1 := string[]();
  s1.push("a" + "");
  s1.push("b" + "");
  s2 := string[]();
  s2.push("c" + "");
  a := Ref[string[]](s1);
  b := Ref[string[]](s2);
  v := string[]();
  v.push("x" + "");
  v.push("y" + "");
  v.push("z" + "");
  v[0:2] = a.borrow.clone();
  v[2:3] = b.borrow.clone();
  assert(v[0] == "a", "v[0]");
  assert(v[1] == "b", "v[1]");
  assert(v[2] == "c", "v[2]");
}

// T0393: Arc as a struct field — synth-drop must call Ref[T].drop on the field.
// Without the fix, the user type's synthesized drop walked fields but skipped
// Arc/Weak (only Mutex/MutexGuard had explicit cases), leaking 1 alloc per Arc.
type ArcFieldBox {
  Ref[int] value;
}

arc_field_no_leak() `test {
  ArcFieldBox b = ArcFieldBox(value: Ref[int](42));
}

// T0393: Ref[string] as a field — heap inner type. Verifies the per-instantiation
// drop is dispatched correctly (Ref[string].drop, not Arc.drop).
type ArcStringFieldBox {
  Ref[string] value;
}

arc_field_string_no_leak() `test {
  ArcStringFieldBox b = ArcStringFieldBox(value: Ref[string]("hello"));
}

// T0393: Arc inside a generic carrier — Box[Ref[int]] must monomorphize the
// synth-drop with the substituted Ref[int] field type.
type GenericFieldBox[T] {
  T value;
}

arc_in_generic_box_no_leak() `test {
  GenericFieldBox[Ref[int]] b = GenericFieldBox[Ref[int]](value: Ref[int](7));
}

// T0393: Multiple Arc fields in same type — verify reverse-order field drop
// loop hits every field, including consecutive Ref[T] entries with different T.
type MultiArcFieldBox {
  Ref[int] a;
  Ref[int] b;
  Ref[string] c;
}

arc_multi_field_no_leak() `test {
  MultiArcFieldBox box = MultiArcFieldBox(a: Ref[int](1),
  b: Ref[int](2),
  c: Ref[string]("hi"));
}

// T0393: Arc field with a user-defined drop — exercises the second call site
// of emitFieldDrops (after the user drop() body runs, not the synth-drop path).
// Without the fix, this path also leaked 1 alloc per Arc.
type ArcUserDropBox {
  Ref[int] value;
  int counter;

  drop(~this) {
    // No-op user drop — auto field drops still run after this body.
  }
}

arc_user_drop_no_leak() `test {
  ArcUserDropBox b = ArcUserDropBox(value: Ref[int](42), counter: 0);
}

// T0393: Arc field inherited from a parent type — AllFields() must surface
// the parent's Arc field for the child's synth drop.
type ArcParent {
  Ref[int] shared;
}

type ArcChild is ArcParent {
  int extra;
}

arc_inherited_field_no_leak() `test {
  ArcChild c = ArcChild(shared: Ref[int](99), extra: 1);
}

// T0488: explicit `.clone()` on the borrow arm is the documented fix when
// arms produce mixed `T&` and `T` for non-Copy `T`. The if-expression's
// joined type is owned `string`; the Arc still owns the original.
test_t0488_mixed_arm_clone_local_ok() `test {
  a := Ref[string]("foo" + "");
  cond := true;
  s := if cond {
    a.borrow.clone()
  } else {
    "owned"
  };
  assert(s == "foo", "clone arm value");
  v := a.borrow;
  assert(v.len == 3, "Arc unaffected by clone");
}

// T0488: making both arms produce `T&` (the all-borrow form) is the other
// valid fix — the joined type stays `string&` and no consume occurs.
test_t0488_all_borrow_arms_local_ok() `test {
  a := Ref[string]("foo" + "");
  cond := true;
  s := if cond {
    a.borrow
  } else {
    a.borrow
  };
  assert(s == "foo", "all-borrow arms value");
  v := a.borrow;
  assert(v.len == 3, "Arc unaffected by all-borrow");
}

// T0488: same explicit `.clone()` fix at a `~T` parameter site.
consume_string_t0488(~string s) {
  // s is owned — promise_string_drop called at scope exit.
}

test_t0488_consume_mixed_arm_clone_ok() `test {
  a := Ref[string]("foo" + "");
  cond := true;
  consume_string_t0488(if cond {
    a.borrow.clone()
  } else {
    "owned"
  });
  v := a.borrow;
  assert(v == "foo", "Arc still owns original");
}

// T0488: return-statement consume site — the function returns owned
// `string`, so a mixed `T&`/`T` if-expression as the return value would be
// rejected without `.clone()`. The clone fix produces a fresh owned string,
// so the Arc keeps its inner pointer intact for the caller.
take_t0488(Ref[string] &a, bool cond) string {
  return if cond {
    a.borrow.clone()
  } else {
    "owned"
  };
}

test_t0488_return_mixed_arm_clone_ok() `test {
  a := Ref[string]("foo" + "");
  v := take_t0488(a, true);
  assert(v == "foo", "clone-arm return value");
  b := a.borrow;
  assert(b.len == 3, "Arc unaffected by return-site clone");
}
