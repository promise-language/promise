type Point {
  int x;
  int y;

  sum(this) int {
    return this.x + this.y;
  }
}

type Animal {
  string name;
  speak(this) string `abstract;
}

type Dog is Animal {
  speak(this) string {
    return "woof";
  }
}

type Cat is Animal {
  speak(this) string {
    return "meow";
  }
}

main() `test(expected: """3
4
7
Rex
woof
Whiskers
meow
Buddy
woof
Luna
meow""") {
  // Constructor + field access
  p := Point(x: 3, y: 4);
  print_line(p.x);
  print_line(p.y);

  // Method call
  print_line(p.sum());

  // Inheritance + virtual dispatch
  Dog d = Dog(name: "Rex");
  print_line(d.name);
  print_line(d.speak());

  Cat c = Cat(name: "Whiskers");
  print_line(c.name);
  print_line(c.speak());

  // Polymorphic: Animal variable holding Dog
  Animal a = Dog(name: "Buddy");
  print_line(a.name);
  print_line(a.speak());

  // Polymorphic: Animal variable holding Cat
  Animal a2 = Cat(name: "Luna");
  print_line(a2.name);
  print_line(a2.speak());
}
