// T0559: Vector[Task[T]].clone() panics at runtime (Task is move-only).
worker_t0559_panic() int {
  return 17;
}

main() `test(expected: "panic: Vector[Task[T]].clone() is not supported; Task is move-only", exclude: wasm) {
  v := Vector[Task[int]]();
  v.push(go worker_t0559_panic());
  v.clone();
}
