// json_test.pr — Tests for JSON encoding and decoding
encode_int_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_int(42)?!;
  assert(enc.to_string() == "42", "encode int");
}

encode_negative_int_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_int(-7)?!;
  assert(enc.to_string() == "-7", "encode negative int");
}

encode_uint_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_uint(100u)?!;
  assert(enc.to_string() == "100", "encode uint");
}

encode_f64_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_f64(3.14)?!;
  string s = enc.to_string();
  assert(s.starts_with("3.14"), "encode f64: {s}");
}

encode_bool_true_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_bool(true)?!;
  assert(enc.to_string() == "true", "encode true");
}

encode_bool_false_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_bool(false)?!;
  assert(enc.to_string() == "false", "encode false");
}

encode_string_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_string("hello")?!;
  assert(enc.to_string() == "\"hello\"", "encode string");
}

encode_string_escapes_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_string("a\"b\\c\nd")?!;
  assert(enc.to_string() == "\"a\\\"b\\\\c\\nd\"", "encode string escapes");
}

encode_none_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_none()?!;
  assert(enc.to_string() == "null", "encode none");
}

encode_empty_object_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_object(0)?!;
  enc.end_object()?!;
  assert(enc.to_string() == "\{}", "encode empty object");
}

encode_object_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_object(2)?!;
  enc.encode_key("name")?!;
  enc.encode_string("Alice")?!;
  enc.encode_key("age")?!;
  enc.encode_int(30)?!;
  enc.end_object()?!;
  assert(enc.to_string() == "\{\"name\":\"Alice\",\"age\":30}", "encode object");
}

encode_empty_array_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_array(0)?!;
  enc.end_array()?!;
  assert(enc.to_string() == "[]", "encode empty array");
}

encode_array_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_array(3)?!;
  enc.encode_int(1)?!;
  enc.encode_int(2)?!;
  enc.encode_int(3)?!;
  enc.end_array()?!;
  assert(enc.to_string() == "[1,2,3]", "encode array");
}

encode_nested_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_object(1)?!;
  enc.encode_key("items")?!;
  enc.begin_array(2)?!;
  enc.encode_string("a")?!;
  enc.encode_string("b")?!;
  enc.end_array()?!;
  enc.end_object()?!;
  assert(enc.to_string() == "\{\"items\":[\"a\",\"b\"]}", "encode nested");
}

decode_int_test() `test {
  JsonDecoder dec = JsonDecoder(data: "42");
  int v = dec.decode_int()?!;
  assert(v == 42, "decode int");
}

decode_negative_int_test() `test {
  JsonDecoder dec = JsonDecoder(data: "-7");
  int v = dec.decode_int()?!;
  assert(v == -7, "decode negative int");
}

decode_uint_test() `test {
  JsonDecoder dec = JsonDecoder(data: "100");
  uint v = dec.decode_uint()?!;
  assert(v == 100u, "decode uint");
}

decode_f64_test() `test {
  JsonDecoder dec = JsonDecoder(data: "3.14");
  f64 v = dec.decode_f64()?!;
  assert(v > 3.13 && v < 3.15, "decode f64");
}

decode_bool_true_test() `test {
  JsonDecoder dec = JsonDecoder(data: "true");
  bool v = dec.decode_bool()?!;
  assert(v == true, "decode true");
}

decode_bool_false_test() `test {
  JsonDecoder dec = JsonDecoder(data: "false");
  bool v = dec.decode_bool()?!;
  assert(v == false, "decode false");
}

decode_string_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"hello\"");
  string v = dec.decode_string()?!;
  assert(v == "hello", "decode string");
}

decode_string_escapes_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"a\\\"b\\\\c\\nd\"");
  string v = dec.decode_string()?!;
  assert(v == "a\"b\\c\nd", "decode string escapes");
}

decode_none_test() `test {
  JsonDecoder dec = JsonDecoder(data: "null");
  bool is_null = dec.decode_none()?!;
  assert(is_null, "decode none");
}

decode_none_not_null_test() `test {
  JsonDecoder dec = JsonDecoder(data: "42");
  bool is_null = dec.decode_none()?!;
  assert(!is_null, "decode none returns false for non-null");
  int v = dec.decode_int()?!;
  assert(v == 42, "can still read value after decode_none returns false");
}

decode_object_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{\"name\":\"Alice\",\"age\":30}");
  dec.begin_object()?!;
  string name = "";
  int age = 0;
  for {
    string? k = dec.next_key()?!;
    if k is absent {
      break;
    }
    string key = k ?: "";
    if key == "name" {
      name = dec.decode_string()?!;
    } else if key == "age" {
      age = dec.decode_int()?!;
    } else {
      dec.skip_value()?!;
    }
  }
  dec.end_object()?!;
  assert(name == "Alice", "decode object name");
  assert(age == 30, "decode object age");
}

decode_empty_object_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{}");
  dec.begin_object()?!;
  string? key = dec.next_key()?!;
  assert(key is absent, "empty object has no keys");
  dec.end_object()?!;
}

decode_array_test() `test {
  // Test array via a wrapping object
  JsonDecoder dec = JsonDecoder(data: "[10,20,30]");
  dec.begin_array()?!;
  // Read first element
  int a = dec.decode_int()?!;
  // Manually skip comma and read second
  dec._skip_whitespace();
  if dec._pos < dec._data.len && dec._data[dec._pos] == ',' {
    dec._pos = dec._pos + 1;
  }
  int b = dec.decode_int()?!;
  dec._skip_whitespace();
  if dec._pos < dec._data.len && dec._data[dec._pos] == ',' {
    dec._pos = dec._pos + 1;
  }
  int c = dec.decode_int()?!;
  dec.end_array()?!;
  assert(a == 10, "decode array[0]");
  assert(b == 20, "decode array[1]");
  assert(c == 30, "decode array[2]");
}

decode_empty_array_test() `test {
  JsonDecoder dec = JsonDecoder(data: "[]");
  dec.begin_array()?!;
  dec.end_array()?!;
}

decode_whitespace_test() `test {
  // Test that decoder handles whitespace around scalar values
  JsonDecoder dec = JsonDecoder(data: "  42  ");
  int v = dec.decode_int()?!;
  assert(v == 42, "whitespace: value is 42");
}

skip_value_test() `test {
  // B0261
  JsonDecoder dec = JsonDecoder(data: "\{\"a\":1,\"b\":\{\"nested\":true},\"c\":3}");
  dec.begin_object()?!;
  int c_val = 0;
  for {
    string? k = dec.next_key()?!;
    if k is absent {
      break;
    }
    string key = k ?: "";
    if key == "c" {
      c_val = dec.decode_int()?!;
    } else {
      dec.skip_value()?!;
    }
  }
  dec.end_object()?!;
  assert(c_val == 3, "skip_value: got c=3");
}

round_trip_int_test() `test {
  string s = encode_string[int](42)?!;
  assert(s == "42", "round trip int encode");
  int v = decode_string[int](move s)?!;
  assert(v == 42, "round trip int decode");
}

round_trip_bool_test() `test {
  string s = encode_string[bool](true)?!;
  assert(s == "true", "round trip bool encode");
  bool v = decode_string[bool](move s)?!;
  assert(v == true, "round trip bool decode");
}

round_trip_string_test() `test {
  string s = encode_string[string]("hello world")?!;
  assert(s == "\"hello world\"", "round trip string encode");
  string v = decode_string[string](move s)?!;
  assert(v == "hello world", "round trip string decode");
}

round_trip_f64_test() `test {
  string s = encode_string[f64](2.5)?!;
  f64 v = decode_string[f64](move s)?!;
  assert(v == 2.5, "round trip f64");
}

round_trip_uint_test() `test {
  string s = encode_string[uint](999u)?!;
  assert(s == "999", "round trip uint encode");
  uint v = decode_string[uint](move s)?!;
  assert(v == 999u, "round trip uint decode");
}

round_trip_i8_test() `test {
  JsonEncoder enc = JsonEncoder();
  i8 val = 42i8;
  val.encode(enc)?!;
  assert(enc.to_string() == "42", "i8 encode");

  JsonDecoder dec = JsonDecoder(data: "42");
  i8 v = i8.decode(dec)?!;
  assert(v == 42i8, "i8 decode");
}

round_trip_i32_test() `test {
  JsonEncoder enc = JsonEncoder();
  i32 val = -1000i32;
  val.encode(enc)?!;
  assert(enc.to_string() == "-1000", "i32 encode");

  JsonDecoder dec = JsonDecoder(data: "-1000");
  i32 v = i32.decode(dec)?!;
  assert(v == -1000i32, "i32 decode");
}

round_trip_u8_test() `test {
