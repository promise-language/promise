// json_test.pr — Tests for JSON encoding and decoding
// ── Encoder tests ───────────────────────────────────────────────────────────
encode_int_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_int(42)!;
  assert(enc.to_string() == "42", "encode int");
}

encode_negative_int_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_int(-7)!;
  assert(enc.to_string() == "-7", "encode negative int");
}

encode_uint_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_uint(100u)!;
  assert(enc.to_string() == "100", "encode uint");
}

encode_f64_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_f64(3.14)!;
  string s = enc.to_string();
  assert(s.starts_with("3.14"), "encode f64: {s}");
}

encode_bool_true_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_bool(true)!;
  assert(enc.to_string() == "true", "encode true");
}

encode_bool_false_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_bool(false)!;
  assert(enc.to_string() == "false", "encode false");
}

encode_string_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_string("hello")!;
  assert(enc.to_string() == "\"hello\"", "encode string");
}

encode_string_escapes_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_string("a\"b\\c\nd")!;
  assert(enc.to_string() == "\"a\\\"b\\\\c\\nd\"", "encode string escapes");
}

encode_none_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_none()!;
  assert(enc.to_string() == "null", "encode none");
}

encode_empty_object_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_object(0)!;
  enc.end_object()!;
  assert(enc.to_string() == "\{}", "encode empty object");
}

encode_object_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_object(2)!;
  enc.encode_key("name")!;
  enc.encode_string("Alice")!;
  enc.encode_key("age")!;
  enc.encode_int(30)!;
  enc.end_object()!;
  assert(enc.to_string() == "\{\"name\":\"Alice\",\"age\":30}", "encode object");
}

encode_empty_array_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_array(0)!;
  enc.end_array()!;
  assert(enc.to_string() == "[]", "encode empty array");
}

encode_array_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_array(3)!;
  enc.encode_int(1)!;
  enc.encode_int(2)!;
  enc.encode_int(3)!;
  enc.end_array()!;
  assert(enc.to_string() == "[1,2,3]", "encode array");
}

encode_nested_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_object(1)!;
  enc.encode_key("items")!;
  enc.begin_array(2)!;
  enc.encode_string("a")!;
  enc.encode_string("b")!;
  enc.end_array()!;
  enc.end_object()!;
  assert(enc.to_string() == "\{\"items\":[\"a\",\"b\"]}", "encode nested");
}

// ── Decoder tests ───────────────────────────────────────────────────────────

decode_int_test() `test {
  JsonDecoder dec = JsonDecoder(data: "42");
  int v = dec.decode_int()!;
  assert(v == 42, "decode int");
}

decode_negative_int_test() `test {
  JsonDecoder dec = JsonDecoder(data: "-7");
  int v = dec.decode_int()!;
  assert(v == -7, "decode negative int");
}

decode_uint_test() `test {
  JsonDecoder dec = JsonDecoder(data: "100");
  uint v = dec.decode_uint()!;
  assert(v == 100u, "decode uint");
}

decode_f64_test() `test {
  JsonDecoder dec = JsonDecoder(data: "3.14");
  f64 v = dec.decode_f64()!;
  assert(v > 3.13 && v < 3.15, "decode f64");
}

decode_bool_true_test() `test {
  JsonDecoder dec = JsonDecoder(data: "true");
  bool v = dec.decode_bool()!;
  assert(v == true, "decode true");
}

decode_bool_false_test() `test {
  JsonDecoder dec = JsonDecoder(data: "false");
  bool v = dec.decode_bool()!;
  assert(v == false, "decode false");
}

decode_string_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"hello\"");
  string v = dec.decode_string()!;
  assert(v == "hello", "decode string");
}

decode_string_escapes_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"a\\\"b\\\\c\\nd\"");
  string v = dec.decode_string()!;
  assert(v == "a\"b\\c\nd", "decode string escapes");
}

decode_none_test() `test {
  JsonDecoder dec = JsonDecoder(data: "null");
  bool is_null = dec.decode_none()!;
  assert(is_null, "decode none");
}

decode_none_not_null_test() `test {
  JsonDecoder dec = JsonDecoder(data: "42");
  bool is_null = dec.decode_none()!;
  assert(!is_null, "decode none returns false for non-null");
  int v = dec.decode_int()!;
  assert(v == 42, "can still read value after decode_none returns false");
}

decode_object_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{\"name\":\"Alice\",\"age\":30}");
  dec.begin_object()!;
  string name = "";
  int age = 0;
  for {
    string? k = dec.next_key()!;
    if k is absent {
      break;
    }
    string key = k ?: "";
    if key == "name" {
      name = dec.decode_string()!;
    } else if key == "age" {
      age = dec.decode_int()!;
    } else {
      dec.skip_value()!;
    }
  }
  dec.end_object()!;
  assert(name == "Alice", "decode object name");
  assert(age == 30, "decode object age");
}

decode_empty_object_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{}");
  dec.begin_object()!;
  string? key = dec.next_key()!;
  assert(key is absent, "empty object has no keys");
  dec.end_object()!;
}

decode_array_test() `test {
  // Test array via a wrapping object
  JsonDecoder dec = JsonDecoder(data: "[10,20,30]");
  dec.begin_array()!;
  // Read first element
  int a = dec.decode_int()!;
  // Manually skip comma and read second
  dec._skip_whitespace();
  if dec._pos < dec._data.len && dec._data[dec._pos] == ',' {
    dec._pos = dec._pos + 1;
  }
  int b = dec.decode_int()!;
  dec._skip_whitespace();
  if dec._pos < dec._data.len && dec._data[dec._pos] == ',' {
    dec._pos = dec._pos + 1;
  }
  int c = dec.decode_int()!;
  dec.end_array()!;
  assert(a == 10, "decode array[0]");
  assert(b == 20, "decode array[1]");
  assert(c == 30, "decode array[2]");
}

decode_empty_array_test() `test {
  JsonDecoder dec = JsonDecoder(data: "[]");
  dec.begin_array()!;
  dec.end_array()!;
}

decode_whitespace_test() `test {
  // Test that decoder handles whitespace around scalar values
  JsonDecoder dec = JsonDecoder(data: "  42  ");
  int v = dec.decode_int()!;
  assert(v == 42, "whitespace: value is 42");
}

skip_value_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{\"a\":1,\"b\":\{\"nested\":true},\"c\":3}");
  dec.begin_object()!;
  int c_val = 0;
  for {
    string? k = dec.next_key()!;
    if k is absent {
      break;
    }
    string key = k ?: "";
    if key == "c" {
      c_val = dec.decode_int()!;
    } else {
      dec.skip_value()!;
    }
  }
  dec.end_object()!;
  assert(c_val == 3, "skip_value: got c=3");
}

// ── Round-trip via Encodable/Decodable on primitives ────────────────────────

round_trip_int_test() `test {
  string s = encode_string[int](42)!;
  assert(s == "42", "round trip int encode");
  int v = decode_string[int](s)!;
  assert(v == 42, "round trip int decode");
}

round_trip_bool_test() `test {
  string s = encode_string[bool](true)!;
  assert(s == "true", "round trip bool encode");
  bool v = decode_string[bool](s)!;
  assert(v == true, "round trip bool decode");
}

round_trip_string_test() `test {
  string s = encode_string[string]("hello world")!;
  assert(s == "\"hello world\"", "round trip string encode");
  string v = decode_string[string](s)!;
  assert(v == "hello world", "round trip string decode");
}

round_trip_f64_test() `test {
  string s = encode_string[f64](2.5)!;
  f64 v = decode_string[f64](s)!;
  assert(v == 2.5, "round trip f64");
}

// ── Round-trip: sized integer types ──────────────────────────────────────────

round_trip_uint_test() `test {
  string s = encode_string[uint](999u)!;
  assert(s == "999", "round trip uint encode");
  uint v = decode_string[uint](s)!;
  assert(v == 999u, "round trip uint decode");
}

round_trip_i8_test() `test {
  JsonEncoder enc = JsonEncoder();
  i8 val = 42i8;
  val.encode(enc)!;
  assert(enc.to_string() == "42", "i8 encode");

  JsonDecoder dec = JsonDecoder(data: "42");
  i8 v = i8.decode(dec)!;
  assert(v == 42i8, "i8 decode");
}

round_trip_i32_test() `test {
  JsonEncoder enc = JsonEncoder();
  i32 val = -1000i32;
  val.encode(enc)!;
  assert(enc.to_string() == "-1000", "i32 encode");

  JsonDecoder dec = JsonDecoder(data: "-1000");
  i32 v = i32.decode(dec)!;
  assert(v == -1000i32, "i32 decode");
}

round_trip_u8_test() `test {
  JsonEncoder enc = JsonEncoder();
  u8 val = 200u8;
  val.encode(enc)!;
  assert(enc.to_string() == "200", "u8 encode");

  JsonDecoder dec = JsonDecoder(data: "200");
  u8 v = u8.decode(dec)!;
  assert(v == 200u8, "u8 decode");
}

round_trip_f32_test() `test {
  JsonEncoder enc = JsonEncoder();
  f32 val = 1.5f32;
  val.encode(enc)!;
  assert(enc.to_string() == "1.5", "f32 encode");

  JsonDecoder dec = JsonDecoder(data: "1.5");
  f32 v = f32.decode(dec)!;
  assert(v == 1.5f32, "f32 decode");
}

round_trip_char_test() `test {
  JsonEncoder enc = JsonEncoder();
  char val = 'A';
  val.encode(enc)!;
  assert(enc.to_string() == "\"A\"", "char encode");

  JsonDecoder dec = JsonDecoder(data: "\"A\"");
  char v = char.decode(dec)!;
  assert(v == 'A', "char decode");
}

// ── Sized type range checking ───────────────────────────────────────────────

decode_i8_overflow_test() `test {
  JsonDecoder dec = JsonDecoder(data: "200");
  (v, err) := i8.decode(dec);
  assert(err is present, "i8 decode 200 should overflow");
}

decode_i8_underflow_test() `test {
  JsonDecoder dec = JsonDecoder(data: "-200");
  (v, err) := i8.decode(dec);
  assert(err is present, "i8 decode -200 should underflow");
}

decode_u8_overflow_test() `test {
  JsonDecoder dec = JsonDecoder(data: "300");
  (v, err) := u8.decode(dec);
  assert(err is present, "u8 decode 300 should overflow");
}

decode_u16_overflow_test() `test {
  JsonDecoder dec = JsonDecoder(data: "70000");
  (v, err) := u16.decode(dec);
  assert(err is present, "u16 decode 70000 should overflow");
}

// ── Encoder edge cases ──────────────────────────────────────────────────────

encode_empty_string_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_string("")!;
  assert(enc.to_string() == "\"\"", "encode empty string");
}

encode_zero_int_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_int(0)!;
  assert(enc.to_string() == "0", "encode zero int");
}

encode_negative_f64_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_f64(-2.5)!;
  assert(enc.to_string() == "-2.5", "encode negative f64");
}

encode_mixed_array_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_array(3)!;
  enc.encode_int(1)!;
  enc.encode_string("two")!;
  enc.encode_bool(true)!;
  enc.end_array()!;
  assert(enc.to_string() == "[1,\"two\",true]", "encode mixed array");
}

encode_object_with_null_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.begin_object(2)!;
  enc.encode_key("a")!;
  enc.encode_int(1)!;
  enc.encode_key("b")!;
  enc.encode_none()!;
  enc.end_object()!;
  assert(enc.to_string() == "\{\"a\":1,\"b\":null}", "encode object with null");
}

// ── Decoder edge cases ──────────────────────────────────────────────────────

decode_empty_string_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"\"");
  string v = dec.decode_string()!;
  assert(v == "", "decode empty string");
}

decode_negative_f64_test() `test {
  JsonDecoder dec = JsonDecoder(data: "-2.5");
  f64 v = dec.decode_f64()!;
  assert(v == -2.5, "decode negative f64");
}

decode_scientific_notation_test() `test {
  JsonDecoder dec = JsonDecoder(data: "1.5e2");
  f64 v = dec.decode_f64()!;
  assert(v == 150.0, "decode 1.5e2");
}

decode_zero_test() `test {
  JsonDecoder dec = JsonDecoder(data: "0");
  int v = dec.decode_int()!;
  assert(v == 0, "decode zero");
}

decode_object_with_null_value_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{\"x\":null,\"y\":1}");
  dec.begin_object()!;
  bool x_is_null = false;
  int y_val = 0;
  for {
    string? k = dec.next_key()!;
    if k is absent {
      break;
    }
    string key = k ?: "";
    if key == "x" {
      x_is_null = dec.decode_none()!;
    } else if key == "y" {
      y_val = dec.decode_int()!;
    } else {
      dec.skip_value()!;
    }
  }
  dec.end_object()!;
  assert(x_is_null, "null value detected");
  assert(y_val == 1, "value after null");
}

skip_value_array_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{\"a\":[1,2,3],\"b\":99}");
  dec.begin_object()!;
  int b_val = 0;
  for {
    string? k = dec.next_key()!;
    if k is absent {
      break;
    }
    string key = k ?: "";
    if key == "b" {
      b_val = dec.decode_int()!;
    } else {
      dec.skip_value()!;
    }
  }
  dec.end_object()!;
  assert(b_val == 99, "skip array, got b=99");
}

skip_value_string_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\{\"a\":\"hello\",\"b\":42}");
  dec.begin_object()!;
  int b_val = 0;
  for {
    string? k = dec.next_key()!;
    if k is absent {
      break;
    }
    string key = k ?: "";
    if key == "b" {
      b_val = dec.decode_int()!;
    } else {
      dec.skip_value()!;
    }
  }
  dec.end_object()!;
  assert(b_val == 42, "skip string, got b=42");
}

// ── Pretty printing ─────────────────────────────────────────────────────────

encode_pretty_object_test() `test {
  JsonEncoder enc = JsonEncoder(pretty: true, indent: 2);
  enc.begin_object(1)!;
  enc.encode_key("x")!;
  enc.encode_int(1)!;
  enc.end_object()!;
  string result = enc.to_string();
  // Should contain newlines and indentation
  assert(result.contains("\n"), "pretty has newlines");
  assert(result.contains("  \"x\""), "pretty has indented key");
}

// ── Decode error tests ──────────────────────────────────────────────────────

decode_error_invalid_bool_test() `test {
  (v, err) := decode_string[int]("abc");
  assert(err is present, "invalid input should error");
}

decode_error_unterminated_string_test() `test {
  (v, err) := decode_string[string]("\"unterminated");
  assert(err is present, "unterminated string should error");
}

decode_error_negative_uint_test() `test {
  JsonDecoder dec = JsonDecoder(data: "-5");
  (v, err) := dec.decode_uint();
  assert(err is present, "negative uint should error");
}

decode_error_position_test() `test {
  // DecodeError should include position information
  JsonDecoder dec = JsonDecoder(data: "   xyz");
  (v, err) := dec.decode_bool();
  assert(err is present, "bad bool should error");
}

// ── JsonValue tests ─────────────────────────────────────────────────────────

parse_value_null_test() `test {
  JsonValue v = parse_value("null")!;
  match v {
    JsonValue.Null => assert(true, "null"),
    _ => assert(false, "expected null"),
  }
}

parse_value_bool_test() `test {
  JsonValue v = parse_value("true")!;
  match v {
    JsonValue.Bool(b) => assert(b == true, "true"),
    _ => assert(false, "expected bool"),
  }
}

parse_value_number_test() `test {
  JsonValue v = parse_value("42")!;
  match v {
    JsonValue.Number(n) => assert(n == 42.0, "number"),
    _ => assert(false, "expected number"),
  }
}

parse_value_string_test() `test {
  JsonValue v = parse_value("\"hello\"")!;
  match v {
    JsonValue.Str(s) => assert(s == "hello", "string"),
    _ => assert(false, "expected string"),
  }
}

parse_value_array_test() `test {
  JsonValue v = parse_value("[1,2,3]")!;
  match v {
    JsonValue.Array(items) => assert(items.len == 3, "array len"),
    _ => assert(false, "expected array"),
  }
}

parse_value_empty_array_test() `test {
  JsonValue v = parse_value("[]")!;
  match v {
    JsonValue.Array(items) => assert(items.len == 0, "empty array"),
    _ => assert(false, "expected array"),
  }
}

parse_value_object_test() `test {
  string data = "\{\"a\":1,\"b\":2}";
  JsonValue v = parse_value(data)!;
  match v {
    JsonValue.Object(fields) => assert(fields.len == 2, "object keys"),
    _ => assert(false, "expected object"),
  }
}

format_value_null_test() `test {
  string s = format_value(JsonValue.Null)!;
  assert(s == "null", "format null");
}

format_value_bool_test() `test {
  string s = format_value(JsonValue.Bool(true))!;
  assert(s == "true", "format true");
}

format_value_string_test() `test {
  string s = format_value(JsonValue.Str("hello"))!;
  assert(s == "\"hello\"", "format string");
}

format_value_array_test() `test {
  JsonValue arr = JsonValue.Array([JsonValue.Number(1.0), JsonValue.Number(2.0)]);
  string s = format_value(arr)!;
  assert(s == "[1,2]", "format array");
}

round_trip_value_test() `test {
  JsonValue arr = JsonValue.Array([JsonValue.Bool(true), JsonValue.Str("x")]);
  string s = format_value(arr)!;
  JsonValue v = parse_value(s)!;
  match v {
    JsonValue.Array(items) => assert(items.len == 2, "rt array"),
    _ => assert(false, "expected array"),
  }
}

nested_value_test() `test {
  // Nested: object containing array
  string data = "\{\"items\":[1,2],\"ok\":true}";
  JsonValue v = parse_value(data)!;
  match v {
    JsonValue.Object(fields) => {
      assert(fields.len == 2, "nested: keys");
      assert(fields.contains("items"), "nested: has items key");
    },
    _ => assert(false, "expected object"),
  }
}

parse_value_false_test() `test {
  JsonValue v = parse_value("false")!;
  match v {
    JsonValue.Bool(b) => assert(b == false, "false"),
    _ => assert(false, "expected bool"),
  }
}

parse_value_negative_number_test() `test {
  JsonValue v = parse_value("-7")!;
  match v {
    JsonValue.Number(n) => assert(n == -7.0, "negative"),
    _ => assert(false, "expected number"),
  }
}

parse_value_float_test() `test {
  JsonValue v = parse_value("3.14")!;
  match v {
    JsonValue.Number(n) => assert(n > 3.13 && n < 3.15, "float"),
    _ => assert(false, "expected number"),
  }
}

parse_value_string_escapes_test() `test {
  JsonValue v = parse_value("\"a\\nb\"")!;
  match v {
    JsonValue.Str(s) => assert(s == "a\nb", "escape"),
    _ => assert(false, "expected string"),
  }
}

parse_value_whitespace_test() `test {
  JsonValue v = parse_value("  42  ")!;
  match v {
    JsonValue.Number(n) => assert(n == 42.0, "whitespace"),
    _ => assert(false, "expected number"),
  }
}

parse_value_nested_arrays_test() `test {
  JsonValue v = parse_value("[[1,2],[3]]")!;
  match v {
    JsonValue.Array(items) => {
      assert(items.len == 2, "outer len");
    },
    _ => assert(false, "expected array"),
  }
}

parse_value_empty_object_test() `test {
  JsonValue v = parse_value("\{}")!;
  match v {
    JsonValue.Object(fields) => assert(fields.len == 0, "empty obj"),
    _ => assert(false, "expected object"),
  }
}

format_value_false_test() `test {
  string s = format_value(JsonValue.Bool(false))!;
  assert(s == "false", "format false");
}

format_value_number_test() `test {
  string s = format_value(JsonValue.Number(42.0))!;
  assert(s == "42", "format number");
}

format_value_empty_array_test() `test {
  string s = format_value(JsonValue.Array(JsonValue[]()))!;
  assert(s == "[]", "format empty array");
}

format_value_object_test() `test {
  map[string, JsonValue] f = {
    "a": JsonValue.Number(1.0)
  };
  JsonValue obj = JsonValue.Object(f);
  string s = format_value(obj)!;
  assert(s.contains("\"a\":1"), "format object");
}

format_value_empty_object_test() `test {
  JsonValue obj = JsonValue.Object(map[string, JsonValue]());
  string s = format_value(obj)!;
  assert(s == "\{}", "format empty object");
}

round_trip_object_test() `test {
  map[string, JsonValue] f = {
    "x": JsonValue.Number(1.0), "y": JsonValue.Str("two")
  };
  JsonValue obj = JsonValue.Object(f);
  string s = format_value(obj)!;
  JsonValue v = parse_value(s)!;
  match v {
    JsonValue.Object(fields) => {
      assert(fields.len == 2, "rt obj keys");
      assert(fields.contains("x"), "rt obj has x");
    },
    _ => assert(false, "expected object"),
  }
}

deep_nesting_test() `test {
  // array inside object: {"data":[1,true,"x"]}
  string data = "\{\"data\":[1,true,\"x\"]}";
  JsonValue v = parse_value(data)!;
  string s = format_value(v)!;
  JsonValue v2 = parse_value(s)!;
  match v2 {
    JsonValue.Object(fields) => {
      assert(fields.contains("data"), "deep: has data key");
    },
    _ => assert(false, "expected object"),
  }
}

// ── Object field value access tests ─────────────────────────────────────────

object_field_value_access_test() `test {
  // Verify we can look up values by key after parsing
  string data = "\{\"name\":\"Alice\",\"age\":30,\"active\":true}";
  JsonValue v = parse_value(data)!;
  match v {
    JsonValue.Object(fields) => {
      assert(fields.len == 3, "field count");
      JsonValue name_val = fields["name"]!;
      match name_val {
        JsonValue.Str(s) => assert(s == "Alice", "name value"),
        _ => assert(false, "expected string for name"),
      }
      JsonValue age_val = fields["age"]!;
      match age_val {
        JsonValue.Number(n) => assert(n == 30.0, "age value"),
        _ => assert(false, "expected number for age"),
      }
      JsonValue active_val = fields["active"]!;
      match active_val {
        JsonValue.Bool(b) => assert(b == true, "active value"),
        _ => assert(false, "expected bool for active"),
      }
    },
    _ => assert(false, "expected object"),
  }
}

nested_object_test() `test {
  // Object containing another object
  string data = "\{\"user\":\{\"name\":\"Bob\",\"score\":42}}";
  JsonValue v = parse_value(data)!;
  match v {
    JsonValue.Object(outer) => {
      assert(outer.len == 1, "outer fields");
      JsonValue user_val = outer["user"]!;
      match user_val {
        JsonValue.Object(inner) => {
          assert(inner.len == 2, "inner fields");
          JsonValue name_val = inner["name"]!;
          match name_val {
            JsonValue.Str(s) => assert(s == "Bob", "nested name"),
            _ => assert(false, "expected string"),
          }
        },
        _ => assert(false, "expected inner object"),
      }
    },
    _ => assert(false, "expected outer object"),
  }
}

round_trip_nested_object_test() `test {
  // Build nested object, format, parse back, verify values
  map[string, JsonValue] inner = {
    "x": JsonValue.Number(1.0)
  };
  map[string, JsonValue] outer = {
    "nested": JsonValue.Object(inner),
    "flat": JsonValue.Str("hello"),
  };
  JsonValue obj = JsonValue.Object(outer);
  string s = format_value(obj)!;
  JsonValue parsed = parse_value(s)!;
  match parsed {
    JsonValue.Object(fields) => {
      assert(fields.len == 2, "rt nested: field count");
      assert(fields.contains("nested"), "rt nested: has nested");
      assert(fields.contains("flat"), "rt nested: has flat");
    },
    _ => assert(false, "expected object"),
  }
}

object_duplicate_key_test() `test {
  // JSON with duplicate keys — last value wins (map semantics)
  string data = "\{\"a\":1,\"a\":2}";
  JsonValue v = parse_value(data)!;
  match v {
    JsonValue.Object(fields) => {
      assert(fields.len == 1, "duplicate key: single entry");
      JsonValue val = fields["a"]!;
      match val {
        JsonValue.Number(n) => assert(n == 2.0, "duplicate key: last wins"),
        _ => assert(false, "expected number"),
      }
    },
    _ => assert(false, "expected object"),
  }
}

object_null_value_test() `test {
  string data = "\{\"x\":null}";
  JsonValue v = parse_value(data)!;
  match v {
    JsonValue.Object(fields) => {
      JsonValue val = fields["x"]!;
      match val {
        JsonValue.Null => assert(true, "null value"),
        _ => assert(false, "expected null"),
      }
    },
    _ => assert(false, "expected object"),
  }
}

// ── String escape coverage ──────────────────────────────────────────────────

encode_string_tab_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_string("a\tb")!;
  assert(enc.to_string() == "\"a\\tb\"", "encode tab");
}

encode_string_cr_test() `test {
  JsonEncoder enc = JsonEncoder();
  enc.encode_string("a\rb")!;
  assert(enc.to_string() == "\"a\\rb\"", "encode cr");
}

encode_string_control_char_test() `test {
  // Control char below 0x20: should be \u00XX
  char nul = 0 as! char;
  JsonEncoder enc = JsonEncoder();
  enc.encode_string(nul.to_string())!;
  assert(enc.to_string() == "\"\\u0000\"", "encode control char");
}

decode_string_tab_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"a\\tb\"");
  string v = dec.decode_string()!;
  assert(v == "a\tb", "decode tab");
}

decode_string_cr_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"a\\rb\"");
  string v = dec.decode_string()!;
  assert(v == "a\rb", "decode cr");
}

decode_string_slash_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"a\\/b\"");
  string v = dec.decode_string()!;
  assert(v == "a/b", "decode escaped slash");
}

decode_string_unicode_escape_test() `test {
  // \u0041 = 'A'
  JsonDecoder dec = JsonDecoder(data: "\"\\u0041\"");
  string v = dec.decode_string()!;
  assert(v == "A", "decode unicode escape");
}

decode_string_backspace_formfeed_test() `test {
  JsonDecoder dec = JsonDecoder(data: "\"\\b\\f\"");
  string v = dec.decode_string()!;
  assert(v.len == 2, "decode backspace+formfeed length");
}

// ── Pretty printing coverage ────────────────────────────────────────────────

encode_pretty_array_test() `test {
  JsonEncoder enc = JsonEncoder(pretty: true, indent: 2);
  enc.begin_array(2)!;
  enc.encode_int(1)!;
  enc.encode_int(2)!;
  enc.end_array()!;
  string result = enc.to_string();
  assert(result.contains("\n"), "pretty array has newlines");
  assert(result.contains("  1"), "pretty array has indented element");
}

encode_pretty_nested_test() `test {
  JsonEncoder enc = JsonEncoder(pretty: true, indent: 2);
  enc.begin_object(1)!;
  enc.encode_key("items")!;
  enc.begin_array(1)!;
  enc.encode_int(42)!;
  enc.end_array()!;
  enc.end_object()!;
  string result = enc.to_string();
  assert(result.contains("\"items\": ["), "pretty nested: key with colon space");
  assert(result.contains("    42"), "pretty nested: double-indented value");
}

format_value_pretty_test() `test {
  map[string, JsonValue] f = {
    "key": JsonValue.Bool(true)
  };
  JsonValue obj = JsonValue.Object(f);
  string s = format_value_pretty(obj)!;
  assert(s.contains("\n"), "format_value_pretty has newlines");
  assert(s.contains("  \"key\""), "format_value_pretty has indented key");
}

encode_pretty_empty_object_test() `test {
  JsonEncoder enc = JsonEncoder(pretty: true);
  enc.begin_object(0)!;
  enc.end_object()!;
  string s = enc.to_string();
  assert(s.contains("\{}"), "pretty empty object contains braces");
  // No indented content inside
  assert(!s.contains("  "), "pretty empty object no indented content");
}

encode_pretty_empty_array_test() `test {
  JsonEncoder enc = JsonEncoder(pretty: true);
  enc.begin_array(0)!;
  enc.end_array()!;
  string s = enc.to_string();
  assert(s.contains("[]"), "pretty empty array contains brackets");
  assert(!s.contains("  "), "pretty empty array no indented content");
}

// ── Mixed structure coverage ────────────────────────────────────────────────

parse_object_in_array_test() `test {
  // Array of objects
  JsonValue v = parse_value("[\{\"a\":1},\{\"b\":2}]")!;
  match v {
    JsonValue.Array(items) => {
      assert(items.len == 2, "array of objects: len");
      match items[0] {
        JsonValue.Object(f) => {
          assert(f.contains("a"), "first obj has a");
        },
        _ => assert(false, "expected object at [0]"),
      }
      match items[1] {
        JsonValue.Object(f) => {
          assert(f.contains("b"), "second obj has b");
        },
        _ => assert(false, "expected object at [1]"),
      }
    },
    _ => assert(false, "expected array"),
  }
}

parse_heterogeneous_array_test() `test {
  // Array with all JSON types
  JsonValue v = parse_value("[null,true,42,\"str\",[],\{}]")!;
  match v {
    JsonValue.Array(items) => {
      assert(items.len == 6, "heterogeneous: 6 items");
      match items[0] {
        JsonValue.Null => assert(true, "item 0: null"),
        _ => assert(false, "expected null"),
      }
      match items[1] {
        JsonValue.Bool(b) => assert(b == true, "item 1: true"),
        _ => assert(false, "expected bool"),
      }
      match items[2] {
        JsonValue.Number(n) => assert(n == 42.0, "item 2: 42"),
        _ => assert(false, "expected number"),
      }
      match items[3] {
        JsonValue.Str(s) => assert(s == "str", "item 3: str"),
        _ => assert(false, "expected string"),
      }
      match items[4] {
        JsonValue.Array(a) => assert(a.len == 0, "item 4: empty array"),
        _ => assert(false, "expected array"),
      }
      match items[5] {
        JsonValue.Object(f) => assert(f.len == 0, "item 5: empty object"),
        _ => assert(false, "expected object"),
      }
    },
    _ => assert(false, "expected array"),
  }
}

round_trip_complex_test() `test {
  // Complex structure: object with array of objects
  string data = "\{\"users\":[\{\"name\":\"A\",\"age\":1},\{\"name\":\"B\",\"age\":2}],\"count\":2}";
  JsonValue v = parse_value(data)!;
  string s = format_value(v)!;
  JsonValue v2 = parse_value(s)!;
  match v2 {
    JsonValue.Object(fields) => {
      assert(fields.len == 2, "complex rt: field count");
      assert(fields.contains("users"), "complex rt: has users");
      assert(fields.contains("count"), "complex rt: has count");
      JsonValue users = fields["users"]!;
      match users {
        JsonValue.Array(items) => assert(items.len == 2, "complex rt: 2 users"),
        _ => assert(false, "expected array"),
      }
    },
    _ => assert(false, "expected object"),
  }
}

// ── Decoder has_next_element array pattern ───────────────────────────────────

decode_array_has_next_element_test() `test {
  JsonDecoder dec = JsonDecoder(data: "[10,20,30]");
  dec.begin_array()!;
  int[] vals = int[]();
  for {
    bool more = dec.has_next_element()!;
    if !more {
      break;
    }
    int v = dec.decode_int()!;
    vals.push(v);
  }
  dec.end_array()!;
  assert(vals.len == 3, "has_next: count");
  assert(vals[0] == 10, "has_next: [0]");
  assert(vals[1] == 20, "has_next: [1]");
  assert(vals[2] == 30, "has_next: [2]");
}

decode_array_has_next_empty_test() `test {
  JsonDecoder dec = JsonDecoder(data: "[]");
  dec.begin_array()!;
  bool more = dec.has_next_element()!;
  assert(!more, "has_next empty: no elements");
  dec.end_array()!;
}

// ── parse_value error cases ─────────────────────────────────────────────────

parse_value_error_empty_test() `test {
  (v, err) := parse_value("");
  assert(err is present, "empty input should error");
}

parse_value_error_invalid_test() `test {
  (v, err) := parse_value("xyz");
  assert(err is present, "invalid token should error");
}

parse_value_error_unterminated_array_test() `test {
  (v, err) := parse_value("[1,2");
  assert(err is present, "unterminated array should error");
}

parse_value_error_unterminated_object_test() `test {
  (v, err) := parse_value("\{\"a\":1");
  assert(err is present, "unterminated object should error");
}

parse_value_error_unterminated_string_test() `test {
  (v, err) := parse_value("\"hello");
  assert(err is present, "unterminated string should error");
}

// ── Whitespace tolerance ────────────────────────────────────────────────────

parse_value_whitespace_object_test() `test {
  // Generous whitespace
  string data = "  \{  \"a\"  :  1  ,  \"b\"  :  2  }  ";
  JsonValue v = parse_value(data)!;
  match v {
    JsonValue.Object(fields) => assert(fields.len == 2, "whitespace obj: 2 fields"),
    _ => assert(false, "expected object"),
  }
}

parse_value_whitespace_array_test() `test {
  JsonValue v = parse_value("  [  1  ,  2  ,  3  ]  ")!;
  match v {
    JsonValue.Array(items) => assert(items.len == 3, "whitespace array: 3 items"),
    _ => assert(false, "expected array"),
  }
}

// ── Number edge cases ───────────────────────────────────────────────────────

parse_value_zero_test() `test {
  JsonValue v = parse_value("0")!;
  match v {
    JsonValue.Number(n) => assert(n == 0.0, "zero"),
    _ => assert(false, "expected number"),
  }
}

parse_value_exponent_test() `test {
  JsonValue v = parse_value("1e3")!;
  match v {
    JsonValue.Number(n) => assert(n == 1000.0, "1e3"),
    _ => assert(false, "expected number"),
  }
}

parse_value_negative_exponent_test() `test {
  JsonValue v = parse_value("1e-2")!;
  match v {
    JsonValue.Number(n) => assert(n > 0.009 && n < 0.011, "1e-2"),
    _ => assert(false, "expected number"),
  }
}

format_value_number_negative_test() `test {
  string s = format_value(JsonValue.Number(-3.5))!;
  assert(s == "-3.5", "format negative float");
}
