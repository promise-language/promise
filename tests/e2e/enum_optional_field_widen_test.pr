}

// --- multi-field variant: mix Optional (bare widen) + non-Optional field ---

multi_field_mixed() `test {
  Mixed e = Mixed.Pair(9, "tag");
  match e {
    Mixed.Pair(a, b) => {
      if v := a {
        assert(v == 9, "widened int? field a holds 9");
      } else {
        assert(false, "expected present a");
      }
      assert(b == "tag", "non-optional field b holds tag");
    },
    Mixed.Boxed(p) => assert(false, "expected Pair"),
    Mixed.Nada => assert(false, "expected Pair"),
  }
}

// --- Optional-of-user-type variant field: bare widen ---

optional_user_type_bare_widen() `test {
  Mixed e = Mixed.Boxed(Pt(x: 3, y: 4));
  match e {
    Mixed.Boxed(p) => {
      if pt := p {
        assert(pt.x == 3, "Pt.x == 3");
        assert(pt.y == 4, "Pt.y == 4");
      } else {
        assert(false, "expected present Pt?");
      }
    },
    Mixed.Pair(a, b) => assert(false, "expected Boxed"),
    Mixed.Nada => assert(false, "expected Boxed"),
  }
}

optional_user_type_none() `test {
  Mixed e = Mixed.Boxed(none);
  match e {
    Mixed.Boxed(p) => {
      if pt := p {
        assert(false, "expected absent Pt?");
      }
    },
    Mixed.Pair(a, b) => assert(false, "expected Boxed"),
    Mixed.Nada => assert(false, "expected Boxed"),
  }
}

// --- generic FUNCTION body: bare TypeParam arg widened into T? variant field
// Exercises the genEnumVariantCallLayout `c.typeSubst != nil` substitution
// branch (expr.go) — uncovered by the original T0608 tests, which all
// construct the variant at a non-generic call site. The bare-widen path is
// the one that works under typeSubst (explicit `T?` here is tracked by T0630).
//
// T0634: the param must be `~T` (owned). A borrowed `T x` moved into a generic
// enum-variant constructor is now correctly rejected by ownership — it aliased
// the caller's value into the variant payload, double-freeing droppable inner
// types (surfaced as `fatal: stack overflow` for T=map[string,int]). The
// `~T` form is the sound construction; callers pass literals/owned locals.

make_box[T](T move x) Box[T] {
  return Box[T].Full(move x);
}

generic_fn_bare_widen_int() `test {
  Box[int] b = make_box(99);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == 99, "generic-fn widened int? holds 99");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// Droppable inner under typeSubst — exercises the preWrapVal leak-safety
// claims (claimStringTemp) inside a monomorphized generic-fn body.
generic_fn_bare_widen_string() `test {
  Box[string] b = make_box("zz");
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == "zz", "generic-fn widened string? holds zz");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_fn_bare_widen_vec() `test {
  int[] d = [4, 5];
  Box[int[]] b = make_box(move d);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v.len == 2, "generic-fn widened int[]? len 2");
        assert(v[1] == 5, "second element");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// T0634: droppable inner that genuinely frees heap (map[K,V], not a .rodata
// literal). Before the fix, a borrowed `T x` aliased the caller's map into the
// variant payload and both were dropped at scope exit → double-free / `fatal:
// stack overflow`. With `~T` the map is moved (no alias); must run leak-free.
generic_fn_bare_widen_map() `test {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  Box[map[string, int]] b = make_box(move m);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v["a"]! == 1, "generic-fn widened map value a");
        assert(v["b"]! == 2, "generic-fn widened map value b");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// --- generic METHOD body (owner type generic): bare this.field into T? field

type Holder[T] {
  T seed;
  boxed(this) Box[T] {
    return Box[T].Full(this.seed);
  }
}

generic_method_bare_widen() `test {
  Holder[int] h = Holder[int](seed: 5);
  Box[int] b = h.boxed();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == 5, "generic-method widened int? holds 5");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// --- generic enum, explicit T? at a NON-generic call site ---
// Distinct from int_explicit_optional (non-generic enum): here the enum is
// generic but the construction site has typeSubst==nil, so vfType resolves
// concretely via the Instance branch of resolveMatchFieldType and the
// explicit arg stays unwrapped (Identical) — must not regress.

generic_enum_explicit_optional() `test {
  int? o = 3;
  Box[int] b = Box[int].Full(o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == 3, "generic-enum explicit int? holds 3");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// --- Optional field in a NON-first position (`i`-indexing of the new code) ---

enum Tagged {
  Rec(string name, int? code),
  Plain,
}

non_first_optional_widen() `test {
  Tagged t = Tagged.Rec("svc", 42);
  match t {
    Tagged.Rec(name, code) => {
      assert(name == "svc", "non-optional first field holds svc");
      if c := code {
        assert(c == 42, "widened int? second field holds 42");
      } else {
        assert(false, "expected present code");
      }
    },
    Tagged.Plain => assert(false, "expected Rec"),
  }
}

non_first_optional_none() `test {
  Tagged t = Tagged.Rec("svc", none);
  match t {
    Tagged.Rec(name, code) => {
      assert(name == "svc", "non-optional first field holds svc");
      if c := code {
        assert(false, "expected absent code");
      }
    },
    Tagged.Plain => assert(false, "expected Rec"),
  }
}

// --- two Optional fields in one variant, both bare-widened ---

enum TwoOpt {
  Both(int? a, string? b),
  Neither,
}

two_optional_widen() `test {
  TwoOpt t = TwoOpt.Both(1, "two");
  match t {
    TwoOpt.Both(a, b) => {
      if av := a {
        assert(av == 1, "first opt field holds 1");
      } else {
        assert(false, "expected present a");
      }
      if bv := b {
        assert(bv == "two", "second opt field holds two");
      } else {
        assert(false, "expected present b");
      }
    },
    TwoOpt.Neither => assert(false, "expected Both"),
  }
}

// --- closure-typed Optional inner: exercises claimEnvTemp(preWrapVal) ---
// A bare lambda widened into a `((int)->int)?` variant field. The env
// allocation must transfer to the enum (no leak / no double-free).

enum CbBox {
  Hold(((int) -> int)? cb),
  Nope,
}

closure_optional_bare_widen() `test {
  CbBox c = CbBox.Hold(|int n| -> n + 1);
  match c {
    CbBox.Hold(s) => {
      if f := s {
        assert(f(10) == 11, "widened closure? adds 1");
      } else {
        assert(false, "expected present cb");
      }
    },
    CbBox.Nope => assert(false, "expected Hold"),
  }
}

closure_optional_none() `test {
  CbBox c = CbBox.Hold(none);
  match c {
    CbBox.Hold(s) => {
      if f := s {
        assert(false, "expected absent cb");
      }
    },
    CbBox.Nope => assert(false, "expected Hold"),
  }
}

// --- T0630: generic FUNCTION body, explicit `T?` arg into T? variant field ---
// Before the fix these panicked with `insertvalue elem type mismatch, expected
// i64, got { i1, i64 }`: genEnumVariantCallLayout concretized exprType via
// c.typeSubst but vfType came from resolveMatchFieldType, which short-circuits
// on the Instance.TypeArgs() identity-map path inside generic bodies. The
// asymmetric Identical(int?, T?) check returned false → spurious wrapOptional
// on an already-Optional aggregate. The fix symmetrizes the substitution.
//
// The helper uses `~T?` (owned) — required for droppable inner types because
// of T0635 (sema misses the "cannot move borrowed parameter" check inside
// generic bodies). With `~T?`, the move is explicit and the caller's drop
// flag is correctly cleared. The Go IR test exercises the equivalent `T?`
// (borrowed) shape with Copy inner type, since that avoids T0635 entirely.

make_box_opt[T](T? move x) Box[T] {
  return Box[T].Full(move x);
}

generic_fn_explicit_opt_int() `test {
  int? o = 7;
  Box[int] b = make_box_opt(o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == 7, "generic-fn explicit int? holds 7");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// Droppable inner under typeSubst — heap-allocated string (not .rodata literal)
// so this genuinely exercises drop ownership of the inner string under the
// generic-fn body's typeSubst.
generic_fn_explicit_opt_string() `test {
  string? o = "ab".to_upper();
  Box[string] b = make_box_opt(move o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == "AB", "generic-fn explicit string? holds AB");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_fn_explicit_opt_vec() `test {
  int[] d = [4, 5, 6];
  int[]? o = d;
  Box[int[]] b = make_box_opt(move o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v.len == 3, "generic-fn explicit int[]? len 3");
        assert(v[0] == 4, "first element");
        assert(v[2] == 6, "last element");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// T0634 (resolved): explicit `T? = map[K,V]?` through the `~T?` generic-fn
// helper. The original double-free (borrowed generic enum-variant ctor arg)
// is now rejected at the ownership stage; the `~T?` form here is sound and
// genuinely frees heap, so it locks the leak-free invariant for T=map.
generic_fn_explicit_opt_map() `test {
  map[string, int] src = {
    "k": 9, "j": 8
  };
  map[string, int]? o = src;
  Box[map[string, int]] b = make_box_opt(move o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v["k"]! == 9, "generic-fn explicit map? value k");
        assert(v["j"]! == 8, "generic-fn explicit map? value j");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// Explicit `T?` local holding `none` — exercises the non-NoneLit branch under
// typeSubst (arg.Value is an IdentExpr to an Optional-typed local). Must
// match-destructure as absent without panic and without leaks.
generic_fn_explicit_none() `test {
  int? o = none;
  Box[int] b = make_box_opt(o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// Optional-of-user-type under typeSubst — explicit `Pt?` into `Box[Pt]` variant.
// User type Pt is heap-allocated, exercises the drop chain through the
// typeSubst-substituted Optional variant data path.
generic_fn_explicit_opt_pt_user() `test {
  Pt? p_opt = Pt(x: 3, y: 4);
  Box[Pt] b = make_box_opt(move p_opt);
  match b {
    Box.Full(s) => {
      if pt := s {
        assert(pt.x == 3, "Pt.x == 3");
        assert(pt.y == 4, "Pt.y == 4");
      } else {
        assert(false, "expected present Pt?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// --- T0630: generic METHOD body (owner type generic), explicit `T?` arg ---

type Wrap[T] {
  T seed;
  mk_opt(this, T? move o) Box[T] {
    return Box[T].Full(move o);
  }
}

generic_method_explicit_opt_int() `test {
  Wrap[int] w = Wrap[int](seed: 5);
  int? o = 8;
  Box[int] b = w.mk_opt(o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == 8, "generic-method explicit int? holds 8");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_method_explicit_opt_string() `test {
  Wrap[string] w = Wrap[string](seed: "seed");
  string? o = "xyz".to_upper();
  Box[string] b = w.mk_opt(move o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == "XYZ", "generic-method explicit string? holds XYZ");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_method_explicit_none() `test {
  Wrap[int] w = Wrap[int](seed: 0);
  int? o = none;
  Box[int] b = w.mk_opt(o);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// --- T0630 coverage: `none` LITERAL inside generic fn/method body ---
// The above `generic_*_explicit_none` cases pass a variable holding none
// (arg.Value = IdentExpr → else-branch of `if isNone`). These cases pass
// `none` directly as a literal (arg.Value = *ast.NoneLit → NoneLit branch
// under c.typeSubst). The NoneLit branch uses zeroValue(fieldLLVM) and
// bypasses the Identical comparison, but the surrounding *types.Optional
// type assertion on `vfType` now relies on the T0630 symmetric substitution
// to recognize `T?` as `*types.Optional` after concretization. Without the
// fix, an Instance.TypeArgs() identity-map path through resolveMatchFieldType
// could leave vfType as a partially-substituted form whose Optional structure
// is still recognized (so this path wasn't the immediate panic source); these
// tests lock the invariant that the NoneLit branch continues to work for the
// full droppable-inner matrix under typeSubst.

make_box_none[T]() Box[T] {
  return Box[T].Full(none);
}

generic_fn_none_literal_int() `test {
  Box[int] b = make_box_none[int]();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_fn_none_literal_string() `test {
  Box[string] b = make_box_none[string]();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_fn_none_literal_vec() `test {
  Box[int[]] b = make_box_none[int[]]();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_fn_none_literal_map() `test {
  Box[map[string, int]] b = make_box_none[map[string, int]]();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_fn_none_literal_pt() `test {
  Box[Pt] b = make_box_none[Pt]();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

type WrapNone[T] {
  T seed;
  mk_none(this) Box[T] {
    return Box[T].Full(none);
  }
}

generic_method_none_literal_int() `test {
  WrapNone[int] w = WrapNone[int](seed: 0);
  Box[int] b = w.mk_none();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_method_none_literal_string() `test {
  WrapNone[string] w = WrapNone[string](seed: "x");
  Box[string] b = w.mk_none();
  match b {
    Box.Full(s) => {
      if v := s {
        assert(false, "expected absent T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

// --- T0635: bare `~T` (owned) generic-fn body, GENUINELY heap-droppable
// inner types (not .rodata literals). The earlier generic_fn_bare_widen_*
// tests only use int / string-literal / int[]-literal, whose .rodata flag
// makes drop a no-op and thus masked the borrowed-param double-free. These
// exercise the consume path of `make_box[T](T move x)` with a heap-allocated
// string and a heap user type Pt: caller's drop flag must be cleared at the
// move into the variant field (no double-free), and the enum drop must free
// exactly once (0 leaks under enforcement). The fix landed via T0634 (the
// expr.go change); these add the T?/Optional-widen heap-droppable regression
// coverage T0634's bare-`T` tests did not exercise.

generic_fn_bare_widen_string_heap() `test {
  string s = "ab".to_upper();
  Box[string] b = make_box(move s);
  match b {
    Box.Full(slot) => {
      if v := slot {
        assert(v == "AB", "bare ~T widened heap string? holds AB");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_fn_bare_widen_pt_user() `test {
  Pt p = Pt(x: 8, y: 9);
  Box[Pt] b = make_box(move p);
  match b {
    Box.Full(slot) => {
      if pt := slot {
        assert(pt.x == 8, "bare ~T widened Pt? holds x=8");
        assert(pt.y == 9, "bare ~T widened Pt? holds y=9");
      } else {
        assert(false, "expected present Pt?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}
