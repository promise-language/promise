// B0353: return inside error handler in go block should exit the goroutine
// cleanly, not produce an LLVM verification error.
fail_always!() int {
  raise error(message: "expected failure");
}

// Basic: return in error handler exits the goroutine.
test_go_block_return_in_error_handler() `test(exclude: wasm) {
  ch := channel[int](capacity: 1);
  go {
    x := fail_always()? e {
      ch.send(42);
      return;
    };
    // Should not reach here
    ch.send(0);
  };
  if v := <-ch {
    assert(v == 42, "error handler return sent 42");
  }
}

// Return in error handler with captured variables that need cleanup.
test_go_block_return_in_error_handler_with_captures() `test(exclude: wasm) {
  ch := channel[int](capacity: 1);
  msg := "hello";
  go {
    x := fail_always()? e {
      ch.send(msg.len);
      return;
    };
    ch.send(0);
  };
  if v := <-ch {
    assert(v == 5, "captured string length is 5");
  }
}

// T1217: a plain `go {}` block is a non-failable scope even when the *enclosing*
// function is failable (`!`). A failable call inside it must be handled locally
// (`?!`); pre-fix, sema wrongly let a bare call auto-propagate / `raise` escape,
// panicking codegen. This confirms the handled-locally path compiles and runs
// correctly with a failable enclosing fn.
work_ret!() int {
  return 7;
}

run_spawn_in_failable!() int {
  ch := channel[int](capacity: 1);
  go {
    n := work_ret()?!;
    ch.send(n);
  };
  if v := <-ch {
    return v;
  }
  return -1;
}

test_go_block_in_failable_fn_local_handling() `test(exclude: wasm) {
  r := run_spawn_in_failable()?!;
  assert(r == 7, "go block in failable fn handled failable call locally");
}

// Return in nested block inside error handler.
test_go_block_return_in_error_handler_nested() `test(exclude: wasm) {
  ch := channel[int](capacity: 1);
  go {
    x := fail_always()? e {
      if true {
        ch.send(99);
        return;
      }
      ch.send(0);
    };
    ch.send(0);
  };
  if v := <-ch {
    assert(v == 99, "nested return sent 99");
  }
}
