type Point {
  int x `value;
  int y `value;
}

main() `test(expected: """1
2
10
2""") {
  Point p = Point(x: 1, y: 2);
  Point q = p; // copy, not alias

  // Verify q has the same values
  print_line(q.x);
  print_line(q.y);

  // Modify q (via reassignment) — p should be unchanged
  q = Point(x: 10, y: 2);
  print_line(q.x);
  print_line(p.y);
}
