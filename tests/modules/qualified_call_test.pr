use mathlib "./mathlib";

test_qualified_add() `test {
  assert(mathlib.add(3, 4) == 7, "mathlib.add(3, 4) == 7");
  assert(mathlib.add(0, 0) == 0, "mathlib.add(0, 0) == 0");
  assert(mathlib.add(-1, 1) == 0, "mathlib.add(-1, 1) == 0");
}

test_qualified_square() `test {
  assert(mathlib.square(5) == 25, "mathlib.square(5) == 25");
  assert(mathlib.square(0) == 0, "mathlib.square(0) == 0");
  assert(mathlib.square(-3) == 9, "mathlib.square(-3) == 9");
}

test_qualified_greet() `test(allow_leaks: true) {
  assert(mathlib.greet("world") == "hello world", "greet world");
  assert(mathlib.greet("promise") == "hello promise", "greet promise");
}

// --- Module-qualified generic function calls (B0100) ---

test_qualified_generic_explicit() `test {
  int r = mathlib.identity[int](42);
  assert(r == 42, "explicit identity[int]");
  string s = mathlib.identity[string]("hi");
  assert(s == "hi", "explicit identity[string]");
}

test_qualified_generic_inferred() `test {
  int r = mathlib.identity(42);
  assert(r == 42, "inferred identity int");
  string s = mathlib.identity("hi");
  assert(s == "hi", "inferred identity string");
}

test_qualified_generic_wrap_explicit() `test {
  int[] r = mathlib.wrap[int](7);
  assert(r[0] == 7, "explicit wrap[int]");
}

test_qualified_generic_wrap_inferred() `test {
  int[] r = mathlib.wrap(7);
  assert(r[0] == 7, "inferred wrap int");
}

test_qualified_generic_failable_explicit() `test {
  int r = mathlib.safe_identity[int](99)!;
  assert(r == 99, "failable explicit");
}

test_qualified_generic_failable_inferred() `test {
  int r = mathlib.safe_identity(99)!;
  assert(r == 99, "failable inferred");
}
