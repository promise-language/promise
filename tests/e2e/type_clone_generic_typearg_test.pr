// T0605: Cloning a generic `clone TYPE (not enum) whose TypeArg is droppable
// (map, vector, heap string, user type with drop) must deep-copy the field.
// The synthesized type clone treats a TypeParam field as copy
// (isCopyField(TypeParam)==true) so it emitted a bare shallow read — both
// original and clone aliased the same heap value → double-free segfault.
// The fix emits a synth-only AutoCloneExpr for TypeParam-containing fields,
// lowered type-directed at mono codegen. Both `j` and `c` are kept live to
// scope exit so both drop paths run (the double-free repro). 0 leaks required.
//
// Parallel to tests/e2e/enum_clone_generic_typearg_test.pr (T0551, enum case).
type BoxT[T] `clone {
  T val;
}

// Droppable TypeArg: map[K,V] — the original repro from the bug report.
test_clone_boxt_map() `test {
  map[string, string] src = map[string, string]();
  src["a"] = "b";
  src["c"] = "d";
  BoxT[map[string, string]] j = BoxT[map[string, string]](val: src);
  BoxT[map[string, string]] c = j.clone();
  assert(c.val.len == 2, "clone has 2 entries");
  assert(c.val.get_or("a", "") == "b", "clone a=b");
  assert(j.val.len == 2, "original still has 2 entries");
  assert(j.val.get_or("c", "") == "d", "original c=d");
}

// Droppable TypeArg: a HEAP string (concatenation, not a .rodata literal — the
// literal/static bit-63 flag would otherwise mask the double-free).
test_clone_boxt_heap_string() `test {
  string s = "a" + "b";
  BoxT[string] j = BoxT[string](val: s);
  BoxT[string] c = j.clone();
  assert(c.val == "ab", "clone string ab");
  assert(j.val == "ab", "original string ab");
}

// TypeArg: string[] — vector of heap strings.
test_clone_boxt_string_vec() `test {
  string[] data = ["x", "y", "z"];
  BoxT[string[]] j = BoxT[string[]](val: data);
  BoxT[string[]] c = j.clone();
  assert(c.val.len == 3, "clone vec len 3");
  assert(c.val[0] == "x", "clone[0]");
  assert(c.val[2] == "z", "clone[2]");
  assert(j.val.len == 3, "original vec len 3");
}

// TypeArg: int[] — vector of copy scalars (vector itself is still heap).
test_clone_boxt_int_vec() `test {
  int[] nums = [1, 2, 3, 4];
  BoxT[int[]] j = BoxT[int[]](val: nums);
  BoxT[int[]] c = j.clone();
  assert(c.val.len == 4, "clone len 4");
  assert(c.val[3] == 4, "clone[3]==4");
  assert(j.val.len == 4, "original len 4");
}

// TypeArg: int — pure copy. Behavior must be unchanged (bit copy).
test_clone_boxt_int() `test {
  BoxT[int] j = BoxT[int](val: 42);
  BoxT[int] c = j.clone();
  assert(c.val == 42, "clone int 42");
  assert(j.val == 42, "original int 42");
}

// TypeArg: a user `clone type wrapping a droppable map field — exercises the
// nested clone-of-clone path (cloneHeapElement prefers Bag.clone()).
type Bag `clone {
  map[string, int] counts;
}

test_clone_boxt_user_clone_type() `test {
  map[string, int] m = map[string, int]();
  m["apples"] = 3;
  Bag b = Bag(counts: m);
  BoxT[Bag] j = BoxT[Bag](val: b);
  BoxT[Bag] c = j.clone();
  assert(c.val.counts.len == 1, "clone bag len 1");
  assert(c.val.counts.get_or("apples", 0) == 3, "clone apples==3");
  assert(j.val.counts.len == 1, "original bag len 1");
  assert(j.val.counts.get_or("apples", 0) == 3, "original apples==3");
}

// Mutating the clone must not affect the original (true deep copy).
test_clone_boxt_map_independence() `test {
  map[string, string] src = map[string, string]();
  src["k"] = "v1";
  BoxT[map[string, string]] j = BoxT[map[string, string]](val: src);
  BoxT[map[string, string]] c = j.clone();
  c.val["k"] = "mutated";
  c.val["extra"] = "new";
  assert(c.val.len == 2, "clone mutated to 2 entries");
  assert(j.val.len == 1, "original unaffected: still 1 entry");
  assert(j.val.get_or("k", "") == "v1", "original value untouched");
}

// Multiple TypeParam fields, both droppable. Each field must resolve its own
// concrete type under the mono substitution.
type Pair[A, B] `clone {
  A first;
  B second;
}

test_clone_pair_two_typeparams() `test {
  string[] sv = ["a", "b"];
  map[string, int] mm = map[string, int]();
  mm["z"] = 3;
  Pair[string[], map[string, int]] j = Pair[string[], map[string, int]](first: sv, second: mm);
  Pair[string[], map[string, int]] c = j.clone();
  assert(c.first.len == 2, "clone first len 2");
  assert(c.second.get_or("z", 0) == 3, "clone second z==3");
  assert(j.first.len == 2, "original first len 2");
  assert(j.second.len == 1, "original second intact");
}

// A concrete non-copy field (heap string) ALONGSIDE a TypeParam field. The
// concrete field keeps its existing synth behavior (explicit .clone()); only
// the TypeParam field routes through AutoCloneExpr. Per-field scoping check.
type Mixed[T] `clone {
  string label;
  T payload;
}

test_clone_mixed_concrete_and_typeparam() `test {
  map[string, int] m = map[string, int]();
  m["k"] = 7;
  Mixed[map[string, int]] j = Mixed[map[string, int]](label: "ta" + "g", payload: m);
  Mixed[map[string, int]] c = j.clone();
  assert(c.label == "tag", "clone concrete-string field intact");
  assert(c.payload.len == 1, "clone TypeParam-map field deep-copied");
  assert(c.payload.get_or("k", 0) == 7, "clone map k==7");
  assert(j.label == "tag", "original label intact");
  assert(j.payload.len == 1, "original map independent and intact");
}

// Optional TypeParam field: BoxT2[T] `clone { T? val; }`. ContainsTypeParam is
// true for Optional[T], so AutoCloneExpr is emitted; codegen lowers it with a
// none-check + deep-clone-of-payload + rewrap.
type BoxT2[T] `clone {
  T? val;
}

// Optional-some: the clone's optional payload must be an independent deep copy
// (the none-check + cloneByType(payload) + rewrap path). The inner payload
// cannot be moved out of the field to peek (correct move-out-of-field rule;
// deep independence of the map itself is already proven by the non-optional
// tests above). Presence is preserved, and keeping both `j` and `c` live to
// scope exit exercises the optional double-drop — the segfault/leak repro.
test_clone_optional_typeparam_some() `test {
  map[string, string] src = map[string, string]();
  src["k"] = "v1";
  BoxT2[map[string, string]] j = BoxT2[map[string, string]](val: src);
  BoxT2[map[string, string]] c = j.clone();
  assert(c.val is present, "clone optional payload present");
  assert(j.val is present, "original optional payload present");
}

// Optional-none: clone must pass the none through (no payload deref) and both
// must drop cleanly.
test_clone_optional_typeparam_none() `test {
  BoxT2[map[string, string]] j = BoxT2[map[string, string]](val: none);
  BoxT2[map[string, string]] c = j.clone();
  assert(c.val is absent, "clone optional payload absent");
  assert(j.val is absent, "original optional payload absent");
}

// Optional of a COPY TypeParam (BoxT2[int] → `int? val`): cloneByType's
// Optional branch must short-circuit to a whole-struct bit copy via
// isAutoCloneBitCopy(elem) — no none-check, no payload deref. Distinct branch
// from the heap-payload optional tests above.
test_clone_optional_copy_typeparam() `test {
  BoxT2[int] j = BoxT2[int](val: 7);
  BoxT2[int] c = j.clone();
  assert(c.val is present, "clone copy-optional present");
  assert(j.val is present, "original copy-optional present");
  BoxT2[int] n = BoxT2[int](val: none);
  BoxT2[int] nc = n.clone();
  assert(nc.val is absent, "clone copy-optional none");
}

// Nested optional TypeParam field: BoxT3[T] `clone { T?? val; }`. Exercises
// cloneByType's Optional branch where the unwrapped element is itself an
// Optional of a heap type — isAutoCloneBitCopy must recurse through Optional
// so the inner map is deep-cloned (a non-recursing predicate short-circuits
// to a bit copy and re-introduces the T0605 double-free one level deeper —
// confirmed: pre-fix this segfaults).
type BoxT3[T] `clone {
  T?? val;
}

test_clone_nested_optional_some() `test {
  map[string, string] src = map[string, string]();
  src["k"] = "v1";
  map[string, string]? inner = src;
  BoxT3[map[string, string]] j = BoxT3[map[string, string]](val: inner);
  BoxT3[map[string, string]] c = j.clone();
  assert(c.val is present, "clone nested-optional outer present");
  assert(j.val is present, "original nested-optional outer present");
}

test_clone_nested_optional_none() `test {
  BoxT3[map[string, string]] j = BoxT3[map[string, string]](val: none);
  BoxT3[map[string, string]] c = j.clone();
  assert(c.val is absent, "clone nested-optional absent");
  assert(j.val is absent, "original nested-optional absent");
}

// T0667: a TUPLE field carrying the TypeParam (`(T, int) pr`). ContainsTypeParam
// recurses into *types.Tuple so the synth emits AutoCloneExpr, but before the
// fix isAutoCloneBitCopy classified every tuple as a bit-copy "scalar tuple"
// (non-named fallthrough) and cloneResolvedValue had no *types.Tuple arm → the
// inner heap member was shallow-aliased → double-free segfault when both `j`
// and `c` drop. The fix adds a *types.Tuple recursion to isAutoCloneBitCopy +
// a per-element extract/cloneByType/insert arm to cloneResolvedValue. Both `j`
// and `c` are kept live to scope exit (the double-free repro). 0 leaks.
// Parallel to the T0662 array gap. Covers the same family as the enum-level
// shapes in enum_clone_optional_typeparam_typearg_test.pr.
type TupBox[T] `clone {
  (T, int) pr;
}
type TupBoxN[T] `clone {
  ((T, int), int) pr;
}
type TupBoxO[T] `clone {
  (T?, int) pr;
}
// T0667 coverage: heap member at a NON-ZERO tuple index, preceded by a scalar.
// The cloneResolvedValue loop must skip element 0 (`int` → cloneByType returns
// it unchanged, clonedElem == elemVal, no insert) and then deep-clone +
// NewInsertValue at index 1. The existing `(T, int)` shapes only ever
// insert-then-skip; `(K, V)` only ever insert-then-insert — neither exercises
// the skip-then-insert ordering nor a heap clone re-inserted at index > 0.
type TupBoxR[T] `clone {
  (int, T) r;
}
// T0667 coverage: 3-element tuple, leading scalar then TWO non-contiguous heap
// members — exercises the per-element loop iterating past index 1 with inserts
// at indices 1 and 2 after a skip at index 0.
type TupBox3[T] `clone {
  (int, T, T) tr;
}

// Droppable TypeArg: map[K,V] — the exact T0667 type-level repro.
test_clone_tupbox_map() `test {
  map[string, string] src = map[string, string]();
  src["a"] = "b";
  TupBox[map[string, string]] j = TupBox[map[string, string]](pr: (src, 7));
  TupBox[map[string, string]] c = j.clone();
  (cm, cn) := c.pr;
  assert(cm.len == 1, "clone tuple map len 1");
  assert(cm.get_or("a", "") == "b", "clone a=b");
  assert(cn == 7, "clone tuple int 7");
  (jm, jn) := j.pr;
  assert(jm.len == 1, "original tuple map len 1 (independent)");
  assert(jn == 7, "original tuple int 7");
}

// Droppable TypeArg: string[] (vector of heap strings) inside the tuple.
test_clone_tupbox_string_vec() `test {
  string[] data = ["x", "y", "z"];
  TupBox[string[]] j = TupBox[string[]](pr: (data, 3));
  TupBox[string[]] c = j.clone();
  (cv, cn) := c.pr;
  assert(cv.len == 3, "clone vec len 3");
  assert(cv[2] == "z", "clone[2]=z");
  (jv, jn) := j.pr;
  assert(jv.len == 3, "original vec len 3 (independent)");
}

// User `clone type (Bag, defined above) as the droppable TypeArg — exercises
// the nested clone-of-clone path inside the tuple per-element clone.
test_clone_tupbox_user_clone_type() `test {
  map[string, int] m = map[string, int]();
  m["apples"] = 3;
  Bag b = Bag(counts: m);
  TupBox[Bag] j = TupBox[Bag](pr: (b, 9));
  TupBox[Bag] c = j.clone();
  (cb, cn) := c.pr;
  assert(cb.counts.len == 1, "clone bag len 1");
  assert(cb.counts.get_or("apples", 0) == 3, "clone apples==3");
  (jb, jn) := j.pr;
  assert(jb.counts.len == 1, "original bag len 1 (independent)");
}

// Copy TypeArg: int — pure scalar tuple, must stay a correct bit copy
// (isAutoCloneBitCopy still returns true: every element is bit-copy).
test_clone_tupbox_int() `test {
  TupBox[int] j = TupBox[int](pr: (42, 7));
  TupBox[int] c = j.clone();
  (ci, cn) := c.pr;
  assert(ci == 42, "clone first 42");
  assert(cn == 7, "clone second 7");
  (ji, jn) := j.pr;
  assert(ji == 42, "original first 42");
}

// Nested-tuple element `((T, int), int) pr` — exercises cloneByType's
// recursion into a nested *types.Tuple element (the heap member is two tuple
// levels deep).
test_clone_tupbox_nested_tuple() `test {
  map[string, string] src = map[string, string]();
  src["k"] = "v";
  TupBoxN[map[string, string]] j = TupBoxN[map[string, string]](pr: ((src, 1), 2));
  TupBoxN[map[string, string]] c = j.clone();
  (cinner, co) := c.pr;
  (cm, ci) := cinner;
  assert(cm.len == 1, "clone nested map len 1");
  assert(cm.get_or("k", "") == "v", "clone k=v");
  assert(ci == 1, "clone inner int 1");
  assert(co == 2, "clone outer int 2");
  (jinner, jo) := j.pr;
  (jm, ji) := jinner;
  assert(jm.len == 1, "original nested map len 1 (independent)");
}

// Tuple-of-optional `(T?, int)`: exercises cloneByType's Optional arm reached
// *through* the per-element tuple recursion (the T0667 concern) AND the
// T0672 destructure path — destructuring a struct field of tuple type with an
// Optional[aggregate] element (now fixed: borrow-sourced destructured locals
// are marked in matchBorrowedIdents so a later if-let does not transfer
// ownership). Both `j` and `c` are kept live and destructured to scope exit
// (the double-free repro: a wrong clone OR a wrong destructure-unwrap
// double-frees the map). IR-level proof of the
// Map.clone-through-Optional-through-tuple recursion is in Go test
// TestGenericTypeCloneTupleOptionalTypeParamField; the destructure-borrow IR
// is in TestDestructureFieldTupleOptionalAggregateNoOwnDrop.
test_clone_tupbox_optional_some() `test {
  map[string, string] src = map[string, string]();
  src["k"] = "v1";
  map[string, string]? mo = src;
  TupBoxO[map[string, string]] j = TupBoxO[map[string, string]](pr: (mo, 5));
  TupBoxO[map[string, string]] c = j.clone();
  (cm, cn) := c.pr;
  assert(cn == 5, "clone tuple int 5");
  if cmm := cm {
    assert(cmm.len == 1, "clone optional map len 1");
    assert(cmm.get_or("k", "") == "v1", "clone k=v1");
  } else {
    assert(false, "clone should be some");
  }
  (jm, jn) := j.pr;
  if jmm := jm {
    assert(jmm.len == 1, "original optional map len 1 (independent)");
  } else {
    assert(false, "original should be some");
  }
}

test_clone_tupbox_optional_none() `test {
  map[string, string]? mo = none;
  TupBoxO[map[string, string]] j = TupBoxO[map[string, string]](pr: (mo, 0));
  TupBoxO[map[string, string]] c = j.clone();
  (cm, cn) := c.pr;
  assert(cn == 0, "clone tuple int 0");
  if cmm := cm {
    assert(false, "clone should be none");
  } else {
    assert(true, "clone none ok");
  }
}

// Mutating the clone's tuple map must not affect the original (true deep copy).
test_clone_tupbox_map_independence() `test {
  map[string, string] src = map[string, string]();
  src["k"] = "v1";
  TupBox[map[string, string]] j = TupBox[map[string, string]](pr: (src, 1));
  TupBox[map[string, string]] c = j.clone();
  (cm, cn) := c.pr;
  cm["k"] = "mutated";
  cm["extra"] = "new";
  assert(cm.len == 2, "clone mutated to 2 entries");
  (jm, jn) := j.pr;
  assert(jm.len == 1, "original unaffected: still 1 entry");
  assert(jm.get_or("k", "") == "v1", "original value untouched");
}

// T0667: heap member at NON-ZERO tuple index `(int, T)` with T=map. The clone
// loop must leave element 0 (`int`) as a bit copy (skip) and deep-clone +
// re-insert the heap map at index 1. Both `j` and `c` kept live to scope exit
// (double-free repro); mutation-independence asserts a true deep copy. 0 leaks.
test_clone_tupboxr_map_nonzero_index() `test {
  map[string, string] src = map[string, string]();
  src["k"] = "v1";
  TupBoxR[map[string, string]] j = TupBoxR[map[string, string]](r: (9, src));
  TupBoxR[map[string, string]] c = j.clone();
  (cn, cm) := c.r;
  assert(cn == 9, "clone leading int 9 (bit copy)");
  assert(cm.len == 1, "clone map len 1");
  assert(cm.get_or("k", "") == "v1", "clone k=v1");
  cm["k"] = "mutated";
  cm["x"] = "y";
  assert(cm.len == 2, "clone mutated to 2 entries");
  (jn, jm) := j.r;
  assert(jn == 9, "original leading int 9");
  assert(jm.len == 1, "original map unaffected: still 1 entry (deep copy)");
  assert(jm.get_or("k", "") == "v1", "original value untouched");
}

// T0667: same shape with a user `clone TypeArg at the non-zero index — the
// per-element clone-of-clone path re-inserted at index 1.
test_clone_tupboxr_user_clone() `test {
  map[string, int] m = map[string, int]();
  m["apples"] = 3;
  Bag b = Bag(counts: m);
  TupBoxR[Bag] j = TupBoxR[Bag](r: (1, b));
  TupBoxR[Bag] c = j.clone();
  (cn, cb) := c.r;
  assert(cn == 1, "clone leading int 1");
  assert(cb.counts.len == 1, "clone bag len 1");
  cb.counts["pears"] = 2;
  (jn, jb) := j.r;
  assert(jb.counts.len == 1, "original bag unaffected: still 1 entry");
}

// T0667: 3-element tuple `(int, T, T)` — leading scalar (skip at index 0) then
// two non-contiguous heap members deep-cloned + re-inserted at indices 1 and 2.
test_clone_tupbox3_three_elements() `test {
  map[string, string] a = map[string, string]();
  a["a"] = "1";
  map[string, string] b = map[string, string]();
  b["b"] = "2";
  b["c"] = "3";
  TupBox3[map[string, string]] j = TupBox3[map[string, string]](tr: (7, a, b));
  TupBox3[map[string, string]] c = j.clone();
  (cn, cm1, cm2) := c.tr;
  assert(cn == 7, "clone leading int 7");
  assert(cm1.len == 1, "clone map1 len 1");
  assert(cm2.len == 2, "clone map2 len 2");
  cm1["extra"] = "z";
  cm2["d"] = "4";
  (jn, jm1, jm2) := j.tr;
  assert(jm1.len == 1, "original map1 unaffected (deep copy at index 1)");
  assert(jm2.len == 2, "original map2 unaffected (deep copy at index 2)");
}

// T0667: pure scalar `(int, T)` with T=int — every element bit-copy, the
// isAutoCloneBitCopy tuple loop returns true (no deep machinery). Runtime
// counterpart of the Go guard TestGenericTypeCloneScalarTupleStaysBitCopy.
test_clone_tupboxr_int_scalar() `test {
  TupBoxR[int] j = TupBoxR[int](r: (5, 99));
  TupBoxR[int] c = j.clone();
  (cn, ci) := c.r;
  assert(cn == 5, "clone first 5");
  assert(ci == 99, "clone second 99");
  (jn, ji) := j.r;
  assert(jn == 5, "original first 5");
  assert(ji == 99, "original second 99");
}
