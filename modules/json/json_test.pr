encode_method_null_test() `test {
  JsonEncoder enc = JsonEncoder();
  JsonValue.Null.encode(enc)?!;
  assert(enc.to_string() == "null", "encode null");
}

encode_method_bool_test() `test {
  JsonEncoder enc = JsonEncoder();
  JsonValue.Bool(false).encode(enc)?!;
  assert(enc.to_string() == "false", "encode false");
}

encode_method_number_test() `test {
  JsonEncoder enc = JsonEncoder();
  JsonValue.Number(-3.14).encode(enc)?!;
  string s = enc.to_string();
  assert(s.starts_with("-3.14"), "encode negative number");
}

encode_method_string_test() `test {
  JsonEncoder enc = JsonEncoder();
  JsonValue.Str("hello\nworld").encode(enc)?!;
  assert(enc.to_string() == "\"hello\\nworld\"", "encode string with escape");
}

encode_method_nested_test() `test {
  // {"items":[null,true],"count":2}
  map[string, JsonValue] fields = {
    "items": JsonValue.Array([JsonValue.Null, JsonValue.Bool(true)]),
    "count": JsonValue.Number(2.0),
  };
  JsonValue obj = JsonValue.Object(move fields);
  JsonEncoder enc = JsonEncoder();
  obj.encode(enc)?!;
  string s = enc.to_string();
  assert(s.contains("\"items\":[null,true]"), "encode nested array in object");
  assert(s.contains("\"count\":2"), "encode nested number in object");
}

format_pretty_round_trip_test() `test {
  map[string, JsonValue] fields = {
    "name": JsonValue.Str("Alice"),
    "scores": JsonValue.Array([JsonValue.Number(10.0), JsonValue.Number(20.0)]),
  };
  JsonValue obj = JsonValue.Object(move fields);
  string pretty = obj.format_pretty()?!;
  // Pretty output should still be valid JSON that parses back
  JsonValue parsed = parse_value(move pretty)?!;
  assert(parsed.is_object, "pretty rt: is object");
  assert(parsed.get("name") is present, "pretty rt: has name");
  assert(parsed.get("scores") is present, "pretty rt: has scores");
  JsonValue? name = parsed.get("name");
  assert(name!.as_string()! == "Alice", "pretty rt: name value");
}

format_method_all_variants_test() `test {
  assert(JsonValue.Null.format()?! == "null", "format null");
  assert(JsonValue.Bool(true).format()?! == "true", "format true");
  assert(JsonValue.Bool(false).format()?! == "false", "format false");
  assert(JsonValue.Number(42.0).format()?! == "42", "format number");
  assert(JsonValue.Str("hi").format()?! == "\"hi\"", "format string");
  assert(JsonValue.Array(JsonValue[]()).format()?! == "[]", "format empty array");
  assert(JsonValue.Object(map[string, JsonValue]()).format()?! == "\{}", "format empty object");
}

parsed_value_methods_test() `test {
  // Verify methods work on values from parse_value, not just constructed values
  string data = "\{\"name\":\"Bob\",\"age\":30,\"tags\":[\"a\",\"b\"],\"active\":true}";
  JsonValue v = parse_value(move data)?!;
  assert(v.is_object, "parsed: is_object");
  assert(!v.is_array, "parsed: not is_array");

  JsonValue? name = v.get("name");
  assert(name is present, "parsed: has name");
  assert(name!.is_string, "parsed: name is_string");
  assert(name!.as_string()! == "Bob", "parsed: name value");

  JsonValue? age = v.get("age");
  assert(age is present, "parsed: has age");
  assert(age!.is_number, "parsed: age is_number");
  assert(age!.as_number()! == 30.0, "parsed: age value");

  JsonValue? tags = v.get("tags");
  assert(tags is present, "parsed: has tags");
  assert(tags!.is_array, "parsed: tags is_array");
  assert(tags!.at(0) is present, "parsed: tags[0] present");
  assert(tags!.at(0)!.as_string()! == "a", "parsed: tags[0] value");
  assert(tags!.at(1)!.as_string()! == "b", "parsed: tags[1] value");

  JsonValue? active = v.get("active");
  assert(active is present, "parsed: has active");
  assert(active!.as_bool()! == true, "parsed: active value");

  JsonValue? missing = v.get("nope");
  assert(missing is absent, "parsed: missing key absent");
}

// B0253: Nested get() on parsed JSON must not double-free.
// parse_value creates heap-allocated map/vector data inside JsonValue enums.
// get() matches on the borrowed enum and returns a cloned value — without proper
// deep-clone in match destructure (B0244) and vector-index return (f9576dc),
// the returned JsonValue shares heap pointers with the original, causing double-free.
parsed_nested_get_test() `test {
  string data = "\{\"outer\":\{\"inner\":\{\"key\":\"deep\"\}\}\}";
  JsonValue root = parse_value(move data)?!;
  if outer := root.get("outer") {
    assert(outer.is_object, "B0253: outer is object");
    if inner := outer.get("inner") {
      assert(inner.is_object, "B0253: inner is object");
      if v := inner.get("key") {
        assert(v.as_string()! == "deep", "B0253: deeply nested string");
      }
    }
  }
}

// B0253: Multiple get() calls on same parsed object must not corrupt data.
parsed_multiple_get_same_object_test() `test {
  string data = "\{\"a\":\{\"x\":1},\"b\":\{\"y\":2}}";
  JsonValue root = parse_value(move data)?!;
  // Call get() multiple times on the same parsed object
  if a := root.get("a") {
    assert(a.is_object, "B0253: a is object");
  }
  if b := root.get("b") {
    assert(b.is_object, "B0253: b is object");
  }
  // Original object should still be intact after multiple gets
  if a2 := root.get("a") {
    assert(a2.is_object, "B0253: a still object after second get");
  }
}

// B0253: get() + as_string() chain on parsed JSON (original bug report scenario).
parsed_get_as_string_chain_test() `test {
  string data = "\{\"tool_input\":\{\"command\":\"hello\"\}\}";
  JsonValue root = parse_value(move data)?!;
  if tool_input := root.get("tool_input") {
    if cmd := tool_input.get("command") {
      if s := cmd.as_string() {
        assert(s == "hello", "B0253: chained get + as_string");
      }
    }
  }
}

// B0281: Enum ctor temps in map literals must be claimed.
// Without the fix, creating a map with enum values using separate variables
// caused a use-after-free (stack overflow) because the enum ctor temp was
// dropped at statement end while the map's Slot still held the same pointers.
enum_ctor_temp_in_map_literal_test() `test {
  map[string, JsonValue] inner = {
    "x": JsonValue.Number(1.0)
  };
  map[string, JsonValue] outer = {
    "nested": JsonValue.Object(move inner)
  };
  JsonValue obj = JsonValue.Object(move outer);
  string s = format_value(obj)?!;
  JsonValue parsed = parse_value(move s)?!;
  assert(parsed.is_object, "round trip nested object");
}

// B0281: Enum ctor temps in vector literals must be claimed.
enum_ctor_temp_in_vector_literal_test() `test {
  JsonValue[] items = [JsonValue.Str("a"), JsonValue.Number(1.0), JsonValue.Bool(true)];
  JsonValue arr = JsonValue.Array(move items);
  string s = format_value(arr)?!;
  assert(s.contains("\"a\""), "vector with enum values");
}

// B0283: Repeated parse→match→get in a single binary must not corrupt the heap.
// The original crash was heap corruption (segfault at 0x0) after ~80 tests in
// single-file mode. Root cause: double-clone in synthesized enum clone methods
// (B0285) leaked intermediate allocations, corrupting heap metadata over time.
// This test exercises the accumulation pattern with many iterations.
repeated_parse_match_get_test() `test {
  int i = 0;
  while i < 50 {
    JsonValue v = parse_value("\{\"k\":\"v\",\"n\":42}")?!;
    match v {
      JsonValue.Object(fields) => {
        assert(fields.len == 2, "B0283: fields len");
      },
      _ => assert(false, "B0283: expected object"),
    }
    if val := v.get("k") {
      assert(val.as_string()! == "v", "B0283: get string");
    }
    if num := v.get("n") {
      assert(num.as_number()! == 42.0, "B0283: get number");
    }
    i = i + 1;
  }
}

// B0283: Repeated nested object parse→get chains must not leak or double-free.
repeated_nested_parse_test() `test {
  int i = 0;
  while i < 30 {
    JsonValue v = parse_value("\{\"a\":\{\"b\":\{\"c\":\"deep\"}}}")?!;
    if a := v.get("a") {
      if b := a.get("b") {
        if c := b.get("c") {
          assert(c.as_string()! == "deep", "B0283: nested chain");
        }
      }
    }
    i = i + 1;
  }
}
