// T0753: Unwrapping an Optional via the optional-handler form (`o? _ { ... }`)
// must not double-free the inner value.
//
// The handler extracts the inner value as an aliasing `extractvalue` — no dup,
// no neutralize. When the source is an *ident*, the source optional already has
// its own scope drop binding that owns the inner allocation (frees it once for
// an owned optional; deliberately a no-op for a borrow-holding optional once
// T0747's isRttiCastBorrow clears the drop flag). So the extracted value must
// NOT be registered as an owned statement temp — doing so double-frees.
//
// This was a pre-existing double-free for the heap-user-type result even on a
// plain owned optional; the borrow-holding case (RTTI cast) is covered in
// tests/e2e/paren_this_test.pr. All values here are HEAP (non-literal) so the
// leak/double-free detector is live; with literal strings/vectors the bit-63
// static-flag no-op guard would mask the double-free.
//
// The non-ident-source counterparts (a call returning T?/string?/T[]?) lock in
// the no-regression guarantee: there the source optional is a temporary with no
// scope drop binding, so the extracted inner MUST stay tracked and freed.
type HBox {
  int n;
  string label;
}

mk_hbox() HBox? {
  return HBox(n: 9, label: "x" + "y");
}

mk_str() string? {
  return "xy".to_upper();
}

mk_vec() int[]? {
  return[3, 4, 5].clone();
}

// --- owned optional, ident source: must NOT track the extracted inner ---------

owned_heap_user_handler_unwrap() `test {
  HBox? o = HBox(n: 5, label: "heap" + "-label");
  v := (o? _ {
    return;
  }).n;
  assert(v == 5, "owned heap user-type handler unwrap reads field");
}

owned_string_handler_unwrap() `test {
  string? o = "abc".to_upper();
  n := (o? _ {
    return;
  }).len;
  assert(n == 3, "owned string handler unwrap reads len");
}

owned_vector_handler_unwrap() `test {
  int[]? o = [1, 2].clone();
  n := (o? _ {
    return;
  }).len;
  assert(n == 2, "owned vector handler unwrap reads len");
}

// --- parenthesized ident source: peeled to the ident, must NOT track ----------
// `(o)? _ {}` / `((o))!` are the same owned-ident unwrap as `o? _ {}` / `o!`;
// the temp-tracking skip peels ParenExpr (isIdentOptionalUnwrapSource) so the
// extracted inner is not double-freed. The heap-user-type field access
// `((o)!).n` crashed before the peel (the value-struct result routes through
// trackHeapUserTypeResult in stmt.go, which the peel fixed). T0776 extended the
// peel to genOptionalForceUnwrap's i8*-inner temp-tracking site so the
// string?/T[]? force-unwrap paren form `((o)!).len` is clean too.

owned_paren_handler_unwrap() `test {
  HBox? o = HBox(n: 11, label: "p" + "q");
  v := ((o)? _ {
    return;
  }).n;
  assert(v == 11, "parenthesized ident handler unwrap, no double-free");
}

// Parenthesized ident source through the i8* (string/vector) handler path: the
// peel must reach the genExpr ErrorHandlerExpr branch's isIdentSource skip so the
// extracted i8* is not tracked as an owned temp (heap values → free is live).
owned_paren_string_handler_unwrap() `test {
  string? o = "ab".to_upper();
  n := ((o)? _ {
    return;
  }).len;
  assert(n == 2, "parenthesized ident string handler unwrap, no double-free");
}

owned_paren_vector_handler_unwrap() `test {
  int[]? o = [7, 8, 9].clone();
  n := ((o)? _ {
    return;
  }).len;
  assert(n == 3, "parenthesized ident vector handler unwrap, no double-free");
}

owned_paren_force_unwrap() `test {
  HBox? o = HBox(n: 13, label: "r" + "s");
  v := ((o)!).n;
  assert(v == 13, "parenthesized ident force-unwrap, no double-free");
}

// --- non-ident source: the extracted inner MUST stay tracked (no regression) --

nonident_heap_user_handler_unwrap() `test {
  v := (mk_hbox()? _ {
    return;
  }).n;
  assert(v == 9, "non-ident heap user-type handler unwrap, no leak");
}

nonident_string_handler_unwrap() `test {
  n := (mk_str()? _ {
    return;
  }).len;
  assert(n == 2, "non-ident string handler unwrap, no leak");
}

nonident_vector_handler_unwrap() `test {
  n := (mk_vec()? _ {
    return;
  }).len;
  assert(n == 3, "non-ident vector handler unwrap, no leak");
}

// T0778: non-diverging handler on an ident-source optional with a fresh
// owned i8* recovery (string / vector) used to LEAK in the absent runtime:
// genBlockValue claims the recovery temp's drop flag, and the T0753
// ident-skip on the ErrorHandlerExpr branch left the merged phi untracked.
// genOptionalHandlerExpr now neutralizes the source's present flag in the
// some-block and tracks the merged phi as an owned temp at the merge block.
// All recovery values are HEAP (non-literal) so the leak gate is live.

// --- transient (intermediate) use: `.len` on the phi -------------------------

nondiverging_string_absent() `test {
  string? o = none;
  n := (o? _ {
    "x" + "y"
  }).len;
  assert(n == 2, "absent runtime: handler recovery consumed transiently");
}

nondiverging_string_present() `test {
  string? o = "ab".to_upper();
  n := (o? _ {
    "x" + "y"
  }).len;
  assert(n == 2, "present runtime: source inner consumed transiently");
}

nondiverging_vector_absent() `test {
  int[]? o = none;
  n := (o? _ {
    [1, 2].clone()
  }).len;
  assert(n == 2, "absent runtime: vector recovery consumed transiently");
}

nondiverging_vector_present() `test {
  int[]? o = [3, 4, 5].clone();
  n := (o? _ {
    [1, 2].clone()
  }).len;
  assert(n == 3, "present runtime: vector inner consumed transiently");
}

// --- bound to a new owner: `string r = o? _ { ... }` -------------------------
// The bind site's B0293 path neutralizes the source ident and claims the phi.
// With T0778, our someBlock neutralize stores the same i1 0 redundantly and
// the bind-site claim still clears the temp — no double-handling.

nondiverging_string_bind_absent() `test {
  string? o = none;
  string r = o? _ {
    "x".to_upper()
  };
  assert(r.len == 1, "absent runtime: handler recovery bound to a new owner");
}

nondiverging_string_bind_present() `test {
  string? o = "ab".to_upper();
  string r = o? _ {
    "x".to_upper()
  };
  assert(r.len == 2, "present runtime: source inner bound to a new owner");
}

nondiverging_vector_bind_absent() `test {
  int[]? o = none;
  int[] r = o? _ {
    [1, 2].clone()
  };
  assert(r.len == 2, "absent runtime: vector recovery bound to a new owner");
}

nondiverging_vector_bind_present() `test {
  int[]? o = [3, 4, 5].clone();
  int[] r = o? _ {
    [1, 2].clone()
  };
  assert(r.len == 3, "present runtime: vector inner bound to a new owner");
}

// --- heap-user-type recovery (no-regression): uses heapTemps, not stmtTemps --
// trackHeapUserTypeResult's ident-skip covers this path; the T0778 fix doesn't
// touch the value-struct (non-i8*) result branch. Both constructor recovery and
// call-result recovery exercised, transient and bind forms.

nondiverging_heap_ctor_absent() `test {
  HBox? o = none;
  v := (o? _ {
    HBox(n: -1, label: "ab" + "cd")
  }).n;
  assert(v == -1, "absent runtime: constructor recovery, transient field");
}

nondiverging_heap_ctor_present() `test {
  HBox? o = HBox(n: 7, label: "p" + "q");
  v := (o? _ {
    HBox(n: -1, label: "ab" + "cd")
  }).n;
  assert(v == 7, "present runtime: source inner, transient field");
}

nondiverging_heap_call_absent() `test {
  HBox? o = none;
  v := (o? _ {
    mk_hbox()!
  }).n;
  assert(v == 9, "absent runtime: call-result recovery, transient field");
}

nondiverging_heap_call_present() `test {
  HBox? o = HBox(n: 7, label: "p" + "q");
  v := (o? _ {
    mk_hbox()!
  }).n;
  assert(v == 7, "present runtime: source inner, transient field");
}

nondiverging_heap_ctor_bind_absent() `test {
  HBox? o = none;
  HBox r = o? _ {
    HBox(n: -1, label: "ab" + "cd")
  };
  assert(r.n == -1, "absent runtime: constructor recovery bound to new owner");
}

nondiverging_heap_ctor_bind_present() `test {
  HBox? o = HBox(n: 7, label: "p" + "q");
  HBox r = o? _ {
    HBox(n: -1, label: "ab" + "cd")
  };
  assert(r.n == 7, "present runtime: source inner bound to new owner");
}

// --- paren-wrapped ident source + non-diverging recovery --------------------
// T0778's neutralize+track path uses isIdentOptionalUnwrapSource, which peels
// ParenExpr; neutralizeForceUnwrapSource peels ParenExpr too (T0577). These
// tests lock the parity: `(o)? _ {fresh}` must behave identically to the bare
// `o? _ {fresh}` form on both runtimes. The existing paren tests
// (owned_paren_string_handler_unwrap etc.) all use a DIVERGING `return;` body —
// they exercise the T0753 ident-skip but not T0778's neutralize+track. A future
// removal of the paren-peel in either helper would silently regress this path
// because the leak gate would still see no diverging-case leak.

nondiverging_paren_string_absent() `test {
  string? o = none;
  n := ((o)? _ {
    "x" + "y"
  }).len;
  assert(n == 2, "paren ident source, absent runtime, transient");
}

nondiverging_paren_string_present() `test {
  string? o = "ab".to_upper();
  n := ((o)? _ {
    "x" + "y"
  }).len;
  assert(n == 2, "paren ident source, present runtime, transient");
}

nondiverging_paren_vector_absent() `test {
  int[]? o = none;
  n := ((o)? _ {
    [1, 2].clone()
  }).len;
  assert(n == 2, "paren ident source, vector absent, transient");
}

nondiverging_paren_vector_present() `test {
  int[]? o = [3, 4, 5].clone();
  n := ((o)? _ {
    [1, 2].clone()
  }).len;
  assert(n == 3, "paren ident source, vector present, transient");
}

// Nested paren — covers the loop in both helpers (each peels iteratively).
nondiverging_nested_paren_string_absent() `test {
  string? o = none;
  n := ((((o)))? _ {
    "x" + "y"
  }).len;
  assert(n == 2, "nested paren ident source, absent runtime");
}

// Bind form with paren — verifies the bind-site neutralize and our someBlock
// neutralize co-operate when source is paren-wrapped.
nondiverging_paren_string_bind_absent() `test {
  string? o = none;
  string r = (o)? _ {
    "x".to_upper()
  };
  assert(r.len == 1, "paren ident source, absent runtime, bind");
}

nondiverging_paren_string_bind_present() `test {
  string? o = "ab".to_upper();
  string r = (o)? _ {
    "x".to_upper()
  };
  assert(r.len == 2, "paren ident source, present runtime, bind");
}

nondiverging_paren_vector_bind_absent() `test {
  int[]? o = none;
  int[] r = (o)? _ {
    [1, 2].clone()
  };
  assert(r.len == 2, "paren ident source, vector absent, bind");
}

nondiverging_paren_vector_bind_present() `test {
  int[]? o = [3, 4, 5].clone();
  int[] r = (o)? _ {
    [1, 2].clone()
  };
  assert(r.len == 3, "paren ident source, vector present, bind");
}

// --- generic method context: c.typeSubst != nil at the T0778 site -----------
// The T0778 fix substitutes type params before classifying the result kind
// (string / vector / other) — that branch is uncovered by the bare top-level
// tests above (c.typeSubst is nil there). When the optional-handler unwrap is
// inside a generic method body specialized for T=string or T=int[], rt comes
// in as the TypeParam and only becomes string/vector after Substitute. Without
// this, a generic monomorphization of the same shape would silently leak.

type GHolder[T] {
  T? o;
  // Reads with a fresh owned recovery — exercises T0778's neutralize+track
  // inside a monomorphized method body (c.typeSubst != nil).
  read_with(this, T move recovery) T {
    return (this.o)? _ {
      recovery
    };
  }
}

nondiverging_generic_string_absent() `test {
  h := GHolder[string](o: none);
  r := h.read_with("ab".to_upper());
  assert(r.len == 2, "generic method, T=string, absent runtime");
}

nondiverging_generic_string_present() `test {
  h := GHolder[string](o: "ab".to_upper());
  r := h.read_with("xy".to_upper());
  assert(r.len == 2, "generic method, T=string, present runtime");
}

nondiverging_generic_vector_absent() `test {
  h := GHolder[int[]](o: none);
  r := h.read_with([1, 2].clone());
  assert(r.len == 2, "generic method, T=int[], absent runtime");
}

nondiverging_generic_vector_present() `test {
  h := GHolder[int[]](o: [3, 4, 5].clone());
  r := h.read_with([1, 2].clone());
  assert(r.len == 3, "generic method, T=int[], present runtime");
}

// T0776: `((o)!).len` on a string? / T[]? ident source must NOT double-free —
// genOptionalForceUnwrap was tracking the extracted inner as an owned statement
// temp for parenthesized sources, racing the source optional's scope drop.
owned_paren_string_force_unwrap() `test {
  string? o = "abc".to_upper();
  n := ((o)!).len;
  assert(n == 3, "parenthesized ident string force-unwrap, no double-free");
}

owned_paren_vector_force_unwrap() `test {
  int[]? o = [1, 2].clone();
  n := ((o)!).len;
  assert(n == 2, "parenthesized ident vector force-unwrap, no double-free");
}

// No-regression: non-ident source must still track and free the extracted inner.
nonident_string_force_unwrap() `test {
  n := (mk_str()!).len;
  assert(n == 2, "non-ident string force-unwrap, no leak");
}

nonident_vector_force_unwrap() `test {
  n := (mk_vec()!).len;
  assert(n == 3, "non-ident vector force-unwrap, no leak");
}

// T0776: exercise the trackTempWithDrop branch (Arc/Weak/Mutex/Task/Channel)
// of the type-aware temp tracker at runtime — the string/vector tests above
// cover trackStringTemp / trackVectorTempWithElemType. Without the ParenExpr
// peel, the extracted Arc handle would be registered as a stmt-temp; at
// scope exit both the source optional and the temp would call
// `Ref[int].drop` on the same handle → atomic refcount goes to zero twice
// → use-after-free of the freed Arc allocation. Arc represents the i8*
// opaque-handle class (the same gate covers Weak/Mutex/Task/Channel).
owned_paren_arc_force_unwrap() `test {
  Ref[int]? o = Ref[int](42);
  n := ((o)!).borrow;
  assert(n == 42, "parenthesized ident Arc force-unwrap, no double-free");
}

owned_paren_mutex_force_unwrap() `test {
  Mutex[int]? o = Mutex[int](7);
  use g := ((o)!).lock();
  assert(g.borrow == 7, "parenthesized ident Mutex force-unwrap, no double-free");
}

// ============================================================================
// T1085: optional-HANDLER (`o? _ { recovery }`) form on opaque i8*-backed
// containers (Channel/Arc) and heap user types (Map/Set) used as a temporary.
// T0778 fixed string/vector; these inner kinds had the identical recovery leak:
//   - ident source, absent runtime: the recovery container is the merged phi's
//     sole owner and leaked (the source's none drop is a no-op, the phi was
//     untracked).
//   - non-ident (call/owned-temp) source: the okVal/phi is an owned temporary
//     the source optional never separately tracks — both runtimes leaked.
// Fix: track the merged phi (i8* via the type-aware tracker, heap user types via
// trackHeapValueTemp) after neutralizing the source ident's present flag.
// ----------------------------------------------------------------------------

mk_chan_opt() Channel[int]? {
  return channel[int](capacity: 1);
}
mk_none_chan_opt() Channel[int]? {
  return none;
}
mk_ref_opt() Ref[int]? {
  return Ref[int](7);
}
mk_none_ref_opt() Ref[int]? {
  return none;
}

mk_imap_opt() map[int, int]? {
  m := map[int, int]();
  m[1] = 10;
  return m;
}
mk_none_imap_opt() map[int, int]? {
  return none;
}

mk_iset_opt() Set[int]? {
  s := Set[int]();
  s.add(5);
  return s;
}
mk_none_iset_opt() Set[int]? {
  return none;
}

// --- ident source, ABSENT runtime: recovery is the phi's sole owner ----------

ident_none_channel_handler_recovery() `test {
  Channel[int]? c = none;
  (c? _ {
    channel[int](capacity: 1)
  }).close();
  assert(true, "absent-runtime channel recovery dropped, no leak");
}

ident_none_arc_handler_recovery() `test {
  Ref[int]? r = none;
  n := (r? _ {
    Ref[int](99)
  }).borrow;
  assert(n == 99, "absent-runtime Arc recovery dropped, no leak");
}

ident_none_map_handler_recovery() `test {
  map[int, int]? m = none;
  n := (m? {
    mk := map[int, int]();
    mk[9] = 9;
    mk
  }).len;
  assert(n == 1, "absent-runtime map recovery dropped, no leak");
}

ident_none_set_handler_recovery() `test {
  Set[int]? s = none;
  n := (s? {
    sk := Set[int]();
    sk.add(3);
    sk
  }).len;
  assert(n == 1, "absent-runtime set recovery dropped, no leak");
}

// --- ident source, present runtime: phi aliases source inner, single owner ---

ident_some_channel_handler() `test {
  Channel[int]? c = channel[int](capacity: 1);
  (c? _ {
    channel[int](capacity: 1)
  }).close();
  assert(true, "present-runtime channel handler, no double-free");
}

ident_some_arc_handler() `test {
  Ref[int]? r = Ref[int](7);
  n := (r? _ {
    Ref[int](99)
  }).borrow;
  assert(n == 7, "present-runtime Arc handler, no double-free");
}

ident_some_map_handler() `test {
  map[int, int]? m = mk_imap_opt();
  n := (m? {
    mk := map[int, int]();
    mk
  }).len;
  assert(n == 1, "present-runtime map handler, no double-free");
}

// --- non-ident (call/owned-temp) source: okVal/phi is an owned temporary ------

call_channel_handler_temp() `test {
  (mk_chan_opt()? _ {
    channel[int](capacity: 1)
  }).close();
  assert(true, "call-source present channel temp dropped, no leak");
}

call_none_channel_handler_temp() `test {
  (mk_none_chan_opt()? _ {
    channel[int](capacity: 1)
  }).close();
  assert(true, "call-source absent channel recovery dropped, no leak");
}

call_arc_handler_temp() `test {
  n := (mk_ref_opt()? _ {
    Ref[int](99)
  }).borrow;
  assert(n == 7, "call-source present Arc temp dropped, no leak");
}

call_none_arc_handler_temp() `test {
  n := (mk_none_ref_opt()? _ {
    Ref[int](99)
  }).borrow;
  assert(n == 99, "call-source absent Arc recovery dropped, no leak");
}

call_map_handler_temp() `test {
  n := (mk_imap_opt()? {
    mk := map[int, int]();
    mk
  }).len;
  assert(n == 1, "call-source present map temp dropped, no leak");
}

call_none_set_handler_temp() `test {
  n := (mk_none_iset_opt()? {
    sk := Set[int]();
    sk.add(3);
    sk
  }).len;
  assert(n == 1, "call-source absent set recovery dropped, no leak");
}

// --- call source, DIVERGING handler: only the present (okVal) path reaches use

call_diverging_channel_handler() `test {
  (mk_chan_opt()? _ {
    return
  }).close();
  assert(true, "call-source diverging channel temp dropped, no leak");
}

// --- regression guards: must stay clean (no double-free) ----------------------

// ident diverging: source drop owns the inner; the phi degenerates to okVal
// aliasing the source — must NOT be tracked.
ident_diverging_channel_handler() `test {
  Channel[int]? c = channel[int](capacity: 1);
  (c? _ {
    return
  }).close();
  assert(true, "ident diverging channel handler, no double-free");
}

// owner-governed member, present path: the owner's drop frees the field — the
// extracted inner must NOT be tracked (i8* handles AND heap user types).
member_channel_handler_present() `test {
  b := ChanBox085(f: channel[int](capacity: 1));
  (b.f? _ {
    channel[int](capacity: 1)
  }).close();
  assert(true, "member channel present, owner drop frees field");
}

member_map_handler_present() `test {
  m := map[int, int]();
  m[1] = 10;
  b := MapBox085(f: move m);
  n := (b.f? {
    mk := map[int, int]();
    mk
  }).len;
  assert(n == 1, "member map present, owner drop frees field");
}

type ChanBox085 {
  Channel[int]? f;
}
type MapBox085 {
  map[int, int]? f;
}

// ============================================================================
// T1085: remaining opaque i8*-backed handle kinds (Mutex/Task/Weak/MutexGuard).
// The Channel/Arc cases above cover two of the six i8* branches in the dispatch
// type-switch; these close the rest. Each kind is exercised in BOTH dispatch
// locations: the ident absent-runtime case hits genOptionalHandlerExpr's
// phi-tracking branch, and the call-source case hits genExpr's non-ident,
// non-owner-governed branch. (MutexGuard's call-source form is omitted — a
// function returning `MutexGuard[T]?` would have to outlive the guard's borrowed
// Mutex, which isn't constructible; the ident form covers its phi branch.)
// ----------------------------------------------------------------------------

mk_mutex_opt() Mutex[int]? {
  return Mutex[int](7);
}
mk_task_opt() Task[int]? {
  return go worker_t085();
}
worker_t085() int {
  return 5;
}
mk_weak_opt() Weak[int]? {
  r := Ref[int](7);
  return r.downgrade();
}

// --- Mutex ------------------------------------------------------------------

ident_none_mutex_handler() `test {
  Mutex[int]? m = none;
  use g := (m? _ {
    Mutex[int](42)
  }).lock();
  assert(g.borrow == 42, "absent-runtime mutex recovery dropped, no leak");
}

call_mutex_handler_temp() `test {
  use g := (mk_mutex_opt()? _ {
    Mutex[int](99)
  }).lock();
  assert(g.borrow == 7, "call-source present mutex temp dropped, no leak");
}

// --- Task -------------------------------------------------------------------

ident_none_task_handler() `test {
  Task[int]? t = none;
  n := <-(t? _ {
    go worker_t085()
  });
  assert(n == 5, "absent-runtime task recovery dropped, no leak");
}

call_task_handler_temp() `test {
  n := <-(mk_task_opt()? _ {
    go worker_t085()
  });
  assert(n == 5, "call-source present task temp dropped, no leak");
}

// --- Weak -------------------------------------------------------------------

ident_none_weak_handler() `test {
  r0 := Ref[int](1);
  Weak[int]? w = none;
  up := (w? _ {
    r0.downgrade()
  }).upgrade();
  n := up? _ {
    Ref[int](0)
  };
  assert(n.borrow == 1, "absent-runtime weak recovery dropped, no leak");
}

call_weak_handler_temp() `test {
  rk := Ref[int](7);
  // The present-runtime weak temp from mk_weak_opt() is the okVal owner tracked
  // by genExpr's branch; upgrade() may yield none (its strong Ref was dropped at
  // mk_weak_opt's return) — the assertion only confirms the temp drops cleanly.
  up := (mk_weak_opt()? _ {
    rk.downgrade()
  }).upgrade();
  n := up? _ {
    Ref[int](-1)
  };
  assert(n.borrow == -1 || n.borrow == 7, "call-source present weak temp dropped, no leak");
}

// --- MutexGuard (ident-only; phi branch) ------------------------------------

ident_none_guard_handler() `test {
  m2 := Mutex[int](9);
  MutexGuard[int]? g = none;
  v := (g? _ {
    m2.lock()
  }).borrow;
  assert(v == 9, "absent-runtime guard recovery dropped, no leak");
}

// --- borrow → owned reassignment state transition ---------------------------
// A heap user-type optional first bound from an RTTI downcast is borrow-holding;
// reassigning it to an OWNED value must clear that mark (genAssignStmt) so the
// later handler unwrap neutralize+tracks the now-owned inner. If the stale mark
// survived, the owned reassigned Sub would leak (untracked phi).

type Base085r {
  int x;
  kind(this) string {
    return "base";
  }
}
type Sub085r is Base085r {
  int y;
  kind(this) string {
    return "sub";
  }
}

borrow_then_owned_reassign(Base085r b) int {
  Sub085r? o = b as Sub085r;
  o = Sub085r(x: 10, y: 20);
  return (o? _ {
    Sub085r(x: -1, y: -1)
  }).y;
}

reassign_borrow_to_owned_handler() `test {
  assert(borrow_then_owned_reassign(Sub085r(x: 1, y: 2)) == 20,
  "owned reassignment of borrow optional, tracked, no leak");
}
