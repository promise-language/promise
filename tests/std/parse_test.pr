// Tests for Parse interface: int.parse, bool.parse, uint.parse, f64.parse, Vector.filled
test_int_parse() `test {
  Scanner r1 = Scanner(s: "42");
  int v1 = int.parse(r1)?!;
  assert(v1 == 42, "parse 42");

  Scanner r2 = Scanner(s: "-17");
  int v2 = int.parse(r2)?!;
  assert(v2 == -17, "parse -17");

  Scanner r3 = Scanner(s: "0");
  int v3 = int.parse(r3)?!;
  assert(v3 == 0, "parse 0");
}

test_int_parse_stops_at_non_digit() `test {
  Scanner r = Scanner(s: "123abc");
  int v = int.parse(r)?!;
  assert(v == 123, "parse 123 from 123abc");
  assert(r.rest() == "bc", "remaining bc");
}

test_bool_parse() `test {
  Scanner r1 = Scanner(s: "true");
  bool v1 = bool.parse(r1)?!;
  assert(v1, "parse true");

  Scanner r2 = Scanner(s: "false");
  bool v2 = bool.parse(r2)?!;
  assert(!v2, "parse false");
}

_try_parse_int(string move s) string {
  Scanner r = Scanner(s: move s);
  int v = int.parse(r)? e {
    return e.message;
  };
  return "ok";
}

test_int_parse_error() `test {
  string result = _try_parse_int("abc");
  assert(result == "expected digit", "error message");
}

test_int_parse_empty() `test {
  string result = _try_parse_int("");
  assert(result == "unexpected end of input", "empty input");
}

test_int_parse_minus_only() `test {
  string result = _try_parse_int("-");
  assert(result == "expected digit", "minus only");
}

_try_parse_bool(string move s) string {
  Scanner r = Scanner(s: move s);
  bool v = bool.parse(r)? e {
    return e.message;
  };
  return "ok";
}

test_bool_parse_error() `test {
  string result = _try_parse_bool("xyz");
  assert(result == "expected 'true' or 'false'", "bad input");
}

test_bool_parse_empty() `test {
  string result = _try_parse_bool("");
  assert(result == "unexpected end of input", "empty input");
}

test_bool_parse_partial() `test {
  string result = _try_parse_bool("tru");
  assert(result == "expected 'true'", "partial true");
}

test_scan_int() `test {
  int v = scan[int]("99")?!;
  assert(v == 99, "scan int");
}

test_sequential_parse() `test {
  Scanner r = Scanner(s: "12 34");
  int a = int.parse(r)?!;
  assert(a == 12, "first int");
  // int.parse already consumed the space (first non-digit)
  int b = int.parse(r)?!;
  assert(b == 34, "second int");
}

// --- uint.parse ---

test_uint_parse() `test {
  Scanner r = Scanner(s: "42");
  uint v = uint.parse(r)?!;
  assert((v as! int) == 42, "parse 42");
}

test_uint_parse_large() `test {
  Scanner r = Scanner(s: "1000000");
  uint v = uint.parse(r)?!;
  assert((v as! int) == 1000000, "parse 1000000");
}

_try_parse_uint(string move s) string {
  Scanner r = Scanner(s: move s);
  uint v = uint.parse(r)? e {
    return e.message;
  };
  return "ok";
}

test_uint_parse_empty() `test {
  string result = _try_parse_uint("");
  assert(result == "unexpected end of input", "empty input");
}

test_uint_parse_non_digit() `test {
  string result = _try_parse_uint("abc");
  assert(result == "expected digit", "non-digit");
}

test_uint_parse_stops_at_non_digit() `test {
  Scanner r = Scanner(s: "123abc");
  uint v = uint.parse(r)?!;
  assert((v as! int) == 123, "parse 123 from 123abc");
  assert(r.rest() == "bc", "remaining bc");
}

test_uint_parse_zero() `test {
  uint v = scan[uint]("0")?!;
  assert((v as! int) == 0, "parse 0");
}

test_scan_uint() `test {
  uint v = scan[uint]("255")?!;
  assert((v as! int) == 255, "scan uint");
}

test_scan_bool() `test {
  bool v1 = scan[bool]("true")?!;
  assert(v1, "scan true");
  bool v2 = scan[bool]("false")?!;
  assert(!v2, "scan false");
}

// --- f64.parse ---

test_f64_parse_integer() `test {
  f64 v = scan[f64]("42")?!;
  assert(v == 42.0, "parse 42");
}

test_f64_parse_decimal() `test {
  f64 v = scan[f64]("3.14")?!;
  // Check with tolerance (floating point)
  assert(v > 3.13 && v < 3.15, "parse 3.14");
}

test_f64_parse_negative() `test {
  f64 v = scan[f64]("-2.5")?!;
  assert(v == -2.5, "parse -2.5");
}

test_f64_parse_zero() `test {
  f64 v = scan[f64]("0")?!;
  assert(v == 0.0, "parse 0");
}

test_f64_parse_zero_point() `test {
  f64 v = scan[f64]("0.0")?!;
  assert(v == 0.0, "parse 0.0");
}

test_f64_parse_scientific() `test {
  f64 v = scan[f64]("1e3")?!;
  assert(v == 1000.0, "parse 1e3");
}

test_f64_parse_scientific_negative_exp() `test {
  f64 v = scan[f64]("5e-2")?!;
  assert(v > 0.049 && v < 0.051, "parse 5e-2");
}

test_f64_parse_scientific_plus() `test {
  f64 v = scan[f64]("2.5e+2")?!;
  assert(v == 250.0, "parse 2.5e+2");
}

test_f64_parse_capital_e() `test {
  f64 v = scan[f64]("1E3")?!;
  assert(v == 1000.0, "parse 1E3");
}

test_f64_parse_negative_scientific() `test {
  f64 v = scan[f64]("-1.5e2")?!;
  assert(v == -150.0, "parse -1.5e2");
}

test_f64_parse_stops_at_non_digit() `test {
  Scanner r = Scanner(s: "3.14abc");
  f64 v = f64.parse(r)?!;
  assert(v > 3.13 && v < 3.15, "parse 3.14 from 3.14abc");
  assert(r.rest() == "bc", "remaining bc");
}

_try_parse_f64(string move s) string {
  Scanner r = Scanner(s: move s);
  f64 v = f64.parse(r)? e {
    return e.message;
  };
  return "ok";
}

test_f64_parse_empty() `test {
  string result = _try_parse_f64("");
  assert(result == "unexpected end of input", "empty input");
}

test_f64_parse_non_numeric() `test {
  string result = _try_parse_f64("abc");
  assert(result == "expected digit", "non-numeric");
}

test_f64_parse_minus_only() `test {
  string result = _try_parse_f64("-");
  assert(result == "expected digit", "minus only");
}

test_f64_parse_leading_dot() `test {
  f64 v = scan[f64](".5")?!;
  assert(v == 0.5, "parse .5 as 0.5");
}

test_f64_parse_negative_integer() `test {
  f64 v = scan[f64]("-42")?!;
  assert(v == -42.0, "parse -42");
}

test_f64_parse_trailing_dot() `test {
  f64 v = scan[f64]("1.")?!;
  assert(v == 1.0, "parse 1.");
}

test_f64_parse_negative_zero() `test {
  f64 v = scan[f64]("-0.0")?!;
  // -0.0 == 0.0 in IEEE 754
  assert(v == 0.0, "parse -0.0");
}

test_vector_filled() `test {
  int[] v = Vector[int].filled(7, 5);
  assert(v.len == 5, "len 5");
  int i = 0;
  while i < v.len {
    assert(v[i] == 7, "element == 7");
    i = i + 1;
  }
}

test_vector_filled_empty() `test {
  int[] v = Vector[int].filled(0, 0);
  assert(v.len == 0, "empty filled");
}

// --- char.parse ---

test_char_parse() `test {
  char c = scan[char]("A")?!;
  assert(c == 'A', "parse A");
}

test_char_parse_digit() `test {
  char c = scan[char]("7")?!;
  assert(c == '7', "parse 7");
}

test_char_parse_space() `test {
  char c = scan[char](" ")?!;
  assert(c == ' ', "parse space");
}

_try_parse_char(string move s) string {
  Scanner r = Scanner(s: move s);
  char v = char.parse(r)? e {
    return e.message;
  };
  return "ok";
}

test_char_parse_empty() `test {
  string result = _try_parse_char("");
  assert(result == "unexpected end of input", "empty input");
}

test_char_parse_from_scanner() `test {
  Scanner r = Scanner(s: "AB");
  char c1 = char.parse(r)?!;
  assert(c1 == 'A', "first char");
  char c2 = char.parse(r)?!;
  assert(c2 == 'B', "second char");
}

// --- f32.parse ---

test_f32_parse_integer() `test {
  f32 v = scan[f32]("42")?!;
  assert(v == 42.0f32, "parse 42");
}

test_f32_parse_decimal() `test {
  f32 v = scan[f32]("3.14")?!;
  assert(v > 3.13f32 && v < 3.15f32, "parse 3.14");
}

test_f32_parse_negative() `test {
  f32 v = scan[f32]("-2.5")?!;
  assert(v == -2.5f32, "parse -2.5");
}

_try_parse_f32(string move s) string {
  Scanner r = Scanner(s: move s);
  f32 v = f32.parse(r)? e {
    return e.message;
  };
  return "ok";
}

test_f32_parse_empty() `test {
  string result = _try_parse_f32("");
  assert(result == "unexpected end of input", "empty input");
}

test_f32_parse_non_numeric() `test {
  string result = _try_parse_f32("abc");
  assert(result == "expected digit", "non-numeric");
}

// --- i8.parse ---

test_i8_parse() `test {
  i8 v = scan[i8]("42")?!;
  assert(v == 42i8, "parse 42");
}

test_i8_parse_negative() `test {
  i8 v = scan[i8]("-17")?!;
  assert(v == -17i8, "parse -17");
}

test_i8_parse_max() `test {
  i8 v = scan[i8]("127")?!;
  assert(v == 127i8, "parse 127");
}

test_i8_parse_min() `test {
  i8 v = scan[i8]("-128")?!;
  assert(v == -128i8, "parse -128");
}

_try_parse_i8(string move s) string {
  Scanner r = Scanner(s: move s);
  i8 v = i8.parse(r)? e {
    return e.message;
  };
  return "ok";
}

test_i8_parse_overflow() `test {
  string result = _try_parse_i8("128");
  assert(result == "value out of i8 range", "overflow");
}

test_i8_parse_underflow() `test {
  string result = _try_parse_i8("-129");
  assert(result == "value out of i8 range", "underflow");
}

test_i8_parse_empty() `test {
  string result = _try_parse_i8("");
  assert(result == "unexpected end of input", "empty");
}

