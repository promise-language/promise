// B0350 / T0351: `Map[K,string] index assign` from a borrow param double-frees
// because the caller still owns the value. T0351 now rejects this at sema.
// Setters that store into a map must take `~string` (consume) and callers
// must clone if they need to retain the source.
type Sink {
  map[string, string] m;

  drop(~this) {
  }

  set(~this, string move key, string move value) {
    this.m[key] = value;
  }

  get(this, string key) string? {
    return this.m[key];
  }
}

test_borrow_param_into_map() `test {
  map[string, string] init = {:};
  sink := Sink(m: move init);
  sink.set("a".clone(), "hello".clone());
  sink.set("b".clone(), "world".clone());

  if v := sink.get("a") {
    assert(v == "hello", "a == hello");
  } else {
    assert(false, "a not found");
  }
  if v := sink.get("b") {
    assert(v == "world", "b == world");
  } else {
    assert(false, "b not found");
  }
}

test_borrow_param_overwrite() `test {
  map[string, string] init = {:};
  sink := Sink(m: move init);
  sink.set("key".clone(), "first".clone());
  sink.set("key".clone(), "second".clone());

  if v := sink.get("key") {
    assert(v == "second", "overwrite");
  } else {
    assert(false, "key not found");
  }
}

test_borrow_from_variable() `test {
  map[string, string] init = {:};
  sink := Sink(m: move init);
  string val = "from_var";
  sink.set("k".clone(), val.clone());

  if v := sink.get("k") {
    assert(v == "from_var", "from variable");
  } else {
    assert(false, "k not found");
  }
}

test_heap_string_into_map() `test {
  string val = "he" + "llo";
  map[string, string] init = {:};
  sink := Sink(m: move init);
  sink.set("k".clone(), val.clone());
  if v := sink.get("k") {
    assert(v == "hello", "heap string stored");
  } else {
    assert(false, "k not found");
  }
}
