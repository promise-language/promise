// Tests that Vector.drop is defined and called for field cleanup (B0157).
// Scope-exit drop for vector variables requires ownership tracking (future work).
// This file tests that types with vector fields correctly free them via drop().
type VecHolder {
  int[] items;
  drop(~this) {
  }
}

test_vector_field_drop() `test {
  VecHolder h = VecHolder(items: [1, 2, 3]);
  assert(h.items.len == 3, "holder items len");
}

test_vector_field_drop_empty() `test {
  VecHolder h = VecHolder(items: []);
  assert(h.items.len == 0, "holder empty items");
}

test_vector_field_drop_after_mutation() `test {
  VecHolder h = VecHolder(items: []);
  h.items.push(10);
  h.items.push(20);
  assert(h.items.len == 2, "holder mutated items");
}
