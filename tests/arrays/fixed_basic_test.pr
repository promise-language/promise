// Fixed-size array basic operations
main() `test(expected: """3
1
2
3
10
20
30
22
6""") {
  // Literal + len
  int[3] arr = [1, 2, 3];
  println("{arr.len}");

  // Index read
  println("{arr[0]}");
  println("{arr[1]}");
  println("{arr[2]}");

  // Index assign
  arr[0] = 10;
  arr[1] = 20;
  arr[2] = 30;
  println("{arr[0]}");
  println("{arr[1]}");
  println("{arr[2]}");

  // Compound assign
  arr[0] += 12;
  println("{arr[0]}");

  // For-in
  int[3] items = [1, 2, 3];
  int sum = 0;
  for x in items {
    sum += x;
  }
  println("{sum}");
}
