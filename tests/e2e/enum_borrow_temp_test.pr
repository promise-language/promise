// T1108: An inline enum-constructor temp (`Enum.Variant(payload)`) with a
// droppable payload passed to a BORROW param must be dropped exactly once at the
// caller's statement end — including its moved-in payload. Previously the temp
// was not tracked when the payload was *moved* into the variant (ident move,
// cast, or call-result), so a borrowed/discarded enum temp leaked its payload.
//
// These tests assert correct results AND (via the suite's zero-leak policy) that
// nothing leaks and nothing double-frees / use-after-frees.
type Holder {
  int n;
}

enum Msg {
  Text(string body),
  Empty,
}

// Borrow param: does not consume the enum — caller must drop the temp.
msg_len(Msg m) Holder {
  return match m {
    Msg.Text(b) => Holder(n: b.len),
    Msg.Empty => Holder(n: 0),
  };
}

// 1. T1108 exact repro: call-result payload (`s.clone()`) to a borrow param.
t1108_sync_call_result_borrow() `test {
  string s = "payload";
  r := msg_len(Msg.Text(s.clone()));
  assert(r.n == 7, "call-result payload result");
}

// 2. Ident-move heap payload (`move s`, heap string) to a borrow param.
t1108_ident_move_borrow() `test {
  string s = "pay" + "load"; // concatenation => heap (non-literal) string
  r := msg_len(Msg.Text(move s));
  assert(r.n == 7, "ident-move payload result");
}

type Resource {
  string name;
  drop(~this) {
  }
}

enum HolderR {
  Has(Resource r),
  Nothing,
}

make_resource(string move name) Resource {
  return Resource(name: move name);
}

// Borrow param that simply ignores the enum (discarded after the call).
consume_holder(HolderR h) {
}

// 3. Discarded enum statement (B0286's own scenario): the temp is borrowed and
//    then thrown away — its moved-in Resource must still be freed.
t1108_discarded_enum_statement() `test {
  consume_holder(HolderR.Has(r: make_resource("test")));
  assert(true, "no leak");
}

enum HolderV {
  Items(string[] list),
  Nothing,
  // Borrow receiver: `this` is borrowed, so a fresh enum temp receiver must be
  // dropped at the caller's statement end.
  count(this) int {
    return match this {
      HolderV.Items(items) => items.len,
      HolderV.Nothing => 0,
    };
  }
}

// 4. Borrow-receiver method call on a fresh enum-constructor temp.
t1108_borrow_receiver_method() `test {
  string[] items = ["alice", "bob"];
  c := HolderV.Items(move items).count();
  assert(c == 2, "borrow-receiver method result");
}

// Move param: callee consumes and drops the enum — caller must NOT also drop it
// (no double-free).
take_holder(HolderR move h) int {
  return match h {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
}

// 5. Move-param no-double-free.
t1108_move_param_no_double_free() `test {
  n := take_holder(HolderR.Has(r: make_resource("test")));
  assert(n == 4, "move-param consumes payload");
}

// 6. Container store no-double-free (regression guard for T1103/B0252): the enum
//    temp's ownership transfers into the map Slot; no statement-end drop fires.
//    The map's scope-exit drop frees the stored payload exactly once.
t1108_container_store_no_double_free() `test {
  map[string, Msg] m = {:};
  m["k"] = Msg.Text("pay" + "load");
  assert(m.len == 1, "stored one entry");
}

// borrow param that consumes an enum temp and returns a NON-enum fresh value.
inspect_holder(HolderR h) Resource {
  return match h {
    HolderR.Has(r) => Resource(name: r.name + "!"),
    HolderR.Nothing => Resource(name: "none"),
  };
}

// move param consuming a Resource (non-enum).
take_resource(Resource move r) int {
  return r.name.len;
}

// 7. Nested: a move-param arg whose value is a non-enum call result, where the
//    call BORROWS an inline enum-constructor temp. The inner HolderR.Has temp is
//    an intermediate the move callee never receives — it must be dropped at the
//    caller's statement end, NOT untracked by the move-param claim (else it
//    leaks). The move-param enum claim is gated on the arg's static type being an
//    enum; here the arg type is Resource, so the inner enum temp stays tracked.
t1108_nested_move_arg_borrows_enum_temp() `test {
  n := take_resource(inspect_holder(HolderR.Has(r: make_resource("test"))));
  assert(n == 5, "nested move-arg borrows enum temp"); // "test!" => 5
}

// Cast-subject payload: an `as!` cast subject moved into an enum-constructor
// variant. The T1108 fix removed the `movedDroppable` suppression from the cast
// branch of genEnumVariantCallLayout, so the enum temp is now tracked
// unconditionally — the cast subject's drop flag was cleared at the move, making
// the enum temp the payload's sole owner.
type Animal {
  string name;
  drop(~this) {
  }
}

type Dog is Animal {
  int legs;
}

enum Pet {
  Owned(Animal a),
  None,
}

// Borrow param: does not consume the enum.
pet_name_len(Pet p) int {
  return match p {
    Pet.Owned(a) => a.name.len,
    Pet.None => 0,
  };
}

// Move param: consumes and drops the enum.
take_pet(Pet move p) int {
  return match p {
    Pet.Owned(a) => a.name.len,
    Pet.None => 0,
  };
}

// 9. Cast-subject payload to a BORROW param: the moved-in Dog (cast to Animal)
//    must be freed at the caller's statement end (zero-leak policy).
t1108_cast_subject_borrow() `test {
  d := Dog(name: "rex", legs: 4);
  n := pet_name_len(Pet.Owned(move d as! Animal));
  assert(n == 3, "cast-subject borrow result");
}

// 10. Cast-subject payload to a MOVE param: the callee consumes & drops the
//     enum; the caller must NOT also drop it (no double-free).
t1108_cast_subject_move_no_double_free() `test {
  d := Dog(name: "fido", legs: 4);
  n := take_pet(Pet.Owned(move d as! Animal));
  assert(n == 4, "cast-subject move consumes payload");
}

// Scenario 8 (`go`-call with an inline enum-constructor temp) is covered by a Go
// IR-shape test (TestEnumCtorTempGoCallNoSyncDrop in t1108_test.go) rather than a
// runtime leak test: a droppable enum payload passed to a go-call still leaks at
// the pre-existing T1106 behavior, so it cannot be a zero-leak `test`. The IR
// test verifies the caller emits NO synchronous `enum.ctor.drop` for the go-call
// path — confirming the T1108 unconditional tracking does not introduce a
// use-after-free / double-free against the spawned goroutine.

// ============================================================================
// T1139: The "claim (untrack) enum-ctor temps for a move slot" pattern is shared
// by every move-consuming codegen site (constructor, Arc/Mutex, Vector.push,
// tuple/vector/fixed-array/map literals). It must be gated on the moved slot's
// static type being an enum. When the slot value is a NON-enum expression that
// internally passes an inline `Enum.Variant(...)` temp BY BORROW to a sub-call
// (here `inspect_holder(HolderR.Has(...))`), that inner enum temp is an
// intermediate the slot never receives — untracking it removes its statement-end
// drop and the payload leaks. Each test below shapes a non-enum slot whose value
// is a borrow-call over an inline `HolderR.Has(droppable)`; the suite's zero-leak
// policy is the assertion (plus a correctness check). The regression guards at
// the end exercise the gate's true branch (enum-typed slot) to confirm the
// existing no-double-free behavior is preserved.

type BoxR {
  Resource r;
}

// 1. Implicit constructor field (T0552 implicit-ctor field loop) — the item's
//    exact repro shape.
t1139_implicit_ctor_field_borrows_enum_temp() `test {
  b := BoxR(r: inspect_holder(HolderR.Has(r: make_resource("test"))));
  assert(b.r.name.len == 5, "implicit ctor field"); // "test!" => 5
}

type BoxNew {
  Resource r;

  new(~this, Resource move r) {
    this.r = r;
  }
}

// 2. Explicit new() constructor with a move param taking the borrow-call result
//    (T0552 explicit-ctor site).
t1139_explicit_new_move_param_borrows_enum_temp() `test {
  b := BoxNew(r: inspect_holder(HolderR.Has(r: make_resource("test"))));
  assert(b.r.name.len == 5, "explicit new move param");
}

// 3. Arc (Ref[T]) construction (T1003 Arc site).
t1139_arc_new_borrows_enum_temp() `test {
  a := Ref[Resource](inspect_holder(HolderR.Has(r: make_resource("test"))));
  assert(a.borrow.name.len == 5, "arc new");
}

// 4. Mutex construction (T1003 Mutex site).
t1139_mutex_new_borrows_enum_temp() `test {
  m := Mutex[Resource](inspect_holder(HolderR.Has(r: make_resource("test"))));
  use guard := m.lock();
  assert(guard.borrow.name.len == 5, "mutex new");
}

// 5. Vector.push (T0741 push site).
t1139_vector_push_borrows_enum_temp() `test {
  Resource[] v = Resource[]();
  v.push(inspect_holder(HolderR.Has(r: make_resource("test"))));
  assert(v[0].name.len == 5, "vector push");
}

// 6. Tuple literal (B0242/T0371 tuple site) — the enum temp is borrowed inside
//    the first element; the second element is an unrelated value.
t1139_tuple_lit_borrows_enum_temp() `test {
  (Resource, int) t = (inspect_holder(HolderR.Has(r: make_resource("test"))), 9);
  (r, n) := t;
  assert(r.name.len == 5, "tuple element"); // "test!" => 5
  assert(n == 9, "tuple int");
}

// 7. Vector literal with a drop-walked element type (B0281 vector-lit site).
t1139_vector_lit_borrows_enum_temp() `test {
  Resource[] v = [inspect_holder(HolderR.Has(r: make_resource("test")))];
  assert(v[0].name.len == 5, "vector literal");
}

// 8. Fixed-array literal (genFixedArrayLit site).
t1139_fixed_array_lit_borrows_enum_temp() `test {
  Resource[1] a = [inspect_holder(HolderR.Has(r: make_resource("test")))];
  assert(a[0].name.len == 5, "fixed-array literal");
}

// 9. Map literal with non-enum key AND non-enum value (B0280/B0281 map site).
//    Neither slot is an enum, so the borrow intermediate must stay tracked.
t1139_map_lit_borrows_enum_temp() `test {
  map[string, Resource] m = {
    "k": inspect_holder(HolderR.Has(r: make_resource("test")))
  };
  // NOTE: bind-then-unwrap rather than `m["k"]!.name` — inline force-unwrap of a
  // map-index optional on a droppable value followed by member access segfaults
  // (pre-existing, unrelated to T1139; tracked as T1144).
  v := m["k"];
  r := v!;
  assert(r.name.len == 5, "map literal"); // "test!" => 5
}

// --- Regression guards: enum-typed slot path (the gate's true branch) still
//     transfers ownership exactly once (no leak, no double-free). ---

type EnumBox {
  HolderR h;
}

// Enum-typed constructor field built directly from an inline enum-ctor temp:
// ownership transfers to the field, the field's synth drop frees it once.
t1139_enum_typed_ctor_field_no_double_free() `test {
  b := EnumBox(h: HolderR.Has(r: make_resource("test")));
  n := match b.h {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed ctor field"); // "test" => 4
}

// Enum-typed vector element built directly from an inline enum-ctor temp:
// the vector owns and drops it once.
t1139_enum_typed_vector_elem_no_double_free() `test {
  HolderR[] v = [HolderR.Has(r: make_resource("test"))];
  n := match v[0] {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed vector element");
}

// The remaining guards exercise the gate's TRUE branch at the OTHER modified
// sites (explicit-new move param, Arc/Mutex, Vector.push, tuple/fixed-array
// literals, map value). Each feeds an inline enum-ctor temp directly into the
// enum-typed slot: the slot must claim/truncate the temp so ownership transfers
// exactly once (a broken gate condition would leak or double-free here).

type EnumBoxNew {
  HolderR h;

  new(~this, HolderR move h) {
    this.h = h;
  }
}

// Explicit new() move param, enum-typed (genConstructorCallMono move-param site).
t1139_enum_typed_explicit_new_no_double_free() `test {
  b := EnumBoxNew(h: HolderR.Has(r: make_resource("test")));
  n := match b.h {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed explicit new");
}

// Arc (Ref[T]) construction, enum-typed (T1003 Arc site).
t1139_enum_typed_arc_no_double_free() `test {
  a := Ref[HolderR](HolderR.Has(r: make_resource("test")));
  n := match a.borrow {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed arc");
}

// Mutex construction, enum-typed (T1003 Mutex site).
t1139_enum_typed_mutex_no_double_free() `test {
  m := Mutex[HolderR](HolderR.Has(r: make_resource("test")));
  use guard := m.lock();
  n := match guard.borrow {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed mutex");
}

// Vector.push, enum-typed (T0741 push site).
t1139_enum_typed_vector_push_no_double_free() `test {
  HolderR[] v = HolderR[]();
  v.push(HolderR.Has(r: make_resource("test")));
  n := match v[0] {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed vector push");
}

// Tuple literal, enum-typed first element (tuple-lit site).
t1139_enum_typed_tuple_no_double_free() `test {
  (HolderR, int) t = (HolderR.Has(r: make_resource("test")), 9);
  (h, k) := t;
  n := match h {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed tuple element");
  assert(k == 9, "enum-typed tuple int");
}

// Fixed-array literal, enum-typed (genFixedArrayLit site).
t1139_enum_typed_fixed_array_no_double_free() `test {
  HolderR[1] a = [HolderR.Has(r: make_resource("test"))];
  n := match a[0] {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed fixed array");
}

// Map literal, enum-typed VALUE (map-lit site, gate's value-enum operand).
t1139_enum_typed_map_value_no_double_free() `test {
  map[string, HolderR] m = {
    "k": HolderR.Has(r: make_resource("test"))
  };
  v := m["k"];
  h := v!;
  n := match h {
    HolderR.Has(r) => r.name.len,
    HolderR.Nothing => 0,
  };
  assert(n == 4, "enum-typed map value");
}
