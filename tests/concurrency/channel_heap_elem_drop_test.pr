// T0663: Channel[T].drop must drop heap-allocated buffered items.
//
// Before the fix, Channel.drop freed the ring buffer as raw bytes without
// dropping the un-received items inside it — leaking one allocation per
// buffered heap element. These tests send more items than they receive so
// the channel is dropped while still holding owned heap items; the test
// harness's zero-leak enforcement is the actual assertion.
type Box {
  int v;
  new(~this, int v) {
    this.v = v;
  }
}

mk_str(int n) string {
  return "v" + n.to_string();
}

// Channel[string]: heap strings left buffered at drop.
chan_string_buffered_drop() `test {
  c := channel[string](capacity: 3);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  r := <-c; // receive one — two remain buffered
  if v := r {
    assert(v == "v1", "first received");
  }
  // c dropped with 2 heap strings still in the ring buffer → must not leak
}

// Channel[Vector[int]]: heap vectors left buffered at drop.
chan_vector_buffered_drop() `test {
  c := channel[Vector[int]](capacity: 2);
  a := Vector[int]();
  a.push(1);
  a.push(2);
  b := Vector[int]();
  b.push(3);
  c.send(a);
  c.send(b);
  // none received — both vectors dropped via the per-element walk
}

// Channel[Box]: user heap type left buffered at drop.
chan_user_type_buffered_drop() `test {
  c := channel[Box](capacity: 3);
  c.send(Box(10));
  c.send(Box(20));
  c.send(Box(30));
  r := <-c;
  if b := r {
    assert(b.v == 10, "first box");
  }
  // 2 Box instances still buffered → pal_free'd by the element walk
}

// Channel[Ref[int]]: Arc handles left buffered at drop.
chan_arc_buffered_drop() `test {
  c := channel[Ref[int]](capacity: 2);
  c.send(Ref[int](7));
  c.send(Ref[int](8));
  // none received — Ref[int].drop runs for each buffered handle
}

// Nested Channel[Channel[string]]: inner channel (with its own buffered
// heap strings) left buffered when the outer channel drops.
chan_nested_channel_drop() `test {
  outer := channel[channel[string]](capacity: 1);
  inner := channel[string](capacity: 2);
  inner.send(mk_str(1));
  inner.send(mk_str(2));
  outer.send(inner);
  // outer dropped with an un-received inner channel that itself holds 2
  // un-received heap strings → recursive element drop must free all 3 allocs
}

// Channel[string] as a user-type field, dropped with heap items buffered.
// Exercises the synthesized-field-drop call site (emitVariantFieldDrop).
type StrChanHolder {
  channel[string] ch;
}

chan_string_field_buffered_drop() `test {
  c := channel[string](capacity: 2);
  c.send(mk_str(1));
  c.send(mk_str(2));
  h := StrChanHolder(ch: c);
  // h dropped → synthesized StrChanHolder.drop → Channel[string].drop walks
  // and frees the 2 buffered heap strings
  assert(true, "field-held channel buffered drop");
}

// Channel[string] shared with a goroutine and dropped with buffered heap
// items: the fan-out scenario where a worker exits early. Refcounted drop
// must still run the element walk exactly once (on the last reference).
chan_string_shared_buffered_drop() `test(exclude: wasm) {
  c := channel[string](capacity: 3);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  go {
    r := <-c; // goroutine drains exactly one
    if v := r {
      assert(v == "v1", "goroutine got first");
    }
  };
  <-c; // main drains one more — one remains buffered
  // both owners drop c; last-ref drop walks the 1 remaining heap string
}

// Ring-buffer wraparound: head advances past 0, buffered items straddle the
// wrap boundary. Exercises slot = (head + idx) % capacity.
chan_string_wraparound_drop() `test {
  c := channel[string](capacity: 2);
  c.send(mk_str(1));
  c.send(mk_str(2));
  r := <-c; // head -> 1, count 1
  if v := r {
    assert(v == "v1", "wrap first");
  }
  c.send(mk_str(3)); // wraps: tail -> 0, count 2 (slots 1 and 0 occupied)
  // dropped with 2 items spanning the wrap boundary → both freed
}

// Regression: fully drained channel must not double-free received items.
// recv advances head / decrements count, so received items leave the
// [head, head+count) window the element-drop walk scans — the unwrapped
// locals own them and drop them at scope exit, the channel walk sees
// count 0 (nothing to drop, no double free). Both manual `<-` and the
// for-in form (see chan_string_forin_drained below) are leak-safe as of
// T0671 — for-in is no longer the only-leaks form.
chan_string_drained_clean() `test {
  c := channel[string](capacity: 3);
  c.send(mk_str(1));
  c.send(mk_str(2));
  a := <-c;
  b := <-c;
  if v := a {
    assert(v == "v1", "drained first");
  }
  if v := b {
    assert(v == "v2", "drained second");
  }
  // channel drops empty; a, b drop at scope exit — no leak, no double free
}

// T0671 for-in companion to chan_string_drained_clean: `for s in c` over a
// closed, fully drained channel[string]. Before T0671 genForInChannel never
// registered a drop binding for the loop variable, so every received heap
// element leaked (one alloc per item). Now the per-iteration loop variable is
// dropped at the end of each iteration (flag-guarded) — zero leak, and the
// channel drops empty so no double-free vs. Channel[string].drop (T0663).
chan_string_forin_drained() `test {
  c := channel[string](capacity: 3);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  c.close();
  acc := "";
  for s in c {
    acc = acc + s; // `+` borrows s (no move) → loop must drop s each iteration
  }
  assert(acc == "v1v2v3", "forin drained content");
  // each received string dropped at end of iteration; acc dropped at scope exit
}

// Regression: value-element channel (no element-drop loop emitted).
chan_int_value_regression() `test {
  c := channel[int](capacity: 4);
  c.send(1);
  c.send(2);
  c.send(3);
  r := <-c;
  if v := r {
    assert(v == 1, "int first");
  }
  // 2 ints still buffered — value type, nothing to drop, no leak
}

// ----------------------------------------------------------------------------
// Coverage gaps (added during T0663 /coverage): the tests above exercise the
// local-var scope-binding and synthesized-field drop sites. The sites below
// were unexercised — each leaked the buffered heap items pre-T0663 and is
// zero-leak post-fix. Confirmed by stash-and-rebuild on clean master.
// ----------------------------------------------------------------------------

mk_chan_with_two() Channel[string]? {
  c := channel[string](capacity: 2);
  c.send(mk_str(1));
  c.send(mk_str(2));
  return c;
}

// Optional[Channel[string]] local dropped WITHOUT unwrapping — exercises
// maybeRegisterOptionalDrop's Channel branch (per-element-type inner drop).
chan_optional_buffered_drop() `test {
  oc := mk_chan_with_two(); // Optional holding a channel with 2 buffered strings
  assert(true, "optional channel dropped without unwrap");
  // oc drops here → optional-inner Channel[string].drop walks the 2 strings
}

// Optional[Channel[string]] unwrapped, partially drained, remainder dropped —
// the unwrapped binding's scope-exit drop must still walk the leftover item.
chan_optional_unwrap_partial_drop() `test {
  oc := mk_chan_with_two();
  if ch := oc {
    r := <-ch; // drain 1, 1 stays buffered when ch drops at if-scope exit
    if v := r {
      assert(v == "v1", "optional unwrap first");
    }
  }
}

// Channel struct-field reassignment — the displaced old channel (still holding
// buffered heap strings) must drop. Exercises genMemberAssign's Channel branch.
type StrChanCell {
  channel[string] ch;
}
chan_field_reassign_buffered_drop() `test {
  c1 := channel[string](capacity: 2);
  c1.send(mk_str(1));
  c1.send(mk_str(2));
  cell := StrChanCell(ch: c1);
  c2 := channel[string](capacity: 2);
  c2.send(mk_str(3));
  cell.ch = c2; // old c1 (2 buffered heap strings) dropped by the reassign
}

// channel[Box] field reassignment — same site as above but a user-heap element
// type, so the element walk must pal_free each displaced Box instance.
type BoxChanCell {
  channel[Box] ch;
}
chan_box_field_reassign_buffered_drop() `test {
  c1 := channel[Box](capacity: 2);
  c1.send(Box(1));
  c1.send(Box(2));
  cell := BoxChanCell(ch: c1);
  c2 := channel[Box](capacity: 1);
  c2.send(Box(3));
  cell.ch = c2; // old c1's 2 buffered Box instances must be freed
}

// Channel moved into a move-closure env; the closure env drop must run the
// per-element-type walk. Exercises analyzeEnvCaptureDrop's Channel branch.
chan_closure_capture_buffered_drop() `test {
  c := channel[string](capacity: 2);
  c.send(mk_str(1));
  c.send(mk_str(2));
  f := move || -> int {
    c.close(); // reference forces a move-capture of c into the closure env
    return 0;
  };
  x := f();
  assert(x == 0, "closure ran");
  // f's env owns c → env drop → Channel[string].drop walks the 2 strings
}

// Generic type holding a channel[T] field, dropped in monomorphized context —
// exercises the c.typeSubst-active path in maybeRegisterDrop / emitFieldDropsFor
// (resolvedElem substitution before getOrCreateChannelDrop).
type ChanWrapper[T] {
  channel[T] ch;
  new(~this, ~channel[T] ch) {
    this.ch = ch;
  }
}
chan_generic_field_buffered_drop() `test {
  c := channel[string](capacity: 2);
  c.send(mk_str(1));
  c.send(mk_str(2));
  w := ChanWrapper[string](c);
  assert(true, "generic channel field dropped");
  // w drops → mono ChanWrapper[string].drop → Channel[string].drop walk
}

// Ref[Channel[string]] — when the Arc refcount hits 0 its inner-drop must run
// the channel's per-element walk. Exercises emitInnerDrop's Channel branch.
chan_arc_wrapped_buffered_drop() `test {
  c := channel[string](capacity: 2);
  c.send(mk_str(1));
  c.send(mk_str(2));
  a := Ref[Channel[string]](c);
  assert(true, "arc-wrapped channel dropped");
  // a drops → Arc inner drop → Channel[string].drop walks the 2 strings
}

// Channel[string]? as a struct FIELD (vs. the local-var optional above) —
// dropped via the holder's synthesized drop. Exercises emitOptionalValueDrop's
// Channel branch (distinct from maybeRegisterOptionalDrop's local-var path).
type OptChanHolder {
  Channel[string]? ch;
}
chan_optional_field_buffered_drop() `test {
  c := channel[string](capacity: 2);
  c.send(mk_str(1));
  c.send(mk_str(2));
  h := OptChanHolder(ch: c);
  assert(true, "optional channel field dropped");
  // h drops → synth OptChanHolder.drop → optional-inner Channel[string].drop
}

// Reassigning an Optional[Channel[string]] field whose old value held buffered
// heap strings. Exercises emitOptionalFieldReassignDrop's Channel branch.
chan_optional_field_reassign_buffered_drop() `test {
  c1 := channel[string](capacity: 2);
  c1.send(mk_str(1));
  c1.send(mk_str(2));
  h := OptChanHolder(ch: c1);
  c2 := channel[string](capacity: 1);
  c2.send(mk_str(3));
  h.ch = c2; // old c1 (2 buffered heap strings) dropped by the optional reassign
}

// ----------------------------------------------------------------------------
// T0671: for-in over a heap-element channel must drop the per-iteration loop
// variable. genForInChannel memcpys each item out of the ring buffer (a real
// move — head/count advanced) into the loop-var alloca, so the loop variable
// owns the only copy. Before T0671 no drop binding was registered, leaking one
// allocation per received heap item. The fix registers a per-iteration drop at
// loopScopeDepth, covering normal iteration end, break, continue, the `_`
// discard, the moved-out (flag-clear) case, and early return. Each test below
// leaked pre-T0671 and is zero-leak post-fix; the break/early-return cases also
// confirm no double-free vs. Channel[T].drop's buffered-remainder walk (T0663).
// ----------------------------------------------------------------------------

// Channel[Vector[int]]: heap vector loop variable dropped each iteration.
chan_vector_forin_drained() `test {
  c := channel[Vector[int]](capacity: 2);
  a := Vector[int]();
  a.push(1);
  a.push(2);
  b := Vector[int]();
  b.push(3);
  b.push(4);
  c.send(a);
  c.send(b);
  c.close();
  total := 0;
  for v in c {
    for x in v {
      total = total + x;
    }
  }
  // v (a heap Vector) dropped at end of each iteration → zero leak
  assert(total == 10, "forin vector sum");
}

// Channel[Box]: user-heap loop variable pal_free'd each iteration.
chan_user_forin_drained() `test {
  c := channel[Box](capacity: 3);
  c.send(Box(10));
  c.send(Box(20));
  c.send(Box(30));
  c.close();
  total := 0;
  for b in c {
    total = total + b.v;
  }
  // each Box instance pal_free'd at end of iteration → zero leak
  assert(total == 60, "forin user sum");
}

// `break` with items still buffered: received items dropped by the loop
// (the break path runs emitScopeCleanup(loopScopeDepth) which includes the
// loop variable), the buffered remainder dropped by Channel[string].drop
// (T0663). Disjoint windows → zero leak, no double-free.
chan_string_forin_break() `test {
  c := channel[string](capacity: 4);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  c.send(mk_str(4));
  // not closed — we break before draining
  count := 0;
  for s in c {
    count = count + s.len;
    if count >= 4 {
      break; // 2 received (dropped by loop), 2 remain buffered
    }
  }
  assert(count == 4, "forin break count");
  // 2 buffered remainder dropped by Channel[string].drop when c drops
}

// `continue` skips even iterations; the skipped loop variable must still be
// dropped via the continue path's emitScopeCleanup(loopScopeDepth).
chan_string_forin_continue() `test {
  c := channel[string](capacity: 4);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  c.send(mk_str(4));
  c.close();
  kept := 0;
  i := 0;
  for s in c {
    i = i + 1;
    if i % 2 == 0 {
      continue; // s dropped here via continue cleanup, not end-of-body
    }
    kept = kept + s.len;
  }
  assert(kept == 4, "forin continue kept"); // items 1 and 3 → 2+2
  // all 4 received dropped (via continue or normal end) → zero leak
}

// `for _ in c`: heap elements are still moved out of the ring buffer, so the
// discard binding must still be dropped (unlike genForInVector's container-
// retains-ownership dup-skip). Zero leak.
chan_string_forin_discard() `test {
  c := channel[string](capacity: 3);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  c.close();
  n := 0;
  for _ in c {
    n = n + 1;
  }
  assert(n == 3, "forin discard count");
}

// Body moves the loop variable into a Vector[string] (push). The move-site
// clearDropFlag zeros the per-iteration drop flag so the loop does NOT drop
// it; the vector owns the strings and Vector[string].drop frees them. No
// double-free, no leak.
chan_string_forin_move() `test {
  c := channel[string](capacity: 3);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  c.close();
  dst := Vector[string]();
  for s in c {
    dst.push(s); // moves s → drop flag cleared → loop skips drop
  }
  assert(dst.len == 3, "forin move count");
  assert(dst[0] == "v1", "forin move first");
  // dst owns the 3 strings → Vector[string].drop frees them at scope exit
}

// Failable helper returns out of the for-in loop mid-drain. The in-flight loop
// variable is dropped via function unwind (emitScopeCleanup(0) at the return),
// the buffered remainder by Channel[string].drop when the caller's c drops.
drain_until!(channel[string] c, int limit) int {
  total := 0;
  for s in c {
    total = total + s.len;
    if total >= limit {
      return total; // s dropped via function unwind
    }
  }
  return total;
}

chan_string_forin_early_return() `test {
  c := channel[string](capacity: 4);
  c.send(mk_str(1));
  c.send(mk_str(2));
  c.send(mk_str(3));
  c.send(mk_str(4));
  // not closed; helper returns after the byte limit (2 items) is reached
  r := drain_until(c, 4)?!;
  assert(r == 4, "forin early return total");
  // 2 received dropped (1 end-of-iter, 1 via return unwind); 2 buffered
  // remainder dropped by Channel[string].drop when c drops in this scope
}

// ----------------------------------------------------------------------------
// T0671 /coverage gaps: the 8 tests above all run the for-in in the
// thread-blocking (non-coroutine) path with at least one iteration. The
// genForInChannel fix also reasons explicitly about (a) the goroutine
// (`c.inCoroutine`) path — where the per-iteration drop binding coexists with
// coro.suspend / cleanup blocks — and (b) the zero-iteration closed+empty path
// (recvNone → exitBlock; loop-var binding popped at codegen time → "no spurious
// drop, no uninitialized read"). Neither was exercised by any test in the suite
// (all goroutine for-in channel consumers use Channel[int], a value element
// where maybeRegisterDrop no-ops). Added below; each leaked / was unverified
// pre-T0671 and is zero-leak post-fix.
// ----------------------------------------------------------------------------

// Goroutine-mode for-in over a heap-element channel: a worker drains a
// channel[string] via `for s in jobs` *inside* a `go {}` block, exercising
// genForInChannel's c.inCoroutine branch (park on recv_waiters + coro.suspend).
// The per-iteration drop binding must still drop each received string across
// suspend/resume. Joined deterministically via `done` so the leak check is
// stable. Mirrors goroutine_workpool.pr's pattern but with a heap element.
chan_string_forin_goroutine_drain() `test {
  jobs := channel[string](capacity: 6);
  done := channel[int](capacity: 1);
  for i in 0..6 {
    jobs.send(mk_str(i));
  }
  jobs.close();
  go {
    total := 0;
    for s in jobs {
      total = total + s.len; // s borrowed; loop drops s each iteration
    }
    done.send(total);
  };
  r := <-done; // join: unblocks only after the goroutine fully drains jobs
  if v := r {
    assert(v == 12, "goroutine forin drained total"); // 6 strings x len 2
  }
  // every received string dropped per-iteration inside the coroutine; jobs
  // drained empty → Channel[string].drop walks nothing → zero leak, no dbl-free
}

// Zero-iteration: for-in over an already-closed, never-sent channel[string].
// recv.check sees count==0 && closed → recvNone → unlock → exitBlock; bodyBlock
// is never entered, and the loop-var drop binding is popped from scopeBindings
// at codegen time. Must NOT drop the uninitialized elemAlloca (no spurious
// string_drop on garbage) and must not leak.
chan_string_forin_closed_empty() `test {
  c := channel[string](capacity: 2);
  c.close(); // closed, nothing ever sent
  n := 0;
  for s in c {
    n = n + s.len; // unreachable — 0 iterations
  }
  assert(n == 0, "forin closed-empty zero iterations");
  // no body entered, no spurious drop of an uninitialized alloca, no leak
}

// Ref[int] element: for-in drains a channel[Ref[int]]. Each loop variable is
// an Arc handle; the per-iteration drop must run Ref[int].drop (atomic refcount
// decrement → frees the control block at 0), a distinct drop path from the
// string/Vector/user-heap cases above. Zero leak (every handle is the last ref).
chan_arc_forin_drained() `test {
  c := channel[Ref[int]](capacity: 3);
  c.send(Ref[int](7));
  c.send(Ref[int](8));
  c.send(Ref[int](9));
  c.close();
  total := 0;
  for a in c {
    total = total + a.borrow; // a.borrow reads inner int; a dropped each iter
  }
  assert(total == 24, "forin arc sum");
  // each Ref[int] handle dropped per-iteration (refcount 1→0) → zero leak
}
