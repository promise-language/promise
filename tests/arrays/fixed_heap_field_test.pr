test_let_then_scope_exit_bare() `test {
  _Bare[2] arr = [_Bare(x: 1), _Bare(x: 2)];
  _Bare x = arr[0];
  assert(x.x == 1, "x intact");
}

// Vector let-then-scope-exit (the 16-test set covered slot-to-slot and
// let-then-overwrite but not this form).
test_let_then_scope_exit_vector() `test {
  Vector[int] v0 = Vector[int]();
  v0.push(7);
