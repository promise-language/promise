// Test the io module (compiled as part of the module).
// flaky leak — sometimes leaks depending on timing
strerror_known_codes() `test {
  assert(_io_strerror(1) == "operation not permitted", "errno 1");
  assert(_io_strerror(2) == "no such file or directory", "errno 2");
  assert(_io_strerror(13) == "permission denied", "errno 13");
  assert(_io_strerror(22) == "invalid argument", "errno 22");
}

strerror_unknown_code() `test {
  string msg = _io_strerror(9999);
  assert(msg == "I/O error (errno 9999)", "unknown errno fallback");
}

make_io_error_test() `test {
  IoError e = _make_io_error(-2);
  assert(e.code == 2, "io error code from -errno");
  assert(e.message == "no such file or directory", "io error message");
}

file_create_exists_remove() `test(exclude: wasm) {
  if File.exists("/tmp/pr_iot_cer") {
    File.remove("/tmp/pr_iot_cer")?!;
  }
  File f = File.create("/tmp/pr_iot_cer")?!;
  f.close()?!;
  assert(File.exists("/tmp/pr_iot_cer"), "file exists after create");
  File.remove("/tmp/pr_iot_cer")?!;
  assert(!File.exists("/tmp/pr_iot_cer"), "file gone after remove");
}

