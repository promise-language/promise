test_execute_invalid_cwd() `test(exclude: wasm) `target(!windows) {
  // Nonexistent cwd → child exits 127 (chdir fails in child)
  ProcessResult result = execute("true", [], working_directory: "/nonexistent_dir_promise_test")?!;
  assert(result.exit_code == 127, "invalid cwd should cause exit 127");
}

test_execute_none_env_inherits() `test(exclude: wasm) `target(!windows) {
  // Absent env = inherit parent (default behavior)
  set_env_var("PROMISE_TEST_INHERIT", "should_see");
  ProcessResult result = execute("sh", ["-c", "echo $PROMISE_TEST_INHERIT"])?!;
  assert(result.exit_code == 0, "sh should exit with 0");
  assert(result.stdout.trim() == "should_see", "absent env should inherit parent vars");
  string? absent;
  set_env_var("PROMISE_TEST_INHERIT", move absent);
}

test_execute_none_cwd_inherits() `test(exclude: wasm) `target(!windows) {
  // Absent cwd = inherit parent cwd (default behavior)
  string original = working_dir?!;
  set_working_dir("/usr")?!;
  ProcessResult result = execute("pwd", [])?!;
  assert(result.exit_code == 0, "pwd should exit with 0");
  assert(result.stdout.trim() == "/usr", "absent cwd should inherit parent cwd");
  set_working_dir(original)?!;
}

test_spawn_custom_env() `test(exclude: wasm) `target(!windows) {
  map[string, string] custom_env = map[string, string]();
  custom_env["PATH"] = "/usr/bin:/bin";
  custom_env["SPAWN_VAR"] = "from_spawn";
  Process p = Process.spawn("sh", ["-c", "echo $SPAWN_VAR"], environment: move custom_env)?!;
  ProcessOutput stdout = p.take_stdout()?!;
  string out = stdout.read_all()?!;
  int code = p.wait()?!;
  assert(code == 0, "sh should exit with 0");
  assert(out.trim() == "from_spawn", "streaming process should see custom env");
}

test_spawn_custom_cwd() `test(exclude: wasm) `target(!windows) {
  Process p = Process.spawn("pwd", [], working_directory: "/usr")?!;
  ProcessOutput stdout = p.take_stdout()?!;
  string out = stdout.read_all()?!;
  int code = p.wait()?!;
  assert(code == 0, "pwd should exit with 0");
  assert(out.trim() == "/usr", "streaming process should run in /usr");
}

_read_one_byte(Reader ~r) u8? {
  return r.read_byte();
}

test_process_output_read_byte() `test(exclude: wasm) `target(!windows) {
  // read_byte() is a non-failable default method on Reader — must be called via Reader type.
  // Returns u8? (present with value, or absent at EOF).
  Process p = Process.spawn("printf", ["AB"])?!;
  ProcessOutput stdout = p.take_stdout()?!;
  u8? b1 = _read_one_byte(stdout);
  u8? b2 = _read_one_byte(stdout);
  int code = p.wait()?!;
  assert(code == 0, "printf should exit with 0");
  assert(b1 is present, "first read_byte should return 'A'");
  assert(b2 is present, "second read_byte should return 'B'");
  if a := b1 {
    assert(a == 65u8, "first byte should be 65 (A)");
  }
  if b := b2 {
    assert(b == 66u8, "second byte should be 66 (B)");
  }
}

test_process_spawn_echo_windows() `test(exclude: wasm) `target(windows) {
  // Guards pal_spawn_streaming_env success path on Windows (was a -1 stub pre PR #1).
  Process p = Process.spawn("cmd", ["/c", "echo hello"])?!;
  ProcessOutput stdout = p.take_stdout()?!;
  string out = stdout.read_all()?!;
  int code = p.wait()?!;
  assert(code == 0, "cmd /c echo should exit 0");
  assert(out.starts_with("hello"), "stdout should contain hello");
}

test_process_spawn_stdin_windows() `test(exclude: wasm) `target(windows) {
  // Exercises the streaming-stdin path that crashed pre-T0904: pal_pipe_write
  // (WriteFile) and pal_pipe_close (CloseHandle) on a raw Win32 HANDLE. Routing
  // these through UCRT _write/_close aborts the process. `sort` reads all of
  // stdin, sorts the lines, and echoes them back, so it round-trips stdin→stdout.
  Process p = Process.spawn("sort", [])?!;
  ProcessInput stdin = p.take_stdin()?!;
  ProcessOutput stdout = p.take_stdout()?!;

  stdin.write_string("hello from stdin")?!; // WriteFile on the HANDLE
  stdin.close()?!; // CloseHandle on the HANDLE — the crash site

  string out = stdout.read_all()?!;
  int code = p.wait()?!;
  assert(code == 0, "sort should exit with 0");
  assert(out.starts_with("hello from stdin"), "sort should echo the single stdin line");
}

test_process_spawn_exit_code_windows() `test(exclude: wasm) `target(windows) {
  Process p = Process.spawn("cmd", ["/c", "exit 7"])?!;
  int code = p.wait()?!;
  assert(code == 7, "exit code should surface from streaming spawn");
}

test_process_spawn_custom_env_windows() `test(exclude: wasm) `target(windows) {
  // Guards emitEnvpToBlock inside EmitSpawnStreamingEnv.
  map[string, string] custom_env = env;
  custom_env["PROMISE_TEST_SPAWN_WIN_VAR"] = "spawn_custom_value";
  Process p = Process.spawn("cmd", ["/c", "echo %PROMISE_TEST_SPAWN_WIN_VAR%"],
  environment: move custom_env)?!;
  ProcessOutput stdout = p.take_stdout()?!;
  string out = stdout.read_all()?!;
  int code = p.wait()?!;
  assert(code == 0, "cmd /c echo should exit 0");
  assert(out.trim() == "spawn_custom_value", "streaming spawn should see custom env");
}

test_process_spawn_custom_cwd_windows() `test(exclude: wasm) `target(windows) {
  // Guards lpCurrentDirectory in EmitSpawnStreamingEnv.
  Process p = Process.spawn("cmd", ["/c", "cd"], working_directory: "C:\\Windows")?!;
  ProcessOutput stdout = p.take_stdout()?!;
  string out = stdout.read_all()?!;
  int code = p.wait()?!;
  assert(code == 0, "cmd /c cd should exit 0");
  assert(out.trim() == "C:\\Windows", "streaming spawn should run in C:\\Windows");
}

test_process_spawn_nonexistent_windows() `test(exclude: wasm) `target(windows) {
  // On Windows, CreateProcessA fails immediately for nonexistent programs.
  bool raised = false;
  Process.spawn("__promise_no_such_program__", [])? e {
    raised = true;
  };
  assert(raised, "spawn of nonexistent program should raise on Windows");
}

test_process_stdin_write_windows() `test(exclude: wasm) `target(windows) {
  // T0900: exercises the streaming pipe WRITE + CLOSE bridges on Windows
  // (pal_pipe_write/pal_pipe_close via WriteFile/CloseHandle, not UCRT _write/_close).
  // findstr "^" matches every input line and echoes it to stdout.
  Process p = Process.spawn("findstr", ["^"])?!;
  ProcessInput stdin = p.take_stdin()?!;
  ProcessOutput stdout = p.take_stdout()?!;

  stdin.write_line("hello from stdin")?!;
  stdin.close()?!;

  string out = stdout.read_all()?!;
  int code = p.wait()?!;
  assert(code == 0, "findstr should exit with 0");
  assert(out.trim() == "hello from stdin", "findstr should echo stdin to stdout");
}

test_process_streaming_read_windows() `test(exclude: wasm) `target(windows) {
  // T0900: exercises incremental pipe READ on Windows (pal_pipe_read via ReadFile,
  // not UCRT _read), including the ERROR_BROKEN_PIPE → EOF mapping at child exit.
  Process p = Process.spawn("cmd", ["/c", "for /L %i in (1,1,100) do @echo %i"])?!;
  ProcessOutput stdout = p.take_stdout()?!;

  Builder b = Builder();
  u8[] buf = u8[].filled(0u8, 4096);
  while true {
    int n = stdout.read(buf)?!;
    if n == 0 {
      break;
    }
    b.write_string(string.from_bytes(buf[0:n]));
  }
  string total = b.to_string();

  int code = p.wait()?!;
  assert(code == 0, "cmd for-loop should exit with 0");
  assert(total.trim().starts_with("1"), "should start with 1");
  assert(total.contains("100"), "should contain 100");
}
