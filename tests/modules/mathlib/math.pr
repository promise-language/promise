// mathlib: a test module exercising functions, types, enums, generics, failables, and drop.
// --- Public functions ---
add(int a, int b) int `public {
  return a + b;
}

square(int x) int `public {
  return x * x;
}

greet(string name) string `public {
  return "hello " + name;
}

// --- Public type with methods ---

type Vec2 `public {
  int x;
  int y;

  sum(this) int {
    return this.x + this.y;
  }

  scale(~this, int factor) {
    this.x = this.x * factor;
    this.y = this.y * factor;
  }

  to_string(this) string {
    return "({this.x}, {this.y})";
  }
}

// --- Public enum with methods ---

enum Color `public {
  Red,
  Green,
  Blue,

  name(this) string `public {
    return match this {
      Color.Red => "red",
      Color.Green => "green",
      Color.Blue => "blue",
    };
  }

  is_primary(this) bool `public {
    return true;
  }

  get index int `public {
    return match this {
      Color.Red => 0,
      Color.Green => 1,
      Color.Blue => 2,
    };
  }
}

color_name(Color c) string `public {
  return c.name();
}

// --- Public enum with payload fields ---

enum Shape `public {
  Circle(int radius),
  Rect(int w, int h),
  Point,
}

// T1131: public recursive container-bearing enum with NO `clone — exercises
// the module synthesized-recursive-clone path. Stored in an outer Map and read
// back via `m[k]!`, the read-back must deep-clone via the compiler-synthesized
// recursive clone (`enumNeedsSynthClone`); the gate in typeNeedsMatchDup must
// fire even though Map[K,V].[] (std-owned) compiles before mathlib declares
// ModTree.clone. JsonValue cannot cover this path because it ships an explicit
// `clone (so enumNeedsSynthClone returns false for it).
enum ModTree `public `doc("Recursive binary-ish tree: a leaf int or a branch holding child trees.") {
  Leaf(int v),
  Branch(ModTree[] kids),
}

// T1131: Map-indirected recursive module enum (no `clone) — mirrors ModTree
// but with the recursion routed through a Map field instead of a Vector, to
// cover the Map-bearing-variant synthesized-clone path across the module
// boundary as well.
enum ModTreeM `public `doc("Recursive tree whose children live in a Map keyed by int.") {
  Empty,
  Node(int v, Map[int, ModTreeM] children),
}

// --- Public generic type ---

type Pair[A, B] `public {
  A first;
  B second;
}

// --- Public failable function ---

safe_divide!(int a, int b) int `public {
  if b == 0 {
    raise error(message: "division by zero");
  }
  return a / b;
}

// --- Public type with drop ---

type Resource `public {
  int id;

  drop(~this) {
  }
}

// T0552: public enum with droppable variant data, used cross-module as a
// field type. Exercises forwardDeclareModuleEnumDrop in emitFieldDropsFor —
// the holder's synth drop body must forward-declare and call this enum's
// drop function when the holder lives in another module.
enum _T0552DropEnum `public {
  Has(Resource r),
  Empty,
}

// --- Public generic functions ---

identity[T](T x) T `public {
  return x;
}

wrap[T](T x) T[] `public {
  T[] result = [x];
  return result;
}

safe_identity![T](T x) T `public {
  return x;
}

// --- Private function (not exported) ---

_internal_helper() int {
  return 999;
}

// --- T0406: tuple-by-value param coverage for module sites ---
// Site 2 (defineModuleFuncs): module free function with droppable tuple param.
take_tuple_in_module((string, int) t) `public {
  // Body intentionally minimal — the test asserts no leak at scope exit.
}

// Site 3 (defineModuleTypeMethods): non-generic method on a module type
// with droppable tuple param.
type TupleConsumer `public {
  int last_n;
  consume_pair((string, int) p) `public {
    (_s, n) := p;
    this.last_n = n;
  }
}

// --- T0468: generic type defined in a module that inherits drop from another
// generic type defined in the same module. Used by tests to verify the
// inherited-drop synthesis runs through the module-compile pipeline path
// (declareMonoInheritedDrops with c.compilingModule != "").
type _T0468ModLogger[T] `public {
  T val;
  drop(~this) {
  }
}

type _T0468ModBox[T] is _T0468ModLogger[T] `public {
  string label;
}

// --- T0507: non-generic type defined in a module that inherits drop from a
// non-generic parent. Exercises the module-compile variant of the T0507
// inherited-drop synthesis (declareInheritedModuleDrops /
// defineInheritedModuleDrops with c.compilingModule != "").
//
// Parent has a heap field (string marker) so the T0507 chain exercises both
// the parent's user-drop auto-appending its own field drop (T0553) and the
// synthesized child drop dropping its own heap field.
type _T0507ModLogger `public {
  string marker;
  drop(~this) {
  }
}

type _T0507ModBox is _T0507ModLogger `public {
  string label;
}

// --- T0553: module-defined non-generic type with a user-written empty drop
// body and a heap field. Exercises the auto-append of field drops at the end
// of a user-written drop body in defineModuleTypeMethods.
type _T0553ModBase `public {
  string s;
  drop(~this) {
  }
}

// T0553 follow-up: module type with a non-empty user drop body alongside a
// heap field. Verifies the auto-append of field drops runs AFTER the user's
// body, not just for empty bodies — defends against a refactor that only
// fires the auto-append when md.Body is empty.
type _T0553ModBaseBody `public {
  string s;
  int counter;
  drop(~this) {
    this.counter = this.counter + 1;
  }
}

// T0553 follow-up: module type with a Vector field + empty user drop body.
// Exercises the auto-append for a non-string heap field type — the field-drop
// path emits @Vector_int.drop instead of @promise_string_drop.
type _T0553ModBaseVec `public {
  int[] v;
  drop(~this) {
  }
}

// T1160: a module-qualified call (`mathlib.make_adder(5)`) reaches the closure
// call-result tracker with a MemberExpr callee whose "receiver" names a module,
// not a value. The alias filter must recognize that and still track the fresh env.
make_adder(int x)() -> int `public {
  return move || -> x + 1;
}

// NOTE (T1240): a module-level GETTER returning a closure (`get adder() -> int`)
// would reach the alias filter's getter arm with a module — not a value — as its
// target, the one combination the free-function call above does not exercise. It
// cannot be tested yet: any reference to such a getter panics codegen
// ("cannot resolve type for member access on <nil>"), because genMemberExpr's
// module-getter intercept decides "getter vs function reference" by asking whether
// the member's result type is a Signature. Pre-existing, unrelated to T1160. Add
// the test here once T1240 lands.

// A module type whose method hands back its own borrowed closure field — the
// alias filter must suppress tracking here (the holder's drop owns the env).
type CallbackBox `public {
  () -> int cb;
  get_cb(this)() -> int `public {
    return this.cb;
  }
}
