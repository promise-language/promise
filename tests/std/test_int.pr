// Test int arithmetic, comparisons, and unary operators
//
// TODO: test hash property
// TODO: test bitwise operators (&, |, ^, <<, >>) when implemented
// TODO: create separate test_uint.pr for unsigned integer types (uint, u8, u16, u32, u64)
test_addition() `test {
  assert(1 + 2 == 3, "1 + 2 == 3");
  assert(0 + 0 == 0, "0 + 0 == 0");
  assert(100 + 200 == 300, "100 + 200 == 300");
  assert(0 - 1 + 1 == 0, "-1 + 1 == 0");
}

test_subtraction() `test {
  assert(5 - 3 == 2, "5 - 3 == 2");
  assert(0 - 5 + 5 == 0, "0 - 5 + 5 == 0");
  assert(10 - 10 == 0, "10 - 10 == 0");
}

test_multiplication() `test {
  assert(3 * 4 == 12, "3 * 4 == 12");
  assert(0 * 100 == 0, "0 * 100 == 0");
  assert(7 * 1 == 7, "7 * 1 == 7");
  assert((0 - 2) * 3 == 0 - 6, "-2 * 3 == -6");
}

test_division() `test {
  assert(10 / 2 == 5, "10 / 2 == 5");
  assert(7 / 3 == 2, "7 / 3 == 2 (integer division)");
  assert(0 / 5 == 0, "0 / 5 == 0");
  assert((0 - 10) / 2 == 0 - 5, "-10 / 2 == -5");
}

test_modulo() `test {
  assert(10 % 3 == 1, "10 % 3 == 1");
  assert(15 % 5 == 0, "15 % 5 == 0");
  assert(7 % 2 == 1, "7 % 2 == 1");
}

test_comparisons() `test {
  assert(1 < 2, "1 < 2");
  assert(!(2 < 1), "!(2 < 1)");
  assert(2 > 1, "2 > 1");
  assert(!(1 > 2), "!(1 > 2)");
  assert(1 <= 1, "1 <= 1");
  assert(1 <= 2, "1 <= 2");
  assert(2 >= 2, "2 >= 2");
  assert(3 >= 1, "3 >= 1");
}

test_equality() `test {
  assert(42 == 42, "42 == 42");
  assert(!(1 == 2), "!(1 == 2)");
  assert(1 != 2, "1 != 2");
  assert(!(5 != 5), "!(5 != 5)");
}

test_unary_negation() `test {
  int x = 5;
  assert(-x == 0 - 5, "-x == -5");
  assert(-(-x) == 5, "-(-x) == 5");
  assert(-0 == 0, "-0 == 0");
}

test_increment_decrement() `test {
  int x = 5;
  x++;
  assert(x == 6, "x++ makes 6");
  x--;
  assert(x == 5, "x-- makes 5");
  x--;
  assert(x == 4, "x-- makes 4");
}

test_compound_assignment() `test {
  int x = 10;
  x += 5;
  assert(x == 15, "+= 5");
  x -= 3;
  assert(x == 12, "-= 3");
  x *= 2;
  assert(x == 24, "*= 2");
  x /= 4;
  assert(x == 6, "/= 4");
  x %= 4;
  assert(x == 2, "%= 4");
}
