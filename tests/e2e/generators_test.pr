// 16. Body local + yield* delegate from vector. The underlying yield (inside
// genYieldDelegateVector) sees the vector binding in c.scopeBindings (added by
// the outer "v" declaration); the snapshot at the per-element yield carries it.
t0504_gen_yieldstar_with_local() stream[int] {
  int[] v = [1, 2, 3, 4, 5];
  yield * v;
}

test_t0504_yieldstar_with_local_break() `test {
  int seen = 0;
  for x in t0504_gen_yieldstar_with_local() {
    seen = seen + 1;
    if seen == 2 {
      break;
    }
  }
  assert(seen == 2, "should yield twice before break");
}

test_t0504_yieldstar_with_local_run() `test {
  int sum = 0;
  for x in t0504_gen_yieldstar_with_local() {
    sum = sum + x;
  }
  assert(sum == 15, "sum should be 15");
}

// 17. Nested generator inside body — for-in loop adds bindingGenerator to the snapshot.
t0504_inner_gen() stream[int] {
  yield 10;
  yield 20;
  yield 30;
}

t0504_gen_nested() stream[int] {
  for y in t0504_inner_gen() {
    yield y;
  }
}

test_t0504_nested_break() `test {
  int seen = 0;
  for x in t0504_gen_nested() {
    seen = seen + 1;
    if seen == 2 {
      break;
    }
  }
  assert(seen == 2, "should reach second yield before break");
}

test_t0504_nested_run() `test {
  int sum = 0;
  for x in t0504_gen_nested() {
    sum = sum + x;
  }
  assert(sum == 60, "sum should be 60");
}

// 18. Failable generator with body local — both break (mid-flight) and raise (error path).
type T0504Err is error {
  string detail;
}

t0504_fail_gen!() stream[int] {
  string s = "x".to_string();
  yield 1;
  yield 2;
}

t0504_fail_gen_raise!() stream[int] {
  string s = "x".to_string();
  yield 1;
  raise T0504Err(message: "boom", detail: "mid");
}

t0504_call_fail_break!() int {
  for x in t0504_fail_gen()?^ {
    return x;
  }
  return 0;
}

t0504_call_fail_run!() int {
  int total = 0;
  for x in t0504_fail_gen()?^ {
    total = total + x;
  }
  return total;
}

t0504_call_fail_raise!() int {
  int total = 0;
  for x in t0504_fail_gen_raise()?^ {
    total = total + x;
  }
  return total;
}

test_t0504_failable_break() `test {
  int n = t0504_call_fail_break()?!;
  assert(n == 1, "break path should return 1");
}

test_t0504_failable_run() `test {
  int sum = t0504_call_fail_run()?!;
  assert(sum == 3, "full iteration should sum 1+2=3");
}

test_t0504_failable_raise() `test {
  bool caught = false;
  t0504_call_fail_raise()? e {
    caught = true;
  };
  assert(caught, "raise should propagate");
}

// 19. Body local + return mid-body — no regression: body-scope cleanup fires on
// return, no double-drop on consumer destroy at final suspend.
t0504_gen_return_mid_body() stream[int] {
  string s = "x".to_string();
  if true {
    return;
  }
  yield 1;
}

test_t0504_return_mid_body() `test {
  for x in t0504_gen_return_mid_body() {
  }
}

// 20. Use-bound body local (bindingClose) — exercises emitCloseCall on the
// per-yield cleanup path. The synthesized drop also calls pal_free on the heap
// instance (T0106), so this validates close + free together.
type T0504UseConn {
  int fd;
  close() {
  }
}

t0504_gen_use_bound() stream[int] {
  use c := T0504UseConn(fd: 7);
  yield 1;
  yield 2;
}

test_t0504_use_bound_break() `test {
  for x in t0504_gen_use_bound() {
    break;
  }
}

test_t0504_use_bound_run() `test {
  for x in t0504_gen_use_bound() {
  }
}

// 21. Heap user type without an explicit drop method (bindingFree) — the type
// has a droppable field (string), so codegen synthesizes a drop and registers
// bindingFree which pal_frees the instance + drops fields.
type T0504HeapNoDrop {
  int x;
  string label;
}

t0504_gen_heap_no_drop() stream[int] {
  T0504HeapNoDrop b = T0504HeapNoDrop(x: 1, label: "z".to_string());
  yield 1;
  yield 2;
}

test_t0504_heap_no_drop_break() `test {
  for x in t0504_gen_heap_no_drop() {
    break;
  }
}

test_t0504_heap_no_drop_run() `test {
  for x in t0504_gen_heap_no_drop() {
  }
}

// 22. Closure with captures (bindingFreeEnv) — the lambda's env struct is heap-
// allocated; the per-yield cleanup must free it on mid-flight destroy.
t0504_gen_closure() stream[int] {
  int n = 7;
  f := |int x| -> x + n;
  int r = f(3);
  yield r;
  yield r + 1;
}

test_t0504_closure_break() `test {
  for x in t0504_gen_closure() {
    break;
  }
}

test_t0504_closure_run() `test {
  int sum = 0;
  for x in t0504_gen_closure() {
    sum = sum + x;
  }
  assert(sum == 21, "10 + 11 = 21");
}

// 23. Mixed binding kinds in the same snapshot — string body local outside a
// for-in over a sub-generator. The yield inside the loop snapshots BOTH the
// outer bindingDropString and the inner bindingGenerator.
t0504_gen_mixed_kinds() stream[int] {
  string s = "outer".to_string();
  for y in t0504_inner_gen() {
    yield y;
  }
}

test_t0504_mixed_kinds_break() `test {
  int seen = 0;
  for x in t0504_gen_mixed_kinds() {
    seen = seen + 1;
    if seen == 2 {
      break;
    }
  }
  assert(seen == 2, "should reach second yield before break");
}

test_t0504_mixed_kinds_run() `test {
  int sum = 0;
  for x in t0504_gen_mixed_kinds() {
    sum = sum + x;
  }
  assert(sum == 60, "sum should be 60");
}

main() {
