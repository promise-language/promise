// T0741: Closure (function-value) ownership in aggregates.
//
// A closure is a fat pointer {fn, env} whose env is a heap struct that may
// itself own captured strings/vectors/nested closures. When a closure is stored
// in an aggregate (enum payload, struct field, optional, fixed array, tuple,
// vector) the aggregate becomes the sole owner of that env and must deep-drop it
// exactly once at the owner's drop. Before T0741 several aggregate kinds either
// skipped the env entirely (leak) or shallow-freed it (captured values leaked).
//
// These are construct-and-drop leak guards (zero-leak enforced) plus the
// double-free guard for the fixed-array-literal claim path. Each loops 30x so a
// per-iteration leak shows up as a 30+ allocation delta.
//
// T0812: escape-then-invoke with a *heap-capturing* closure read back out of an
// aggregate field into a local (e.g. `f := h.cb; f()`) is now memory-safe. The
// read aliases (borrows) the aggregate's heap env rather than registering an
// owning env-free binding for the local, so the env is freed exactly once by the
// aggregate's own drop. See the "escape-then-invoke (T0812)" section below.
//
// T0816: the borrow's lifetime is now enforced by ownership. The local bound by
// `f := h.cb` (struct/optional field or container element) is Borrowed AND holds
// a shared borrow on the source aggregate's root, so the unsound escapes are
// rejected at compile time (no runtime test possible):
//   - returning it past the aggregate's lifetime (`return f;`) — UAF on escape;
//   - re-storing it into another owning aggregate (`CbHolder(cb: f)`) — double
//     free;
//   - moving/consuming or reassigning the source while the local is still live
//     (`sink(h)` / `h = ...`) — frees the env out from under the local (UAF).
// All compile-rejection cases are covered in the Go ownership tests (TestT0816*).
// Same-scope read-and-invoke below stays valid, and consuming the source after
// the local's last use stays valid via NLL narrowing.
enum Cb {
  holds(() -> int cb), empty,
}
enum OptCbEnum {
  holds((() -> int)? cb), empty,
}
type StructCb {
  () -> int cb;
}
type OptCb {
  (() -> int)? cb;
}
type ArrCb {
  (() -> int)[2] cbs;
}
type TupCb {
  (int, () -> int) pair;
}

// --- Enum payload (Part A) ---

enum_payload_no_capture() `test {
  i := 0;
  while i < 30 {
    c := Cb.holds(cb: || -> 1);
    i = i + 1;
  }
  assert(i == 30, "");
}

enum_payload_copy_capture() `test {
  i := 0;
  while i < 30 {
    n := i;
    c := Cb.holds(cb: move || -> n + 1);
    i = i + 1;
  }
  assert(i == 30, "");
}

enum_payload_heap_capture() `test {
  i := 0;
  while i < 30 {
    s := "enum" + " payload"; // heap string captured by move
    c := Cb.holds(cb: move || -> s.len);
    i = i + 1;
  }
  assert(i == 30, "");
}

optional_of_enum_with_closure() `test {
  i := 0;
  while i < 30 {
    s := "x" + "y";
    Cb? o = Cb.holds(cb: move || -> s.len);
    i = i + 1;
  }
  assert(i == 30, "");
}

vector_of_enum_with_closure() `test {
  i := 0;
  while i < 30 {
    v := Vector[Cb]();
    s := "vv" + "ww";
    v.push(Cb.holds(cb: move || -> s.len)); // enum-with-closure moved into vector
    i = i + 1;
  }
  assert(i == 30, "");
}

// Optional closure as an *enum variant payload* `(() -> int)?` — exercises
// emitOptionalValueDrop's Signature case reached via emitVariantFieldDrop's
// optional branch in the synthesized enum drop. Some-case (heap capture) and
// none-case (no env), both leak-free.
enum_variant_optional_closure_some() `test {
  i := 0;
  while i < 30 {
    s := "a" + "b";
    e := OptCbEnum.holds(cb: move || -> s.len);
    i = i + 1;
  }
  assert(i == 30, "");
}

enum_variant_optional_closure_none() `test {
  i := 0;
  while i < 30 {
    OptCbEnum e = OptCbEnum.holds(cb: none);
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- Struct closure field (Part B) ---

struct_field_heap_capture() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    h := StructCb(cb: move || -> s.len); // struct owns env + captured string
    i = i + 1;
  }
  assert(i == 30, "");
}

struct_field_no_capture() `test {
  i := 0;
  while i < 30 {
    h := StructCb(cb: || -> 7);
    i = i + 1;
  }
  assert(i == 30, "");
}

struct_field_copy_only_capture() `test {
  i := 0;
  while i < 30 {
    n := i;
    h := StructCb(cb: move || -> n + 1);
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- Optional / array closure struct field (Part C) ---

optional_closure_field() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    h := OptCb(cb: move || -> s.len);
    i = i + 1;
  }
  assert(i == 30, "");
}

// Local `Optional[closure]` binding (not a struct field) — exercises the
// optional binding's drop path directly via emitOptionalValueDrop's Signature
// case, independent of OptCb's field drop.
local_optional_closure_binding() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    (() -> int)? o = move || -> s.len;
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: Force-unwrap a LOCAL optional closure into a new local (`f := o!`) and
// invoke it. The unwrap transfers the heap env from `o` to `f`; `o`'s present
// flag is cleared so only `f` owns/frees the env. Heap-capturing closure.
unwrap_local_optional_closure() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    (() -> int)? o = move || -> s.len;
    f := o!;
    assert(f() == 8, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: drop-only path — `f := o!` with no invoke. Crashed identically on
// master (double-free of the env at scope exit), proving it is a drop/ownership
// bug, not an invoke bug.
unwrap_local_optional_closure_no_invoke() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    (() -> int)? o = move || -> s.len;
    f := o!;
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: reassign the local optional closure (case H) before unwrapping. The
// reassignment drops the old env and re-arms the drop flag; the new env is
// claimed by `o` and transferred to `f`.
reassign_local_optional_closure() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    t := "re" + "armed!";
    (() -> int)? o = move || -> s.len;
    o = move || -> t.len;
    f := o!;
    assert(f() == 8, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: move the local optional closure into another local (`g := o`) — the
// move clears `o`'s optional drop flag so only `g` owns the env. Invoke via `g`.
move_local_optional_closure() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    (() -> int)? o = move || -> s.len;
    g := o;
    f := g!;
    assert(f() == 8, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: `move`-captured int-only closure — a heap env that captures no heap
// data (the env-free path with a no-op env drop fn). Force-unwrap and invoke.
unwrap_local_optional_closure_int_capture() `test {
  i := 0;
  while i < 30 {
    n := 41;
    (() -> int)? o = move || -> n + 1;
    f := o!;
    assert(f() == 42, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: absent (`none`) typed optional closure — the optdrop binding is still
// registered for the Signature inner type, but with the present flag false the
// drop must skip the inner env free (no crash, no leak on an empty optional).
none_local_optional_closure() `test {
  i := 0;
  while i < 30 {
    (() -> int)? o = none;
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: conditionally-present optional closure — exercises the *runtime*
// present-flag branch in emitOptionalLocalValueDrop's Signature case: half the
// iterations `o` holds a heap env (drop frees it), half it stays `none` (skip).
conditional_local_optional_closure() `test {
  i := 0;
  while i < 30 {
    (() -> int)? o = none;
    if i % 2 == 0 {
      s := "cap" + "tured";
      o = move || -> s.len;
    }
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: reassign a *present* optional closure to `none` — the reassign must
// drop the old env (present=true old value) and leave the optional absent, so
// scope exit frees nothing more. Distinct from the present->present reassign.
reassign_local_optional_closure_to_none() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    (() -> int)? o = move || -> s.len;
    o = none;
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0814: closure capturing a *vector* (not a string) — force-unwrap and invoke.
// Exercises deep-drop of a non-string heap capture through the Signature env
// path (the env drop fn must release the captured vector's backing buffer).
unwrap_local_optional_closure_vector_capture() `test {
  i := 0;
  while i < 30 {
    v := [1, 2, 3];
    v.push(4);
    (() -> int)? o = move || -> v.len;
    f := o!;
    assert(f() == 4, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

array_closure_field() `test {
  i := 0;
  while i < 30 {
    s := "a" + "b";
    t := "c" + "d";
    h := ArrCb(cbs: [move || -> s.len, move || -> t.len]);
    i = i + 1;
  }
  assert(i == 30, "");
}

// Untyped `[...]` of closures — infers as Vector[() -> int] (genArrayLit), NOT a
// fixed array. Guards the vector-literal claim path (claimEnvTemp per element).
local_vector_literal_of_closures() `test {
  i := 0;
  while i < 30 {
    s := "a" + "b";
    arr := [move || -> s.len, || -> 2];
    i = i + 1;
  }
  assert(i == 30, "");
}

// Explicitly-typed local fixed-array binding of closures — the literal Part-A
// double-free guard: the LOCAL array binding's element drop (bindingDropArray)
// now fires, so genFixedArrayLit's claim site must claim each closure env
// exactly once (no `fatal: invalid free (bad header magic)`). Distinct drop
// site from the ArrCb struct field (array_closure_field, via arrayFieldNeedsDrop).
local_fixed_array_binding_of_closures() `test {
  i := 0;
  while i < 30 {
    s := "a" + "b";
    (() -> int)[2] arr = [move || -> s.len, || -> 2];
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- Tuple-nested closure ---

tuple_nested_closure_field() `test {
  i := 0;
  while i < 30 {
    s := "t" + "u";
    h := TupCb(pair: (3, move || -> s.len));
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- Vector[closure] literal + push + remove ---

vector_closure_literal_and_push() `test {
  i := 0;
  while i < 30 {
    s := "v" + "c";
    v := [move || -> s.len];
    t := "p" + "q";
    v.push(move || -> t.len);
    i = i + 1;
  }
  assert(i == 30, "");
}

vector_closure_remove() `test {
  i := 0;
  while i < 30 {
    s := "v" + "c";
    v := [move || -> s.len, || -> 7];
    v.remove(0); // removed element's env must be dropped, not leaked
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- Implicit dup of an enum-with-closure container (T0813 memory-safety guard) ---
//
// Duplicating a closure-containing aggregate is semantically meaningless (a
// closure env can't be deep-cloned). T0813 makes the *explicit* container
// clone()/filled() of such a type a compile error, but residual *implicit* dup
// paths (a vector slice `v[:]`) still reach the codegen element-clone loop. That
// path must NOT turn the pre-existing leak into a *double-free*: enabling closure
// drop in enum variants (Part A) means emitVariantFieldDup nulls the cloned
// variant's closure slot so only the source owns the env. This guards that the
// implicit dup neither crashes nor leaks (the source env is dropped once).
slice_vector_of_enum_with_closure_is_memory_safe() `test {
  i := 0;
  while i < 30 {
    s := "shared" + " env";
    v := Vector[Cb]();
    v.push(Cb.holds(cb: move || -> s.len));
    v2 := v[:]; // implicit dup: cloned variant's closure slot is nulled — no shared env
    assert(v.len == 1, "");
    assert(v2.len == 1, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- Implicit dup of a struct-with-closure-field container (T0813) ---
//
// The struct heap-user-type dup path (dupHeapValueFields, reached by a vector
// slice over a Vector[StructCb]) memcpy's the element instance, aliasing the
// closure field's env pointer into both vectors. The struct's synthesized drop
// frees that env, so on master this double-frees. T0813 nulls the cloned slot in
// dupHeapValueFields so the source keeps sole ownership (dropped exactly once).
// Guards that the implicit dup neither crashes (double-free) nor leaks.
slice_vector_of_struct_with_closure_is_memory_safe() `test {
  i := 0;
  while i < 30 {
    s := "shared" + " env";
    v := Vector[StructCb]();
    v.push(StructCb(cb: move || -> s.len));
    v2 := v[:]; // implicit dup: cloned struct's closure slot is nulled — no shared env
    assert(v.len == 1, "");
    assert(v2.len == 1, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- No-capture invoke (null env — has nothing to double-free) ---

invoke_no_capture_from_vector() `test {
  v := [|| -> 11, || -> 22];
  f := v[0];
  assert(f() == 11, "");
}

invoke_no_capture_from_optional_field() `test {
  h := OptCb(cb: || -> 9);
  f := h.cb!;
  assert(f() == 9, "");
}

invoke_no_capture_from_array_field() `test {
  h := ArrCb(cbs: [|| -> 4, || -> 8]);
  f := h.cbs[0];
  assert(f() == 4, "");
}

// --- escape-then-invoke (T0812) ---
//
// Read a *heap-capturing* closure out of an owning aggregate into a local, then
// invoke it. The read borrows the aggregate's heap env (no owning env-free
// binding for the local), so the aggregate's drop frees the env exactly once —
// no double-free / use-after-free. The leak-sensitive cases loop 30x so a
// per-iteration leak surfaces as a 30+ allocation delta (zero-leak enforced).

make_struct_cb(int n) StructCb {
  s := "cap" + "tured"; // heap string captured by the closure's env
  return StructCb(cb: move || -> s.len + n);
}

invoke_heap_capture_from_struct_field() `test {
  i := 0;
  while i < 30 {
    h := make_struct_cb(5);
    f := h.cb; // copies {fn,env}; f borrows h's env (no owning binding)
    assert(f() == 13, ""); // "captured".len (8) + 5
    i = i + 1;
  }
  assert(i == 30, "");
}

invoke_heap_capture_from_optional_field() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    h := OptCb(cb: move || -> s.len + 2);
    f := h.cb!; // force-unwrap of an optional closure field — still a borrow
    assert(f() == 10, ""); // 8 + 2
    i = i + 1;
  }
  assert(i == 30, "");
}

invoke_heap_capture_from_vector_index() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    v := [move || -> s.len + 1];
    f := v[0]; // container element read — borrows v's element env
    assert(f() == 9, ""); // 8 + 1
    i = i + 1;
  }
  assert(i == 30, "");
}

// Double-read of the same struct field — both locals borrow the single env, and
// only h's drop frees it. Before T0812 each local got an owning env-free binding,
// double-(triple-)freeing the env.
invoke_same_field_twice() `test {
  i := 0;
  while i < 30 {
    h := make_struct_cb(0);
    f := h.cb;
    g := h.cb;
    assert(f() == 8, ""); // "captured".len
    assert(g() == 8, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// move-captured int-only closure: the env is still heap-allocated (capturing any
// value forces a heap env) but holds no captured heap data. Reading it out and
// invoking exercises the env-only-heap double-free path.
invoke_copy_capture_from_struct_field() `test {
  i := 0;
  while i < 30 {
    n := 7;
    h := StructCb(cb: move || -> n + 100);
    f := h.cb;
    assert(f() == 107, "");
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0895: read a heap-capturing closure out of an aggregate into a *pre-declared*
// local via assignment (`f = h.cb`, vs the var-decl `f := h.cb` above). The
// assignment path borrows the aggregate's env exactly like the var-decl path
// (codegen clears f's env-free drop flag), so the env is freed once by h's drop —
// no double-free, no leak. Compile-rejection of the assignment-path escapes is
// covered by the Go ownership tests (TestT0895*).
read_and_invoke_via_assign() `test {
  i := 0;
  while i < 30 {
    h := make_struct_cb(5);
    () -> int f = || -> 0;
    f = h.cb; // assignment into a pre-declared local — borrows h's env
    assert(f() == 13, ""); // "captured".len (8) + 5
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0895: optional closure field force-unwrap into a *pre-declared* local via
// assignment (`f = h.cb!`). Exercises the OptionalUnwrapExpr peel arm of the
// assignment-path codegen (isClosureAggregateBorrow clears f's env-free flag) so
// the env is freed once by h's drop — memory-safe, no leak.
read_and_invoke_optional_via_assign() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    h := OptCb(cb: move || -> s.len + 2);
    () -> int f = || -> 0;
    f = h.cb!; // optional-field force-unwrap into a pre-declared local — borrows
    assert(f() == 10, ""); // 8 + 2
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0895: forced-cast optional unwrap into a pre-declared local via assignment
// (`f = h.cb as!(() -> int)`). Exercises the CastExpr.Force peel arm of the
// assignment-path codegen — memory-safe, no leak.
read_and_invoke_cast_via_assign() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    h := OptCb(cb: move || -> s.len + 3);
    () -> int f = || -> 0;
    f = h.cb as!(() -> int); // forced-cast unwrap into a pre-declared local
    assert(f() == 11, ""); // 8 + 3
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0895: container-element read into a pre-declared local via assignment
// (`f = v[0]`). Exercises the IndexExpr arm of the assignment-path codegen —
// f borrows v's element env, freed once by v's drop. Memory-safe, no leak.
read_and_invoke_vector_via_assign() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    v := [move || -> s.len + 1];
    () -> int f = || -> 0;
    f = v[0]; // container element into a pre-declared local — borrows v's env
    assert(f() == 9, ""); // 8 + 1
    i = i + 1;
  }
  assert(i == 30, "");
}

// T0895: owned-return boundary via assignment — a getter returning a *fresh*
// closure assigned into a pre-declared local must keep f's owning env-free
// binding (isClosureAggregateBorrow returns false for getters, so the drop flag
// is NOT cleared). f frees the fresh env exactly once — no leak, no double-free.
read_owned_getter_via_assign() `test {
  i := 0;
  while i < 30 {
    fac := CbFactory(base: 0);
    () -> int f = || -> 1;
    f = fac.build; // getter returns a fresh OWNED closure; f frees its env
    assert(f() == 7, ""); // "factory".len
    i = i + 1;
  }
  assert(i == 30, "");
}

// Forced cast of an optional closure field (`h.cb as! (() -> int)`) — the cast
// form of the optional-field unwrap. isClosureAggregateBorrow peels the forced
// CastExpr whose subject is an Optional, so this read is classified as a borrow
// exactly like the `h.cb!` form above. (Covers the CastExpr-peel branch.)
invoke_heap_capture_from_optional_field_as_cast() `test {
  i := 0;
  while i < 30 {
    s := "cap" + "tured";
    h := OptCb(cb: move || -> s.len + 3);
    f := h.cb as!(() -> int); // forced cast unwrap — borrows h's env
    assert(f() == 11, ""); // 8 + 3
    i = i + 1;
  }
  assert(i == 30, "");
}

// --- owned-return exclusions (T0812) ---
//
// A getter or user-defined `[]` that *returns a fresh closure by value* yields an
// OWNED closure the local must free — isClosureAggregateBorrow must NOT treat
// these as borrows (else the fresh env leaks). These confirm the local keeps its
// owning env-free binding and frees the env exactly once (zero-leak enforced).

type CbFactory {
  int base;
  // getter building a fresh heap-capturing closure each call
  get build() -> int {
    s := "fac" + "tory";
    return move || -> s.len;
  }
}

type CbIndexBox {
  int unused;
  // user-defined non-native `[]` building a fresh heap-capturing closure
  [](this, int k)() -> int {
    s := "ind" + "exed";
    return move || -> s.len + k;
  }
}

owned_closure_from_getter() `test {
  i := 0;
  while i < 30 {
    fac := CbFactory(base: 0);
    f := fac.build; // getter returns a fresh OWNED closure; f frees its env
    assert(f() == 7, ""); // "factory".len
    i = i + 1;
  }
  assert(i == 30, "");
}

owned_closure_from_user_index() `test {
  i := 0;
  while i < 30 {
    b := CbIndexBox(unused: 0);
    f := b[2]; // user `[]` returns a fresh OWNED closure; f frees its env
    assert(f() == 9, ""); // "indexed".len (7) + 2
    i = i + 1;
  }
  assert(i == 30, "");
}
