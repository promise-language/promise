// test_hash.pr — Tests for FNV-1a hash implementation

test_int_hash_deterministic() `test {
    int x = 42;
    assert(x.hash == x.hash, "same value same hash");
    int y = 42;
    assert(x.hash == y.hash, "equal values equal hash");
}

test_int_hash_different_values() `test {
    int a = 0;
    int b = 1;
    assert(a.hash != b.hash, "0 vs 1");
    int c = 100;
    assert(a.hash != c.hash, "0 vs 100");
    assert(b.hash != c.hash, "1 vs 100");
}

test_uint_hash() `test {
    uint x = 42;
    uint y = 42;
    assert(x.hash == y.hash, "equal uint same hash");
    uint z = 99;
    assert(x.hash != z.hash, "different uint different hash");
}

test_bool_hash() `test {
    bool t = true;
    bool f = false;
    assert(t.hash == t.hash, "true deterministic");
    assert(f.hash == f.hash, "false deterministic");
    assert(t.hash != f.hash, "true vs false");
}

test_char_hash() `test {
    char a = 'a';
    char b = 'b';
    assert(a.hash == a.hash, "char deterministic");
    assert(a.hash != b.hash, "a vs b");
}

test_string_hash() `test {
    string s = "hello";
    string t = "hello";
    assert(s.hash == t.hash, "equal strings same hash");
    string u = "world";
    assert(s.hash != u.hash, "different strings different hash");
}

test_hash_as_map_key() `test {
    // Verifies hash works end-to-end with map lookups
    map[int, int] m = {:};
    m[1] = 10;
    m[2] = 20;
    m[42] = 420;
    if v1 := m[1] { assert(v1 == 10, "m[1]"); } else { assert(false, "m[1] missing"); }
    if v2 := m[2] { assert(v2 == 20, "m[2]"); } else { assert(false, "m[2] missing"); }
    if v3 := m[42] { assert(v3 == 420, "m[42]"); } else { assert(false, "m[42] missing"); }
}

test_hash_zero() `test {
    int z = 0;
    // Hash of zero should be a valid non-zero hash (FNV-1a property)
    assert(z.hash != 0, "hash of 0 is non-zero");
}

test_negative_int_hash() `test {
    int neg = -1;
    int pos = 1;
    assert(neg.hash != pos.hash, "-1 vs 1");
    assert(neg.hash == neg.hash, "-1 deterministic");
}

test_large_values() `test {
    // Max/min boundaries should produce distinct hashes
    int big = 9223372036854775807;
    int small = -9223372036854775807;
    assert(big.hash != small.hash, "max vs min");
    assert(big.hash != 0.hash, "max vs 0");
    // Adjacent values should differ
    int a = 1000000;
    int b = 1000001;
    assert(a.hash != b.hash, "adjacent values");
}

test_expected_fnv1a_values() `test {
    // Pin exact FNV-1a 64-bit output to catch algorithmic drift
    assert(0.hash == -6284781860667377211, "fnv1a(0)");
    assert(1.hash == -8517097267634966620, "fnv1a(1)");
    assert(42.hash == -55488592825689361, "fnv1a(42)");
    int neg = -1;
    assert(neg.hash == -8289690350564177859, "fnv1a(-1)");
    int max_int = 9223372036854775807;
    assert(max_int.hash == -8289549613075766851, "fnv1a(max)");
}
