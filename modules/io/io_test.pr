// ── Dir.make_all ─────────────────────────────────────────────────────────────

dir_make_all_nested() `test(allow_leaks: true, exclude: "wasm32") {
  // Clean up first
  if Dir.exists("/tmp/pr_iot_mkall/a/b") {
    Dir.remove("/tmp/pr_iot_mkall/a/b")!;
  }
  if Dir.exists("/tmp/pr_iot_mkall/a") {
    Dir.remove("/tmp/pr_iot_mkall/a")!;
  }
  if Dir.exists("/tmp/pr_iot_mkall") {
    Dir.remove("/tmp/pr_iot_mkall")!;
  }

  Dir.make_all("/tmp/pr_iot_mkall/a/b")!;
  assert(Dir.exists("/tmp/pr_iot_mkall"), "top dir exists");
  assert(Dir.exists("/tmp/pr_iot_mkall/a"), "middle dir exists");
  assert(Dir.exists("/tmp/pr_iot_mkall/a/b"), "leaf dir exists");

  // Clean up
  Dir.remove("/tmp/pr_iot_mkall/a/b")!;
  Dir.remove("/tmp/pr_iot_mkall/a")!;
  Dir.remove("/tmp/pr_iot_mkall")!;
}

dir_make_all_existing() `test(allow_leaks: true, exclude: "wasm32") {
  if !Dir.exists("/tmp/pr_iot_mkall2") {
    Dir.make("/tmp/pr_iot_mkall2")!;
  }
  // Should not error on existing directory
  Dir.make_all("/tmp/pr_iot_mkall2")!;
  assert(Dir.exists("/tmp/pr_iot_mkall2"), "still exists after make_all on existing");
  Dir.remove("/tmp/pr_iot_mkall2")!;
}

// ── Dir.list ─────────────────────────────────────────────────────────────────

dir_list_basic() `test(allow_leaks: true, exclude: "wasm32") {
  // Create a directory with known files
  if !Dir.exists("/tmp/pr_iot_list") {
    Dir.make("/tmp/pr_iot_list")!;
  }
  File.write_content("/tmp/pr_iot_list/aaa.txt", "a")!;
  File.write_content("/tmp/pr_iot_list/bbb.txt", "b")!;

  string[] entries = Dir.list("/tmp/pr_iot_list")!;
  assert(entries.len >= 2, "at least 2 entries");

  // Check that our files are present (order may vary)
  bool found_a = false;
  bool found_b = false;
  int i = 0;
  while i < entries.len {
    if entries[i] == "aaa.txt" {
      found_a = true;
    }
    if entries[i] == "bbb.txt" {
      found_b = true;
    }
    i += 1;
  }
  assert(found_a, "aaa.txt in listing");
  assert(found_b, "bbb.txt in listing");

  // No . or .. in listing
  i = 0;
  while i < entries.len {
    assert(entries[i] != ".", "no dot entry");
    assert(entries[i] != "..", "no dotdot entry");
    i += 1;
  }

  // Clean up
  File.remove("/tmp/pr_iot_list/aaa.txt")!;
  File.remove("/tmp/pr_iot_list/bbb.txt")!;
  Dir.remove("/tmp/pr_iot_list")!;
}

dir_list_empty() `test(exclude: "wasm32") {
  if !Dir.exists("/tmp/pr_iot_list_e") {
    Dir.make("/tmp/pr_iot_list_e")!;
  }
  string[] entries = Dir.list("/tmp/pr_iot_list_e")!;
  assert(entries.len == 0, "empty dir has no entries");
  Dir.remove("/tmp/pr_iot_list_e")!;
}

dir_list_nonexistent() `test(exclude: "wasm32") {
  bool caught = false;
  Dir.list("/tmp/pr_iot_list_noexist")? e {
    caught = true;
  };
  assert(caught, "listing nonexistent dir raises error");
}

// ── read_line (via file fd) ──────────────────────────────────────────────────

read_line_from_file() `test(exclude: "wasm32") {
  File.write_content("/tmp/pr_iot_readline", "line1\nline2\nline3")!;
  File f = File.open("/tmp/pr_iot_readline", readonly: true)!;

  string line1 = _io_file_read_line(f._fd);
  int rc1 = _io_errno();
  assert(rc1 == 0, "no error on line1");
  assert(line1 == "line1", "first line");

  string line2 = _io_file_read_line(f._fd);
  int rc2 = _io_errno();
  assert(rc2 == 0, "no error on line2");
  assert(line2 == "line2", "second line");

  string line3 = _io_file_read_line(f._fd);
  int rc3 = _io_errno();
  assert(rc3 == 0, "no error on line3");
  assert(line3 == "line3", "third line (no trailing newline)");

  // EOF
  string line4 = _io_file_read_line(f._fd);
  int rc4 = _io_errno();
  assert(rc4 == _io_eof_sentinel(), "EOF sentinel after last line");

  f.close()!;
  File.remove("/tmp/pr_iot_readline")!;
}

read_line_crlf() `test(exclude: "wasm32") {
  File.write_content("/tmp/pr_iot_rlcrlf", "hello\r\nworld\r\n")!;
  File f = File.open("/tmp/pr_iot_rlcrlf", readonly: true)!;

  string line1 = _io_file_read_line(f._fd);
  int rc1 = _io_errno();
  assert(rc1 == 0, "no error on crlf line1");
  assert(line1 == "hello", "crlf line1 stripped");

  string line2 = _io_file_read_line(f._fd);
  int rc2 = _io_errno();
  assert(rc2 == 0, "no error on crlf line2");
  assert(line2 == "world", "crlf line2 stripped");

  f.close()!;
  File.remove("/tmp/pr_iot_rlcrlf")!;
}

read_line_empty_lines() `test(exclude: "wasm32") {
  File.write_content("/tmp/pr_iot_rlempty", "\n\nhello\n\n")!;
  File f = File.open("/tmp/pr_iot_rlempty", readonly: true)!;

  string l1 = _io_file_read_line(f._fd);
  assert(_io_errno() == 0, "e1");
  assert(l1 == "", "first empty line");

  string l2 = _io_file_read_line(f._fd);
  assert(_io_errno() == 0, "e2");
  assert(l2 == "", "second empty line");

  string l3 = _io_file_read_line(f._fd);
  assert(_io_errno() == 0, "e3");
  assert(l3 == "hello", "hello line");

  string l4 = _io_file_read_line(f._fd);
  assert(_io_errno() == 0, "e4");
  assert(l4 == "", "trailing empty line");

  string l5 = _io_file_read_line(f._fd);
  assert(_io_errno() == _io_eof_sentinel(), "EOF after trailing newline");

  f.close()!;
  File.remove("/tmp/pr_iot_rlempty")!;
}

read_line_empty_file() `test(exclude: "wasm32") {
  File.write_content("/tmp/pr_iot_rlef", "")!;
  File f = File.open("/tmp/pr_iot_rlef", readonly: true)!;
  string line = _io_file_read_line(f._fd);
  assert(_io_errno() == _io_eof_sentinel(), "EOF on empty file");
  f.close()!;
  File.remove("/tmp/pr_iot_rlef")!;
}

read_line_long_line() `test(exclude: "wasm32") {
  // Line longer than initial 256-byte buffer to test buffer growth
  string long = "";
  int i = 0;
  while i < 400 {
    long = long + "x";
    i += 1;
  }
  File.write_content("/tmp/pr_iot_rllong", long + "\n")!;
  File f = File.open("/tmp/pr_iot_rllong", readonly: true)!;
  string line = _io_file_read_line(f._fd);
  assert(_io_errno() == 0, "no error on long line");
  assert(line.len == 400, "long line length preserved");
  f.close()!;
  File.remove("/tmp/pr_iot_rllong")!;
}

read_line_single_no_newline() `test(allow_leaks: true, exclude: "wasm32") {
  File.write_content("/tmp/pr_iot_rlsingle", "onlythis")!;
  File f = File.open("/tmp/pr_iot_rlsingle", readonly: true)!;
  string line = _io_file_read_line(f._fd);
  assert(_io_errno() == 0, "no error");
  assert(line == "onlythis", "single line no trailing newline");
  // Next read should be EOF
  _io_file_read_line(f._fd);
  assert(_io_errno() == _io_eof_sentinel(), "EOF after single line");
  f.close()!;
  File.remove("/tmp/pr_iot_rlsingle")!;
}

