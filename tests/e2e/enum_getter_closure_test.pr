// T1096: an enum getter whose return type is a function type
// (`get adder() -> int` on an enum). This is the enum-path analog of the struct
// getter case (T1253, tests/e2e/instance_getter_function_test.pr). The ownership
// pass's closureAggregateBorrowSource used to only exclude struct (Named) getters
// from the closure-borrow classification, so an enum getter's fresh OWNED closure
// was falsely treated as a borrow — a returned local was rejected at compile time,
// diverging from codegen (which frees the env correctly). With the enum-getter arm
// restored, the local owns the closure and may be returned/bound/dropped.
//
// Every test relies on the zero-tolerance leak check to enforce that the
// materialized closure env is freed exactly once.
//
// NOTE: these tests exercise the getter *reference* form (`f := e.adder; f()`),
// which is what T1096 makes ownership-legal. The *direct*-call form `e.adder()`
// hits a separate, pre-existing codegen gap (the enum analog of T1253 gap #1) and
// is tracked independently as T1258 — do not add direct-call cases here until that
// bug is fixed.
enum E {
  A, B,
  // Getter returning a CAPTURING closure (env is heap-allocated).
  get adder() -> int `doc("Returns a closure capturing a local.") {
    int base = 41;
    return move || -> base + 1;
  }
}

// The exact repro: return the enum getter's closure from a helper, then invoke.
make_adder(E e)(() -> int) `doc("Returns the closure yielded by e.adder.") {
  f := e.adder;
  return f;
}

test_enum_getter_closure_returned() `test {
  e := E.A;
  f := make_adder(e);
  assert(f() == 42, "returned adder() should be 42");
}

// Bind-and-invoke in the same scope.
test_enum_getter_closure_bind_invoke() `test {
  e := E.B;
  f := e.adder;
  assert(f() == 42, "bound adder() should be 42");
}

// A capturing closure returned and dropped WITHOUT invocation — the leak check
// confirms the heap env is freed exactly once even though it is never called.
test_enum_getter_closure_dropped_uninvoked() `test {
  e := E.A;
  f := make_adder(e);
  // f is not invoked; it must still be freed at scope exit.
}

// Generic enum: exercises the *types.Instance origin path in extractEnumOrigin.
enum Box[T] {
  Empty, Full,
  get maker() -> int `doc("Returns a closure capturing a local.") {
    int base = 41;
    return move || -> base + 1;
  }
}

make_maker(Box[int] b)(() -> int) `doc("Returns the closure yielded by b.maker.") {
  f := b.maker;
  return f;
}

test_generic_enum_getter_closure_returned() `test {
  b := Box[int].Empty;
  f := make_maker(b);
  assert(f() == 42, "generic enum maker() should be 42");
}

test_generic_enum_getter_closure_bind_invoke() `test {
  b := Box[int].Full;
  f := b.maker;
  assert(f() == 42, "b.maker bound should be 42");
}

// Getter reached through a SHARED BORROW of the enum (`a.borrow.adder`, where
// `a.borrow` has type `E&`). This exercises the SharedRef-unwrapping arm of
// extractEnumOrigin: the receiver type is `*types.SharedRef` around the enum, so
// the plain `extractNamedType` check returns nil and the enum arm must recurse
// through the borrow to find the enum origin. Without that recursion the fresh
// OWNED closure would be misclassified as a borrow and returning it rejected —
// this is the exact codegen-lockstep gap T1096 restores for the borrowed-receiver
// shape.
use_arc_adder(Ref[E] a)(() -> int) `doc("Returns the closure yielded by a.borrow.adder.") {
  f := a.borrow.adder;
  return f;
}

test_enum_getter_closure_via_borrow_returned() `test {
  a := Ref[E](E.A);
  f := use_arc_adder(a);
  assert(f() == 42, "adder() via Ref borrow should be 42");
}

// Same borrowed-receiver shape, dropped without invocation — the leak check
// confirms the heap env is freed exactly once through the borrow path too.
test_enum_getter_closure_via_borrow_dropped_uninvoked() `test {
  a := Ref[E](E.B);
  f := use_arc_adder(a);
  // f is not invoked; it must still be freed at scope exit.
}
