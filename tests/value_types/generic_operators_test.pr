// B0224: Operator methods on generic value types.
type Pair[T: Equal] {
  T a `value;
  T b `value;

  == (Pair[T] other) bool => this.a == other.a && this.b == other.b;
  != (Pair[T] other) bool => !(this == other);
}

test_generic_value_eq() `test {
  p := Pair[int](a: 1, b: 2);
  q := Pair[int](a: 1, b: 2);
  assert(p == q, "equal pairs should be equal");
}

test_generic_value_neq() `test {
  p := Pair[int](a: 1, b: 2);
  q := Pair[int](a: 3, b: 4);
  assert(p != q, "different pairs should not be equal");
  assert(!(p == q), "negated == should match !=");
}

test_generic_value_string_eq() `test {
  p := Pair[string](a: "hello", b: "world");
  q := Pair[string](a: "hello", b: "world");
  assert(p == q, "equal string pairs should be equal");
}

test_generic_value_string_neq() `test {
  p := Pair[string](a: "hello", b: "world");
  q := Pair[string](a: "goodbye", b: "world");
  assert(p != q, "different string pairs should not be equal");
}
