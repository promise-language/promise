// Tests for os module: env vars, working dir, exit, args, executable_path, execute.
test_get_env_var_path() `test(exclude: wasm) {
  string? path = get_env_var("PATH");
  assert(path is present, "PATH should be present");
}

test_get_env_var_home() `test(exclude: wasm) `target(!windows) {
  string? home = get_env_var("HOME");
  assert(home is present, "HOME should be present");
  if h := home {
    assert(h.len > 0, "HOME should be non-empty");
  }
}

test_get_env_var_home() `test(exclude: wasm) `target(windows) {
  string? home = get_env_var("USERPROFILE");
  assert(home is present, "USERPROFILE should be present");
  if h := home {
    assert(h.len > 0, "USERPROFILE should be non-empty");
  }
}

test_get_env_var_absent() `test(exclude: wasm) {
  string? val = get_env_var("PROMISE_NONEXISTENT_VAR_12345");
  assert(val is absent, "absent variable returns none");
}

test_get_env_var_unwrap() `test(exclude: wasm) {
  string? path = get_env_var("PATH");
  if p := path {
    assert(p.len > 0, "PATH value should be non-empty");
  } else {
    assert(false, "PATH should be present");
  }
}

test_get_env_var_empty_value() `test(exclude: wasm) {
  // Test that a present env var can be unwrapped and compared.
  // Use PATH which is guaranteed present on all platforms.
  string? path = get_env_var("PATH");
  if p := path {
    assert(p == p, "unwrapped env var should equal itself");
  } else {
    assert(false, "PATH should be present");
  }
}

test_working_dir_is_stable() `test(exclude: wasm) {
  string cwd1 = working_dir?!;
  string cwd2 = working_dir?!;
  assert(cwd1 == cwd2, "reading working_dir twice should return the same value");
}

test_working_dir_nonempty() `test(exclude: wasm) {
  string cwd = working_dir?!;
  assert(cwd.len > 0, "working directory should be non-empty");
}

test_working_dir_absolute() `test(exclude: wasm) {
  string cwd = working_dir?!;
  // On POSIX: starts with "/". On Windows: drive letter like "C:\".
  bool is_abs = cwd.starts_with("/") || (cwd.len >= 3 && cwd[1] == ':');
  assert(is_abs, "working directory should be absolute path");
}

test_temp_dir_nonempty() `test(exclude: wasm) {
  string tmp = temp_dir;
  assert(tmp.len > 0, "temp directory should be non-empty");
}

test_temp_dir_no_trailing_separator() `test(exclude: wasm) {
  string tmp = temp_dir;
  // The getter strips a single trailing '/' or '\' so callers append uniformly.
  bool trailing = tmp.ends_with("/") || tmp.ends_with("\\");
  assert(!trailing, "temp directory should not end with a path separator");
}

test_temp_dir_is_stable() `test(exclude: wasm) {
  string t1 = temp_dir;
  string t2 = temp_dir;
  assert(t1 == t2, "reading temp_dir twice should return the same value");
}

// --- temp_dir internals (T0930) ---
// The env-derived temp dir on a typical runner has no trailing separator, so
// these exercise _strip_trailing_sep's stripping/empty/lone-separator branches
// directly, and drive _temp_dir_lookup's env-present and fallback branches via
// controlled environment state (restored before asserting so a failed assert
// cannot leak env mutations into later tests in this binary).

test_strip_trailing_sep_forward_slash() `test(exclude: wasm) {
  assert(_strip_trailing_sep("/tmp/") == "/tmp", "trailing '/' should be stripped");
}

test_strip_trailing_sep_backslash() `test(exclude: wasm) {
  assert(_strip_trailing_sep("C:\\Temp\\") == "C:\\Temp", "trailing '\\' should be stripped");
}

test_strip_trailing_sep_no_separator() `test(exclude: wasm) {
  assert(_strip_trailing_sep("/tmp") == "/tmp", "POSIX path without trailing separator is unchanged");
  assert(_strip_trailing_sep("C:\\Temp") == "C:\\Temp", "Windows path without trailing separator is unchanged");
}

test_strip_trailing_sep_empty() `test(exclude: wasm) {
  assert(_strip_trailing_sep("") == "", "empty string is unchanged");
}

test_strip_trailing_sep_lone_separator() `test(exclude: wasm) {
  assert(_strip_trailing_sep("/") == "", "lone '/' becomes empty");
  assert(_strip_trailing_sep("\\") == "", "lone '\\' becomes empty");
}

test_strip_trailing_sep_removes_one_only() `test(exclude: wasm) {
  // Only a single trailing separator is removed, not a run of them.
  assert(_strip_trailing_sep("a//") == "a/", "only one trailing separator is removed");
}

test_temp_dir_uses_env_with_strip() `test(exclude: wasm) `target(windows) {
  string? orig_temp = get_env_var("TEMP");
  set_env_var("TEMP", "C:\\PromiseTempDirTest\\");
  string got = temp_dir;
  set_env_var("TEMP", move orig_temp); // restore (absent -> unset)
  assert(got == "C:\\PromiseTempDirTest", "temp_dir should return TEMP with the trailing separator stripped");
}

test_temp_dir_uses_env_with_strip() `test(exclude: wasm) `target(!windows) {
  string? orig = get_env_var("TMPDIR");
  set_env_var("TMPDIR", "/promise/tmp/dir/");
  string got = temp_dir;
  set_env_var("TMPDIR", move orig); // restore (absent -> unset)
  assert(got == "/promise/tmp/dir", "temp_dir should return TMPDIR with the trailing separator stripped");
}

test_temp_dir_fallback_when_unset() `test(exclude: wasm) `target(windows) {
  string? orig_temp = get_env_var("TEMP");
  string? orig_tmp = get_env_var("TMP");
  string? unset_temp;
  set_env_var("TEMP", move unset_temp);
  string? unset_tmp;
  set_env_var("TMP", move unset_tmp);
  string got = temp_dir;
  set_env_var("TEMP", move orig_temp); // restore both before asserting
  set_env_var("TMP", move orig_tmp);
  assert(got == "C:\\Windows\\Temp", "temp_dir should fall back to C:\\Windows\\Temp when TEMP and TMP are unset");
}

test_temp_dir_fallback_when_unset() `test(exclude: wasm) `target(!windows) {
  string? orig = get_env_var("TMPDIR");
  string? unset;
  set_env_var("TMPDIR", move unset);
  string got = temp_dir;
  set_env_var("TMPDIR", move orig); // restore before asserting
  assert(got == "/tmp", "temp_dir should fall back to /tmp when TMPDIR is unset");
}

test_args_returns_empty_in_test_runner() `test(exclude: wasm) {
  string[] a = args;
  // Test runner passes no user args, so args should be empty
  assert(a.len == 0, "args should be empty in test runner");
}

test_args_is_iterable() `test(exclude: wasm) {
  string[] a = args;
  int count = 0;
  for _ in a {
    count = count + 1;
  }
  assert(count == 0, "iterating empty args should produce zero elements");
}

test_executable_path_returns_string() `test(exclude: wasm) {
  string exe = executable_path;
  assert(exe.len > 0, "executable_path should be non-empty");
}

test_executable_path_contains_slash() `test(exclude: wasm) {
  string exe = executable_path;
  // The executable path should be an absolute or relative path with a separator.
  // On Windows the separator is "\", on POSIX it is "/".
  bool has_sep = exe.contains("/") || exe.contains("\\");
  assert(has_sep, "executable_path should contain a path separator");
}

test_executable_path_is_stable() `test(exclude: wasm) {
  string exe1 = executable_path;
  string exe2 = executable_path;
  assert(exe1 == exe2, "reading executable_path twice should return the same value");
}

test_execute_echo() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("echo", ["hello"])?!;
  assert(result.exit_code == 0, "echo should exit with 0");
  assert(result.stdout.starts_with("hello"), "stdout should contain hello");
}

test_execute_exit_code() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("false", [])?!;
  assert(result.exit_code != 0, "false should exit with non-zero");
}

test_execute_echo_windows() `test(exclude: wasm) `target(windows) {
  // Execution-level guard for the pal_spawn_env success path (was a -1 stub pre PR #1)
  // and the emitArgvToCmdline over-quoting regression.
  ProcessResult result = execute("cmd", ["/c", "echo hello"])?!;
  assert(result.exit_code == 0, "cmd /c echo should exit 0");
  assert(result.stdout.starts_with("hello"), "stdout should contain hello");
}

test_execute_exit_code_windows() `test(exclude: wasm) `target(windows) {
  ProcessResult result = execute("cmd", ["/c", "exit 3"])?!;
  assert(result.exit_code == 3, "exit code should surface");
}

test_execute_true() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("true", [])?!;
  assert(result.exit_code == 0, "true should exit with 0");
  assert(result.stdout.len == 0, "true should produce no stdout");
  assert(result.stderr.len == 0, "true should produce no stderr");
}

test_execute_captures_stdout() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("printf", ["one two three"])?!;
  assert(result.stdout == "one two three", "stdout should match printf output");
}

test_execute_captures_stderr() `test(exclude: wasm) `target(!windows) {
  // sh -c 'echo err >&2' writes to stderr
  ProcessResult result = execute("sh", ["-c", "echo err >&2"])?!;
  assert(result.exit_code == 0, "sh should exit with 0");
  assert(result.stderr.starts_with("err"), "stderr should contain err");
}

// exec_replace replaces the process image on success (never returns), so a batch
// test can only verify the failure path: launching a missing program raises an
// error rather than replacing the process. (T0770)
test_exec_replace_missing_raises() `test(exclude: wasm) {
  bool raised = false;
  int rc = exec_replace("/nonexistent/promise/exec/target", [])? e {
    raised = true;
    -1
  };
  assert(raised, "exec_replace of a missing program raises");
  assert(rc == -1, "recovery yields the sentinel");
}

test_execute_multiple_args() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("echo", ["a", "b", "c"])?!;
  assert(result.stdout.starts_with("a b c"), "echo should join arguments with spaces");
}

test_execute_empty_args() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("echo", [])?!;
  assert(result.exit_code == 0, "echo with no args should succeed");
}

test_execute_process_result_fields() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("echo", ["test"])?!;
  // Verify all fields are accessible
  int code = result.exit_code;
  string out = result.stdout;
  string err = result.stderr;
  assert(code == 0, "exit code should be 0");
  assert(out.len > 0, "stdout should be non-empty");
}

test_execute_nonexistent_program() `test(exclude: wasm) `target(!windows) {
  // On POSIX, a nonexistent program still returns a ProcessResult
  // with exit code 127 (the execvp-failure convention).
  ProcessResult result = execute("__promise_no_such_program__", [])?!;
  assert(result.exit_code == 127, "nonexistent program should exit with 127");
}

_execute_nonexistent() bool {
  // Helper: returns true if execute() raises an error for a nonexistent program.
  execute("__promise_no_such_program__", [])? e {
    return true;
  };
  return false;
}

test_execute_nonexistent_program_windows() `test(exclude: wasm) `target(windows) {
  // On Windows, CreateProcessA fails for nonexistent programs,
  // so execute() raises an error instead of returning a ProcessResult.
  assert(_execute_nonexistent(), "execute of nonexistent program should raise an error on Windows");
}

test_execute_args_with_spaces() `test(exclude: wasm) `target(!windows) {
  // Verify arguments containing spaces are passed through correctly
  ProcessResult result = execute("printf", ["%s|%s", "hello world", "foo bar"])?!;
  assert(result.exit_code == 0, "printf should exit with 0");
  assert(result.stdout == "hello world|foo bar", "arguments with spaces should be preserved");
}

test_execute_specific_exit_code() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("sh", ["-c", "exit 42"])?!;
  assert(result.exit_code == 42, "should capture exact exit code 42");
}

test_execute_stdout_and_stderr_together() `test(exclude: wasm) `target(!windows) {
  // Command that writes to both stdout and stderr
  ProcessResult result = execute("sh", ["-c", "echo out; echo err >&2"])?!;
  assert(result.exit_code == 0, "should exit with 0");
  assert(result.stdout.starts_with("out"), "stdout should contain out");
  assert(result.stderr.starts_with("err"), "stderr should contain err");
}

test_execute_multiline_stdout() `test(exclude: wasm) `target(!windows) {
  ProcessResult result = execute("printf", ["line1\nline2\nline3"])?!;
  assert(result.exit_code == 0, "printf should exit with 0");
  assert(result.stdout == "line1\nline2\nline3", "multiline output should be preserved");
}

test_execute_large_output() `test(exclude: wasm) `target(!windows) {
  // Generate >4096 bytes to exercise the realloc growth path in __pal_read_all.
  // seq 1 1000 produces ~3893 bytes; seq 1 2000 produces ~8893 bytes.
  ProcessResult result = execute("sh", ["-c", "seq 1 2000"])?!;
  assert(result.exit_code == 0, "seq should exit with 0");
  assert(result.stdout.len > 4096, "output should exceed initial 4096-byte buffer");
  assert(result.stdout.starts_with("1\n2\n3\n"), "output should start with first numbers");
  assert(result.stdout.ends_with("2000\n"), "output should end with last number");
}

test_execute_large_stderr() `test(exclude: wasm) `target(!windows) {
  // Generate >4KB on stderr to exercise the goroutine read path.
  ProcessResult result = execute("sh", ["-c", "seq 1 2000 >&2"])?!;
  assert(result.exit_code == 0, "seq to stderr should exit with 0");
  assert(result.stderr.len > 4096, "stderr should exceed 4096 bytes");
  assert(result.stderr.starts_with("1\n2\n3\n"), "stderr should start with first numbers");
  assert(result.stderr.ends_with("2000\n"), "stderr should end with last number");
  assert(result.stdout.len == 0, "stdout should be empty");
}

test_execute_large_stdout_and_stderr() `test(exclude: wasm) `target(!windows) {
  // Write >64KB to BOTH streams simultaneously — the exact scenario that
  // deadlocked before concurrent reads (B0028). The child writes to stdout
  // and stderr in alternating chunks; if either pipe blocks because the
  // reader isn't draining it, the child stalls and the test hangs.
  ProcessResult result = execute("sh", ["-c", "seq 1 10000; seq 1 10000 >&2"])?!;
  assert(result.exit_code == 0, "should exit with 0");
  assert(result.stdout.len > 40000, "stdout should be large");
  assert(result.stderr.len > 40000, "stderr should be large");
  assert(result.stdout.starts_with("1\n"), "stdout should start correctly");
  assert(result.stderr.starts_with("1\n"), "stderr should start correctly");
  assert(result.stdout.ends_with("10000\n"), "stdout should end correctly");
  assert(result.stderr.ends_with("10000\n"), "stderr should end correctly");
}

test_execute_only_stderr() `test(exclude: wasm) `target(!windows) {
  // No stdout, only stderr — goroutine reads empty stdout while main thread gets content.
  ProcessResult result = execute("sh", ["-c", "echo error_only >&2"])?!;
  assert(result.exit_code == 0, "should exit with 0");
  assert(result.stdout.len == 0, "stdout should be empty");
  assert(result.stderr.starts_with("error_only"), "stderr should have content");
}

test_execute_empty_string_args() `test(exclude: wasm) `target(!windows) {
  // Empty strings should be passed as distinct argv entries
  ProcessResult result = execute("printf", ["%s|%s|%s", "", "mid", ""])?!;
  assert(result.exit_code == 0, "printf should exit with 0");
  assert(result.stdout == "|mid|", "empty string args should produce empty segments");
}

test_execute_special_characters() `test(exclude: wasm) `target(!windows) {
  // Tabs, quotes, and backslashes in arguments
  ProcessResult result = execute("printf", ["%s", "tab\there \"quote\" back\\slash"])?!;
  assert(result.exit_code == 0, "printf should exit with 0");
  assert(result.stdout.contains("\t"), "tab should be preserved");
  assert(result.stdout.contains("\""), "quotes should be preserved");
  assert(result.stdout.contains("\\"), "backslash should be preserved");
}

test_execute_sequential_calls() `test(exclude: wasm) `target(!windows) {
  // Verify TLS globals are properly reset between sequential execute calls
  ProcessResult r1 = execute("printf", ["first"])?!;
  assert(r1.stdout == "first", "first call stdout should be 'first'");

  ProcessResult r2 = execute("printf", ["second"])?!;
  assert(r2.stdout == "second", "second call stdout should be 'second'");

  ProcessResult r3 = execute("true", [])?!;
  assert(r3.stdout.len == 0, "third call stdout should be empty");
}

test_execute_fail_with_stderr() `test(exclude: wasm) `target(!windows) {
  // Command that writes to stderr and exits non-zero
  ProcessResult result = execute("sh", ["-c", "echo failure >&2; exit 1"])?!;
  assert(result.exit_code == 1, "should exit with 1");
  assert(result.stderr.starts_with("failure"), "stderr should contain failure message");
}

test_execute_exact_echo_output() `test(exclude: wasm) `target(!windows) {
  // echo appends a trailing newline — verify exact output
  ProcessResult result = execute("echo", ["hello"])?!;
  assert(result.stdout == "hello\n", "echo output should be exactly 'hello\\n'");
}

test_execute_many_args() `test(exclude: wasm) `target(!windows) {
  // Stress the argv construction with many arguments
  ProcessResult result = execute("echo", ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j"])?!;
  assert(result.exit_code == 0, "echo should exit with 0");
  assert(result.stdout.starts_with("a b c d e f g h i j"), "all 10 arguments should be passed");
}

test_execute_multiple_args_windows() `test(exclude: wasm) `target(windows) {
  // Pre-fix, emitArgvToCmdline over-quoted every arg, breaking `cmd /c`.
  ProcessResult result = execute("cmd", ["/c", "echo", "a", "b", "c"])?!;
  assert(result.exit_code == 0, "cmd /c echo should exit 0");
  assert(result.stdout.starts_with("a b c"), "args joined with spaces");
}

test_execute_inherits_env() `test(exclude: wasm) `target(!windows) {
  // Child process should see environment variables set by parent
  set_env_var("PROMISE_TEST_EXEC_ENV", "inherited_value");
  ProcessResult result = execute("sh", ["-c", "echo $PROMISE_TEST_EXEC_ENV"])?!;
  assert(result.exit_code == 0, "sh should exit with 0");
  assert(result.stdout.starts_with("inherited_value"), "child should inherit env var");
  // Clean up
  string? absent;
  set_env_var("PROMISE_TEST_EXEC_ENV", move absent);
}

test_execute_inherits_cwd() `test(exclude: wasm) `target(!windows) {
  // Child process should run in the parent's current working directory
  string original = working_dir?!;
  set_working_dir("/usr")?!;
  ProcessResult result = execute("sh", ["-c", "pwd"])?!;
  assert(result.exit_code == 0, "sh should exit with 0");
  assert(result.stdout.starts_with("/usr"), "child should inherit working directory");
  set_working_dir(original)?!;
}

test_execute_inherits_cwd() `test(exclude: wasm) `target(windows) {
  // On Windows, CreateProcessA with lpCurrentDirectory=NULL inherits the parent's CWD.
  // Verify set_working_dir + working_dir round-trips (child inheritance is guaranteed by the OS).
  string original = working_dir?!;
  set_working_dir("C:\\Windows")?!;
  string cwd = working_dir?!;
  assert(cwd == "C:\\Windows", "working directory should be C:\\Windows after set");
  set_working_dir(original)?!;
}

test_execute_custom_cwd_windows() `test(exclude: wasm) `target(windows) {
  // Spawns with lpCurrentDirectory set; `cd` with no args prints the current directory.
  ProcessResult result = execute("cmd", ["/c", "cd"], working_directory: "C:\\Windows")?!;
  assert(result.exit_code == 0, "cmd /c cd should exit 0");
  assert(result.stdout.trim() == "C:\\Windows", "child should run in C:\\Windows");
}

test_set_env_var_new() `test(exclude: wasm) {
  // Set a new variable and read it back
  set_env_var("PROMISE_TEST_SET_ENV_1", "hello");
  string? val = get_env_var("PROMISE_TEST_SET_ENV_1");
  assert(val is present, "newly set variable should be present");
  if v := val {
    assert(v == "hello", "variable should have the value we set");
  }
}

test_set_env_var_overwrite() `test(exclude: wasm) {
  // Set, then overwrite with a different value
  set_env_var("PROMISE_TEST_SET_ENV_2", "first");
  set_env_var("PROMISE_TEST_SET_ENV_2", "second");
  string? val = get_env_var("PROMISE_TEST_SET_ENV_2");
  if v := val {
    assert(v == "second", "overwritten variable should have the new value");
  } else {
    assert(false, "overwritten variable should be present");
  }
}

test_set_env_var_empty() `test(exclude: wasm) `target(!windows) {
  // Set to empty string — should be present but empty (POSIX behavior)
  set_env_var("PROMISE_TEST_SET_ENV_3", "");
  string? val = get_env_var("PROMISE_TEST_SET_ENV_3");
  assert(val is present, "variable set to empty should be present");
  if v := val {
    assert(v.len == 0, "variable set to empty should have zero length");
  }
}

test_set_env_var_empty() `test(exclude: wasm) `target(windows) {
  // On Windows, _putenv_s(name, "") removes the variable (OS behavior).
  // Verify that setting to empty effectively unsets it.
  set_env_var("PROMISE_TEST_SET_ENV_3", "something");
  string? before = get_env_var("PROMISE_TEST_SET_ENV_3");
  assert(before is present, "variable should be present before clearing");
  set_env_var("PROMISE_TEST_SET_ENV_3", "");
  string? after = get_env_var("PROMISE_TEST_SET_ENV_3");
  assert(after is absent, "variable set to empty should be absent on Windows");
}

test_set_env_var_unset() `test(exclude: wasm) {
  // Set a variable then unset it
  set_env_var("PROMISE_TEST_SET_ENV_4", "temp");
  string? val1 = get_env_var("PROMISE_TEST_SET_ENV_4");
  assert(val1 is present, "variable should be present after set");

  // Unset by passing absent
  string? absent;
  set_env_var("PROMISE_TEST_SET_ENV_4", move absent);
  string? val2 = get_env_var("PROMISE_TEST_SET_ENV_4");
  assert(val2 is absent, "variable should be absent after unset");
}

test_set_env_var_unset_nonexistent() `test(exclude: wasm) {
  // Unsetting a variable that doesn't exist should not error
  string? absent;
  set_env_var("PROMISE_NONEXISTENT_UNSET_TEST", move absent);
  string? val = get_env_var("PROMISE_NONEXISTENT_UNSET_TEST");
  assert(val is absent, "nonexistent variable should remain absent");
}

test_set_working_dir() `test(exclude: wasm) `target(!windows) {
  // Save original, change to /usr, verify, restore
  // (avoid /tmp which is a symlink to /private/tmp on macOS)
  string original = working_dir?!;
  string original2 = working_dir?!;
  set_working_dir("/usr")?!;
  string cwd = working_dir?!;
  assert(cwd == "/usr", "working directory should be /usr after set");
  // Restore
  set_working_dir(original)?!;
  string restored = working_dir?!;
  assert(restored == original2, "working directory should be restored");
}

test_set_working_dir() `test(exclude: wasm) `target(windows) {
  string original = working_dir?!;
  string original2 = working_dir?!;
  set_working_dir("C:\\Windows")?!;
  string cwd = working_dir?!;
  assert(cwd == "C:\\Windows", "working directory should be C:\\Windows after set");
  set_working_dir(original)?!;
  string restored = working_dir?!;
  assert(restored == original2, "working directory should be restored");
}

test_set_working_dir_nonexistent() `test(exclude: wasm) {
  // Changing to a nonexistent path should raise an error
  bool got_error = false;
  set_working_dir("/promise_nonexistent_path_12345")? e {
    got_error = true;
  };
  assert(got_error, "set_working_dir to nonexistent path should raise error");
}

test_set_working_dir_preserves_env() `test(exclude: wasm) `target(!windows) {
  // Verify that changing cwd doesn't affect environment variables
  set_env_var("PROMISE_TEST_CWD_ENV", "keep");
  string original = working_dir?!;
  set_working_dir("/tmp")?!;
  string? val = get_env_var("PROMISE_TEST_CWD_ENV");
  assert(val is present, "env var should survive cwd change");
  set_working_dir(original)?!;
}

test_set_working_dir_preserves_env() `test(exclude: wasm) `target(windows) {
  set_env_var("PROMISE_TEST_CWD_ENV", "keep");
  string original = working_dir?!;
  set_working_dir("C:\\Windows")?!;
  string? val = get_env_var("PROMISE_TEST_CWD_ENV");
  assert(val is present, "env var should survive cwd change");
  set_working_dir(original)?!;
}

