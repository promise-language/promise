// Tests for Scanner type
test_read_byte() `test {
  Scanner r = Scanner(s: "hi");
  if b := r.read_byte() {
    assert((b as! int) == 104, "h = 104");
  } else {
    assert(false, "expected byte");
  }
  if b := r.read_byte() {
    assert((b as! int) == 105, "i = 105");
  } else {
    assert(false, "expected byte");
  }
}

test_read_byte_empty() `test {
  Scanner r = Scanner(s: "");
  if b := r.read_byte() {
    assert(false, "expected none");
  }
}

test_position() `test {
  Scanner r = Scanner(s: "abc");
  assert(r.position == 0, "initial 0");
  r.read_byte();
  assert(r.position == 1, "after 1 read");
  r.read_byte();
  assert(r.position == 2, "after 2 reads");
}

test_has_next() `test {
  Scanner r = Scanner(s: "x");
  assert(r.has_next, "initially true");
  r.read_byte();
  assert(!r.has_next, "after reading all");
}

test_rest() `test {
  Scanner r = Scanner(s: "hello");
  assert(r.rest() == "hello", "full rest");
  r.read_byte();
  assert(r.rest() == "ello", "after 1 read");
  r.read_byte();
  assert(r.rest() == "llo", "after 2 reads");
}

test_read() `test {
  Scanner r = Scanner(s: "hello");
  u8[] buf = Vector[u8].filled(0 as! u8, 3);
  int n = r.read(buf);
  assert(n == 3, "read 3 bytes");
  assert(r.position == 3, "position after read");
  assert(r.rest() == "lo", "remaining after read");
}

test_read_partial() `test {
  Scanner r = Scanner(s: "hi");
  u8[] buf = Vector[u8].filled(0 as! u8, 5);
  int n = r.read(buf);
  assert(n == 2, "only 2 bytes available");
  assert(!r.has_next, "exhausted");
}

test_read_empty() `test {
  Scanner r = Scanner(s: "");
  u8[] buf = Vector[u8].filled(0 as! u8, 3);
  int n = r.read(buf);
  assert(n == 0, "read 0 from empty");
}
