// Error handling: ?, !, ? handler, raise.

// Simple propagation
readAll!(String path) String {
  File f = open(path)?^;
  String data = f.read()?^;
  f.close()?^;
  return data;
}

// Unwrap (panic on error)
forceRead(String path) String {
  return open(path)?!.read()?!;
}

// Error handler with named binding
safeRead(String path) String {
  String content = readAll(path) ? e {
    return "error: " + e.message;
  };
  return content;
}

// Error handler without binding (unnamed)
safeRead2(String path) String {
  String content = readAll(path) ? {
    return "failed";
  };
  return content;
}

// Error handler with discard
safeRead3(String path) String {
  String content = readAll(path) ? _ {
    return "failed";
  };
  return content;
}

// Raise
validate!(Int x) Int {
  if x < 0 {
    raise ValidationError("negative");
  }
  if x > 100 {
    raise ValidationError("too large");
  }
  return x;
}

// Chained propagation
processChain!() String {
  String raw = readAll("input.txt")?^;
  String parsed = parse(raw)?^;
  String result = transform(parsed)?^;
  return result;
}

// Error handling with postfix precedence
exprPrecedence!() Int {
  // ^ binds tighter than +
  Int a = compute()?^ + 1;

  // ! binds tighter than *
  Int b = compute()?! * 2;

  // Optional chain + propagate
  Int c = obj?.method()?^;

  // Chained calls with propagation
  Int d = a.b()?.c()?!.d()?^;

  return a + b;
}

// Multiple error paths
multiError!() Int {
  Int a = computeA() ? {
    return 0;
  };
  Int b = computeB() ? e {
    raise WrappedError(e);
  };
  Int c = computeC()?^;
  return a + b + c;
}
