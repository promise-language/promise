type Point {
  int x `value;
  int y `value;

  sum(&this) int {
    return this.x + this.y;
  }

  scale(&this, int factor) Point {
    return Point(x: this.x * factor, y: this.y * factor);
  }
}

main() `test(expected: """7
6
8""") {
  p := Point(x: 3, y: 4);
  print_line(p.sum());

  Point q = p.scale(factor: 2);
  print_line(q.x);
  print_line(q.y);
}
