// Arithmetic and operator tests: precedence, bitwise, compound assignment,
// edge cases.
// --- operator precedence: multiply before add ---
test_precedence_mul_add() `test {
  assert(2 + 3 * 4 == 14, "2 + 3*4 = 14");
  assert(3 * 4 + 2 == 14, "3*4 + 2 = 14");
}

// --- operator precedence: division ---

test_precedence_div() `test {
  assert(10 / 2 + 3 == 8, "10/2 + 3 = 8");
  assert(3 + 10 / 2 == 8, "3 + 10/2 = 8");
}

// --- parentheses override ---

test_parentheses() `test {
  assert((2 + 3) * 4 == 20, "(2+3)*4 = 20");
  assert(2 * (3 + 4) == 14, "2*(3+4) = 14");
  assert((10 - 2) * (3 + 1) == 32, "(10-2)*(3+1) = 32");
}

// --- modulo ---

test_modulo() `test {
  assert(10 % 3 == 1, "10 % 3 = 1");
  assert(7 % 7 == 0, "7 % 7 = 0");
  assert(15 % 4 == 3, "15 % 4 = 3");
  assert(100 % 10 == 0, "100 % 10 = 0");
}

// --- unary negation ---

test_negation() `test {
  int x = 5;
  assert(-x == -5, "negation of 5");
  assert(-(-x) == 5, "double negation");
  assert(-(3 + 4) == -7, "negation of sum");
}

// --- compound assignment ---

test_compound_add() `test {
  int x = 10;
  x += 5;
  assert(x == 15, "10 += 5 = 15");
}

test_compound_sub() `test {
  int x = 10;
  x -= 3;
  assert(x == 7, "10 -= 3 = 7");
}

test_compound_mul() `test {
  int x = 4;
  x *= 3;
  assert(x == 12, "4 *= 3 = 12");
}

test_compound_div() `test {
  int x = 20;
  x /= 4;
  assert(x == 5, "20 /= 4 = 5");
}

test_compound_mod() `test {
  int x = 17;
  x %= 5;
  assert(x == 2, "17 %= 5 = 2");
}

// --- increment / decrement ---

test_inc_dec() `test {
  int a = 0;
  a++;
  a++;
  a++;
  assert(a == 3, "inc 3 times = 3");
  a--;
  assert(a == 2, "dec once = 2");
}

// --- bitwise AND ---

test_bitwise_and() `test {
  assert((0b1100 & 0b1010) == 0b1000, "1100 & 1010 = 1000");
  assert((0xFF & 0x0F) == 0x0F, "FF & 0F = 0F");
  assert((0 & 42) == 0, "0 & anything = 0");
}

// --- bitwise OR ---

test_bitwise_or() `test {
  assert((0b1100 | 0b1010) == 0b1110, "1100 | 1010 = 1110");
  assert((0 | 42) == 42, "0 | 42 = 42");
}

// --- bitwise XOR ---

test_bitwise_xor() `test {
  assert((0b1100 ^ 0b1010) == 0b0110, "1100 ^ 1010 = 0110");
  assert((42 ^ 42) == 0, "x ^ x = 0");
  assert((42 ^ 0) == 42, "x ^ 0 = x");
}

// --- bitwise NOT ---

test_bitwise_not() `test {
  int x = 0;
  assert(~x == -1, "~0 = -1 (all bits set)");
}

// --- left shift ---

test_left_shift() `test {
  assert((1 << 0) == 1, "1 << 0 = 1");
  assert((1 << 1) == 2, "1 << 1 = 2");
  assert((1 << 3) == 8, "1 << 3 = 8");
  assert((1 << 10) == 1024, "1 << 10 = 1024");
  assert((3 << 2) == 12, "3 << 2 = 12");
}

// --- right shift ---

test_right_shift() `test {
  assert((8 >> 1) == 4, "8 >> 1 = 4");
  assert((16 >> 2) == 4, "16 >> 2 = 4");
  assert((1024 >> 10) == 1, "1024 >> 10 = 1");
  assert((7 >> 1) == 3, "7 >> 1 = 3");
}

// --- comparison operators ---

test_comparisons() `test {
  assert(1 < 2, "1 < 2");
  assert(2 > 1, "2 > 1");
  assert(3 <= 3, "3 <= 3");
  assert(3 >= 3, "3 >= 3");
  assert(3 <= 5, "3 <= 5");
  assert(5 >= 3, "5 >= 3");
  assert(1 != 2, "1 != 2");
  assert(5 == 5, "5 == 5");
}

// --- logical operators ---

test_logical_and() `test {
  assert((true && true) == true, "T && T = T");
  assert((true && false) == false, "T && F = F");
  assert((false && true) == false, "F && T = F");
  assert((false && false) == false, "F && F = F");
}

test_logical_or() `test {
  assert((true || true) == true, "T || T = T");
  assert((true || false) == true, "T || F = T");
  assert((false || true) == true, "F || T = T");
  assert((false || false) == false, "F || F = F");
}

test_logical_not() `test {
  assert(!false == true, "!false = true");
  assert(!true == false, "!true = false");
}

// --- complex expressions ---

test_complex_expr() `test {
  int a = 3;
  int b = 4;
  int c = 5;
  // (a*a + b*b) == c*c => Pythagorean triple
  assert(a * a + b * b == c * c, "3-4-5 Pythagorean triple");
}

// --- division truncation ---

test_int_division() `test {
  assert(7 / 2 == 3, "7/2 truncates to 3");
  assert(1 / 3 == 0, "1/3 truncates to 0");
  assert(10 / 10 == 1, "10/10 = 1");
}

// --- negative arithmetic ---

test_negative_arithmetic() `test {
  assert(-3 + 5 == 2, "-3 + 5 = 2");
  assert(-3 * -4 == 12, "-3 * -4 = 12");
  assert(-10 / 3 == -3, "-10 / 3 = -3");
}

// --- chained operations ---

test_chained_ops() `test {
  int result = 1 + 2 + 3 + 4 + 5;
  assert(result == 15, "1+2+3+4+5 = 15");
}

// --- float arithmetic ---

test_float_basic() `test {
  f64 x = 1.5;
  f64 y = 2.5;
  f64 sum = x + y;
  assert(sum > 3.99 && sum < 4.01, "1.5 + 2.5 = 4.0");
}

test_float_mul() `test {
  f64 x = 0.1;
  f64 y = 10.0;
  f64 product = x * y;
  assert(product > 0.99 && product < 1.01, "0.1 * 10 ~ 1.0");
}

test_float_div() `test {
  f64 x = 1.0;
  f64 y = 3.0;
  f64 r = x / y;
  assert(r > 0.33 && r < 0.34, "1/3 ~ 0.333");
}
