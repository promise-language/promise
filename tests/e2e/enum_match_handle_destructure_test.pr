// T0623: match-destructure of an enum variant whose field transitively owns
// a single-owner handle (Task/Mutex/MutexGuard) MOVES the subject — the
// binding takes ownership of the handle and the subject's synth enum drop is
// suppressed. T0482 conservatively rejected this; T0623 makes it sound.
// Zero leaks (T0067).
worker_t0623() int {
  return 42;
}

worker_double(int n) int {
  return n * 2;
}

// --- Direct Task in a variant — moves and awaits via the binding ---

enum Job {
  Pending,
  Running(Task[int] t),
}

test_match_task_held_moves_and_awaits() `test(exclude: wasm) {
  job := Job.Running(go worker_t0623());
  match job {
    Job.Pending => assert(false, "should not be pending"),
    Job.Running(t) => {
      x := <-t;
      assert(x == 42, "task result through move-out binding");
    },
  }
}

test_match_task_held_drops_without_await() `test(exclude: wasm) {
  // Move-out binding drops at arm end (Task.drop joins + frees). Zero leaks.
  job := Job.Running(go worker_t0623());
  match job {
    Job.Pending => assert(false, "should not be pending"),
    Job.Running(t) => assert(true, "binding owns the task; drops at arm end"),
  }
}

// --- Mixed variants: one moves, one does not — both arms leak-free ---

enum Event {
  Stored(string s),
  Held(Task[int] t),
}

test_match_mixed_held_path() `test(exclude: wasm) {
  e := Event.Held(go worker_t0623());
  match e {
    Event.Stored(s) => assert(false, "wrong arm"),
    Event.Held(t) => {
      n := <-t;
      assert(n == 42, "held arm awaits");
    },
  }
}

test_match_mixed_stored_path() `test {
  e := Event.Stored("hi");
  match e {
    Event.Stored(s) => assert(s == "hi", "stored arm dups the string"),
    Event.Held(_) => assert(false, "wrong arm"),
  }
}

// --- Mutex in a variant — moves and uses through the binding ---

enum MutexHolder {
  Empty,
  Locked(Mutex[int] m),
}

test_match_mutex_held_moves() `test(exclude: wasm) {
  h := MutexHolder.Locked(Mutex[int](10));
  match h {
    MutexHolder.Empty => assert(false, "wrong arm"),
    MutexHolder.Locked(m) => {
      use g := m.lock();
      assert(g.borrow == 10, "locked through moved mutex");
      g.borrow = 20;
      assert(g.borrow == 20, "set via guard");
    },
  }
}

// --- Generic enum variant whose type-param resolves to a handle ---

enum BoxG[T] {
  Empty,
  Has(T v),
}

test_match_generic_box_handle() `test(exclude: wasm) {
  b := BoxG[Task[int]].Has(go worker_t0623());
  match b {
    BoxG.Empty => assert(false, "wrong arm"),
    BoxG.Has(t) => {
      n := <-t;
      assert(n == 42, "generic box task await");
    },
  }
}

// --- Wildcard `_` in the handle slot is NOT a move; subject's drop fires ---

test_match_handle_wildcard_still_drops_subject() `test(exclude: wasm) {
  job := Job.Running(go worker_t0623());
  match job {
    Job.Pending => assert(false, "wrong arm"),
    Job.Running(_) => assert(true, "wildcard does not move; synth drop frees the Task"),
  }
}

// --- Short-form destructure (Held(t) without enum prefix) ---

test_match_short_destructure_form() `test(exclude: wasm) {
  e := Event.Held(go worker_t0623());
  match e {
    Stored(s) => assert(false, "wrong arm"),
    Held(t) => {
      n := <-t;
      assert(n == 42, "short-form destructure moves through");
    },
  }
}

// --- Multiple match-arm shapes on the same subject (sequential matches) ---

enum Pair {
  None,
  One(Task[int] a),
}

test_match_sequential_handles() `test(exclude: wasm) {
  p1 := Pair.One(go worker_double(5));
  match p1 {
    Pair.None => assert(false, "wrong arm"),
    Pair.One(a) => {
      n := <-a;
      assert(n == 10, "first await");
    },
  }

  p2 := Pair.One(go worker_double(7));
  match p2 {
    Pair.None => assert(false, "wrong arm"),
    Pair.One(a) => {
      n := <-a;
      assert(n == 14, "second await");
    },
  }
}

// --- Multi-field variant with both a dup'd string and a moved handle ---
// The handle field is null'd in the subject's variant data so the synth enum
// drop skips it, while the sibling string field is still freed by the synth
// drop. Without the null-out, either the handle would double-free or the
// string would leak. Use a heap (non-literal) string so the leak path is real.

enum HeapMulti {
  Empty,
  Pair(string s, Task[int] t),
}

make_heap_string() string {
  return "hello" + " world";
}

test_match_multi_field_heap_string() `test(exclude: wasm) {
  e := HeapMulti.Pair(make_heap_string(), go worker_t0623());
  match e {
    HeapMulti.Empty => assert(false, "wrong arm"),
    HeapMulti.Pair(s, t) => {
      assert(s == "hello world", "string copy survives");
      n := <-t;
      assert(n == 42, "task awaits");
    },
  }
}

// Wildcard in the handle slot of a multi-field variant: NOT a moving arm.
// The synth drop still frees both the string and the handle.

test_match_multi_field_wildcard_handle() `test(exclude: wasm) {
  e := HeapMulti.Pair(make_heap_string(), go worker_t0623());
  match e {
    HeapMulti.Empty => assert(false, "wrong arm"),
    HeapMulti.Pair(s, _) => {
      assert(s == "hello world", "string copy survives");
    },
  }
}

// --- Match in a loop: per-iteration move + drop registration ---
// Each iteration constructs a fresh Job, moves the Task into the binding, and
// awaits it. The per-iteration drop binding must be cleaned up correctly so
// the next iteration starts fresh. Zero leaks across 3 iterations.

test_match_handle_in_loop() `test(exclude: wasm) {
  int total = 0;
  for i in 0..3 {
    job := Job.Running(go worker_t0623());
    match job {
      Job.Pending => assert(false, "wrong arm"),
      Job.Running(t) => {
        n := <-t;
        total = total + n;
      },
    }
  }
  assert(total == 126, "3 iterations * 42");
}

// --- Two handle fields in one variant: both moved + both null'd ---
// The moving arm binds both fields; both Tasks transfer ownership to the
// bindings and both subject slots are null'd so the synth drop skips both.

enum TwoHandles {
  None,
  Both(Task[int] a, Task[int] b),
}

test_match_two_handles_in_variant() `test(exclude: wasm) {
  p := TwoHandles.Both(go worker_t0623(), go worker_double(21));
  match p {
    TwoHandles.None => assert(false, "wrong arm"),
    TwoHandles.Both(a, b) => {
      x := <-a;
      y := <-b;
      assert(x == 42, "first handle awaited");
      assert(y == 42, "second handle awaited");
    },
  }
}

// --- Re-initialize the subject after move-out ---
// After the first match moves `job`, reassigning it must produce a fresh
// owned binding that the second match can move out again. Tests ownership
// reset on reassignment and codegen drop-flag reset.

test_match_reinit_after_move() `test(exclude: wasm) {
  Job job = Job.Running(go worker_t0623());
  match job {
    Job.Pending => assert(false, "wrong arm"),
    Job.Running(t) => {
      n := <-t;
      assert(n == 42, "first await");
    },
  }
  job = Job.Running(go worker_double(50));
  match job {
    Job.Pending => assert(false, "wrong arm"),
    Job.Running(t) => {
      n := <-t;
      assert(n == 100, "second await after reinit");
    },
  }
}

// --- Early return from a moving arm: scope cleanup correctness ---
// The moving arm returns immediately after awaiting. Scope-exit cleanup must
// run the binding's drop (no-op after await consumes the Task) and the
// subject's synth drop on the null'd variant data (also no-op).

return_from_held(~Job j) int {
  match j {
    Job.Pending => {
      return -1;
    },
    Job.Running(t) => {
      n := <-t;
      return n;
    },
  }
}

test_match_early_return_from_moving_arm() `test(exclude: wasm) {
  job := Job.Running(go worker_t0623());
  r := return_from_held(job);
  assert(r == 42, "early return from moving arm");
}

// --- T0633: variant field is a USER-TYPE WRAPPER that transitively owns a
// single-owner handle (not the handle directly). The wrapper field lowers to
// the {i8*,i8*} value struct, so the moved-out slot is zero-init'd as
// {null,null} (not a bare i8* null). The subject's synth enum drop walks that
// zeroed slot and must null-check the extracted instance ptr before calling
// the wrapper's drop — otherwise it dereferences null and segfaults. Zero
// leaks: the binding owns the wrapper (drops it once: inner Task.drop +
// pal_free), the subject's synth drop skips the zeroed slot.

type TaskWrapper {
  Task[int] t;
}

enum Wrap {
  Empty,
  Inner(TaskWrapper w),
}

test_match_nested_wrapper_moves_and_awaits() `test(exclude: wasm) {
  w := Wrap.Inner(TaskWrapper(t: go worker_t0623()));
  match w {
    Wrap.Empty => assert(false, "wrong arm"),
    Wrap.Inner(wrapper) => {
      n := <-wrapper.t;
      assert(n == 42, "task inside wrapped struct");
    },
  }
}

test_match_nested_wrapper_drops_without_await() `test(exclude: wasm) {
  // Wrapper moves into the binding, the inner Task is never consumed via <-.
  // The binding's drop (TaskWrapper.drop -> Task.drop joins + frees) runs once
  // at arm end; the subject's synth Wrap.drop skips the zeroed slot. Zero leaks.
  w := Wrap.Inner(TaskWrapper(t: go worker_t0623()));
  match w {
    Wrap.Empty => assert(false, "wrong arm"),
    Wrap.Inner(wrapper) => assert(true, "binding owns the wrapper; drops at arm end"),
  }
}

// Mixed variant: a sibling heap string plus the handle wrapper. Only the
// wrapper slot is moved/zeroed; the string must still be freed by the synth
// enum drop. Without the null-guard the synth drop would segfault on the
// zeroed wrapper slot before ever reaching the string free.

enum WrapMixed {
  None,
  Both(string label, TaskWrapper w),
}

test_match_nested_wrapper_mixed_field() `test(exclude: wasm) {
  m := WrapMixed.Both(make_heap_string(), TaskWrapper(t: go worker_t0623()));
  match m {
    WrapMixed.None => assert(false, "wrong arm"),
    WrapMixed.Both(s, wrapper) => {
      assert(s == "hello world", "sibling string copy survives");
      n := <-wrapper.t;
      assert(n == 42, "wrapped task awaited");
    },
  }
}

// Wildcard `_` on the wrapper slot: NOT a moving arm. The constructed wrapper
// has a non-null instance ptr, so the synth enum drop's null-guard passes
// through and frees it normally (TaskWrapper.drop -> Task.drop + pal_free).

test_match_nested_wrapper_wildcard() `test(exclude: wasm) {
  w := Wrap.Inner(TaskWrapper(t: go worker_t0623()));
  match w {
    Wrap.Empty => assert(false, "wrong arm"),
    Wrap.Inner(_) => assert(true, "wildcard: synth drop frees the wrapper"),
  }
}

// Generic wrapper (B0202 mono-instance synth-drop branch). Holder[int] is a
// codegen-time monomorphized type whose synth drop is dispatched by mangled
// mono name; the same null-guard must protect its instance-deref path.

type Holder[T] {
  Task[T] handle;
}

enum GWrap {
  GEmpty,
  GInner(Holder[int] h),
}

test_match_generic_wrapper_moves() `test(exclude: wasm) {
  g := GWrap.GInner(Holder[int](handle: go worker_t0623()));
  match g {
    GWrap.GEmpty => assert(false, "wrong arm"),
    GWrap.GInner(holder) => {
      n := <-holder.handle;
      assert(n == 42, "generic wrapper task await");
    },
  }
}

// --- T0633 (extended): FirstNestedSingleOwnerHandle also matches a handle
// nested in a fixed array, an Optional, or a tuple — none of which lower to a
// bare pointer slot. The moved-out slot must be zero-init'd with a correctly
// typed aggregate zeroinitializer (an `i64 0` would be a type-incompatible
// store for an `[N x i8*]` array slot). Zero leaks: the binding owns the
// aggregate, the subject's synth enum drop walks the zeroed slot with all
// nested handle pointers null (per-handle drops null-check at entry).

enum TaskArr {
  Empty,
  Arr(Task[int][2] ts),
}

// NOTE: this asserts the move-out + drop path only (no `<-ts[i]`). Receiving
// directly on an indexed handle element (`<-coll[i]`) is a separate
// pre-existing segfault tracked as T0638 — keep this test independent of it.
// The T0633 concern here is: the array slot null-out emits a correctly typed
// `[N x i8*] zeroinitializer` (not the invalid `i64 0` from c.zeroValue's
// default arm), the binding owns the array (its drop frees both tasks), and
// the subject's synth enum drop skips the zeroed slot — zero leaks, no
// double-free, no segfault.
test_match_array_of_handles_moves() `test(exclude: wasm) {
  a := TaskArr.Arr([go worker_t0623(), go worker_double(21)]);
  match a {
    TaskArr.Empty => assert(false, "wrong arm"),
    TaskArr.Arr(ts) => {
      assert(true, "array moved into binding; binding drop frees both tasks");
    },
  }
}

test_match_array_of_handles_wildcard() `test(exclude: wasm) {
  a := TaskArr.Arr([go worker_t0623(), go worker_t0623()]);
  match a {
    TaskArr.Empty => assert(false, "wrong arm"),
    TaskArr.Arr(_) => assert(true, "wildcard: synth drop frees both tasks"),
  }
}

enum TaskOpt {
  Empty,
  Held(Task[int]? t),
}

test_match_optional_handle_moves() `test(exclude: wasm) {
  o := TaskOpt.Held(go worker_t0623());
  match o {
    TaskOpt.Empty => assert(false, "wrong arm"),
    TaskOpt.Held(t) => {
      if tt := t {
        n := <-tt;
        assert(n == 42, "optional-wrapped task awaited");
      } else {
        assert(false, "optional should be present");
      }
    },
  }
}

test_match_optional_handle_wildcard() `test(exclude: wasm) {
  o := TaskOpt.Held(go worker_t0623());
  match o {
    TaskOpt.Empty => assert(false, "wrong arm"),
    TaskOpt.Held(_) => assert(true, "wildcard: synth drop frees the optional task"),
  }
}

// Array of user-type wrappers — combines the array slot (Part 1) with the
// per-element user-wrapper drop (Part 2 null-guard) in one path.

enum WrapArr {
  Empty,
  Arr(TaskWrapper[2] ws),
}

test_match_array_of_wrappers_moves() `test(exclude: wasm) {
  a := WrapArr.Arr([TaskWrapper(t: go worker_t0623()), TaskWrapper(t: go worker_t0623())]);
  match a {
    WrapArr.Empty => assert(false, "wrong arm"),
    WrapArr.Arr(ws) => {
      n0 := <-ws[0].t;
      n1 := <-ws[1].t;
      assert(n0 == 42 && n1 == 42, "both wrapped array tasks awaited");
    },
  }
}

// --- T0633 (extended): variant field is a POLYMORPHIC user-type wrapper.
// Base has a child (Derived) → needsVtable(Base) is true, so the subject's
// synth enum drop routes the wrapper-field drop through emitVariantFieldDrop's
// POLYMORPHIC branch — emitStructuralInstanceDrop, which dispatches Base's
// drop indirectly via the typeinfo drop_fn_ptr and dereferences the instance
// ptr (loadVariantPtr) with no null-check. The Part-1 zero-init'd moved-out
// Base value-struct slot would segfault there without the T0633 null-guard.
// This branch is distinct from the plain-wrapper (named synth drop) and
// generic-wrapper (mono synth drop) branches exercised above. Zero leaks: the
// binding owns the Base (its polymorphic drop frees the inner Task + pal_free),
// the subject's synth drop skips the zeroed slot via the null-guard.

type PolyBase {
  Task[int] t;
  describe() string {
    return "base";
  }
}

type PolyDerived is PolyBase {
  describe() string {
    return "derived";
  }
}

enum PolyWrap {
  Empty,
  Held(PolyBase b),
}

test_match_polymorphic_wrapper_moves_and_awaits() `test(exclude: wasm) {
  w := PolyWrap.Held(PolyBase(t: go worker_t0623()));
  match w {
    PolyWrap.Empty => assert(false, "wrong arm"),
    PolyWrap.Held(b) => {
      n := <-b.t;
      assert(n == 42, "task inside polymorphic wrapper");
    },
  }
}

test_match_polymorphic_wrapper_drops_without_await() `test(exclude: wasm) {
  // Wrapper moves into the binding, inner Task never consumed via <-. The
  // binding's polymorphic drop runs once at arm end; the subject's synth
  // PolyWrap.drop skips the zeroed slot via the null-guard. Zero leaks.
  w := PolyWrap.Held(PolyBase(t: go worker_t0623()));
  match w {
    PolyWrap.Empty => assert(false, "wrong arm"),
    PolyWrap.Held(b) => assert(true, "binding owns the polymorphic wrapper; drops at arm end"),
  }
}

// Wildcard `_` on the polymorphic wrapper slot: NOT a moving arm. The
// constructed Base has a non-null instance ptr, so the synth enum drop's
// null-guard passes through and frees it via the polymorphic
// emitStructuralInstanceDrop path (typeinfo drop_fn_ptr → Task.drop + pal_free).

test_match_polymorphic_wrapper_wildcard() `test(exclude: wasm) {
  w := PolyWrap.Held(PolyBase(t: go worker_t0623()));
  match w {
    PolyWrap.Empty => assert(false, "wrong arm"),
    PolyWrap.Held(_) => assert(true, "wildcard: synth drop frees the polymorphic wrapper"),
  }
}

// --- T0633 (extended): variant field is a TUPLE that transitively owns a
// single-owner handle. firstNestedSingleOwnerHandle recurses into
// *types.Tuple (clone.go:274), so the T0623 move-out path fires. A
// (Task[int], int) tuple lowers to the MIXED pointer+scalar aggregate
// `{ i8*, i64 }` — structurally distinct from the {i8*,i8*} value-struct
// wrapper and the [N x i8*] array slots tested above — so nullSubjectHandleSlot
// must zero-init it via the else-branch `NewZeroInitializer` (a bare-pointer
// NewNull or c.zeroValue's `i64 0` default would be a type-incompatible
// store). The subject's synth enum drop walks the tuple element through the
// direct Task drop (which null-checks at entry), so the zeroed task ptr is a
// safe no-op. Zero leaks: the binding owns the tuple (its drop joins+frees the
// inner Task), the subject's synth drop skips the zeroed task ptr.

enum TupHold {
  Empty,
  Pair((Task[int], int) p),
}

test_match_tuple_handle_moves_and_awaits() `test(exclude: wasm) {
  h := TupHold.Pair((go worker_t0623(), 7));
  match h {
    TupHold.Empty => assert(false, "wrong arm"),
    TupHold.Pair(p) => {
      (tk, sib) := p;
      n := <-tk;
      assert(n == 42, "task inside tuple variant field");
      assert(sib == 7, "tuple sibling int survives");
    },
  }
}

test_match_tuple_handle_drops_without_await() `test(exclude: wasm) {
  // Tuple moves into the binding, inner Task never consumed via <-. The
  // binding's drop joins+frees the Task once at arm end; the subject's synth
  // TupHold.drop skips the zeroed task ptr. Zero leaks.
  h := TupHold.Pair((go worker_t0623(), 9));
  match h {
    TupHold.Empty => assert(false, "wrong arm"),
    TupHold.Pair(p) => assert(true, "binding owns the tuple; drops at arm end"),
  }
}

// Wildcard `_` on the tuple slot: NOT a moving arm. The constructed tuple's
// task ptr is non-null, so the synth enum drop frees it normally
// (Task[int].drop joins + frees).

test_match_tuple_handle_wildcard() `test(exclude: wasm) {
  h := TupHold.Pair((go worker_t0623(), 3));
  match h {
    TupHold.Empty => assert(false, "wrong arm"),
    TupHold.Pair(_) => assert(true, "wildcard: synth drop frees the tuple's task"),
  }
}
