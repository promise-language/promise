// Tuple tests: creation, destructuring, as return values.
// --- basic tuple creation ---
test_tuple_basic() `test {
  (int, string) pair = (42, "hello");
  (a, b) := pair;
  assert(a == 42, "first element is 42");
  assert(b == "hello", "second element is hello");
}

// --- tuple of same types ---

test_tuple_same_type() `test {
  (int, int) coords = (10, 20);
  (x, y) := coords;
  assert(x == 10, "x = 10");
  assert(y == 20, "y = 20");
}

// --- tuple returned from function ---

swap(int a, int b)(int, int) {
  return (b, a);
}

test_tuple_return() `test {
  (x, y) := swap(1, 2);
  assert(x == 2, "swapped first = 2");
  assert(y == 1, "swapped second = 1");
}

// --- tuple with bool ---

test_tuple_with_bool() `test {
  (bool, int) result = (true, 42);
  (ok, val) := result;
  assert(ok == true, "bool element");
  assert(val == 42, "int element");
}

// --- tuple in assignment ---

min_max(int a, int b)(int, int) {
  if a < b {
    return (a, b);
  }
  return (b, a);
}

test_min_max() `test {
  (lo, hi) := min_max(10, 3);
  assert(lo == 3, "min is 3");
  assert(hi == 10, "max is 10");

  (lo2, hi2) := min_max(5, 5);
  assert(lo2 == 5, "equal: min = 5");
  assert(hi2 == 5, "equal: max = 5");
}

// --- tuple of strings ---

test_tuple_strings() `test {
  (string, string) pair = ("hello", "world");
  (a, b) := pair;
  assert(a == "hello", "first string");
  assert(b == "world", "second string");
  string combined = a + " " + b;
  assert(combined == "hello world", "combined strings");
}

// --- tuple in loop ---

test_tuple_in_loop() `test {
  int sum_x = 0;
  int sum_y = 0;
  for i in 0..5 {
    (x, y) := (i, i * 2);
    sum_x += x;
    sum_y += y;
  }
  assert(sum_x == 10, "sum of x: 0+1+2+3+4 = 10");
  assert(sum_y == 20, "sum of y: 0+2+4+6+8 = 20");
}

// --- divmod function ---

divmod(int a, int b)(int, int) {
  return (a / b, a % b);
}

test_divmod() `test {
  (q, r) := divmod(17, 5);
  assert(q == 3, "17 / 5 = 3");
  assert(r == 2, "17 % 5 = 2");

  (q2, r2) := divmod(10, 3);
  assert(q2 == 3, "10 / 3 = 3");
  assert(r2 == 1, "10 % 3 = 1");
}

// --- tuple to_string (B0254: verify no leak from convertToString temps) ---

test_tuple_interpolation() `test {
  (int, int) pair = (1, 2);
  string s = "{pair}";
  assert(s == "(1, 2)", s);
}

// --- failable destructure with heap user type (B0263) ---

type Pt {
  int x;
  int y;
}

make_pt!() Pt {
  return Pt(x: 10, y: 20);
}

test_failable_destructure_no_leak() `test {
  (p, err) := make_pt();
  assert(err is absent, "no error");
  assert(p.x == 10, "x");
  assert(p.y == 20, "y");
}

fail_pt!() Pt {
  raise error(message: "fail");
}

test_failable_destructure_error_path() `test {
  (p, err) := fail_pt();
  assert(err is present, "should error");
}

// --- T0371: Tuple values with heap-tracked fields ownership ---
// All cases below previously leaked, double-freed, or returned UAF garbage.

type _T0371Box {
  int n;
}

// Case B: standalone tuple var with heap string concat (was leaking).
test_t0371_var_tuple_string_concat() `test {
  s := "a" + "b";
  (int, string) t = (1, s);
  (a, b) := t;
  assert(a == 1, "first");
  assert(b == "ab", "tuple held the concat result");
}

// Case D: inline tuple lit with heap string, then read after binding (was UAF).
test_t0371_inline_tuple_string_concat() `test {
  (int, string) t = (1, "a" + "b");
  (a, b) := t;
  assert(a == 1, "first");
  assert(b == "ab", "second survived destructure");
}

// Case E: direct destructure of inline tuple (was UAF).
test_t0371_destructure_inline() `test {
  (a, b) := (1, "a" + "b");
  assert(a == 1, "first");
  assert(b == "ab", "second survived inline destructure");
}

// Destructure of a variable-bound tuple that owns its fields.
test_t0371_destructure_var() `test {
  (int, string) t = (1, "a" + "b");
  (a, b) := t;
  assert(a == 1, "first");
  assert(b == "ab", "second");
}

// Case 1: standalone tuple var with heap user type (was leaking).
test_t0371_var_tuple_box() `test {
  (int, _T0371Box) t = (1, _T0371Box(n: 5));
  (a, b) := t;
  assert(a == 1, "first");
  assert(b.n == 5, "box field");
}

// Case A: vector-literal containing tuple-with-Box, variable case (was double-free).
test_t0371_vector_var_tuple_box() `test {
  (int, _T0371Box)[] v = [(1, _T0371Box(n: 5)), (2, _T0371Box(n: 10))];
  assert(v.len == 2, "vector len");
  int sum = 0;
  for tup in v {
    (i, b) := tup;
    sum = sum + b.n;
  }
  assert(sum == 15, "5 + 10 = 15");
}

// Vector of tuples with heap strings, bound to a variable.
test_t0371_vector_var_tuple_string() `test {
  (int, string)[] v = [(1, "a" + "b"), (2, "c" + "d")];
  assert(v.len == 2, "vector len");
  int total = 0;
  for tup in v {
    (i, s) := tup;
    total = total + s.len;
  }
  assert(total == 4, "ab + cd = 4 chars");
}

// Tuple returned from a function with heap string fields.
swap_str_t0371(string move a, string move b)(string, string) {
  return (b, a);
}

test_t0371_tuple_returned_from_func() `test {
  (x, y) := swap_str_t0371("hello", "world");
  assert(x == "world", "x");
  assert(y == "hello", "y");
}

// Nested tuple with a heap string at depth 1.
test_t0371_nested_tuple_string() `test {
  ((int, string), int) t = ((1, "a" + "b"), 3);
  (inner, c) := t;
  (a, b) := inner;
  assert(a == 1, "a");
  assert(b == "ab", "b");
  assert(c == 3, "c");
}

// Tuple containing a vector field — drop must walk and free the vector.
test_t0371_tuple_with_vector() `test {
  (int, string[]) t = (1, ["x", "y"]);
  (i, v) := t;
  assert(i == 1, "first");
  assert(v.len == 2, "vector len inside tuple");
}

// Vector of tuples with heap strings consumed via for-in (case 2 borrow path).
sum_lengths((int, string)[] v) int {
  int total = 0;
  for tup in v {
    (i, s) := tup;
    total = total + s.len;
  }
  return total;
}

test_t0371_for_in_destructure_borrow() `test {
  (int, string)[] v = [(1, "a" + "b"), (2, "c" + "d")];
  int n = sum_lengths(v);
  assert(n == 4, "ab + cd = 4");
}

// T0371: enum variant with tuple-of-string field. Pre-T0371 this leaked or
// UAF'd because sema's fieldTypeHasDrop didn't recurse into tuples, so the
// enum got no drop and the inner string was never freed. Fixed by making
// fieldTypeHasDrop and variantFieldNeedsDrop recurse into tuple elements.
enum _T0371Pair {
  _T0371Empty,
  _T0371Some((int, string) data),
}

test_t0371_enum_with_tuple_string() `test {
  s := _T0371Pair._T0371Some(data: (1, "a" + "b"));
  match s {
    _T0371Empty => assert(false, "should be some"),
    _T0371Some(d) => {
      (a, b) := d;
      assert(a == 1, "first");
      assert(b == "ab", "second");
    },
  };
}

// Deeply nested: vector of tuple-of-tuple-with-string.
test_t0371_vector_nested_tuple() `test {
  ((int, string), int)[] v = [((1, "a" + "b"), 3), ((2, "c" + "d"), 4)];
  assert(v.len == 2, "vector len");
  int sum = 0;
  for elem in v {
    (inner, c) := elem;
    sum = sum + c;
  }
  assert(sum == 7, "3 + 4 = 7");
}

// Tuple with a vector field whose elements are heap strings.
test_t0371_tuple_with_string_vec() `test {
  (int, string[]) t = (1, ["a" + "b", "c" + "d"]);
  (i, v) := t;
  assert(i == 1, "first");
  assert(v.len == 2, "vec len");
  assert(v[0] == "ab", "v[0]");
  assert(v[1] == "cd", "v[1]");
}

// Tuple variable reassignment must drop the old tuple's fields before storing
// the new value. Without proper bindingDropTuple dispatch in genAssignStmt,
// the old string would leak.
test_t0371_reassign_tuple_string() `test {
  (int, string) t = (1, "a" + "b");
  t = (2, "c" + "d");
  (a, b) := t;
  assert(a == 2, "reassigned int");
  assert(b == "cd", "reassigned string");
}

// Tuple element is an enum constructor with heap variant data. genTupleLit's
// savedEnumTemps loop must clear the enum-ctor temp's drop flag so the tuple
// is the unique owner of the enum's variant data. Without the loop, the enum
// ctor temp would be freed at stmt end while the tuple still references it.
enum _T0371Color {
  _T0371Red,
  _T0371Tagged(string label),
}

test_t0371_tuple_containing_enum_ctor() `test {
  (int, _T0371Color) t = (1, _T0371Color._T0371Tagged(label: "a" + "b"));
  (i, c) := t;
  assert(i == 1, "i");
  match c {
    _T0371Red => assert(false, "should be tagged"),
    _T0371Tagged(s) => assert(s == "ab", "label"),
  };
}

// Tuple containing a channel field. Drop walk must reach Channel.drop via
// emitVariantFieldDrop's channel branch; closing happens automatically on drop.
test_t0371_tuple_with_channel() `test {
  channel[int] ch = channel[int](capacity: 4);
  (int, channel[int]) t = (1, ch);
  (i, c) := t;
  c.send(42);
  assert(i == 1, "i");
}

// Move tuple variable into a function parameter. The receiving param takes
// ownership; the source's drop flag must be cleared so its scope-exit walk
// doesn't double-free.
take_t0371_tuple((int, string) move t) string {
  (a, b) := t;
  return b;
}

test_t0371_move_into_func() `test {
  (int, string) t = (1, "a" + "b");
  string s = take_t0371_tuple(move t);
  assert(s == "ab", "moved into func");
}

// Early return inside a function with a tuple var: emitEarlyDrops must
// dispatch bindingDropTuple so the tuple's heap fields are freed before
// the function returns.
maybe_early_t0371(bool flag) int {
  (int, string) t = (1, "a" + "b");
  if flag {
    return 99;
  }
  (a, b) := t;
  return a;
}

test_t0371_early_return_with_tuple_var() `test {
  assert(maybe_early_t0371(true) == 99, "early branch (drops tuple)");
  assert(maybe_early_t0371(false) == 1, "late branch (consumes tuple)");
}

// Break inside a loop with a tuple var per iteration: emitScopeCleanup must
// drop the tuple before exiting the loop body.
test_t0371_break_with_tuple_var() `test {
  int n = 0;
  for i in 0..10 {
    (int, string) t = (i, "a" + "b");
    n += i;
    if i == 3 {
      break;
    }
  }
  assert(n == 6, "0+1+2+3 = 6");
}

// Continue inside a loop with a tuple var: emitScopeCleanup must drop the
// tuple before continuing to the next iteration.
test_t0371_continue_with_tuple_var() `test {
  int n = 0;
  for i in 0..5 {
    (int, string) t = (i, "x" + "y");
    if i % 2 == 1 {
      continue;
    }
    n += i;
  }
  assert(n == 6, "0+2+4 = 6");
}

// Raise inside a failable function with a tuple var: scope cleanup on raise
// must drop the tuple's heap fields.
fail_with_t0371_tuple!() int {
  (int, string) t = (1, "a" + "b");
  raise error(message: "boom");
}

test_t0371_raise_with_tuple_var() `test {
  (n, err) := fail_with_t0371_tuple();
  assert(err is present, "should error");
}

// Conditional move: tuple consumed in one branch, dropped via dropflag in the
// other. Tests that emitTupleDropCall's flag check correctly suppresses the
// walk on the consumed branch and runs it on the unconsumed branch.
choose_or_drop_t0371(bool flag) string {
  (int, string) t = (1, "a" + "b");
  if flag {
    (a, b) := t;
    return b;
  }
  return "none";
}

test_t0371_conditional_move() `test {
  assert(choose_or_drop_t0371(true) == "ab", "consumed");
  assert(choose_or_drop_t0371(false) == "none", "dropped via flag");
}

// Pure-value tuple (all primitive fields) must NOT register a drop binding
// — tupleNeedsDrop returns false. Negative test (no leak, no perf hit).
test_t0371_pure_value_tuple_no_drop() `test {
  (int, int) t = (1, 2);
  (a, b) := t;
  assert(a == 1, "a");
  assert(b == 2, "b");
}

// Nested pure-value tuple — recursion in tupleNeedsDrop returns false.
test_t0371_pure_value_nested_tuple() `test {
  ((int, int), int) t = ((1, 2), 3);
  (inner, c) := t;
  (a, b) := inner;
  assert(a == 1, "a");
  assert(b == 2, "b");
  assert(c == 3, "c");
}

// Generic function with tuple-of-T local. Exercises emitTupleDropCall's
// typeSubst != nil branch: the tuple type's elements get substituted at
// monomorphization so the drop walk uses the concrete element types.
make_then_drop_t0371[T](T move x, T move y) {
  (T, T) t = (x, y);
}

test_t0371_generic_fn_tuple_local() `test {
  make_then_drop_t0371[string]("a" + "b", "c" + "d");
}

// T0370: heap string in tuple-element vector survives multiple reads.
// Without dup-on-read, the first read aliases v's element data; the
// destructure binding then drops the heap string, leaving v's element
// pointing into freed memory. The second v[0] read would segfault.
test_t0370_heap_string_repeated_read() `test {
  v := (string, int)[]();
  v.push(("first".to_string(), 100));
  v.push(("second".to_string(), 200));
  t := v[0];
  (s, n) := t;
  assert(s == "first", "first read string");
  assert(n == 100, "first read int");
  t0 := v[0];
  (s0, n0) := t0;
  assert(s0 == "first", "second read string");
  assert(n0 == 100, "second read int");
}

// T0370: tuple with two heap-string elements — both fields need dup.
test_t0370_two_heap_strings() `test {
  v := (string, string)[]();
  v.push(("a" + "b", "c" + "d"));
  t := v[0];
  (s1, s2) := t;
  assert(s1 == "ab", "s1");
  assert(s2 == "cd", "s2");
}

// T0370: tuple with vector element — vector field also needs dup.
test_t0370_tuple_with_vector_elem() `test {
  v := (string, int[])[]();
  vec := int[]();
  vec.push(1);
  vec.push(2);
  v.push(("hello".to_string(), vec));
  t := v[0];
  (s, ints) := t;
  assert(s == "hello", "string");
  assert(ints.len == 2, "vec len");
}

// T0370: nested tuple in vector — inner tuple's heap fields need recursive dup.
test_t0370_nested_tuple_vec() `test {
  v := ((string, int), int)[]();
  v.push((("first".to_string(), 1), 10));
  t := v[0];
  (inner, outer) := t;
  (s, n) := inner;
  assert(s == "first", "nested string");
  assert(n == 1, "nested int");
  assert(outer == 10, "outer");
}

// T0370: function returning a tuple-vec, then reading multiple elements.
make_pairs_t0370()(string, int)[] {
  v := (string, int)[]();
  v.push(("x".to_string(), 1));
  v.push(("y".to_string(), 2));
  return v;
}

test_t0370_returned_tuple_vec_reread() `test {
  v := make_pairs_t0370();
  t := v[0];
  (s, n) := t;
  assert(s == "x", "first");
  assert(n == 1, "first int");
  t1 := v[1];
  (s1, n1) := t1;
  assert(s1 == "y", "second");
  assert(n1 == 2, "second int");
}

// T0370: typed var decl path — `(string, int) t = v[0];` (vs the inferred `:=`).
// genTypedVarDecl sets dupTupleFieldAccess just like genInferredVarDecl.
test_t0370_typed_var_decl() `test {
  v := (string, int)[]();
  v.push(("a" + "b", 1));
  (string, int) t = v[0];
  (s, n) := t;
  assert(s == "ab", "first");
  assert(n == 1, "first int");
  (string, int) t2 = v[0];
  (s2, n2) := t2;
  assert(s2 == "ab", "second");
  assert(n2 == 1, "second int");
}

// T0370: tuple with channel field in vector — dupTupleValue delegates to
// maybeDupPushElement which dups channel via dupChannel (refcount inc).
test_t0370_tuple_with_channel_vec() `test {
  v := (string, channel[int])[]();
  ch := channel[int](capacity: 4);
  v.push(("hello".to_string(), ch));
  t := v[0];
  (s, c) := t;
  c.send(42);
  assert(s == "hello", "string");
}

// T0370: tuple with droppable enum field in vector — dupTupleValue delegates
// to maybeDupPushElement which dups enum via cloneEnumValue / dupEnumElementInPlace.
enum _T0370EnumTag {
  _T0370Plain,
  _T0370Tagged(string label),
}

test_t0370_tuple_with_enum_vec() `test {
  v := (int, _T0370EnumTag)[]();
  v.push((1, _T0370EnumTag._T0370Tagged(label: "x" + "y")));
  t := v[0];
  (i, c) := t;
  match c {
    _T0370Plain => assert(false, "should be tagged"),
    _T0370Tagged(s) => assert(s == "xy", "label"),
  };
  assert(i == 1, "i");
}

// T0370: tuple with heap user-type field in vector — dupTupleValue delegates
// to maybeDupPushElement which dups via cloneHeapElement (memcpy + sub-field dup).
type _T0370Box {
  string label;
  drop(~this) {
  }
}

test_t0370_tuple_with_heap_user_vec() `test {
  v := (int, _T0370Box)[]();
  v.push((1, _T0370Box(label: "a" + "b")));
  t := v[0];
  (i, b) := t;
  assert(i == 1, "i");
  assert(b.label == "ab", "box label");
}

// T0370: generic function reading tuple from vector — exercises typeSubst != nil
// branch in dupTupleValue so the substituted concrete element type is used.
read_first_t0370[T]((string, T)[] move v) string {
  t := v[0];
  (s, _) := t;
  return s;
}

test_t0370_generic_read_from_tuple_vec() `test {
  v := (string, int)[]();
  v.push(("a" + "b", 99));
  s := read_first_t0370[int](move v);
  assert(s == "ab", "generic read");
}

// T0370: for-in over tuple-vec borrow path is unaffected by the fix —
// dupTupleFieldAccess flag is not set in that path so no duplicate dup happens.
// Regression guard.
test_t0370_for_in_no_regression() `test {
  v := (string, int)[]();
  v.push(("a" + "b", 1));
  v.push(("c" + "d", 2));
  int total = 0;
  string concat = "";
  for tup in v {
    (s, n) := tup;
    concat += s;
    total += n;
  }
  assert(total == 3, "total");
  assert(concat == "abcd", "concat");
}

// T0399: v2.push(v[i]) for Vector[(string, int)] must deep-clone the tuple.
// Without dup, both vectors alias the same heap-string pointers; when v drops
// at the inner block end, v2's elements point into freed memory.
test_t0399_push_indexed_heap_string() `test {
  v2 := (string, int)[]();
  {
    v := (string, int)[]();
    v.push(("a" + "b", 1));
    v.push(("c" + "d", 2));
    v2.push(v[0]);
    v2.push(v[1]);
  }
  t := v2[0];
  (s, n) := t;
  assert(s == "ab", "v2[0] string survived");
  assert(n == 1, "v2[0] int");
  t1 := v2[1];
  (s1, n1) := t1;
  assert(s1 == "cd", "v2[1] string survived");
  assert(n1 == 2, "v2[1] int");
}

// T0399: two heap-string fields.
test_t0399_push_indexed_two_heap_strings() `test {
  v2 := (string, string)[]();
  {
    v := (string, string)[]();
    v.push(("a" + "b", "c" + "d"));
    v2.push(v[0]);
  }
  t := v2[0];
  (s1, s2) := t;
  assert(s1 == "ab", "first");
  assert(s2 == "cd", "second");
}

// T0399: vector field inside the tuple.
test_t0399_push_indexed_tuple_with_vector() `test {
  v2 := (string, int[])[]();
  {
    v := (string, int[])[]();
    inner := int[]();
    inner.push(10);
    inner.push(20);
    v.push(("hello".to_string(), inner));
    v2.push(v[0]);
  }
  t := v2[0];
  (s, ints) := t;
  assert(s == "hello", "string");
  assert(ints.len == 2, "vec len");
  assert(ints[0] == 10, "vec[0]");
  assert(ints[1] == 20, "vec[1]");
}

// T0399: nested tuple.
test_t0399_push_indexed_nested_tuple() `test {
  v2 := ((string, int), int)[]();
  {
    v := ((string, int), int)[]();
    v.push((("first".to_string(), 1), 10));
    v2.push(v[0]);
  }
  t := v2[0];
  (inner, outer) := t;
  (s, n) := inner;
  assert(s == "first", "nested string");
  assert(n == 1, "nested int");
  assert(outer == 10, "outer");
}

// T0399: slice push via for-in — exercises slice-element walk.
test_t0399_for_in_slice_push() `test {
  v2 := (string, int)[]();
  {
    v := (string, int)[]();
    v.push(("a" + "b", 1));
    v.push(("c" + "d", 2));
    // T0978: a for-in binding aliases the slice's element storage, so moving it
    // into v2 (`v2.push(elem)`) would double-free at the slice temp's drop. Drain
    // the slice with `.pop()`, which transfers ownership of each element.
    slice := v[0:1];
    while slice.len > 0 {
      v2.push(slice.pop()!);
    }
  }
  t := v2[0];
  (s, n) := t;
  assert(s == "ab", "slice push string");
  assert(n == 1, "slice push int");
}

// T0441: 3-element tuple destructure (grammar fix — was parser error).
test_t0441_three_element_destructure() `test {
  t := ("a", "b", "c");
  (s1, s2, s3) := t;
  assert(s1 == "a", "s1");
  assert(s2 == "b", "s2");
  assert(s3 == "c", "s3");
}

// T0441: 4-element tuple destructure.
test_t0441_four_element_destructure() `test {
  t := (1, 2, 3, 4);
  (a, b, c, d) := t;
  assert(a == 1, "a");
  assert(b == 2, "b");
  assert(c == 3, "c");
  assert(d == 4, "d");
}

// T0441: 3-element tuple returned from a function.
triple(int x)(int, int, int) {
  return (x, x * 2, x * 3);
}

test_t0441_three_element_from_func() `test {
  (a, b, c) := triple(3);
  assert(a == 3, "a");
  assert(b == 6, "b");
  assert(c == 9, "c");
}

// T0441: 3-element tuple with mixed types.
test_t0441_three_element_mixed_types() `test {
  t := (42, "hello", true);
  (n, s, flag) := t;
  assert(n == 42, "int");
  assert(s == "hello", "string");
  assert(flag == true, "bool");
}

// T0399: re-push a droppable tuple variable in a loop. First iteration moves;
// subsequent iterations hit the IdentExpr-with-drop-flag dup branch (line
// 4520). Without `pushElemNeedsDup`'s tuple branch, the runtime CFG isn't
// generated and the re-pushed slots alias the moved-out tuple's heap fields,
// crashing with "invalid free" on Vector.drop. Sibling to Vector.filled.
test_t0399_repush_owned_tuple_loop() `test {
  v := (string, int)[]();
  t := ("hello".to_string(), 42);
  int i = 0;
  while i < 3 {
    v.push(move t);
    i = i + 1;
  }
  assert(v.len == 3, "len");
  e0 := v[0];
  (s0, n0) := e0;
  assert(s0 == "hello", "v[0] string");
  assert(n0 == 42, "v[0] int");
  e2 := v[2];
  (s2, n2) := e2;
  assert(s2 == "hello", "v[2] string");
  assert(n2 == 42, "v[2] int");
}

// T0420: generic constructor with tuple-of-heap-user TypeArg. Pre-fix this
// panicked in codegen with "store operands are not compatible" because
// instanceFieldLLVMType lowered the heap user element inside the tuple to
// bare i8* via llvmType, while the expression-side resolveType produced the
// full {i8*, i8*} value struct.
type _T0420BoxT[T] {
  T value;
}
type _T0420Inner {
  string s;
}

test_t0420_generic_tuple_heap_user() `test {
  _T0420BoxT[(int, _T0420Inner)] b = _T0420BoxT[(int, _T0420Inner)](value: (7, _T0420Inner(s: "x" + "y")));
  (n, inner) := b.value;
  assert(n == 7, "first");
  assert(inner.s == "xy", "heap user inside tuple");
}

// T0420: tuple with two droppable elements (string + heap user) inside generic.
test_t0420_generic_tuple_string_heap_user() `test {
  _T0420BoxT[(string, _T0420Inner)] b = _T0420BoxT[(string, _T0420Inner)](value: ("hi" + "!", _T0420Inner(s: "a" + "b")));
  (s, inner) := b.value;
  assert(s == "hi!", "first");
  assert(inner.s == "ab", "second heap user");
}

// T0420: vector inside tuple TypeArg — element type must lower correctly.
test_t0420_generic_tuple_vector() `test {
  _T0420BoxT[(int, string[])] b = _T0420BoxT[(int, string[])](value: (1, ["a" + "b", "c" + "d"]));
  (n, v) := b.value;
  assert(n == 1, "first");
  assert(v.len == 2, "vec len");
  assert(v[0] == "ab", "vec[0]");
  assert(v[1] == "cd", "vec[1]");
}

// T0420 coverage: nested tuple inside tuple TypeArg — exercises recursive
// tuple lowering in instanceFieldLLVMType and recursive drop in
// emitVariantFieldDrop.
test_t0420_generic_nested_tuple() `test {
  _T0420BoxT[((int, _T0420Inner), string)] b = _T0420BoxT[((int, _T0420Inner), string)](value: ((1, _T0420Inner(s: "a" + "b")), "c" + "d"));
  (inner_pair, s) := b.value;
  (n, inner) := inner_pair;
  assert(n == 1, "nested first");
  assert(inner.s == "ab", "nested heap user");
  assert(s == "cd", "outer string");
}

// T0420 coverage: tuple-of-primitives TypeArg — negative case. Field type
// lowering must still recurse into the tuple (mismatch would also panic),
// but no synth drop should be generated.
test_t0420_generic_tuple_all_primitives() `test {
  _T0420BoxT[(int, bool)] b = _T0420BoxT[(int, bool)](value: (42, true));
  (n, flag) := b.value;
  assert(n == 42, "primitive int");
  assert(flag == true, "primitive bool");
}

// --- T0406: plain tuple-by-value parameters with droppable fields ---
// Tuple construction at the call site clears source drop flags (the tuple
// takes ownership of its elements). Without a callee-side drop binding, the
// heap data is orphaned. These tests verify the callee drops correctly.

_t0406_take_tuple_param((string, int) t) {
}

test_t0406_tuple_param_drop() `test {
  _t0406_take_tuple_param(("hello".to_string(), 42));
}

_t0406_take_tuple_typed[T](T value) {
}

test_t0406_generic_tuple_param_drop() `test {
  _t0406_take_tuple_typed[(string, int)](("hello".to_string(), 42));
}

test_t0406_vector_filled_droppable_tuple() `test {
  (string, int)[] v = Vector[(string, int)].filled(("x".to_string(), 1), 0);
  assert(v.len == 0, "empty filled vector");
}

_t0406_take_nested_tuple(((string, int), int) t) {
}

test_t0406_nested_tuple_param_drop() `test {
  _t0406_take_nested_tuple((("hi".to_string(), 1), 2));
}

_t0406_take_tuple_with_vector((string, int[]) t) {
}

test_t0406_tuple_with_vector_param() `test {
  int[] xs = [1, 2, 3];
  _t0406_take_tuple_with_vector(("hi".to_string(), xs));
}

_t0406_use_field((string, int) t) {
  // Borrow access via destructuring — string is moved out, int is primitive.
  (s, n) := t;
  assert(n == 42, "param int field");
  assert(s == "hello", "param string field");
}

test_t0406_use_param_then_exit() `test {
  _t0406_use_field(("hello".to_string(), 42));
}

// Site 4 non-mono path: non-generic method on user type.
// `Vector.filled` covers Site 4 with substitution; this covers Site 4 without.
type _T0406Holder {
  int counter;
  consume(~this, (string, int) t) {
    (s, n) := t;
    this.counter = this.counter + n + s.len;
  }
}

test_t0406_user_method_tuple_param() `test {
  h := _T0406Holder(counter: 0);
  h.consume(("hello".to_string(), 42));
  assert(h.counter == 47, "method updated counter (5 + 42)");
}

// Generic user type with non-generic method taking a tuple-with-typevar param.
// Exercises Site 4 mono path with substitution-inside-tuple (Vector.filled has
// substitution-equals-tuple).
type _T0406GBox[T] {
  T value;
  set_pair(~this, (string, T) p) {
    (s, v) := p;
    this.value = v;
    assert(s.len > 0, "string moved into local");
  }
}

test_t0406_generic_user_method_tuple_typevar() `test {
  b := _T0406GBox[int](value: 0);
  b.set_pair(("hello".to_string(), 7));
  assert(b.value == 7, "set_pair updated value");
}

// T0481: `(_, n) := t` with an owned tuple source must drop the discarded
// heap field. Without the fix, the source's drop flag is cleared (transfer
// to LHS) but the `_` slot has no owner → memory leak.

test_t0481_discard_at_index_0() `test {
  t := ("hello".to_string(), 42);
  (_, n) := t;
  assert(n == 42, "second field destructured");
}

test_t0481_discard_at_index_1() `test {
  t := (42, "hello".to_string());
  (n, _) := t;
  assert(n == 42, "first field destructured");
}

test_t0481_three_element_double_discard() `test {
  t := ("a".to_string(), "b".to_string(), 42);
  (_, _, n) := t;
  assert(n == 42, "third field destructured, two strings discarded");
}

_t0481_take((string, int) t) {
  (_, n) := t;
  assert(n == 42, "param destructure with discard");
}

test_t0481_param_destructure_discard() `test {
  _t0481_take(("hello".to_string(), 42));
}

test_t0481_borrow_source_discard() `test {
  (string, int)[] v = [("hello".to_string(), 5), ("world".to_string(), 7)];
  int total = 0;
  for tup in v {
    (_, n) := tup;
    total = total + n;
  }
  assert(total == 12, "borrowed destructure with discard");
}

// T0481: Discard a heap user type. Exercises the named-type drop path
// in maybeRegisterDrop (Type.drop instead of promise_string_drop).
type _T0481Box {
  string label;
}

test_t0481_discard_user_type() `test {
  t := (_T0481Box(label: "discarded".to_string()), 42);
  (_, n) := t;
  assert(n == 42, "user type discarded, int kept");
}

// T0481: Discard a vector. Exercises Vector.drop instead of promise_string_drop.
test_t0481_discard_vector() `test {
  (string[], int) t = (["a" + "b", "c" + "d"], 99);
  (_, n) := t;
  assert(n == 99, "vector discarded, int kept");
}

// T0481: Discard a nested tuple. Exercises the tupdrop path in maybeRegisterDrop
// — the discarded slot is itself a tuple and must walk its inner droppable fields.
test_t0481_discard_nested_tuple() `test {
  inner := ("inner".to_string(), 7);
  outer := (inner, 42);
  (_, n) := outer;
  assert(n == 42, "nested tuple discarded, int kept");
}

// T0481: Middle-position discard with droppable fields on both sides ensures
// indices around `_` aren't disturbed by the synthetic-key insertion.
test_t0481_discard_middle() `test {
  t := ("first".to_string(), "middle".to_string(), "third".to_string());
  (a, _, c) := t;
  assert(a == "first", "first kept");
  assert(c == "third", "third kept");
}

// T0481: Function-call source. `s.Value` is a *ast.CallExpr (not IdentExpr),
// so the trailing clearDropFlag(ident) is skipped — discarded slot must still
// own and free its piece via the registered drop binding.
_t0481_returns_pair()(string, int) {
  return ("call_result".to_string(), 33);
}

test_t0481_discard_call_source() `test {
  (_, n) := _t0481_returns_pair();
  assert(n == 33, "call-source destructure with discard");
}

// T0481: Tuple-literal source — `s.Value` is a *ast.TupleLitExpr directly,
// not an IdentExpr. genTupleLit's per-element-claim path plus the discard
// drop binding must cover the heap field.
test_t0481_discard_tuple_literal_source() `test {
  (_, n) := ("literal".to_string(), 17);
  assert(n == 17, "literal-source destructure with discard");
}

// ===========================================================================
// T1233: A tuple holding heap-owning fields (a capturing closure, a heap
// string, a vector) passed by value to a PLAIN (borrow) tuple param must be
// owned by the CALLER — the callee borrows it. Before the fix a plain tuple
// param registered a callee-side drop (T0406) while the ownership checker still
// let the caller reuse/own the tuple, so the two co-owned it: a double-free
// (hard crash for a closure env, silent UB for strings/vectors). Also, a
// capturing closure destructured out of an owned tuple never got an env-free
// binding, leaking its heap env. These tests lock in single-free + zero-leak.
// ===========================================================================

_t1233_make_adder(int x)() -> int {
  return move || -> x + 1;
}
_t1233_make_str_pair()(string, int) {
  return ("t1233" + " heap", 1);
}
_t1233_make_vec_pair()(int[], int) {
  return ([1, 2, 3], 1);
}
_t1233_take_closure_tuple((() -> int, int) t) {
}
_t1233_take_str_tuple((string, int) t) {
}
_t1233_take_vec_tuple((int[], int) t) {
}

// (a) Destructure a closure out of an owned tuple — the env must be freed once
// via the destructured local's bindingFreeEnv (was a leak).
_t1233_destructure_closure() `test {
  (() -> int, int) t = (_t1233_make_adder(6), 1);
  (g, n) := t;
  assert(g() == 7, "destructured closure returns x+1");
  assert(n == 1, "int element kept");
}

// (d) Pass an owned closure-tuple VARIABLE to a plain param — the callee
// borrows, the caller's own drop frees it once (was a double-free crash).
_t1233_pass_closure_var() `test {
  (() -> int, int) t = (_t1233_make_adder(6), 1);
  _t1233_take_closure_tuple(t);
}

// (e) Reuse an owned closure-tuple after passing it to a borrow param — the
// ownership model permits reuse; a callee-drop would have crashed on the 2nd
// pass (env already freed).
_t1233_reuse_closure_var() `test {
  (() -> int, int) t = (_t1233_make_adder(6), 1);
  _t1233_take_closure_tuple(t);
  _t1233_take_closure_tuple(t);
}

// (f) Pass a closure-tuple LITERAL to a plain param — no owning caller variable,
// so a caller-side statement temp frees the env once after the call returns.
_t1233_pass_closure_literal() `test {
  _t1233_take_closure_tuple((_t1233_make_adder(6), 1));
}

// A borrowed closure-tuple param destructured INSIDE the callee must NOT get an
// owning env-free — the caller owns the tuple. Proves Stage 1 fires only for
// genuinely-owned sources.
_t1233_destructure_borrowed((() -> int, int) t) {
  (g, n) := t;
  assert(g() == 7, "borrowed destructure reads closure");
  assert(n == 1, "int kept");
}
_t1233_borrowed_destructure_no_double_free() `test {
  (() -> int, int) t = (_t1233_make_adder(6), 1);
  _t1233_destructure_borrowed(t);
}

// A closure-tuple moved into a `move` (consume) param — the callee owns and
// drops it exactly once (the RefMut path keeps callee-drop).
_t1233_consume_closure_tuple((() -> int, int) move t) {
  (g, n) := t;
  assert(g() == 7, "consumed closure reads");
  assert(n == 1, "int kept");
}
_t1233_move_consume() `test {
  (() -> int, int) t = (_t1233_make_adder(6), 1);
  _t1233_consume_closure_tuple(move t);
}

// String analogs of d/e/f — previously a silent double-free (glibc-tolerated);
// now provably single-free under the borrow model.
_t1233_str_reuse_var() `test {
  (string, int) t = _t1233_make_str_pair();
  _t1233_take_str_tuple(t);
  _t1233_take_str_tuple(t);
}
_t1233_str_literal() `test {
  _t1233_take_str_tuple(("t1233" + " lit", 1));
}
_t1233_str_call_result() `test {
  _t1233_take_str_tuple(_t1233_make_str_pair());
}

// Vector analogs of d/e/f.
_t1233_vec_reuse_var() `test {
  (int[], int) t = _t1233_make_vec_pair();
  _t1233_take_vec_tuple(t);
  _t1233_take_vec_tuple(t);
}
_t1233_vec_literal() `test {
  _t1233_take_vec_tuple(([9, 8, 7], 1));
}

// Loop with a fresh droppable tuple literal each iteration — the caller temp's
// drop flag must be reset after each drop so a reused temp isn't double-freed.
_t1233_loop_literal() `test {
  for i in 0..3 {
    _t1233_take_str_tuple(("iter" + " str", i));
  }
  assert(true, "loop of droppable tuple literals — no double-free");
}

// Nested tuple containing a closure-tuple, passed as a literal.
_t1233_take_nested(((() -> int, int), int) t) {
}
_t1233_nested_literal() `test {
  _t1233_take_nested(((_t1233_make_adder(6), 1), 2));
}

// Bare droppable-tuple expression statements (discarded) — genTupleLit claims
// each element into the aggregate, so the discarded aggregate must be dropped
// field-wise at statement end (was a leak).
_t1233_bare_str_literal() `test {
  ("bare" + " str", 1);
  assert(true, "bare tuple literal statement — no leak");
}
_t1233_bare_call_result() `test {
  _t1233_make_str_pair();
  assert(true, "bare tuple-returning call statement — no leak");
}
_t1233_bare_closure_literal() `test {
  (_t1233_make_adder(6), 1);
  assert(true, "bare closure-tuple literal statement — no leak");
}

// Bare-DISCARD of a BORROWED tuple (mirror of the arg-passing borrow cases): a
// discarded struct-field read (`h.t;`) and a discarded owned-variable statement
// (`v;`) are borrows — dropDiscardedTuple's tupleArgIsCallerOwnedTemp returns
// false, so NO caller temp is registered. A stray drop here would double-free
// against the holder's field drop / the variable's own bindingDropTuple. The
// owner stays live and usable afterward. Exercises dropDiscardedTuple's borrow
// early-return arm, which the bare-literal discards above do not reach.
_t1233_bare_field_discard_borrow() `test {
  h := _T1233Holder(t: ("c" + "d", 2));
  h.t;
  (s, n) := h.t;
  assert(s == "cd", "holder still owns the tuple field after bare discard");
  assert(n == 2, "int element intact");
}
_t1233_bare_ident_discard_borrow() `test {
  (string, int) v = ("e" + "f", 3);
  v;
  (s, n) := v;
  assert(s == "ef", "variable still owns the tuple after bare discard");
  assert(n == 3, "int element intact");
}

// A generator's by-value tuple param is copied into its coroutine frame and read
// LAZILY during iteration — a lifetime that outlives the call statement. A tuple
// TEMP (literal / call result with heap fields) passed to a generator must NOT be
// dropped at statement end (a use-after-free — the generator reads freed heap
// during iteration); it gets a SCOPE-level owned drop instead. These tests read
// the tuple's HEAP fields (string concat, closure call) across iteration so a
// premature free manifests (corrupted length → OOM, or a freed env). Regression
// guards: the modified generator test read only the int field and missed this.
_t1233_gen_str((string, int) t) stream[string] {
  (s, n) := t;
  for i in 0..n {
    yield s + "!";
  }
}
_t1233_gen_closure((() -> int, int) t) stream[int] {
  (g, n) := t;
  for i in 0..n {
    yield g();
  }
}

// (g1) String-tuple LITERAL with a heap concat, passed to a generator, read each
// iteration. Statement-end drop would free the string before iteration → UAF.
_t1233_gen_string_literal() `test {
  out := [""];
  for x in _t1233_gen_str(("t1233" + " heap", 3)) {
    out.push(move x);
  }
  assert(out.len == 4, "3 yields + initial");
  assert(out[1] == "t1233 heap!", "heap string valid during iteration");
  assert(out[3] == "t1233 heap!", "still valid on last iteration");
}

// (g2) String-tuple CALL RESULT passed to a generator — same lifetime hazard.
_t1233_gen_string_call() `test {
  out := [""];
  for x in _t1233_gen_str(_t1233_make_str_pair()) {
    out.push(move x);
  }
  assert(out[1] == "t1233 heap!", "call-result heap string valid during iteration");
}

// (g3) Closure-tuple LITERAL passed to a generator, invoked each iteration. The
// heap env must survive until the stream is exhausted (scope-level drop), not be
// freed at statement end.
_t1233_gen_closure_literal() `test {
  sum := 0;
  for x in _t1233_gen_closure((_t1233_make_adder(6), 3)) {
    sum += x;
  }
  assert(sum == 21, "3 * (6+1)");
}

// (g4) Owned closure-tuple VARIABLE passed to a generator — a borrow: the caller's
// own scope-level drop keeps it alive; the generator must not also drop (would be
// a double-free crash for the env). The variable stays usable afterward.
_t1233_gen_closure_var() `test {
  (() -> int, int) t = (_t1233_make_adder(6), 2);
  sum := 0;
  for x in _t1233_gen_closure(t) {
    sum += x;
  }
  (g, n) := t;
  assert(sum == 14, "2 * 7");
  assert(g() == 7, "variable still usable after generator borrow");
}

// An owned tuple is also produced (as a FRESH value the caller must free) by a
// getter and by a user-defined non-native `[]` operator. Passing such a result
// directly to a plain (borrow) tuple param is a caller temp — not a borrow like
// a plain field read or a native container index — so the caller drops it once
// after the call. Without the owned-return exemption in
// tupleArgIsCallerOwnedTemp these leak (the callee no longer drops, T1233).
type _T1233Box {
  string s;
  // user-defined index returns a fresh owned tuple
  [](int i)(string, int) {
    return (this.s + "!", i);
  }
  // getter returns a fresh owned tuple
  get pair(string, int) {
    return (this.s + "?", 5);
  }
  // method returning a two-string tuple (LLVM {i8*,i8*})
  ss(int i)(string, string) {
    return (this.s + "a", this.s + "b");
  }
}
_t1233_take_si((string, int) t) {
}
_t1233_take_ss((string, string) t) {
}
_t1233_user_index_owned_arg() `test {
  b := _T1233Box(s: "hi");
  _t1233_take_si(b[0]);
}
_t1233_getter_owned_arg() `test {
  b := _T1233Box(s: "hi");
  _t1233_take_si(b.pair);
}
// Two-string tuple result has LLVM type {i8*,i8*} — the same shape as a heap
// user-type value struct. Confirms the caller tuple temp does not double-free
// against any stray heap-value tracking of the operator/getter result.
_t1233_two_string_owned_arg() `test {
  b := _T1233Box(s: "hi");
  _t1233_take_ss(b.ss(0));
}

// ---------------------------------------------------------------------------
// Coverage completion for the tupleArgIsCallerOwnedTemp BORROW branches and the
// error-path temp cleanup arm. The tests above only exercised the OWNED-temp
// branches (literal/call default, user `[]`, getter). These lock in the mirror
// cases where the tuple is a genuine BORROW (no caller temp → the container /
// owner frees it once) plus the failable error path.
// ---------------------------------------------------------------------------

// A native container index (`v[i]`) of a tuple aliases storage the vector owns —
// isUserIndexExpr is false, so tupleArgIsCallerOwnedTemp returns false and NO
// caller temp is registered. A stray caller drop here would double-free against
// the vector's element walk. Passing (no double-free) + the vector still owning
// the live element afterward proves the borrow path.
_t1233_native_index_borrow() `test {
  (string, int)[] v = [("a" + "b", 1)];
  _t1233_take_si(v[0]);
  (s, n) := v[0];
  assert(s == "ab", "vector still owns the indexed tuple element");
  assert(n == 1, "int element intact");
}

// A plain struct field read (`h.t`) of a tuple is a borrow — isGetterCallExpr is
// false, so no caller temp. A stray caller drop would double-free against the
// holder's field drop. The holder still owns the field after the call.
type _T1233Holder {
  (string, int) t;
}
_t1233_field_read_borrow() `test {
  h := _T1233Holder(t: ("c" + "d", 2));
  _t1233_take_si(h.t);
  (s, n) := h.t;
  assert(s == "cd", "holder still owns the tuple field");
  assert(n == 2, "int element intact");
}

// A droppable tuple-literal temp passed to a FAILABLE callee that raises: on the
// error-propagation path the caller must still drop the temp exactly once
// (emitStmtTempCleanupForErrorPath's tuple arm, not just cleanupStmtTemps). The
// non-error path is covered by the cases above; this exercises the error arm so
// the heap string in the arg isn't leaked when the call unwinds.
_t1233_take_si_fail!((string, int) t) int {
  raise error(message: "t1233 boom");
}
_t1233_prop_through!() int {
  return _t1233_take_si_fail(("err" + " path", 1));
}
_t1233_error_path_temp_drop() `test {
  _t1233_prop_through()? e {
    assert(e.message == "t1233 boom", "error propagated through failable tuple-arg call");
    return;
  };
  assert(false, "failable call should have raised");
}

// ---------------------------------------------------------------------------
// Monomorphized (generic) tuple temps. Inside a generic body the tuple type is
// `(T, int)` with a TypeParam field; registerTupleStmtTemp / emitTupleTempDrop /
// dropDiscardedTuple all run with c.typeSubst active, so the tuple type must be
// substituted (T → the concrete droppable type) before the field-wise drop walk.
// The non-generic cases above never exercise that substitution branch. These
// instantiate the same generic with two different heap element types so the
// per-instance drop walk (string vs vector) is monomorphized and leak-checked.
// ---------------------------------------------------------------------------
_t1233_gwrap[T]((T, int) t) {
}
// generic caller: builds a `(T, int)` tuple LITERAL temp (the T field a fresh
// droppable value from the maker), passed to a borrow param → caller drops it
// once at statement end (registerTupleStmtTemp under typeSubst; emitTupleTempDrop
// substitutes T → the concrete droppable type before the field-wise walk).
_t1233_gpass[T](() -> T make) {
  _t1233_gwrap[T]((make(), 1));
}
_t1233_gmake[T](() -> T make)(T, int) {
  return (make(), 1);
}
// generic bare-discard: a discarded call returning `(T, int)` → dropDiscardedTuple
// registers it under typeSubst; freed field-wise at statement end.
_t1233_gdiscard[T](() -> T make) {
  _t1233_gmake[T](make);
}
_t1233_generic_tuple_temp() `test {
  _t1233_gpass[string](|| -> "g" + "en"); // T = string (heap element)
  _t1233_gpass[int[]](|| -> [1, 2, 3]); // T = int[] (heap vector element)
}
_t1233_generic_bare_discard() `test {
  _t1233_gdiscard[string](|| -> "dis" + "card"); // T = string
  _t1233_gdiscard[int[]](|| -> [4, 5, 6]); // T = int[]
}
