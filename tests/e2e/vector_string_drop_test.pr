// B0189: Vector[string] element drop tests.
// Verifies that string elements inside vectors are properly freed when the
// vector is dropped, preventing memory leaks.
// Basic: split result vector drops its string elements.
test_split_drop() `test {
  string[] parts = "hello,world,foo".split(",");
  assert(parts.len == 3, "split len");
  assert(parts[0] == "hello", "first");
  assert(parts[1] == "world", "second");
  assert(parts[2] == "foo", "third");
}

// Shared strings between vectors: dup-on-push prevents double-free.
test_shared_strings() `test {
  string[] source = "a,b,c".split(",");
  string[] dest = string[]();
  int i = 0;
  while i < source.len {
    dest.push(source[i]);
    i = i + 1;
  }
  assert(dest.len == 3, "dest len");
  assert(dest[0] == "a", "dest first");
  assert(dest[2] == "c", "dest third");
}

// Push string literals into vector.
test_push_literals() `test {
  string[] v = string[]();
  v.push("hello");
  v.push("world");
  assert(v.len == 2, "len");
  assert(v[0] == "hello", "first");
}

// Push string concat temps into vector.
test_push_concat_temps() `test {
  string[] v = string[]();
  v.push("hello" + " " + "world");
  v.push("foo" + "bar");
  assert(v.len == 2, "len");
  assert(v[0] == "hello world", "first");
}

// Remove drops the removed string element.
test_remove_drops_element() `test {
  string[] v = string[]();
  v.push("alice");
  v.push("bob");
  v.push("charlie");
  v.remove(1);
  assert(v.len == 2, "len after remove");
  assert(v[0] == "alice", "first after remove");
  assert(v[1] == "charlie", "second after remove");
}

// Normalize-like pattern: pop + push between two vectors.
// B0196: pop() discarded result is now dropped by dropDiscardedOptionalString.
test_normalize_pattern() `test {
  string[] parts = "a,b,c,d".split(",");
  string[] result = string[]();
  int i = 0;
  while i < parts.len {
    string part = parts[i];
    if part == "c" {
      result.pop();
    } else {
      result.push(part);
    }
    i = i + 1;
  }
  assert(result.len == 2, "result len");
  assert(result[0] == "a", "result first");
  assert(result[1] == "d", "result second");
}

// Return string from function with vector in scope.
_first_part(string input) string {
  string[] parts = input.split(",");
  if parts.len > 0 {
    return parts[0];
  }
  return "";
}

test_return_from_vector_scope() `test {
  string result = _first_part("hello,world");
  assert(result == "hello", "returned first part");
}

// T0364 regression: vector literal with heap (concat-result) element.
// Without T0366's claimStringTemp in genArrayLit, the concat temp would be
// freed at end-of-statement while the vector slot still points at it,
// causing UAF on the subsequent read.
test_literal_concat_elem_read() `test {
  string[] vec = ["hello " + "first "];
  assert(vec[0] == "hello first ", "concat element read");
}

// T0364: function-call result as literal element exercises the same path.
_concat_string() string {
  return "alpha" + "/" + "beta";
}
test_literal_call_elem_read() `test {
  string[] vec = [_concat_string()];
  assert(vec[0] == "alpha/beta", "call-result element read");
}

// T0364: mix of literal and heap elements — every slot must outlive the
// statement and stay readable. Multi-element form catches per-slot regressions.
test_literal_mixed_concat_and_literal() `test {
  string[] vec = ["raw", "x" + "y", _concat_string(), "z"];
  assert(vec.len == 4, "len");
  assert(vec[0] == "raw", "literal slot 0");
  assert(vec[1] == "xy", "concat slot 1");
  assert(vec[2] == "alpha/beta", "call slot 2");
  assert(vec[3] == "z", "literal slot 3");
}

// T0364: same fix line (claimStringTemp at expr.go:6674) also covers Vector
// stmt-temps. Without it, vector-of-vectors with a call-result inner element
// would double-free: the stmt-temp cleanup runs Vector.drop on the inner
// vector while the outer literal's slot still owns it. Inner-string elements
// make the regression visible — without the fix, scribbled freed memory
// makes the read crash. The variadic case is covered by t0331_variadic_temps;
// this is the explicit literal shape.
_make_str_inner() string[] {
  string[] v = string[]();
  v.push("alpha");
  v.push("beta");
  return v;
}
test_literal_with_vector_call_element() `test {
  string[][] vv = [_make_str_inner(), _make_str_inner()];
  assert(vv.len == 2, "outer len");
  assert(vv[0].len == 2, "inner 0 len");
  assert(vv[0][0] == "alpha", "[0][0]");
  assert(vv[0][1] == "beta", "[0][1]");
  assert(vv[1][0] == "alpha", "[1][0]");
  assert(vv[1][1] == "beta", "[1][1]");
}
