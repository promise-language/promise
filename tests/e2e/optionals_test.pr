// Test functions for optional values.
// --- Truthiness narrowing ---
truthiness_string_present() `test(allow_leaks: true) {
  string? cc = "hello";
  if cc {
    string s = cc;
    assert(s == "hello", "truthiness narrows string? to string");
  } else {
    assert(false, "should enter then branch");
  }
}

truthiness_string_none() `test(allow_leaks: true) {
  string? cc = none;
  if cc {
    assert(false, "should not enter then branch");
  }
}

truthiness_int_present() `test(allow_leaks: true) {
  int? x = 42;
  if x {
    int n = x;
    assert(n == 42, "truthiness narrows int? to int");
  } else {
    assert(false, "should enter then branch");
  }
}

truthiness_int_none() `test(allow_leaks: true) {
  int? x = none;
  if x {
    assert(false, "should not enter then branch");
  }
}

// --- is present narrowing ---

is_present_string() `test(allow_leaks: true) {
  string? s = "world";
  if s is present {
    string v = s;
    assert(v == "world", "is present narrows string?");
  } else {
    assert(false, "should enter then branch");
  }
}

is_present_bool() `test(allow_leaks: true) {
  bool? verbose = true;
  if verbose is present {
    bool b = verbose;
    assert(b == true, "is present narrows bool?");
  } else {
    assert(false, "should enter then branch");
  }
}

is_present_none() `test(allow_leaks: true) {
  int? x = none;
  if x is present {
    assert(false, "should not enter then branch");
  }
}

// --- is absent ---

is_absent_none() `test(allow_leaks: true) {
  int? x = none;
  if x is absent {
    assert(true, "is absent detects none");
  } else {
    assert(false, "should enter then branch");
  }
}

is_absent_value() `test(allow_leaks: true) {
  int? x = 42;
  if x is absent {
    assert(false, "should not enter then branch");
  }
}

// --- if-unwrap ---

if_unwrap_present() `test(allow_leaks: true) {
  string? name = "Alice";
  if n := name {
    assert(n == "Alice", "if-unwrap binds value");
  } else {
    assert(false, "should enter then branch");
  }
}

if_unwrap_absent() `test(allow_leaks: true) {
  string? name = none;
  if n := name {
    assert(false, "should not enter then branch");
  }
}

// --- Elvis operator ---

elvis_none_default() `test(allow_leaks: true) {
  string? x = none;
  string result = x ?: "default";
  assert(result == "default", "elvis gives default for none");
}

elvis_value_kept() `test(allow_leaks: true) {
  string? x = "actual";
  string result = x ?: "default";
  assert(result == "actual", "elvis keeps present value");
}

// --- String interpolation with optionals ---

interp_present_int() `test(allow_leaks: true) {
  int? x = 42;
  string s = "{x}";
  assert(s == "42", "interpolate present int?");
}

interp_none_int() `test(allow_leaks: true) {
  int? x = none;
  string s = "{x}";
  assert(s == "none", "interpolate none int?");
}

interp_present_string() `test(allow_leaks: true) {
  string? name = "Bob";
  string s = "hello {name}";
  assert(s == "hello Bob", "interpolate present string?");
}

interp_none_string() `test(allow_leaks: true) {
  string? name = none;
  string s = "hello {name}";
  assert(s == "hello none", "interpolate none string?");
}

interp_present_bool() `test(allow_leaks: true) {
  bool? b = true;
  string s = "{b}";
  assert(s == "true", "interpolate present bool?");
}

interp_none_bool() `test(allow_leaks: true) {
  bool? b = none;
  string s = "{b}";
  assert(s == "none", "interpolate none bool?");
}

// --- Optional user-defined types ---

type Point {
  int x;
  int y;
}

narrowing_type_present() `test(allow_leaks: true) {
  Point p = Point(x: 3, y: 4);
  Point? mp = p;
  if mp {
    assert(mp.x == 3, "narrowed type field x");
    assert(mp.y == 4, "narrowed type field y");
  } else {
    assert(false, "should enter then branch");
  }
}

narrowing_type_none() `test(allow_leaks: true) {
  Point? mp = none;
  if mp {
    assert(false, "should not enter then branch");
  }
}

is_present_type() `test(allow_leaks: true) {
  Point p = Point(x: 5, y: 6);
  Point? mp = p;
  if mp is present {
    Point inner = mp;
    assert(inner.x == 5, "is present narrows type");
  } else {
    assert(false, "should enter then branch");
  }
}

// --- Narrowing with else ---

narrowing_with_else() `test {
  string? cc = none;
  bool entered_else = false;
  if cc {
    assert(false, "should not enter then branch");
  } else {
    entered_else = true;
  }
  assert(entered_else, "else branch executes for none");
}

// --- Multiple narrowings in sequence ---

multiple_narrowings() `test(allow_leaks: true) {
  string? a = "first";
  string? b = none;
  bool a_ok = false;
  bool b_absent = false;
  if a {
    a_ok = true;
  }
  if b {
    assert(false, "b should not be present");
  } else {
    b_absent = true;
  }
  assert(a_ok, "a was present");
  assert(b_absent, "b was absent");
}

// --- Shadowing: same var name in inner scope after narrowing ---

shadowing_after_narrowing() `test(allow_leaks: true) {
  int? x = 42;
  if x {
    int n = x;
    assert(n == 42, "narrowed x inside if");
  }
  // x is still int? here
  string s = "{x}";
  assert(s == "42", "x still usable as int? after narrowing block");
}

// --- Uninitialized optional vars ---

uninit_optional_int() `test(allow_leaks: true) {
  int? x;
  assert("{x}" == "none", "uninitialized int? is none");
}

uninit_optional_string() `test(allow_leaks: true) {
  string? s;
  assert("{s}" == "none", "uninitialized string? is none");
}

uninit_optional_then_assign() `test(allow_leaks: true) {
  int? x;
  x = 42;
  if x {
    int n = x;
    assert(n == 42, "assigned after init narrows correctly");
  }
}

// --- Negated narrowing (!cc) ---

negated_narrowing_none() `test(allow_leaks: true) {
  string? cc = none;
  if !cc {
    assert(true, "!cc enters then when cc is none");
  } else {
    assert(false, "should not enter else");
  }
}

negated_narrowing_present() `test(allow_leaks: true) {
  string? cc = "hello";
  if !cc {
    assert(false, "should not enter then when cc is present");
  } else {
    string s = cc;
    assert(s == "hello", "!cc narrows in else branch");
  }
}

negated_narrowing_no_else() `test(allow_leaks: true) {
  int? x = none;
  bool entered = false;
  if !x {
    entered = true;
  }
  assert(entered, "!x enters then when x is none");
}

// --- Compound narrowing (&&) ---

compound_narrowing_both_present() `test(allow_leaks: true) {
  int? a = 10;
  string? b = "world";
  if a && b {
    int x = a;
    string y = b;
    assert(x == 10, "compound narrows a");
    assert(y == "world", "compound narrows b");
  } else {
    assert(false, "should enter then when both present");
  }
}

compound_narrowing_first_absent() `test(allow_leaks: true) {
  int? a = none;
  string? b = "hello";
  if a && b {
    assert(false, "should not enter then when a is none");
  }
}

compound_narrowing_second_absent() `test(allow_leaks: true) {
  int? a = 42;
  string? b = none;
  if a && b {
    assert(false, "should not enter then when b is none");
  }
}

compound_narrowing_both_absent() `test(allow_leaks: true) {
  int? a = none;
  string? b = none;
  if a && b {
    assert(false, "should not enter then when both none");
  }
}

compound_narrowing_with_else() `test(allow_leaks: true) {
  int? a = none;
  string? b = "hi";
  bool entered_else = false;
  if a && b {
    assert(false, "should not enter then");
  } else {
    entered_else = true;
  }
  assert(entered_else, "else entered when compound fails");
}

// --- Optional chaining on user-defined types ---

optional_chain_present() `test(allow_leaks: true) {
  Point p = Point(x: 7, y: 8);
  Point? mp = p;
  int? px = mp?.x;
  int? py = mp?.y;
  if px is present {
    assert(px == 7, "optional chain extracts field x");
  } else {
    assert(false, "px should be present");
  }
  if py is present {
    assert(py == 8, "optional chain extracts field y");
  } else {
    assert(false, "py should be present");
  }
}

optional_chain_none() `test(allow_leaks: true) {
  Point? mp = none;
  int? px = mp?.x;
  assert("{px}" == "none", "optional chain on none gives none");
}

// --- is absent narrowing (post-divergence) ---

is_absent_narrows_after_diverge() `test(allow_leaks: true) {
  int? x = 42;
  if x is absent {
    assert(false, "should not enter then");
    return;
  }
  // x is narrowed to int here
  int y = x;
  assert(y == 42, "is absent diverge narrows x to int");
}

negated_narrows_after_diverge() `test(allow_leaks: true) {
  int? x = 10;
  if !x {
    assert(false, "should not enter then");
    return;
  }
  // x is narrowed to int here
  int y = x;
  assert(y == 10, "!x diverge narrows x to int");
}

is_absent_else_narrows() `test(allow_leaks: true) {
  int? x = 99;
  if x is absent {
    assert(false, "should not enter then");
  } else {
    int n = x;
    assert(n == 99, "is absent else narrows x");
  }
}

// --- as! on optionals ---

as_bang_optional_present() `test(allow_leaks: true) {
  int? x = 42;
  int y = x as! int;
  assert(y == 42, "as! unwraps present optional");
}

// --- Optional force-unwrap (x!) ---

force_unwrap_present() `test(allow_leaks: true) {
  int? x = 42;
  int y = x!;
  assert(y == 42, "x! unwraps present optional");
}

force_unwrap_string() `test(allow_leaks: true) {
  string? s = "hello";
  string v = s!;
  assert(v == "hello", "s! unwraps present string optional");
}

// --- Optional handler (x ? _ { recovery }) ---

optional_handler_none() `test(allow_leaks: true) {
  int? x = none;
  int y = x? _ {
    0;
  };
  assert(y == 0, "handler provides recovery for none");
}

optional_handler_present() `test(allow_leaks: true) {
  int? x = 42;
  int y = x? _ {
    0;
  };
  assert(y == 42, "handler keeps present value");
}

optional_handler_diverge() `test(allow_leaks: true) {
  int? x = none;
  int result = -1;
  if true {
    int y = x? _ {
      result = 99;
      return;
    };
  }
  assert(result == 99, "handler can diverge");
}

// --- Double unwrap: failable returning optional ---

get_value() int?! {
  return 42;
}

get_none() int?! {
  return none;
}

double_unwrap_error_then_optional() `test(allow_leaks: true) {
  int? val = get_value()!;
  int y = val!;
  assert(y == 42, "double unwrap: error then optional");
}

double_unwrap_failable_optional_handler() `test(allow_leaks: true) {
  int? val = get_none()!;
  int y = val? _ {
    -1;
  };
  assert(y == -1, "handler on none after error unwrap");
}

// --- is absent narrowing: user-defined types ---

is_absent_narrows_user_type() `test(allow_leaks: true) {
  Point? p = Point(x: 5, y: 6);
  if p is absent {
    return;
  }
  Point q = p;
  assert(q.x == 5, "is absent narrows user type field x");
  assert(q.y == 6, "is absent narrows user type field y");
}

// is_absent narrowing with return (not raise, since test funcs can't be failable)
is_absent_narrows_user_type_return() `test(allow_leaks: true) {
  Point? p = Point(x: 1, y: 2);
  if p is absent {
    return;
  }
  // p narrowed to Point after return
  assert(p.x == 1, "narrowed after return x");
  assert(p.y == 2, "narrowed after return y");
}

// narrowing does NOT apply when then-body doesn't diverge
is_absent_no_post_narrow_without_diverge() `test(allow_leaks: true) {
  int? x = 42;
  if x is absent {
    // does NOT diverge — no post-narrowing
  }
  // x is still int? here, so interpolation should work
  string s = "{x}";
  assert(s == "42", "x remains int? without diverge");
}

// --- Force-unwrap: expression positions ---

force_unwrap_in_expression() `test(allow_leaks: true) {
  int? x = 10;
  int y = x! + 5;
  assert(y == 15, "x! in arithmetic expression");
}

force_unwrap_user_type() `test(allow_leaks: true) {
  Point? p = Point(x: 3, y: 4);
  Point q = p!;
  assert(q.x == 3, "force unwrap user type x");
  assert(q.y == 4, "force unwrap user type y");
}

force_unwrap_in_call() `test(allow_leaks: true) {
  int? x = 7;
  string s = "{x!}";
  assert(s == "7", "force unwrap in interpolation");
}

// --- as! on optionals: more types ---

as_bang_string_optional() `test(allow_leaks: true) {
  string? s = "world";
  string v = s as! string;
  assert(v == "world", "as! on string optional");
}

as_bang_user_type() `test(allow_leaks: true) {
  Point? p = Point(x: 8, y: 9);
  Point q = p as! Point;
  assert(q.x == 8, "as! on user type optional x");
  assert(q.y == 9, "as! on user type optional y");
}

// --- Optional handler: more types ---

handler_string_recovery() `test(allow_leaks: true) {
  string? s = none;
  string v = s? _ {
    "fallback";
  };
  assert(v == "fallback", "handler string recovery on none");
}

handler_string_present() `test(allow_leaks: true) {
  string? s = "actual";
  string v = s? _ {
    "fallback";
  };
  assert(v == "actual", "handler keeps present string");
}

handler_user_type() `test(allow_leaks: true) {
  Point? p = none;
  Point q = p? _ {
    Point(x: 0, y: 0);
  };
  assert(q.x == 0, "handler user type recovery x");
  assert(q.y == 0, "handler user type recovery y");
}

handler_user_type_present() `test(allow_leaks: true) {
  Point? p = Point(x: 5, y: 6);
  Point q = p? _ {
    Point(x: 0, y: 0);
  };
  assert(q.x == 5, "handler keeps present user type x");
  assert(q.y == 6, "handler keeps present user type y");
}

// --- Optional user-defined type as struct field (B0030) ---

type Location {
  int x;
  int y;
}

type Place {
  string name;
  Location? location;
}

optional_user_field_constructor_some() `test(allow_leaks: true) {
  p := Place(name: "home", location: Location(x: 1, y: 2));
  assert(p.name == "home", "name field");
  loc := p.location!;
  assert(loc.x == 1, "location x");
  assert(loc.y == 2, "location y");
}

optional_user_field_constructor_none() `test(allow_leaks: true) {
  p := Place(name: "unknown");
  assert(p.name == "unknown", "name field");
}

optional_user_field_assign_some() `test(allow_leaks: true) {
  p := Place(name: "a");
  p.location = Location(x: 10, y: 20);
  loc := p.location!;
  assert(loc.x == 10, "assigned location x");
  assert(loc.y == 20, "assigned location y");
}

optional_user_field_assign_none() `test(allow_leaks: true) {
  p := Place(name: "a", location: Location(x: 1, y: 2));
  p.location = none;
}

optional_user_field_explicit_none_in_constructor() `test(allow_leaks: true) {
  p := Place(name: "nowhere", location: none);
  assert(p.name == "nowhere", "name field");
}

// Nested optional user types
type Container {
  Place? inner;
}

optional_nested_user_field() `test(allow_leaks: true) {
  c := Container(inner: Place(name: "nested", location: Location(x: 5, y: 6)));
  p := c.inner!;
  assert(p.name == "nested", "nested name");
  loc := p.location!;
  assert(loc.x == 5, "nested location x");
  assert(loc.y == 6, "nested location y");
}
