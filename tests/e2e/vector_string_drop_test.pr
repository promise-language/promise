// B0189: Vector[string] element drop tests.
// Verifies that string elements inside vectors are properly freed when the
// vector is dropped, preventing memory leaks.
// Basic: split result vector drops its string elements.
test_split_drop() `test {
  string[] parts = "hello,world,foo".split(",");
  assert(parts.len == 3, "split len");
  assert(parts[0] == "hello", "first");
  assert(parts[1] == "world", "second");
  assert(parts[2] == "foo", "third");
}

// Shared strings between vectors: dup-on-push prevents double-free.
test_shared_strings() `test {
  string[] source = "a,b,c".split(",");
  string[] dest = string[]();
  int i = 0;
  while i < source.len {
    dest.push(source[i]);
    i = i + 1;
  }
  assert(dest.len == 3, "dest len");
  assert(dest[0] == "a", "dest first");
  assert(dest[2] == "c", "dest third");
}

// Push string literals into vector.
test_push_literals() `test {
  string[] v = string[]();
  v.push("hello");
  v.push("world");
  assert(v.len == 2, "len");
  assert(v[0] == "hello", "first");
}

// Push string concat temps into vector.
test_push_concat_temps() `test {
  string[] v = string[]();
  v.push("hello" + " " + "world");
  v.push("foo" + "bar");
  assert(v.len == 2, "len");
  assert(v[0] == "hello world", "first");
}

// Remove drops the removed string element.
test_remove_drops_element() `test {
  string[] v = string[]();
  v.push("alice");
  v.push("bob");
  v.push("charlie");
  v.remove(1);
  assert(v.len == 2, "len after remove");
  assert(v[0] == "alice", "first after remove");
  assert(v[1] == "charlie", "second after remove");
}

// Normalize-like pattern: pop + push between two vectors.
// B0196: pop() discarded result is now dropped by dropDiscardedOptionalString.
test_normalize_pattern() `test {
  string[] parts = "a,b,c,d".split(",");
  string[] result = string[]();
  int i = 0;
  while i < parts.len {
    string part = parts[i];
    if part == "c" {
      result.pop();
    } else {
      result.push(move part);
    }
    i = i + 1;
  }
  assert(result.len == 2, "result len");
  assert(result[0] == "a", "result first");
  assert(result[1] == "d", "result second");
}

// Return string from function with vector in scope.
_first_part(string input) string {
  string[] parts = input.split(",");
  if parts.len > 0 {
    return parts[0];
  }
  return "";
}

test_return_from_vector_scope() `test {
  string result = _first_part("hello,world");
  assert(result == "hello", "returned first part");
}

// T0364 regression: vector literal with heap (concat-result) element.
// Without T0366's claimStringTemp in genArrayLit, the concat temp would be
// freed at end-of-statement while the vector slot still points at it,
// causing UAF on the subsequent read.
test_literal_concat_elem_read() `test {
  string[] vec = ["hello " + "first "];
  assert(vec[0] == "hello first ", "concat element read");
}

// T0364: function-call result as literal element exercises the same path.
_concat_string() string {
  return "alpha" + "/" + "beta";
}
test_literal_call_elem_read() `test {
  string[] vec = [_concat_string()];
  assert(vec[0] == "alpha/beta", "call-result element read");
}

// T0364: mix of literal and heap elements — every slot must outlive the
// statement and stay readable. Multi-element form catches per-slot regressions.
test_literal_mixed_concat_and_literal() `test {
  string[] vec = ["raw", "x" + "y", _concat_string(), "z"];
  assert(vec.len == 4, "len");
  assert(vec[0] == "raw", "literal slot 0");
  assert(vec[1] == "xy", "concat slot 1");
  assert(vec[2] == "alpha/beta", "call slot 2");
  assert(vec[3] == "z", "literal slot 3");
}

// T0364: same fix line (claimStringTemp at expr.go:6674) also covers Vector
// stmt-temps. Without it, vector-of-vectors with a call-result inner element
// would double-free: the stmt-temp cleanup runs Vector.drop on the inner
// vector while the outer literal's slot still owns it. Inner-string elements
// make the regression visible — without the fix, scribbled freed memory
// makes the read crash. The variadic case is covered by t0331_variadic_temps;
// this is the explicit literal shape.
_make_str_inner() string[] {
  string[] v = string[]();
  v.push("alpha");
  v.push("beta");
  return v;
}
test_literal_with_vector_call_element() `test {
  string[][] vv = [_make_str_inner(), _make_str_inner()];
  assert(vv.len == 2, "outer len");
  assert(vv[0].len == 2, "inner 0 len");
  assert(vv[0][0] == "alpha", "[0][0]");
  assert(vv[0][1] == "beta", "[0][1]");
  assert(vv[1][0] == "alpha", "[1][0]");
  assert(vv[1][1] == "beta", "[1][1]");
}

// T0369 regression: vector literal as a transient (fn arg / for-in source)
// with heap-tracked elements. The buffer's heap-temp drop must walk droppable
// elements before freeing — without that, claimStringTemp/claimHeapTemp at the
// element store transferred ownership from the stmt-temp to the buffer, and a
// buffer-only palFree leaked the elements.
_t0369_first_string(string[] v) string {
  if v.len > 0 {
    return v[0];
  }
  return "empty";
}

test_t0369_literal_arg_heap_string() `test {
  string s = _t0369_first_string(["hello " + "first "]);
  assert(s == "hello first ", "heap string element");
}

// T0369: nested heap vector via literal arg.
_t0369_first_int_vec(int[][] vv) int {
  if vv.len > 0 && vv[0].len > 0 {
    return vv[0][0];
  }
  return -1;
}
_t0369_make_int_vec(int x) int[] {
  return[x, x + 1];
}

test_t0369_literal_arg_vec_of_heap_vec() `test {
  int n = _t0369_first_int_vec([_t0369_make_int_vec(10)]);
  assert(n == 10, "nested heap vector element");
}

// T0369: for-in with heap string elements.
test_t0369_for_in_heap_strings() `test {
  string out = "";
  for s in["a" + "1", "b" + "2"] {
    out = out + s;
  }
  assert(out == "a1b2", "for-in heap string elements");
}

// T0369: for-in with heap inner vector elements.
test_t0369_for_in_heap_inner_vec() `test {
  int total = 0;
  for v in[_t0369_make_int_vec(1), _t0369_make_int_vec(3)] {
    total = total + v[0];
  }
  assert(total == 4, "for-in heap inner vector elements");
}

// T0369: heap user-type elements via literal arg.
type _T0369Box {
  int n;
}

_t0369_first_box(_T0369Box[] v) int {
  if v.len > 0 {
    return v[0].n;
  }
  return -1;
}

test_t0369_literal_arg_heap_user_type() `test {
  int n = _t0369_first_box([_T0369Box(n: 1), _T0369Box(n: 2)]);
  assert(n == 1, "heap user-type element");
}

// T0369: enum element with droppable variant data via literal arg.
enum _T0369Maybe {
  Some(string s),
  None,
}

_t0369_first_maybe(_T0369Maybe[] v) string {
  if v.len > 0 {
    match v[0] {
      _T0369Maybe.Some(s) => {
        return s;
      },
      _ => {
        return "empty";
      },
    }
  }
  return "x";
}

test_t0369_literal_arg_enum_heap_variant() `test {
  string s = _t0369_first_maybe([_T0369Maybe.Some(s: "hi" + "ya")]);
  assert(s == "hiya", "enum heap variant element");
}

// T0369 negative: literal assigned to a variable still works (var binding's
// Vector[T].drop walks elements; heap-temp claim at assign clears the temp's
// drop flag, so cleanupHeapTemps does nothing).
test_t0369_literal_assigned_var() `test {
  string[] v = ["x" + "y"];
  assert(v[0] == "xy", "assigned-to-var case");
}

// T0369: vector slice with heap string elements as transient (B0223 site
// patched in parallel — same heapTemp infrastructure).
_t0369_first_via_slice(string[] v) string {
  if v.len > 0 {
    return v[0];
  }
  return "empty";
}

test_t0369_vector_slice_transient_heap_strings() `test {
  string[] v = ["x" + "y", "z" + "1"];
  string r = _t0369_first_via_slice(v[0:1]);
  assert(r == "xy", "slice transient with heap strings");
}

// T0369: vector literal whose element type *transitively* contains a droppable
// tuple (e.g., Vector[Vector[(int, string)]]). The fix's containsDroppableTuple
// check is recursive — without recursion, the outer walk would reach the
// tuple via emitVariantFieldDrop's vector-field branch and double-drop the
// stmtTemp-tracked inner string. We don't dereference the tuple's string
// (asserts only on the int) because the tuple-with-string variable-assignment
// case is the underlying T0371 bug — out of scope for T0369. This test guards
// the regression that the buffer + heap-string cleanup remains balanced.
_t0369_outer_first_int(int[][] vv) int {
  if vv.len > 0 && vv[0].len > 0 {
    return vv[0][0];
  }
  return -1;
}
_t0369_outer_first_box((int, _T0369Box)[][] vv) int {
  if vv.len > 0 && vv[0].len > 0 {
    (a, b) := vv[0][0];
    return b.n;
  }
  return -1;
}

test_t0369_nested_vec_of_tuple_box() `test {
  int n = _t0369_outer_first_box([[(1, _T0369Box(n: 9))]]);
  assert(n == 9, "nested vector of tuple-with-box element");
}

// T0369: vector literal of tuple with a heap user-type field as transient.
// Walk is suppressed via containsDroppableTuple → both the box's heap temp
// and the buffer's heap temp clean up independently at stmt end. Before
// containsDroppableTuple was recursive, this leaked the box; before walk-
// suppression, the original genArrayLit double-freed the box.
_t0369_first_tup_box((int, _T0369Box)[] v) int {
  if v.len > 0 {
    (a, b) := v[0];
    return b.n;
  }
  return -1;
}

test_t0369_literal_arg_tuple_with_box() `test {
  int n = _t0369_first_tup_box([(1, _T0369Box(n: 7)), (2, _T0369Box(n: 8))]);
  assert(n == 7, "tuple-with-box element");
}

// T0369 coverage extension: for-in source with heap user-type elements.
// Exercises the literal-as-iterator-source path with the user-type element
// drop branch in emitVectorElementDropLoop.
test_t0369_for_in_heap_user_type() `test {
  int total = 0;
  for b in[_T0369Box(n: 1), _T0369Box(n: 2), _T0369Box(n: 3)] {
    total = total + b.n;
  }
  assert(total == 6, "for-in heap user-type elements");
}

// T0369 coverage extension: for-in source with enum-heap-variant elements.
// Each element carries droppable variant data (string from concat).
test_t0369_for_in_enum_heap_variant() `test {
  int count = 0;
  for m in[_T0369Maybe.Some(s: "a" + "b"), _T0369Maybe.Some(s: "c" + "d")] {
    count = count + 1;
  }
  assert(count == 2, "for-in enum heap-variant elements");
}

// T0369 coverage extension: bare expression-statement consumes the vector
// literal directly. cleanupHeapTemps fires at statement end — must walk
// elements + free buffer with no orphaned heap allocations.
test_t0369_expr_stmt_heap_strings() `test {
  ["a" + "b", "c" + "d"];
  assert(true, "raw expression-stmt with heap-element vector literal");
}

// T0369 coverage extension: function returns a heap-element vector literal,
// caller consumes it inline via .len (transient — no caller variable owns it).
// Tests the fn-return → caller-transient flow through trackVectorHeapTempWithElemType.
_t0369_make_str_vec() string[] {
  return["a" + "1", "b" + "2"];
}

test_t0369_returned_vec_consumed_inline() `test {
  int n = _t0369_make_str_vec().len;
  assert(n == 2, "returned heap-element vector consumed inline");
}

// T0369 coverage extension: error-path cleanup. emitHeapTempCleanupForErrorPath
// got the same elemType walk fix as cleanupHeapTemps. When a failable call
// raises after a vector literal arg, the literal's elements (heap strings,
// heap user types, enum heap variants) must be dropped on the error path
// before the error propagates.
_t0369_always_fail!() int {
  raise error(message: "fail");
}

_t0369_use_str_vec(string[] v, int x) int {
  return x + v.len;
}

_t0369_use_box_vec(_T0369Box[] v, int x) int {
  return x + v.len;
}

_t0369_use_enum_vec(_T0369Maybe[] v, int x) int {
  return x + v.len;
}

_t0369_pattern_str_then_fail!() int {
  return _t0369_use_str_vec(["a" + "1", "b" + "2"], _t0369_always_fail());
}

_t0369_pattern_box_then_fail!() int {
  return _t0369_use_box_vec([_T0369Box(n: 1), _T0369Box(n: 2)], _t0369_always_fail());
}

_t0369_pattern_enum_then_fail!() int {
  return _t0369_use_enum_vec([_T0369Maybe.Some(s: "x" + "y")], _t0369_always_fail());
}

test_t0369_error_path_heap_strings() `test {
  _t0369_pattern_str_then_fail()? e {
    assert(e.message == "fail", "error propagated, vector literal cleaned");
  };
}

test_t0369_error_path_heap_user_type() `test {
  _t0369_pattern_box_then_fail()? e {
    assert(e.message == "fail", "error propagated, vector literal cleaned");
  };
}

test_t0369_error_path_enum_heap_variant() `test {
  _t0369_pattern_enum_then_fail()? e {
    assert(e.message == "fail", "error propagated, vector literal cleaned");
  };
}

// T0372 regression: vector slice with non-string heap element types must NOT
// double-free against the parent vector. Vector.[:]'s push path only dups
// strings (B0189); for other element types the slice's slots alias the
// parent's pointers. Slice transient cleanup walks elements only when the
// element type is `string` — for other types it does buffer-only Vector.drop,
// leaving the parent's elements valid for its own end-of-scope drop. See
// T0376 for the proper fix that lets the walk be unconditional again.
_t0372_first_box_via_slice(_T0369Box[] v) int {
  if v.len > 0 {
    return v[0].n;
  }
  return -1;
}

test_t0372_slice_transient_heap_user_type() `test {
  _T0369Box[] v = [_T0369Box(n: 1), _T0369Box(n: 2), _T0369Box(n: 3)];
  int n = _t0372_first_box_via_slice(v[1:3]);
  assert(n == 2, "slice transient over heap user-type elements");
}

// T0372: slice with inner-vector elements (each inner vector is heap).
_t0372_make_int_vec(int x) int[] {
  return[x, x + 1];
}

_t0372_first_inner_via_slice(int[][] vv) int {
  if vv.len > 0 && vv[0].len > 0 {
    return vv[0][0];
  }
  return -1;
}

test_t0372_slice_transient_inner_vec() `test {
  int[][] vv = [_t0372_make_int_vec(10), _t0372_make_int_vec(20), _t0372_make_int_vec(30)];
  int n = _t0372_first_inner_via_slice(vv[1:3]);
  assert(n == 20, "slice transient over inner-vector elements");
}

// T0372: slice with enum-with-droppable-variant elements.
_t0372_first_maybe_via_slice(_T0369Maybe[] v) string {
  if v.len > 0 {
    match v[0] {
      _T0369Maybe.Some(s) => {
        return s;
      },
      _ => {
        return "empty";
      },
    }
  }
  return "x";
}

test_t0372_slice_transient_enum_droppable() `test {
  _T0369Maybe[] v = [_T0369Maybe.Some(s: "a" + "b"), _T0369Maybe.Some(s: "c" + "d"), _T0369Maybe.Some(s: "e" + "f")];
  string s = _t0372_first_maybe_via_slice(v[1:3]);
  assert(s == "cd", "slice transient over enum-droppable-variant elements");
}

// T0376: Vector.[:] deep-clones non-string heap elements on push, so a slice
// of a transient source vector owns independent copies. Without the fix, the
// non-Ident push path stored aliased pointers and the slice transient walk
// (now unconditional) would double-free against the source's element walk.
_t0376_make_box_vec() _T0369Box[] {
  return[_T0369Box(n: 1), _T0369Box(n: 2), _T0369Box(n: 3)];
}

test_t0376_slice_transient_source_box() `test {
  int n = _t0369_first_box(_t0376_make_box_vec()[1:3]);
  assert(n == 2, "slice of transient source with heap user-type elements");
}

// T0376: slice of a transient source with inner-vector elements.
_t0376_make_int_vec_vec() int[][] {
  return[_t0372_make_int_vec(10), _t0372_make_int_vec(20), _t0372_make_int_vec(30)];
}

test_t0376_slice_transient_source_inner_vec() `test {
  int n = _t0372_first_inner_via_slice(_t0376_make_int_vec_vec()[1:3]);
  assert(n == 20, "slice of transient source with inner-vector elements");
}

// T0376: slice of a transient source with enum-droppable-variant elements.
_t0376_make_maybe_vec() _T0369Maybe[] {
  return[_T0369Maybe.Some(s: "a" + "b"), _T0369Maybe.Some(s: "c" + "d"), _T0369Maybe.Some(s: "e" + "f")];
}

test_t0376_slice_transient_source_enum() `test {
  string s = _t0372_first_maybe_via_slice(_t0376_make_maybe_vec()[1:3]);
  assert(s == "cd", "slice of transient source with enum-droppable-variant elements");
}

// T0376: slice outlives its source vector. The slice must own independent
// heap user-type instances — without the deep-clone, this would crash with
// use-after-free when the source's element walk drops boxes the slice still
// references.
_t0376_slice_then_drop_source() _T0369Box[] {
  _T0369Box[] src = [_T0369Box(n: 10), _T0369Box(n: 20), _T0369Box(n: 30)];
  _T0369Box[] sl = src[1:3];
  return sl;
}

test_t0376_slice_outlives_source() `test {
  _T0369Box[] sl = _t0376_slice_then_drop_source();
  assert(sl.len == 2, "slice has 2 elements after source drop");
  assert(sl[0].n == 20, "element 0 readable after source drop");
  assert(sl[1].n == 30, "element 1 readable after source drop");
}

// T0376: polymorphic vector slice transient. cloneHeapElement uses the static
// element layout for the memcpy size, which truncates concrete subtypes
// (e.g., Circle → Shape size, dropping radius). For polymorphic element types
// (those needing a vtable), the IndexExpr push dup is suppressed and the slice
// tracking falls back to buffer-only Vector.drop. The slice slots alias the
// source's elements — safe in transient form because the source outlives the
// slice (a known limitation for variable-bound polymorphic slices, separate bug).
type _T0376Shape {
  format!(Writer ~w) {
    w.write_string("shape");
  }
}

type _T0376Circle is _T0376Shape {
  int radius;
  format!(Writer ~w) {
    w.write_string("circle({this.radius})");
  }
}

_t0376_first_shape_str(_T0376Shape[] shapes) string {
  if shapes.len > 0 {
    return "{shapes[0]}";
  }
  return "empty";
}

test_t0376_polymorphic_slice_transient() `test {
  _T0376Shape[] shapes = Vector[_T0376Shape]();
  shapes.push(_T0376Circle(radius: 1));
  shapes.push(_T0376Circle(radius: 2));
  shapes.push(_T0376Circle(radius: 3));
  string s = _t0376_first_shape_str(shapes[1:3]);
  assert(s == "circle(2)", "polymorphic slice transient preserves concrete type");
}

// T0387: polymorphic vector slice assigned to a variable. Pre-T0387, the slice
// slot aliased the source's element pointer; both drops walked the elements and
// the second drop double-freed. T0387 added a clone_fn_ptr slot to typeinfo so
// dupHeapValue dispatches to the runtime concrete type's clone (correct memcpy
// size + sub-field dup). Both source and slice now own independent Circle
// instances, so the second drop is safe.
type _T0387Shape {
  format!(Writer ~w) {
    w.write_string("shape");
  }
}

type _T0387Circle is _T0387Shape {
  int radius;
  format!(Writer ~w) {
    w.write_string("circle({this.radius})");
  }
}

test_t0387_polymorphic_variable_bound_slice() `test {
  _T0387Shape[] shapes = Vector[_T0387Shape]();
  shapes.push(_T0387Circle(radius: 1));
  shapes.push(_T0387Circle(radius: 2));
  shapes.push(_T0387Circle(radius: 3));
  _T0387Shape[] slice = shapes[1:3];
  string r0 = "{slice[0]}";
  string r1 = "{slice[1]}";
  assert(r0 == "circle(2)", "polymorphic slice preserves Circle.radius for first elem");
  assert(r1 == "circle(3)", "polymorphic slice preserves Circle.radius for second elem");
  assert(slice.len == 2, "slice has 2 elements");
}

// T0387: polymorphic slice outliving its source vector. Source drops at the
// callee scope exit; the slice slots no longer alias source pointers (they are
// independent clones). Without the clone_fn_ptr dispatch, the slice elements
// would dangle. This is the same root cause as the variable-bound double-free.
_t0387_make_poly_slice() _T0387Shape[] {
  _T0387Shape[] src = Vector[_T0387Shape]();
  src.push(_T0387Circle(radius: 10));
  src.push(_T0387Circle(radius: 20));
  src.push(_T0387Circle(radius: 30));
  return src[1:3];
}

test_t0387_polymorphic_slice_outlives_source() `test {
  _T0387Shape[] sl = _t0387_make_poly_slice();
  assert(sl.len == 2, "slice has 2 elements after source drop");
  string r0 = "{sl[0]}";
  string r1 = "{sl[1]}";
  assert(r0 == "circle(20)", "element 0 readable + correct after source drop");
  assert(r1 == "circle(30)", "element 1 readable + correct after source drop");
}

// T0387: polymorphic subtype with a droppable string field. Tests that the
// synthesized clone fn dups subclass-only droppable fields (Container.label),
// not just the size. Pre-T0387, the static layout walk missed these fields.
type _T0387Container is _T0387Shape {
  string label;
  format!(Writer ~w) {
    w.write_string("container({this.label})");
  }
}

test_t0387_polymorphic_subtype_string_field() `test {
  _T0387Shape[] shapes = Vector[_T0387Shape]();
  shapes.push(_T0387Container(label: "a" + "b"));
  shapes.push(_T0387Container(label: "c" + "d"));
  _T0387Shape[] slice = shapes[0:2];
  string r0 = "{slice[0]}";
  string r1 = "{slice[1]}";
  assert(r0 == "container(ab)", "subtype string field preserved through clone");
  assert(r1 == "container(cd)", "second subtype string field preserved");
}

// T0387: polymorphic subtype with a droppable Vector field (with droppable
// elements). Exercises dupHeapValueFields' vector-field branch (dupVector +
// emitVectorElementCloneLoop) inside the synthesized clone fn. Pre-T0387 the
// static layout walk missed _T0387Tagged.tags entirely.
type _T0387Tagged is _T0387Shape {
  string[] tags;
  format!(Writer ~w) {
    w.write_string("tagged");
  }
}

test_t0387_polymorphic_subtype_vector_field() `test {
  _T0387Shape[] shapes = Vector[_T0387Shape]();
  string[] tags1 = Vector[string]();
  tags1.push("a" + "b");
  tags1.push("c" + "d");
  shapes.push(_T0387Tagged(tags: move tags1));
  string[] tags2 = Vector[string]();
  tags2.push("e" + "f");
  shapes.push(_T0387Tagged(tags: move tags2));
  _T0387Shape[] slice = shapes[0:2];
  string r0 = "{slice[0]}";
  string r1 = "{slice[1]}";
  assert(r0 == "tagged", "tagged element 0 readable after clone");
  assert(r1 == "tagged", "tagged element 1 readable after clone");
  assert(slice.len == 2, "slice has 2 elements");
}

// T0387: three-level inheritance — typeinfo dispatch on the deepest concrete
// type. Polymorphic vector typed as the topmost base; instances are the
// deepest subclass. Synth-clone for _T0387Level3 walks all inherited fields
// (label from Level2, extra from Level3). Verifies the clone_fn_ptr in
// typeinfo points to the right per-concrete-type clone fn through a chain.
type _T0387Level1 {
  format!(Writer ~w) {
    w.write_string("level1");
  }
}

type _T0387Level2 is _T0387Level1 {
  string label;
  format!(Writer ~w) {
    w.write_string("level2({this.label})");
  }
}

type _T0387Level3 is _T0387Level2 {
  int extra;
  format!(Writer ~w) {
    w.write_string("level3({this.label},{this.extra})");
  }
}

test_t0387_three_level_inheritance_clone() `test {
  _T0387Level1[] items = Vector[_T0387Level1]();
  items.push(_T0387Level3(label: "x" + "y", extra: 42));
  items.push(_T0387Level3(label: "p" + "q", extra: 7));
  _T0387Level1[] slice = items[0:2];
  string r0 = "{slice[0]}";
  string r1 = "{slice[1]}";
  assert(r0 == "level3(xy,42)", "level-3 clone preserves inherited label and own extra");
  assert(r1 == "level3(pq,7)", "second level-3 clone");
  assert(slice.len == 2, "slice len");
}

// T0387: explicit user-code `dest.push(src[i])` for polymorphic types — the
// same dup-on-push path as Vector.[:], but exercised in plain user code (not
// stdlib). Pre-T0387 this had a polymorphic carve-out at expr.go:4670 (no
// dup, alias instead) so both vectors would double-free. Now both own
// independent concrete subtype copies.
test_t0387_polymorphic_dest_push() `test {
  _T0387Shape[] src = Vector[_T0387Shape]();
  src.push(_T0387Circle(radius: 1));
  src.push(_T0387Circle(radius: 2));
  src.push(_T0387Circle(radius: 3));
  _T0387Shape[] dest = Vector[_T0387Shape]();
  int i = 0;
  while i < src.len {
    dest.push(src[i]);
    i = i + 1;
  }
  assert(dest.len == 3, "dest len after loop push");
  string d0 = "{dest[0]}";
  string d2 = "{dest[2]}";
  string s0 = "{src[0]}";
  string s2 = "{src[2]}";
  assert(d0 == "circle(1)", "dest[0]");
  assert(d2 == "circle(3)", "dest[2]");
  assert(s0 == "circle(1)", "src[0] still readable after dup");
  assert(s2 == "circle(3)", "src[2] still readable after dup");
}

// T0376: direct user-visible `dest.push(src[i])` for non-string heap user
// types. Same IndexExpr branch as Vector.[:]'s `result.push(this[i])`, but
// exercised in plain user code (not stdlib) with both src and dest reaching
// scope-exit drop. Without the deep-clone, dest's slot would alias src's
// pointer and the second drop would double-free.
test_t0376_direct_loop_push_box() `test {
  _T0369Box[] src = [_T0369Box(n: 1), _T0369Box(n: 2), _T0369Box(n: 3)];
  _T0369Box[] dest = _T0369Box[]();
  int i = 0;
  while i < src.len {
    dest.push(src[i]);
    i = i + 1;
  }
  assert(dest.len == 3, "dest len after loop push");
  assert(dest[0].n == 1, "dest[0]");
  assert(dest[2].n == 3, "dest[2]");
  assert(src[0].n == 1, "src[0] still readable after dup");
  assert(src[2].n == 3, "src[2] still readable after dup");
}

// T0376: direct user-visible `dest.push(src[i])` for droppable-variant enums.
test_t0376_direct_loop_push_enum() `test {
  _T0369Maybe[] src = [_T0369Maybe.Some(s: "a" + "b"), _T0369Maybe.Some(s: "c" + "d")];
  _T0369Maybe[] dest = _T0369Maybe[]();
  int i = 0;
  while i < src.len {
    dest.push(src[i]);
    i = i + 1;
  }
  assert(dest.len == 2, "dest len after loop push");
  assert(_t0369_first_maybe(dest) == "ab", "dest first variant string");
  assert(_t0369_first_maybe(src) == "ab", "src first variant string after dup");
}

// T0388: push of a MemberExpr that resolves to a Vector field on a droppable
// owner. Without the fix, dest's slot would alias the inner buffer of h.arr;
// at end-of-scope both _MFHolder.drop and Vector[Vector[int]].drop would free
// the same buffer (invalid free / double free).
type _T0388Holder {
  int[] arr;
}

_t0388_make_int_vec() int[] {
  int[] v = int[]();
  v.push(1);
  v.push(2);
  return v;
}

test_t0388_member_field_push_inner_vec() `test {
  _T0388Holder h = _T0388Holder(arr: _t0388_make_int_vec());
  int[][] v = int[][]();
  v.push(move h.arr);
  assert(v.len == 1, "v len");
  assert(v[0].len == 2, "v[0] len");
  assert(v[0][0] == 1, "v[0][0]");
  assert(v[0][1] == 2, "v[0][1]");
  assert(h.arr.len == 2, "h.arr still readable after push");
  assert(h.arr[0] == 1, "h.arr[0] still readable");
}

// T0388: push of a string field on a droppable owner. The string-element path
// already dup'd via post-load c.dupString(argVal) (B0189), so this test pins
// down that the new container-flag setting doesn't double-dup or leak.
type _T0388StrHolder {
  string s;
}

test_t0388_member_field_push_string() `test {
  _T0388StrHolder h = _T0388StrHolder(s: "hi" + "ya");
  string[] v = string[]();
  v.push(move h.s);
  assert(v.len == 1, "v len");
  assert(v[0] == "hiya", "v[0]");
  assert(h.s == "hiya", "h.s still readable after push");
}

// T0388: push of a Channel field on a droppable owner. dupChannel is an
// incref, so the source channel still owns a ref after the push and is
// freed exactly once across owner-drop and vector-drop. Capacity 2 lets us
// confirm both refs reach the same underlying channel without blocking.
type _T0388ChanHolder {
  channel[int] ch;
}

test_t0388_member_field_push_channel() `test(exclude: wasm) {
  _T0388ChanHolder h = _T0388ChanHolder(ch: channel[int](capacity: 2));
  channel[int][] v = channel[int][]();
  v.push(move h.ch);
  assert(v.len == 1, "v len");
  h.ch.send(7);
  v[0].send(8);
  if a := <-h.ch {
    assert(a == 7, "first recv from source ref");
  } else {
    assert(false, "expected first recv to succeed");
  }
  if b := <-v[0] {
    assert(b == 8, "second recv from vector slot");
  } else {
    assert(false, "expected second recv to succeed");
  }
}

// T0388: push of a value returned from an instance getter. genGetterCall
// returns a fresh allocation that's already heap-tracked; the dup flag must
// NOT be consumed (mirrors the T0376 enum/polymorphic-ctor regression risk).
// genFieldAccess is bypassed — only `field := named.LookupField(e.Field)`
// success calls genFieldAccess; getters route through genGetterCall.
type _T0388GetterHolder {
  get fresh int[] {
    int[] v = int[]();
    v.push(100);
    v.push(200);
    return v;
  }
}

test_t0388_member_field_push_does_not_break_instance_getter() `test {
  _T0388GetterHolder h = _T0388GetterHolder();
  int[][] v = int[][]();
  v.push(move h.fresh);
  assert(v.len == 1, "v len");
  assert(v[0].len == 2, "v[0] len");
  assert(v[0][0] == 100, "v[0][0]");
  assert(v[0][1] == 200, "v[0][1]");
}

// T0388: push of a native getter result (Arc.borrow). Native getters return
// early in genMemberExpr before reaching genFieldAccess, so the dup flag is
// not consumed and the borrow path is unaffected.
test_t0388_member_field_push_does_not_break_native_getter() `test {
  Ref[int] a = Ref[int](42);
  int[] v = int[]();
  v.push(a.borrow);
  assert(v.len == 1, "v len");
  assert(v[0] == 42, "v[0]");
  assert(a.borrow == 42, "arc value still readable");
}
