// Tests for auto-propagation of failable calls used as function/method/constructor arguments.
parse_int(string s) int! {
  if s == "42" {
    return 42;
  }
  if s == "7" {
    return 7;
  }
  raise error(message: "bad: " + s);
}

get_string(bool fail) string! {
  if fail {
    raise error(message: "no string");
  }
  return "hello";
}

// ============================================================
// Section 1: Failable call as function argument
// ============================================================

use_int(int x) int {
  return x;
}

auto_prop_func_arg() int! {
  return use_int(parse_int("42"));
}

test_func_arg_success() `test(allow_leaks: true) {
  int r = auto_prop_func_arg()!;
  assert(r == 42, "failable arg to function succeeds");
}

auto_prop_func_arg_fail() int! {
  return use_int(parse_int("bad"));
}

try_func_arg_fail() bool {
  auto_prop_func_arg_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_func_arg_fail() `test(allow_leaks: true) {
  assert(try_func_arg_fail(), "failable arg to function propagates error");
}

// ============================================================
// Section 2: Failable call as method argument
// ============================================================

type Wrapper {
  use_int(&this, int x) int {
    return x;
  }
}

auto_prop_method_arg() int! {
  w := Wrapper();
  return w.use_int(parse_int("42"));
}

test_method_arg_success() `test(allow_leaks: true) {
  int r = auto_prop_method_arg()!;
  assert(r == 42, "failable arg to method succeeds");
}

auto_prop_method_arg_fail() int! {
  w := Wrapper();
  return w.use_int(parse_int("bad"));
}

try_method_arg_fail() bool {
  auto_prop_method_arg_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_method_arg_fail() `test(allow_leaks: true) {
  assert(try_method_arg_fail(), "failable arg to method propagates error");
}

