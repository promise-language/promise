// T1129: Recursive enum (Vector- or Map-indirected) stored in an outer Map/Vector
// segfaulted on read-back via `m[k]!`/`v[i]!` + match. The read-back must deep-clone
// the recursive enum (the container retains ownership of the same value), which
// requires a runtime-recursive synthesized clone — the inline shallow dup path
// (excluded for recursive enums by the B0289/T1110 cycle guard) cannot do depth-≥2
// copies correctly. This file exercises the read-back path the sibling
// enum_recursive_container_test.pr deliberately omits. All cases must be leak-free.
//
// The *module-defined* analog of this enum — a recursive container-bearing enum
// declared in a catalog module (no `clone), stored in an outer Map and read back
// via `m[k]!` — is covered by tests/modules/module_recursive_enum_dup_test.pr
// (fixed under T1131: the read-back dup gate is now phase-invariant so the synth
// clone is requested even when Map[K,V].[] compiles before the module declares
// the enum's clone).
enum Tree {
  Leaf(int v), Branch(Tree[] kids),
}

enum TreeM {
  Empty, Node(int v, Map[int, TreeM] children),
}

// Generic recursive enum — exercises the monomorphized synth-clone path.
enum GTree[T] {
  GLeaf(T v), GBranch(GTree[T][] kids),
}

// Vector-indirected recursion in an outer Map, read back via m[k]! + match (repro).
recursive_enum_in_map() `test {
  outer := Map[int, Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 1));
  kids.push(Tree.Leaf(v: 2));
  outer[1] = Tree.Branch(kids: move kids);
  got := outer[1]!;
  match got {
    Branch(ks) => {
      assert(ks.len == 2, "branch should have 2 kids");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Map-indirected recursion in an outer Map, read back via m[k]! + match (repro).
recursive_map_enum_in_map() `test {
  outer := Map[int, TreeM]();
  children := Map[int, TreeM]();
  children[1] = TreeM.Empty;
  outer[1] = TreeM.Node(v: 7, children: move children);
  got := outer[1]!;
  match got {
    Node(v, _) => {
      assert(v == 7, "node value should be 7");
    },
    Empty => {
      assert(false, "expected Node");
    },
  }
}

// Depth-2 tree read back TWICE — proves the map's stored copy stays valid after
// the first read drops its independent clone (the depth-≥2 correctness that the
// inline shallow path cannot give).
recursive_enum_depth2_read_twice() `test {
  outer := Map[int, Tree]();
  inner_kids := Vector[Tree]();
  inner_kids.push(Tree.Leaf(v: 10));
  inner_kids.push(Tree.Leaf(v: 20));
  kids := Vector[Tree]();
  kids.push(Tree.Branch(kids: move inner_kids));
  kids.push(Tree.Leaf(v: 30));
  outer[1] = Tree.Branch(kids: move kids);

  first := outer[1]!;
  match first {
    Branch(ks) => {
      assert(ks.len == 2, "outer branch has 2 kids");
      match ks[0] {
        Branch(inner) => {
          assert(inner.len == 2, "inner branch has 2 kids");
        },
        Leaf(_) => {
          assert(false, "expected nested Branch");
        },
      }
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }

  // Read again — the stored value must be untouched by the first read's drop.
  second := outer[1]!;
  match second {
    Branch(ks) => {
      assert(ks.len == 2, "second read: 2 kids");
    },
    Leaf(_) => {
      assert(false, "expected Branch on second read");
    },
  }
}

// Same recursive enum inside a Vector, read back via v[i]! + match.
recursive_enum_in_vector() `test {
  outer := Vector[Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 5));
  outer.push(Tree.Branch(kids: move kids));
  got := outer[0];
  match got {
    Branch(ks) => {
      assert(ks.len == 1, "branch should have 1 kid");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Fixed-size array index `arr[i]` of a recursive enum must deep-clone on read —
// exercises the genArrayIndex dup-on-read branch (the Vector cases above hit
// genVectorIndex instead). Without it, `got` aliases the array slot and got's drop
// + the array's element walk double-free the variant data (fatal for recursion).
recursive_enum_in_array() `test {
  kids1 := Vector[Tree]();
  kids1.push(Tree.Leaf(v: 1));
  kids1.push(Tree.Leaf(v: 2));
  kids2 := Vector[Tree]();
  kids2.push(Tree.Leaf(v: 3));
  arr := [Tree.Branch(kids: move kids1), Tree.Branch(kids: move kids2)];
  got := arr[0];
  match got {
    Branch(ks) => {
      assert(ks.len == 2, "arr[0] branch should have 2 kids");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Assignment (not var-decl) from a fixed-size array index: `got = arr[i]` must
// also deep-clone (genAssignStmt bareIdxRhs path for an array RHS).
recursive_enum_assign_from_array() `test {
  inner := Vector[Tree]();
  inner.push(Tree.Leaf(v: 7));
  arr := [Tree.Branch(kids: move inner), Tree.Leaf(v: 8)];
  got := Tree.Leaf(v: 99);
  got = arr[0];
  match got {
    Branch(ks) => {
      assert(ks.len == 1, "assigned array branch should have 1 kid");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Assignment (not var-decl) from a Vector index: `got = v[i]` must also deep-clone.
recursive_enum_assign_from_vector() `test {
  v := Vector[Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 1));
  kids.push(Tree.Leaf(v: 2));
  v.push(Tree.Branch(kids: move kids));
  got := Tree.Leaf(v: 99);
  got = v[0];
  match got {
    Branch(ks) => {
      assert(ks.len == 2, "assigned branch should have 2 kids");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Direct `match outer[k]!` (no intermediate local) — the read is an owned-rvalue
// subject: the Map's `[]` body deep-clones the recursive enum via its synthesized
// clone, so nothing else owns the returned value. subjectIsOwnedRvalueEnum's
// typeNeedsMatchDup branch must give it the T1119 spill-drop, else the owned clone
// leaks. Exercises the owned-rvalue path the `got := outer[k]!` cases above skip.
recursive_enum_in_map_direct_match() `test {
  outer := Map[int, Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 1));
  kids.push(Tree.Leaf(v: 2));
  outer[1] = Tree.Branch(kids: move kids);
  match outer[1]! {
    Branch(ks) => {
      assert(ks.len == 2, "direct-match branch should have 2 kids");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// T1130: a Map element read back out of a Vector[Map[K, RecursiveEnum]] must be
// deep-cloned. Map/Set are excluded from isDroppableHeapUserType (T0440), so the
// generic heap-user dup-on-read branch skips them — but when Map/Set is the ELEMENT
// of a native Vector/Array (whose `[]` does not dup), `got := v[i]` aliases the
// container's slot → got's drop and the vector's element walk double-free the Map.
// These cases must be leak-free and crash-free.

// Exact repro: read a Map element back out of a CLONED Vector[Map[...]], index it.
map_element_from_cloned_vector() `test {
  inner := Map[int, Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 1));
  inner[0] = Tree.Branch(kids: move kids);
  maps := Vector[Map[int, Tree]]();
  maps.push(move inner);
  maps2 := maps.clone();
  got := maps2[0];
  match got[0]! {
    Branch(ks) => {
      assert(ks.len == 1, "cloned-vec map element branch should have 1 kid");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Non-cloned Vector[Map[...]] element read-back via `got := v[i]`.
map_element_from_vector() `test {
  inner := Map[int, Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 5));
  kids.push(Tree.Leaf(v: 6));
  inner[0] = Tree.Branch(kids: move kids);
  maps := Vector[Map[int, Tree]]();
  maps.push(move inner);
  got := maps[0];
  match got[0]! {
    Branch(ks) => {
      assert(ks.len == 2, "vec map element branch should have 2 kids");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
  // The container's stored map must survive got's drop — read again.
  got2 := maps[0];
  assert(got2.len == 1, "stored map untouched after first read");
}

// Assignment form `got = v[i]` of a Vector[Map[...]] element.
map_element_assign_from_vector() `test {
  inner := Map[int, Tree]();
  inner[0] = Tree.Leaf(v: 9);
  maps := Vector[Map[int, Tree]]();
  maps.push(move inner);
  got := Map[int, Tree]();
  got = maps[0];
  assert(got.len == 1, "assigned map element has 1 entry");
}

// Typed-var-decl form `Map[K,V] got = v[i]` of a Vector[Map[...]] element.
// Exercises the genTypedVarDecl flag site (distinct from the `:=` and `=` forms).
map_element_typed_decl_from_vector() `test {
  inner := Map[int, Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 7));
  inner[0] = Tree.Branch(kids: move kids);
  maps := Vector[Map[int, Tree]]();
  maps.push(move inner);
  Map[int, Tree] got = maps[0];
  match got[0]! {
    Branch(ks) => {
      assert(ks.len == 1, "typed-decl map element branch should have 1 kid");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
  Map[int, Tree] got2 = maps[0];
  assert(got2.len == 1, "stored map untouched after typed-decl read");
}

// Map element read back out of a fixed-size array of maps (genArrayIndex path).
map_element_from_array() `test {
  m0 := Map[int, Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 1));
  m0[0] = Tree.Branch(kids: move kids);
  m1 := Map[int, Tree]();
  m1[0] = Tree.Leaf(v: 2);
  arr := [m0, m1];
  got := arr[0];
  match got[0]! {
    Branch(ks) => {
      assert(ks.len == 1, "array map element branch should have 1 kid");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Set element read back out of a Vector[Set[...]] (the Set arm of isMapOrSetType).
set_element_from_vector() `test {
  s := Set[int]();
  s.add(1);
  s.add(2);
  sets := Vector[Set[int]]();
  sets.push(move s);
  got := sets[0];
  assert(got.len == 2, "vec set element has 2 entries");
  got2 := sets[0];
  assert(got2.len == 2, "stored set untouched after first read");
}

// Set element read back out of a fixed-size array of sets (the Set arm of the
// genArrayIndex isMapOrSetType branch — distinct from the Vector native-index path).
set_element_from_array() `test {
  s0 := Set[int]();
  s0.add(1);
  s0.add(2);
  s1 := Set[int]();
  s1.add(3);
  arr := [s0, s1];
  got := arr[0];
  assert(got.len == 2, "array set element has 2 entries");
  got2 := arr[0];
  assert(got2.len == 2, "stored set untouched after first read");
}

// Assignment form `got = arr[i]` of a fixed-size-array map element — exercises
// genAssignStmt's bareIdxRhs path with an array (not Vector) index source.
map_element_assign_from_array() `test {
  m0 := Map[int, Tree]();
  m0[0] = Tree.Leaf(v: 1);
  m1 := Map[int, Tree]();
  m1[0] = Tree.Leaf(v: 2);
  arr := [m0, m1];
  got := Map[int, Tree]();
  got = arr[0];
  assert(got.len == 1, "assigned array map element has 1 entry");
}

// Typed-var-decl form `Map[K,V] got = arr[i]` of an array map element — exercises
// genTypedVarDecl's flag site combined with the genArrayIndex deep-clone.
map_element_typed_decl_from_array() `test {
  m0 := Map[int, Tree]();
  kids := Vector[Tree]();
  kids.push(Tree.Leaf(v: 7));
  m0[0] = Tree.Branch(kids: move kids);
  m1 := Map[int, Tree]();
  m1[0] = Tree.Leaf(v: 2);
  arr := [m0, m1];
  Map[int, Tree] got = arr[0];
  match got[0]! {
    Branch(ks) => {
      assert(ks.len == 1, "typed-decl array map element branch should have 1 kid");
    },
    Leaf(_) => {
      assert(false, "expected Branch");
    },
  }
}

// Exact bug shape: a Map element bearing a MAP-recursive enum (TreeM), read back
// out of a CLONED Vector[Map[...]]. Mirrors the JsonNode/Dict repro (recursion
// through a Map, not a Vector) — the inner enum's clone must deep-copy the nested
// child map so got and the container's element own disjoint heap.
map_recursive_enum_element_from_cloned_vector() `test {
  inner := Map[int, TreeM]();
  children := Map[int, TreeM]();
  children[0] = TreeM.Empty;
  inner[0] = TreeM.Node(v: 9, children: move children);
  maps := Vector[Map[int, TreeM]]();
  maps.push(move inner);
  maps2 := maps.clone();
  got := maps2[0];
  match got[0]! {
    Node(v, ks) => {
      assert(v == 9, "node value preserved through cloned-vec read");
      assert(ks.len == 1, "node child map should have 1 entry");
    },
    Empty => {
      assert(false, "expected Node");
    },
  }
}

// Generic recursive enum stored in an outer Map, read back via m[k]! + match.
generic_recursive_enum_in_map() `test {
  outer := Map[int, GTree[int]]();
  kids := Vector[GTree[int]]();
  kids.push(GTree[int].GLeaf(v: 1));
  kids.push(GTree[int].GLeaf(v: 2));
  outer[1] = GTree[int].GBranch(kids: move kids);
  got := outer[1]!;
  match got {
    GBranch(ks) => {
      assert(ks.len == 2, "gbranch should have 2 kids");
    },
    GLeaf(_) => {
      assert(false, "expected GBranch");
    },
  }
}
