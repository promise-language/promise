// B0116: Empty default body must not hang — previously treated as no-default (blocking).
select_empty_default_single() `test(allow_leaks: true) {
  ch := channel[int](capacity: 1);
  select {
    v := <-ch:
    default:
  }
  assert(true, "single empty default must not block");
}

select_empty_default_twice() `test(allow_leaks: true) {
  ch := channel[int](capacity: 1);
  select {
    v := <-ch: default:
  }
  select {
    v := <-ch: default:
  }
  assert(true, "two consecutive empty defaults must not block");
}

select_empty_default_in_loop() `test(allow_leaks: true) {
  ch := channel[int](capacity: 1);
  int count = 0;
  while count < 5 {
    select {
      v := <-ch: default:
    }
    count = count + 1;
  }
  assert(count == 5, "empty default in loop");
}

select_empty_default_send() `test(allow_leaks: true) {
  ch := channel[int](capacity: 1);
  ch.send(42);
  // Channel is full — send case should not be ready, take default
  select {
    ch.send(99): default:
  }
  // Original value should still be there
  if val := <-ch {
    assert(val == 42, "original value preserved");
  } else {
    assert(false, "expected value from channel");
  }
}
