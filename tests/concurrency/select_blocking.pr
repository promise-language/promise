// Select with blocking: no channel is ready, goroutine parks and waits.
main() `test(expected: "42") {
  ch1 := channel[int](capacity: 1);
  ch2 := channel[int](capacity: 1);

  // Spawn a goroutine that sends on ch2 after a moment
  go {
    ch2.send(42);
  };

  // Both channels are empty — select blocks until ch2 is ready
  select {
    v := <-ch1:
    if val := v {
      print_line(0);
    }
    v := <-ch2:
    if val := v {
      print_line(val);
    }
  }
}
