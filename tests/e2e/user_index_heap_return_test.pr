// T0647: a user-defined non-native `[](int i) T` returning a heap type
// previously LEAKED the owned operator return at the call site. genIndexExpr's
// `[]` read path (genMethodIndex) lacked the post-call heap-temp tracking that
// the *ast.CallExpr genExpr case applies to ordinary method calls, so `s[i]`
// leaked where the IDENTICAL `s.at(i)` did not. Fixed by:
//   (1) trackUserIndexResult — mirrors the CallExpr post-call tracking at the
//       genMethodIndex tail (string/vector/Arc/.../heap-user owned returns),
//   (2) isUserIndexExpr — exempts the user `[]` read from the borrow-RHS
//       drop-flag clearing in genVarDecl/genInferredVarDecl (it returns an
//       owned temp claimed into the LHS, not a container borrow).
//
// Every test is a batch test — the harness fails on ANY leaked allocation
// (zero-tolerance). Each type pairs the `[]` operator with an IDENTICAL plain
// `at()` method: the operator must be ownership-equivalent to the method
// (0 leak, no double-free). Native container indexing (std `Vector[string]`
// direct `v[0]`) stays a borrow and must NOT be over-tracked.
// ---------- string element (the core repro) ----------
type SBox {
  string[] d;
  [](int i) string {
    return this.d[i];
  }
  at(int i) string {
    return this.d[i];
  }
}

test_t0647_string_temporary() `test {
  s := SBox(d: ["a", "bb", "ccc"]);
  assert(s[1].len == 2, "operator temporary use");
  assert(s.at(1).len == 2, "method temporary use (baseline)");
}

test_t0647_string_binding() `test {
  s := SBox(d: ["a", "bb"]);
  x := s[1];
  assert(x.len == 2, "operator result bound to local");
  y := s.at(0);
  assert(y.len == 1, "method result bound to local (baseline)");
}

take_str(string v) int {
  return v.len;
}

test_t0647_string_fn_arg() `test {
  s := SBox(d: ["hello", "hi"]);
  assert(take_str(s[0]) == 5, "operator result passed as fn arg");
  assert(take_str(s.at(1)) == 2, "method result passed as fn arg (baseline)");
}

test_t0647_string_baseline_native_no_overtrack() `test {
  // std Vector[string] direct index stays a borrow — must not be over-tracked
  // (would double-free) nor leak. Guards the native-path scoping of the fix.
  v := ["aa", "bbb", "c"];
  assert(v[0].len == 2, "native vector index read 1");
  assert(v[1].len == 3, "native vector index read 2");
  k := v[2];
  assert(k.len == 1, "native vector index bound");
}

// ---------- string via ~ / & receiver ----------
sbox_idx_mut(SBox ~s) int {
  return s[1].len; // temporary-use path under a ~ receiver
}
sbox_idx_shared(SBox &s) int {
  x := s[0]; // binding path under a & receiver
  return x.len;
}

test_t0647_string_ref_params() `test {
  assert(sbox_idx_mut(SBox(d: ["q", "wer"])) == 3, "[] via ~ receiver (temp)");
  assert(sbox_idx_shared(SBox(d: ["zzzz", "y"])) == 4, "[] via & receiver (bind)");
}

// ---------- generic GBox[T] with string payload ----------
type GBox[T] {
  Vector[T] d;
  [](int i) T {
    return this.d[i];
  }
  at(int i) T {
    return this.d[i];
  }
}

test_t0647_generic_string() `test {
  g := GBox[string](d: ["a", "bb", "ccc"]);
  assert(g[2].len == 3, "generic operator temporary");
  z := g[0];
  assert(z.len == 1, "generic operator binding");
  assert(g.at(1).len == 2, "generic method baseline");
}

gbox_idx_mut[X](GBox[X] ~g, int i) X {
  return g[i];
}
gbox_idx_shared[X](GBox[X] &g, int i) X {
  v := g[i];
  return v;
}

test_t0647_generic_string_fwd() `test {
  assert(gbox_idx_mut[string](GBox[string](d: ["mm", "n"]), 0) == "mm",
  "generic [] forward via ~");
  assert(gbox_idx_shared[string](GBox[string](d: ["p", "qqq"]), 1) == "qqq",
  "generic [] forward via & (bound)");
}

// ---------- freshly-constructed Vector[T] return ----------
// Exercises trackUserIndexResult's vector branch (trackVectorTempWithElemType)
// with an unambiguously owned vector. (A nested-vector *element* return —
// `[](int i) Vector[T] { return this.rows[i]; }` over a Vector[Vector[T]]
// field — is blocked by the pre-existing, unrelated bug T0648, which crashes
// the IDENTICAL plain method too; covered there, not here.)
type VBox {
  int n;
  [](int i) Vector[int] {
    return[this.n, i, this.n + i];
  }
  at(int i) Vector[int] {
    return[this.n, i, this.n + i];
  }
}

test_t0647_vector_return() `test {
  v := VBox(n: 10);
  assert(v[2].len == 3, "operator fresh-vector temporary");
  r := v[1];
  assert(r.len == 3, "operator fresh-vector binding");
  assert(v.at(0).len == 3, "method fresh-vector baseline");
}

// ---------- aliased whole-field Vector return (double-free risk) ----------
type WBox {
  string[] d;
  [](int i) string[] {
    return this.d; // returns the WHOLE owned field (aliased)
  }
  at(int i) string[] {
    return this.d;
  }
}

test_t0647_whole_field_vector() `test {
  w := WBox(d: ["x" + "1", "y" + "2", "z" + "3"]);
  a := w[0];
  assert(a.len == 3, "operator whole-field read 1");
  b := w[1];
  assert(b.len == 3, "operator whole-field read 2 (no double-free)");
  c := w.at(0);
  assert(c.len == 3, "method whole-field baseline (no double-free)");
}

// ---------- heap user type with drop + clone ----------
type Item {
  string name;
  clone(this) Item {
    return Item(name: this.name);
  }
  drop(~this) {
  }
}
type IBox {
  Item[] items;
  [](int i) Item {
    return this.items[i].clone();
  }
  at(int i) Item {
    return this.items[i].clone();
  }
}

test_t0647_heap_user_clone() `test {
  ib := IBox(items: [Item(name: "p" + "q"), Item(name: "r" + "s")]);
  assert(ib[0].name == "pq", "operator heap-user temporary");
  it := ib[1];
  assert(it.name == "rs", "operator heap-user binding");
  assert(ib.at(0).name == "pq", "method heap-user baseline");
}

// ---------- Map[K,V] value (force-unwrapped to a bare heap V) ----------
type MBox {
  map[string, string] m;
  [](string k) string {
    return this.m[k]!;
  }
  at(string k) string {
    return this.m[k]!;
  }
}

test_t0647_map_value() `test {
  map[string, string] mm = {:};
  mm["k"] = "v" + "1";
  mb := MBox(m: mm);
  assert(mb["k"].len == 2, "operator map-value temporary");
  mv := mb["k"];
  assert(mv.len == 2, "operator map-value binding");
  assert(mb.at("k").len == 2, "method map-value baseline");
}

// ---------- native concurrency handles (Arc / Weak) ----------
// trackUserIndexResult dispatches an i8* `[]` return through the same
// AsArc/AsWeak/AsMutex/AsTask/AsMutexGuard branches the *ast.CallExpr genExpr
// case uses (T0555 / T0561). Those native-handle branches were exercised by
// NO test for the user-`[]` read path (the original T0647 suite only covered
// string / vector / heap-user / map). Arc / Weak are covered here; each
// operator is paired with an IDENTICAL plain at() method, so the `[]` return
// must be ownership-equivalent (0 leak, no double-free under the batch
// harness) — exactly like the proven CallExpr handle-temp tracking it mirrors.
//
// The single-owner handles Mutex / Task / MutexGuard are covered in the
// dedicated T0650 section at the end of this file. They were previously
// OMITTED because a user-defined non-native `[]` returning a single-owner
// native handle was wrongly rejected at the ownership pass
// (`rejectIndexExprSingleOwnerMove`, ownership/expr.go) even though the
// IDENTICAL plain method compiled, ran, and was 0-leak. T0650 added the
// ownership exemption (isUserIndexExpr), which also made
// trackUserIndexResult's AsMutex/AsTask/AsMutexGuard branches reachable.
take_arc_i(Arc[int] a) int {
  return a.borrow;
}

// Arc[int] — operator returns an owned clone (refcount++); must be Arc-dropped
// (refcount--) at statement end (temp / fn-arg) and scope exit (binding).
type ArcBox {
  Arc[int] a;
  [](int i) Arc[int] {
    return this.a.clone();
  }
  at(int i) Arc[int] {
    return this.a.clone();
  }
}

test_t0647_arc_return() `test {
  b := ArcBox(a: Arc[int](7));
  assert(take_arc_i(b[0]) == 7, "operator Arc as borrow fn-arg (temp)");
  x := b[1];
  assert(x.borrow == 7, "operator Arc binding (claimed into x)");
  assert(take_arc_i(b.at(0)) == 7, "method Arc baseline");
}

// Weak[int] — operator returns an owned Weak from .downgrade(); must be
// Weak-dropped.
type WeakBox {
  Arc[int] a;
  [](int i) Weak[int] {
    return this.a.downgrade();
  }
  at(int i) Weak[int] {
    return this.a.downgrade();
  }
}

test_t0647_weak_return() `test {
  wb := WeakBox(a: Arc[int](9));
  if u := wb[0].upgrade() {
    assert(u.borrow == 9, "operator Weak temporary -> upgrade");
  } else {
    assert(false, "weak upgrade should succeed (Arc alive)");
  }
  w := wb[1];
  if u := w.upgrade() {
    assert(u.borrow == 9, "operator Weak binding -> upgrade");
  } else {
    assert(false, "weak binding upgrade should succeed");
  }
  if u := wb.at(0).upgrade() {
    assert(u.borrow == 9, "method Weak baseline");
  } else {
    assert(false, "method weak upgrade should succeed");
  }
}

// ---------- single-owner native handles (Mutex / Task / MutexGuard) — T0650 ----------
// A user-defined non-native `[]` returning a single-owner native handle was
// wrongly rejected at the ownership pass: rejectIndexExprSingleOwnerMove keyed
// solely on the IndexExpr result type, blind to whether the read was a native
// container slot-alias (correctly rejected — moving out double-frees at the
// container drop) or an ordinary user method returning a fresh / `.lock()`-
// derived owned handle (no slot to alias). The IDENTICAL plain at() method
// always compiled, ran, and was 0-leak. T0650 added the isUserIndexExpr
// ownership exemption (mirrors codegen/stmt.go); the codegen side (T0647
// trackUserIndexResult AsMutex/AsTask/AsMutexGuard + getOrCreateMutexDrop /
// getOrCreateTaskDrop / MutexGuard.drop) was already shipped and is now
// reachable. Each `[]` is paired with an IDENTICAL at() baseline; the batch
// harness enforces 0-leak / no-double-free at runtime.
worker_t0650() int {
  return 42;
}
take_mtx_i(Mutex[int] m) {
}
take_task_i(Task[int] t) {
}

// Mutex[int] — operator returns a freshly-constructed owned Mutex; must be
// Mutex-dropped at statement end (temp / fn-arg) and scope exit (binding).
type MtxBox {
  int n;
  [](int i) Mutex[int] {
    return Mutex[int](this.n + i);
  }
  at(int i) Mutex[int] {
    return Mutex[int](this.n + i);
  }
}

test_t0650_mutex_return() `test {
  b := MtxBox(n: 100);
  take_mtx_i(b[0]);
  m := b[1];
  {
    use g := m.lock();
    assert(g.borrow == 101, "operator Mutex binding -> lock");
  }
  take_mtx_i(b.at(0));
}

// MutexGuard[int] — operator returns a guard from this.m.lock(); it must be
// guard-dropped (unlock) exactly once. Reads are sequential (single underlying
// Mutex) so no two guards are ever alive simultaneously.
type MgBox {
  Mutex[int] m;
  [](int i) MutexGuard[int] {
    return this.m.lock();
  }
  at(int i) MutexGuard[int] {
    return this.m.lock();
  }
}

test_t0650_mutexguard_return() `test {
  mgb := MgBox(m: Mutex[int](42));
  assert(mgb[0].borrow == 42, "operator guard temporary");
  {
    g := mgb[0];
    assert(g.borrow == 42, "operator guard binding");
  }
  assert(mgb.at(0).borrow == 42, "method guard baseline");
}

// Task[int] — operator returns an owned go-spawned Task; must be Task-dropped
// (G struct + result buffer) exactly once.
type TaskBox {
  [](int i) Task[int] {
    return go worker_t0650();
  }
  at(int i) Task[int] {
    return go worker_t0650();
  }
}

test_t0650_task_return() `test(exclude: wasm) {
  tb := TaskBox();
  take_task_i(tb[0]);
  t := tb[1];
  r := <-t;
  assert(r == 42, "operator Task awaited");
  take_task_i(tb.at(0));
}

// ---------- peel-loop composition over a user `[]` returning a handle ----------
// rejectIndexExprSingleOwnerMove peels ParenExpr / OptionalUnwrapExpr (T0596 /
// T0612) before applying the T0650 isUserIndexExpr exemption. The cases above
// only use the bare `b[i]` shape; these exercise the exemption *through* the
// peel loop at runtime (an AI agent writes `take((box[i]))` or, for a fallible
// accessor `[](int i) Mutex[int]?`, `m := box[i]!`). Only the proven-0-leak
// shapes are live here.

// ParenExpr peel over a plain-handle user `[]` — consume + binding. Proven
// 0-leak (control row in /tmp/t0650_leak_scope.pr / peel_probe).
test_t0650_paren_peel() `test {
  b := MtxBox(n: 500);
  take_mtx_i((b[0])); // ParenExpr peel, consume site
  m := (b[1]); // ParenExpr peel, var-decl site
  {
    use g := m.lock();
    assert(g.borrow == 501, "paren-peel binding -> lock");
  }
}

// Optional-returning user `[]` at a BINDING site (with and without `!`).
// Both proven 0-leak: the unwrapped handle becomes a tracked variable whose
// scope-exit drop frees it exactly once.
type OptMtxBoxE {
  int n;
  [](int i) Mutex[int]? {
    return Mutex[int](this.n + i);
  }
}

test_t0650_optional_bind() `test {
  b := OptMtxBoxE(n: 700);
  m := b[0]!; // OptionalUnwrap peel, var-decl site (0-leak)
  {
    use g := m.lock();
    assert(g.borrow == 700, "optional `[]` `!`-bind -> lock");
  }
  mo := b[1]; // Optional bind, no unwrap (0-leak)
  {
    use g2 := mo!.lock();
    assert(g2.borrow == 701, "optional `[]` no-unwrap bind -> lock");
  }
}

// ---------- DEFERRED behind T0654 (pre-existing codegen leak, NOT T0650) ----------
// An Optional-returning non-native method/`[]` whose result is `!`-unwrapped
// at a CONSUME or TEMP site (e.g. `take_mtx_i(b[0]!)`, `use g := b[0]!.lock()`)
// LEAKS the owned Optional<handle> — the CallExpr/`[]` handle-temp tracking
// (codegen/expr.go T0555/T0561 + trackUserIndexResult) classifies on the
// un-peeled `Mutex[int]?` type, so AsMutex/AsTask never fire and the temp is
// never dropped. The IDENTICAL plain method `at()!` leaks the same, so this is
// a pre-existing, T0650-independent codegen gap — filed as **T0654**. The
// binding site (covered live above) is 0-leak. Enable the consume/temp
// `!`-unwrap rows here once T0654 lands (skeleton/repro in /tmp/t0650_bug_repro.pr,
// and the Go ownership-pass acceptance is already locked by
// TestT0650_UserIndexOptionalMutexUnwrapAllowed in ownership_test.go).
// (Mirrors how this file originally deferred Mutex/Task behind T0650 and how
// T0647 deferred the T0648 nested-vector case: covered where fixed, not here.)
