// Select with multiple receive cases, only one ready.
main() `test(expected: "got 99") {
  ch1 := channel[int](capacity: 1);
  ch2 := channel[int](capacity: 1);
  ch3 := channel[int](capacity: 1);

  // Only ch2 has data
  ch2.send(99);

  select {
    v := <-ch1:
      print_line("from ch1");
    v := <-ch2:
      if val := v {
        print_line("got {val}");
      }
    v := <-ch3:
      print_line("from ch3");
  }
}
