// B0158: Auto-synthesized drop for types with droppable fields.
// Types without explicit drop() but containing fields whose types have drop()
// should auto-get a compiler-synthesized drop that cleans up those fields.
type Inner {
  string name;

  drop(~this) {
    print_line("drop: " + this.name);
  }
}

// Outer has no explicit drop, but Inner has one → synthesized drop for Outer
type Outer {
  Inner inner;
}

// Pair has no explicit drop, but has two Inner fields → synthesized drop calls both
type Pair {
  Inner a;
  Inner b;
}

// Middle has no explicit drop, but Inner does → synthesized drop for Middle
type Middle {
  Inner inner;
  int extra;
}

// Top has no explicit drop, but Middle gets synthesized drop → cascading
type Top {
  Middle mid;
}

// Mixed has both droppable and non-droppable fields
type Mixed {
  int x;
  Inner inner;
  bool flag;
}

// --- Batch tests: verify compilation, construction, and field access ---

test_synth_drop_construct() `test {
  o := Outer(inner: Inner(name: "hello"));
  assert(o.inner.name == "hello", "field access works");
}

test_synth_drop_pair_construct() `test {
  p := Pair(a: Inner(name: "A"), b: Inner(name: "B"));
  assert(p.a.name == "A", "pair field a");
  assert(p.b.name == "B", "pair field b");
}

test_synth_drop_mixed_construct() `test {
  m := Mixed(x: 42, inner: Inner(name: "mix"), flag: true);
  assert(m.x == 42, "mixed int field");
  assert(m.inner.name == "mix", "mixed inner field");
  assert(m.flag, "mixed bool field");
}

test_synth_drop_cascading_construct() `test {
  t := Top(mid: Middle(inner: Inner(name: "deep"), extra: 99));
  assert(t.mid.inner.name == "deep", "cascading field access");
  assert(t.mid.extra == 99, "cascading extra field");
}

// --- B0167: Types with string/vector fields get synthesized drops ---
// The synthesized drop does NOT free string/vector fields (avoiding double-free),
// but it does pal_free the instance and cascades to nested droppable types.

type StringHolder {
  string label;
  int id;
}

type StringOuter {
  StringHolder holder;
  int tag;
}

type VecHolder {
  int[] items;
  int tag;
}

test_string_field_synth_drop() `test {
  StringHolder h = StringHolder(label: "test", id: 1);
  assert(h.label == "test", "B0167: string field");
  assert(h.id == 1, "B0167: int field");
}

test_string_field_cascade() `test {
  StringOuter o = StringOuter(holder: StringHolder(label: "cascade", id: 2), tag: 42);
  assert(o.holder.label == "cascade", "B0167: cascading string field");
  assert(o.tag == 42, "B0167: outer tag");
}

test_vector_field_synth_drop() `test {
  int[] v = int[]();
  v.push(10);
  v.push(20);
  VecHolder h = VecHolder(items: v, tag: 99);
  assert(h.tag == 99, "B0167: vector field type");
}
