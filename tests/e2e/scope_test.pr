// Scope tests: variable scoping in control flow constructs.
// --- variable scope in if ---
test_scope_in_if() `test(allow_leaks: true) {
  int x = 10;
  if true {
    int y = 20;
    assert(y == 20, "y accessible in if block");
    assert(x == 10, "x accessible in if block");
  }
  // y is not accessible here, only x
  assert(x == 10, "x still accessible after if");
}

// --- variable scope in if/else ---

test_scope_if_else() `test(allow_leaks: true) {
  int x = 0;
  if true {
    int temp = 42;
    x = temp;
  } else {
    int temp = 99;
    x = temp;
  }
  assert(x == 42, "x set in if branch");
}

// --- for loop creates scope per iteration ---

test_for_scope_per_iteration() `test(allow_leaks: true) {
  int last = -1;
  for i in 0..10 {
    int local = i * i;
    last = local;
  }
  assert(last == 81, "last square is 9*9=81");
}

// --- variable declared in outer, modified in inner ---

test_outer_modified_inner() `test(allow_leaks: true) {
  int sum = 0;
  for i in 0..5 {
    sum += i;
    if i % 2 == 0 {
      sum += 100;
    }
  }
  // (0+100) + 1 + (2+100) + 3 + (4+100) = 310
  assert(sum == 310, "outer var modified in nested blocks");
}

// --- variable scope in while ---

test_scope_in_while() `test(allow_leaks: true) {
  int count = 0;
  int n = 3;
  while n > 0 {
    int step = 1;
    count += step;
    n--;
  }
  assert(count == 3, "counted 3 steps");
}

// --- nested if scope ---

test_nested_if_scope() `test(allow_leaks: true) {
  int x = 1;
  if x > 0 {
    int y = x * 2;
    if y > 0 {
      int z = y * 3;
      assert(z == 6, "z = 1*2*3 = 6");
    }
    assert(y == 2, "y still 2");
  }
  assert(x == 1, "x still 1");
}

// --- for-in loop variable scoped to body ---

test_for_loop_var_scope() `test(allow_leaks: true) {
  int total = 0;
  for i in 0..5 {
    total += i;
  }
  assert(total == 10, "0+1+2+3+4 = 10");
}

// --- while with inner declarations ---

test_while_inner_decl() `test(allow_leaks: true) {
  int n = 5;
  int result = 1;
  while n > 0 {
    int factor = n;
    result *= factor;
    n--;
  }
  // 5! = 120
  assert(result == 120, "5! = 120");
}

// --- sequential if blocks with same-named vars ---

test_sequential_blocks() `test(allow_leaks: true) {
  int x = 0;
  if true {
    int temp = 10;
    x += temp;
  }
  if true {
    int temp = 20;
    x += temp;
  }
  if true {
    int temp = 30;
    x += temp;
  }
  assert(x == 60, "10 + 20 + 30 = 60");
}

// --- classic for loop variable scope ---

test_classic_for_scope() `test(allow_leaks: true) {
  int sum = 0;
  for i := 0; i < 5; i++ {
    int val = i * 10;
    sum += val;
  }
  assert(sum == 100, "0+10+20+30+40 = 100");
}

// --- reuse for-in loop variable name across loops ---

test_for_in_var_reuse() `test(allow_leaks: true) {
  int sum1 = 0;
  for i in 0..3 {
    sum1 += i;
  }
  int sum2 = 0;
  for i in 10..13 {
    sum2 += i;
  }
  assert(sum1 == 3, "0+1+2 = 3");
  assert(sum2 == 33, "10+11+12 = 33");
}

// --- reuse for-in loop variable with different types ---

test_for_in_var_reuse_different_types() `test(allow_leaks: true) {
  int total = 0;
  string[] items = ["a", "bb", "ccc"];
  for item in items {
    total += 1;
  }
  int[] nums = [10, 20, 30];
  for item in nums {
    total += item;
  }
  assert(total == 63, "3 + 10+20+30 = 63");
}

// --- reuse classic for loop variable ---

test_classic_for_var_reuse() `test(allow_leaks: true) {
  int sum1 = 0;
  for i := 0; i < 3; i++ {
    sum1 += i;
  }
  int sum2 = 0;
  for i := 10; i < 13; i++ {
    sum2 += i;
  }
  assert(sum1 == 3, "0+1+2 = 3");
  assert(sum2 == 33, "10+11+12 = 33");
}

// --- reuse while loop body variable ---

test_while_var_reuse() `test(allow_leaks: true) {
  int n = 3;
  while n > 0 {
    int x = n * 10;
    assert(x > 0, "x positive in first while");
    n--;
  }
  int m = 3;
  while m > 0 {
    int x = m * 100;
    assert(x > 0, "x positive in second while");
    m--;
  }
}

// --- reuse nested for loop variables ---

test_nested_for_var_reuse() `test(allow_leaks: true) {
  int sum = 0;
  for i in 0..3 {
    for j in 0..3 {
      sum += 1;
    }
  }
  int sum2 = 0;
  for i in 0..2 {
    for j in 0..2 {
      sum2 += 1;
    }
  }
  assert(sum == 9, "3*3 = 9");
  assert(sum2 == 4, "2*2 = 4");
}

// --- reuse if block variable ---

test_if_var_reuse() `test(allow_leaks: true) {
  int x = 1;
  if x == 1 {
    int y = 10;
    assert(y == 10, "y == 10 in first if");
  }
  if x == 1 {
    int y = 20;
    assert(y == 20, "y == 20 in second if");
  }
}

// --- reuse match block variable ---

test_match_var_reuse() `test(allow_leaks: true) {
  int val = 1;
  string r1 = match val {
    1 => "one",
    _ => "other",
  };
  string r2 = match val {
    1 => "uno",
    _ => "otro",
  };
  assert(r1 == "one", "first match");
  assert(r2 == "uno", "second match");
}

// --- owned type variable reuse across for loops ---

type ScopedResource {
  int id;

  drop(~this) {
  }
}

test_for_owned_var_reuse() `test(allow_leaks: true) {
  for i in 0..3 {
    r := ScopedResource(id: i);
    assert(r.id == i, "owned var in first loop");
  }
  for i in 0..3 {
    r := ScopedResource(id: i + 10);
    assert(r.id == i + 10, "owned var in second loop");
  }
}

// --- owned type variable reuse across if blocks ---

test_if_owned_var_reuse() `test(allow_leaks: true) {
  if true {
    r := ScopedResource(id: 1);
    assert(r.id == 1, "owned var in first if");
  }
  if true {
    r := ScopedResource(id: 2);
    assert(r.id == 2, "owned var in second if");
  }
}
