// ============================================================
// Section 11: Constructor with explicit new()
// ============================================================

type Clamped {
  int value;

  new(~this, int v) {
    if v < 0 {
      this.value = 0;
    } else {
      this.value = v;
    }
  }
}

auto_prop_explicit_new() int! {
  c := Clamped(v: parse_int("42"));
  return c.value;
}

test_explicit_new_arg_success() `test(allow_leaks: true) {
  int r = auto_prop_explicit_new()!;
  assert(r == 42, "failable arg to explicit new() succeeds");
}

auto_prop_explicit_new_fail() int! {
  c := Clamped(v: parse_int("bad"));
  return c.value;
}

try_explicit_new_fail() bool {
  auto_prop_explicit_new_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_explicit_new_arg_fail() `test(allow_leaks: true) {
  assert(try_explicit_new_fail(), "failable arg to explicit new() propagates");
}

// ============================================================
// Section 12: Value type constructor
// ============================================================

type Vec2 {
  int x `value;
  int y `value;
}

auto_prop_value_type() int! {
  v := Vec2(x: parse_int("42"), y: parse_int("7"));
  return v.x + v.y;
}

test_value_type_arg_success() `test(allow_leaks: true) {
  int r = auto_prop_value_type()!;
  assert(r == 49, "failable args to value type: 42 + 7");
}

auto_prop_value_type_fail() int! {
  v := Vec2(x: parse_int("bad"), y: parse_int("7"));
  return v.x + v.y;
}

try_value_type_fail() bool {
  auto_prop_value_type_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_value_type_arg_fail() `test(allow_leaks: true) {
  assert(try_value_type_fail(), "failable arg to value type propagates");
}

// ============================================================
// Section 13: Virtual method dispatch
// ============================================================

type Shape {
  accepts(int v) int `abstract;
}

type Circle is Shape {
  accepts(int v) int {
    return v * 2;
  }
}

auto_prop_virtual(Shape s) int! {
  return s.accepts(parse_int("7"));
}

test_virtual_method_arg() `test(allow_leaks: true) {
  Circle c = Circle();
  int r = auto_prop_virtual(c)!;
  assert(r == 14, "failable arg through virtual dispatch");
}

// ============================================================
// Section 14: Enum variant constructor
// ============================================================

enum Result {
  Ok(int value),
  Err(string msg),
}

auto_prop_enum_variant() Result! {
  return Result.Ok(value: parse_int("42"));
}

test_enum_variant_arg_success() `test(allow_leaks: true) {
  Result r = auto_prop_enum_variant()!;
  match r {
    Result.Ok(v) => assert(v == 42, "failable arg to enum variant"),
    Result.Err(m) => assert(false, "unexpected error"),
  }
}

auto_prop_enum_variant_fail() Result! {
  return Result.Ok(value: parse_int("bad"));
}

try_enum_variant_fail() bool {
  auto_prop_enum_variant_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_enum_variant_arg_fail() `test(allow_leaks: true) {
  assert(try_enum_variant_fail(), "failable arg to enum variant propagates");
}

