// --- generic enum Box[T] with T? field: copy inner ---

generic_int_bare_widen() `test {
  Box[int] b = Box[int].Full(42);
  match b {
    Box.Full(s) => {
      if v := s {
        assert(v == 42, "generic Box[int] bare-widened holds 42");
      } else {
        assert(false, "expected present T?");
      }
    },
    Box.Vacant => assert(false, "expected Full"),
  }
}

generic_int_none_literal() `test {
  Box[int] b = Box[int].Full(none);
  match b {
