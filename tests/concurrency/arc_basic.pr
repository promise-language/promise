// Arc[T] basic tests — T0155
arc_new_borrow_int() `test {
  a := Arc[int](42);
  assert(a.borrow == 42, "int borrow");
}

arc_new_borrow_string() `test {
  a := Arc[string]("hello");
  assert(a.borrow == "hello", "string borrow");
}

arc_new_borrow_bool() `test {
  a := Arc[bool](true);
  assert(a.borrow == true, "bool borrow");
}

arc_new_borrow_f64() `test {
  a := Arc[f64](3.14);
  assert(a.borrow == 3.14, "f64 borrow");
}

arc_clone_shares_value() `test {
  a := Arc[int](100);
  b := a.clone();
  assert(a.borrow == 100, "original after clone");
  assert(b.borrow == 100, "clone value");
}

arc_clone_string() `test {
  a := Arc[string]("shared");
  b := a.clone();
  assert(a.borrow == "shared", "original string");
  assert(b.borrow == "shared", "cloned string");
}

arc_multiple_clones() `test {
  a := Arc[int](7);
  b := a.clone();
  c := a.clone();
  d := b.clone();
  assert(a.borrow == 7, "a");
  assert(b.borrow == 7, "b");
  assert(c.borrow == 7, "c");
  assert(d.borrow == 7, "d");
}

arc_cross_goroutine() `test {
  a := Arc[int](42);
  ch := channel[int]();
  go {
    ch.send(a.borrow);
  };
  r := <-ch;
  assert(r! == 42, "cross-goroutine value");
}

arc_clone_cross_goroutine() `test {
  a := Arc[int](123);
  ch := channel[int]();
  b := a.clone();
  go {
    ch.send(b.borrow);
  };
  assert(a.borrow == 123, "original intact");
  r := <-ch;
  assert(r! == 123, "clone cross-goroutine");
}

// User-defined type tests — T0272
type ArcPoint {
  int x;
}

arc_borrow_user_type() `test {
  a := Arc[ArcPoint](ArcPoint(x: 5));
  assert(a.borrow.x == 5, "user type borrow");
}

type ArcPair {
  int x;
  int y;
}

arc_borrow_user_type_two_fields() `test {
  a := Arc[ArcPair](ArcPair(x: 3, y: 7));
  assert(a.borrow.x == 3, "field x");
  assert(a.borrow.y == 7, "field y");
}

type ArcDroppable {
  int val;
  drop(~this) {
  }
}

arc_borrow_user_type_with_drop() `test {
  a := Arc[ArcDroppable](ArcDroppable(val: 99));
  assert(a.borrow.val == 99, "droppable borrow");
  b := a.clone();
  assert(b.borrow.val == 99, "droppable clone borrow");
}

type ArcWithString {
  string name;
  int id;
}

arc_borrow_user_type_synth_drop() `test {
  a := Arc[ArcWithString](ArcWithString(name: "test", id: 7));
  assert(a.borrow.name == "test", "synth drop name");
  assert(a.borrow.id == 7, "synth drop id");
}

// Arc[int[]] — vector inner drop path
arc_vector_element() `test {
  v := [10, 20, 30];
  a := Arc[int[]](v);
  int[] borrowed = a.borrow;
  assert(borrowed.len == 3, "vector len");
  assert(borrowed[0] == 10, "vector[0]");
  assert(borrowed[2] == 30, "vector[2]");
}
