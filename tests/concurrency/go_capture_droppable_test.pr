// B0354: Go blocks must transfer ownership of droppable captures.
// Without the fix, the outer scope drops the value before the goroutine
// uses it, causing use-after-free / closed-fd / dangling pointer.
test_string_capture_in_goroutine() `test(exclude: "wasm32") {
  done := channel[int](capacity: 1);
  s := "hello world from outer scope";
  go {
    assert(s.len == 28, "string len");
    assert(s.starts_with("hello"), "string prefix");
    done.send(1);
  };
  r := <-done;
  if v := r {
    assert(v == 1, "received");
  }
}

test_vector_capture_in_goroutine() `test(exclude: "wasm32") {
  done := channel[int](capacity: 1);
  v := [1, 2, 3, 4, 5];
  go {
    assert(v.len == 5, "vec len");
    int sum = 0;
    for x in v {
      sum += x;
    }
    assert(sum == 15, "vec sum");
    done.send(1);
  };
  r := <-done;
  if x := r {
    assert(x == 1, "received");
  }
}

test_multiple_droppable_captures() `test(exclude: "wasm32") {
  done := channel[int](capacity: 1);
  s := "promise";
  v := [10, 20, 30];
  go {
    assert(s.len == 7, "string len");
    assert(v.len == 3, "vec len");
    assert(v[0] == 10, "vec elem");
    done.send(42);
  };
  r := <-done;
  if x := r {
    assert(x == 42, "received");
  }
}

type Payload {
  string name;
  int value;
}

read_payload(string name, int value, channel[int]~ch) {
  assert(name.len == 5, "payload name");
  assert(value == 99, "payload value");
  ch.send(1);
}

test_user_type_fields_captured() `test(exclude: "wasm32") {
  done := channel[int](capacity: 1);
  p := Payload(name: "hello", value: 99);
  go {
    read_payload(p.name, p.value, done);
  };
  r := <-done;
  if x := r {
    assert(x == 1, "user type path");
  }
}

type Greeter {
  string prefix;

  greet(this, string ~name, channel[int]~ch) {
    int n = this.prefix.len + name.len;
    ch.send(n);
  }
}

test_go_method_call_via_block() `test(exclude: "wasm32") {
  done := channel[int](capacity: 1);
  g := Greeter(prefix: "hi ");
  nm := "world";
  go g.greet(nm, done);
  r := <-done;
  if x := r {
    assert(x == 8, "method call via block");
  }
}
