// T0061: String drop at scope exit — verify no leaks for heap-allocated strings.
// String literals are in .rodata (not freed) — no leak
string_literal_no_leak() `test {
  s := "hello";
  assert(s.len == 5, "literal len");
}

// String concatenation creates heap-allocated string — should be freed at scope exit
string_concat_no_leak() `test {
  a := "hello";
  b := " world";
  c := a + b;
  assert(c.len == 11, "concat len");
}

// String passed to function is borrowed — caller frees at scope exit
string_borrow_on_func_call() `test {
  s := "test" + "ing";
  assert(s.contains("test"), "contains");
  assert(s.len == 7, "borrow len");
}

// String returned from function — ownership transfers to caller
string_return_no_double_free() `test {
  s := make_greeting("world");
  assert(s.len == 11, "return len");
}

make_greeting(string name) string {
  return "hello " + name;
}

// Multiple string variables in same scope — all freed
multiple_strings_no_leak() `test {
  a := "foo" + "bar";
  b := "baz" + "qux";
  c := a + b;
  assert(c.len == 12, "multi len");
}

// String assigned to another variable — source flag cleared, no double free
string_move_on_assignment() `test(allow_leaks: true) {
  a := "hello" + " world";
  b := a;
  assert(b.len == 11, "move len");
}

// String in nested scope — freed when inner scope exits
string_nested_scope() `test {
  x := "outer";
  if true {
    y := "inner" + " string";
    assert(y.len == 12, "inner len");
  }
  assert(x.len == 5, "outer len");
}

// String in conditional branch — freed correctly
string_in_if() `test {
  s := "test" + "ing";
  if s.len > 3 {
    t := "yes" + "!";
    assert(t.len == 4, "if branch len");
  }
  assert(s.len == 7, "outer if len");
}

// String in loop — freed each iteration
string_in_loop() `test {
  i := 0;
  while i < 5 {
    s := "loop" + "iter";
    assert(s.len == 8, "loop len");
    i += 1;
  }
}

// B0168: String concat temp in assertion — dropped at statement end
string_concat_temp_in_assert() `test {
  assert("hello " + "world" == "hello world", "concat temp");
}

// B0168: String concat temp passed to function — dropped after call returns
// (1 leak from print_line's internal Builder.to_string() temp, not from concat)
string_concat_temp_in_call() `test {
  print_line("hello " + "world");
}

// B0168: to_string temp in assertion — dropped at statement end
to_string_temp_in_assert() `test {
  assert(42.to_string() == "42", "int to_string");
  assert(true.to_string() == "true", "bool to_string");
}

// B0168: Concat temp stored in constructor — claimed, not double-freed
// (1 leak from StringHolder lacking synthesized drop for string field)
type StringHolder {
  string value;
}
string_concat_in_constructor() `test(allow_leaks: true) {
  h := StringHolder(value: "hello " + "world");
  assert(h.value == "hello world", "constructor concat");
}
