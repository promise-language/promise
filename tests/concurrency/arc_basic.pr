// Arc[T] basic tests — T0155
arc_new_borrow_int() `test {
  a := Arc[int](42);
  assert(a.borrow == 42, "int borrow");
}

arc_new_borrow_string() `test {
  a := Arc[string]("hello");
  assert(a.borrow == "hello", "string borrow");
}

arc_new_borrow_bool() `test {
  a := Arc[bool](true);
  assert(a.borrow == true, "bool borrow");
}

arc_new_borrow_f64() `test {
  a := Arc[f64](3.14);
  assert(a.borrow == 3.14, "f64 borrow");
}

arc_clone_shares_value() `test {
  a := Arc[int](100);
  b := a.clone();
  assert(a.borrow == 100, "original after clone");
  assert(b.borrow == 100, "clone value");
}

arc_clone_string() `test {
  a := Arc[string]("shared");
  b := a.clone();
  assert(a.borrow == "shared", "original string");
  assert(b.borrow == "shared", "cloned string");
}

arc_multiple_clones() `test {
  a := Arc[int](7);
  b := a.clone();
  c := a.clone();
  d := b.clone();
  assert(a.borrow == 7, "a");
  assert(b.borrow == 7, "b");
  assert(c.borrow == 7, "c");
  assert(d.borrow == 7, "d");
}

arc_cross_goroutine() `test {
  a := Arc[int](42);
  ch := channel[int]();
  go {
    ch.send(a.borrow);
  };
  r := <-ch;
  assert(r! == 42, "cross-goroutine value");
}

arc_clone_cross_goroutine() `test {
  a := Arc[int](123);
  ch := channel[int]();
  b := a.clone();
  go {
    ch.send(b.borrow);
  };
  assert(a.borrow == 123, "original intact");
  r := <-ch;
  assert(r! == 123, "clone cross-goroutine");
}

// User-defined type tests — T0272
type ArcPoint {
  int x;
}

arc_borrow_user_type() `test {
  a := Arc[ArcPoint](ArcPoint(x: 5));
  assert(a.borrow.x == 5, "user type borrow");
}

type ArcPair {
  int x;
  int y;
}

arc_borrow_user_type_two_fields() `test {
  a := Arc[ArcPair](ArcPair(x: 3, y: 7));
  assert(a.borrow.x == 3, "field x");
  assert(a.borrow.y == 7, "field y");
}

type ArcDroppable {
  int val;
  drop(~this) {
  }
}

arc_borrow_user_type_with_drop() `test {
  a := Arc[ArcDroppable](ArcDroppable(val: 99));
  assert(a.borrow.val == 99, "droppable borrow");
  b := a.clone();
  assert(b.borrow.val == 99, "droppable clone borrow");
}

type ArcWithString {
  string name;
  int id;
}

arc_borrow_user_type_synth_drop() `test {
  a := Arc[ArcWithString](ArcWithString(name: "test", id: 7));
  assert(a.borrow.name == "test", "synth drop name");
  assert(a.borrow.id == 7, "synth drop id");
}

// Arc[int[]] — vector inner drop path
arc_vector_element() `test {
  v := [10, 20, 30];
  a := Arc[int[]](v);
  int[] borrowed = a.borrow;
  assert(borrowed.len == 3, "vector len");
  assert(borrowed[0] == 10, "vector[0]");
  assert(borrowed[2] == 30, "vector[2]");
}

// T0367: Arc[string[]] — heap container with heap elements. Without the fix,
// `borrowed`'s drop and Arc's inner drop both free the same buffer → segfault
// when the second drop reads scribbled string pointers from the freed buffer.
arc_borrow_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  borrowed := a.borrow;
  assert(borrowed.len == 1, "heap vec len");
}

// T0367: Arc[string] with a heap-allocated string — silently double-frees
// without the fix (string drop's bit-63 check happens to mask it).
arc_borrow_heap_string() `test {
  s := "hello" + "";
  a := Arc[string](s);
  borrowed := a.borrow;
  assert(borrowed.len == 5, "heap string len");
}

// T0367: Optional-chained borrow via Weak.upgrade!.
arc_borrow_optional_chain() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  w := a.downgrade();
  if strong := w.upgrade() {
    borrowed := strong.borrow;
    assert(borrowed.len == 1, "weak upgrade borrow len");
  }
}

// T0367: Typed var decl path (`T borrowed = a.borrow`) with heap T.
// `arc_vector_element` exercises this syntax with a static literal that masks
// the bug via Vector.drop's bit-63 check; this variant pushes a heap-allocated
// element so the static-flag short-circuit cannot hide a double-free.
arc_borrow_typed_decl_heap_vec() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  string[] borrowed = a.borrow;
  assert(borrowed.len == 1, "typed decl heap vec");
}

// T0367: `.borrow` inside a generic function — monomorphization preserves
// the dropflag-clear when T is heap.
arc_borrow_len[T](Arc[Vector[T]] arc) int {
  borrowed := arc.borrow;
  return borrowed.len;
}

arc_borrow_in_generic_fn() `test {
  v := string[]();
  v.push("hello" + "");
  a := Arc[string[]](v);
  assert(arc_borrow_len[string](a) == 1, "generic borrow len");
}

// T0379: Reassignment of `.borrow` to an existing local must clear the dropflag
// re-armed by the unconditional reset in the assignment path. Without the fix,
// `borrowed`'s drop frees the inner buffer that Arc still owns → segfault.
arc_borrow_reassign_after_borrow() `test {
  v1 := string[]();
  v1.push("hello" + "");
  v2 := string[]();
  v2.push("world" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "reassigned borrow len");
}

// T0379: Owned→borrow reassignment. The original local owns its vector; the
// reassignment must drop the owned vec, store the borrow pointer, and clear
// the dropflag so scope cleanup doesn't free the parent's buffer.
arc_borrow_reassign_after_owned() `test {
  owned := string[]();
  owned.push("owned" + "");
  v := string[]();
  v.push("borrowed" + "");
  a := Arc[string[]](v);
  owned = a.borrow;
  assert(owned.len == 1, "owned reassigned to borrow");
}

// T0379: Arc[string] analog. Exercises the string-drop alias-check branch
// (bindingDropString) in the reassignment path.
arc_borrow_reassign_heap_string() `test {
  s1 := "hello" + "";
  s2 := "world" + "";
  a1 := Arc[string](s1);
  a2 := Arc[string](s2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 5, "reassigned string borrow");
}

// T0379: Multiple alternating reassignments — each must override the dropflag
// re-arm so cleanup never double-frees.
arc_borrow_reassign_alternating() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);
  borrowed := a1.borrow;
  borrowed = a2.borrow;
  borrowed = a1.borrow;
  assert(borrowed.len == 1, "alternating reassign");
}

// T0379: Borrow→owned reassignment (negative test). The fix must NOT fire when
// RHS is an owned constructor — the local now owns the new value and its drop
// must run at scope exit. A regression that always cleared the dropflag would
// leak the new vector here.
arc_borrow_reassign_to_owned() `test {
  v := string[]();
  v.push("borrowed" + "");
  a := Arc[string[]](v);
  borrowed := a.borrow;
  borrowed = string[]();
  borrowed.push("owned" + "");
  assert(borrowed.len == 1, "borrow reassigned to owned");
}

// T0379: Typed-decl path (T0367) followed by reassignment (T0379). Verifies
// integration between the two fixes — the typed decl clears the flag, then the
// reassignment correctly re-clears it after the unconditional re-arm.
arc_borrow_typed_decl_reassign() `test {
  v1 := string[]();
  v1.push("a" + "");
  v2 := string[]();
  v2.push("b" + "");
  a1 := Arc[string[]](v1);
  a2 := Arc[string[]](v2);
  string[] borrowed = a1.borrow;
  borrowed = a2.borrow;
  assert(borrowed.len == 1, "typed decl + reassign");
}

// T0379: Reassign inside a loop body. Each iteration re-arms the flag at the
// reassignment site and the fix must clear it; cleanup at scope exit must see
// flag=0. A bug here would surface as cumulative leaks across iterations.
arc_borrow_reassign_in_loop() `test {
  v := string[]();
  v.push("loop" + "");
  a := Arc[string[]](v);
  borrowed := a.borrow;
  i := 0;
  while i < 4 {
    borrowed = a.borrow;
    i = i + 1;
  }
  assert(borrowed.len == 1, "reassign in loop");
}
