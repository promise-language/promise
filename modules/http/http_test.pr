    return; // expected: unsupported scheme
  };
  assert(false, "should have raised an error");
}

// ── Response headers parsed ─────────────────────────────────────────────────

test_response_headers() `test(exclude: "wasm32", timeout: "10s") {
  net.TcpListener listener = net.TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;

  go {
    Response resp = http_get("http://127.0.0.1:" + port.to_string() + "/")?!;
    // Headers are lowercase — iterate directly to avoid B0341 (non-Copy field double-drop)
    bool found = false;
    for k, v in resp.response_headers {
      if k == "x-custom" && v == "hello" {
        found = true;
      }
    }
    assert(found, "x-custom header found");
  };

  _serve_once(listener, "HTTP/1.1 200 OK\r\nX-Custom: hello\r\nContent-Length: 2\r\nConnection: close\r\n\r\nok")?!;
  listener.close()?!;
  sleep(Duration.from_millis(100));
}

// ── Internal helper unit tests (no network) ─────────────────────────────────

test_method_to_string() `test(exclude: "wasm32") {
  assert(_method_to_string(Method.Get) == "GET", "GET");
  assert(_method_to_string(Method.Post) == "POST", "POST");
  assert(_method_to_string(Method.Put) == "PUT", "PUT");
  assert(_method_to_string(Method.Delete) == "DELETE", "DELETE");
  assert(_method_to_string(Method.Patch) == "PATCH", "PATCH");
  assert(_method_to_string(Method.Head) == "HEAD", "HEAD");
  assert(_method_to_string(Method.Options) == "OPTIONS", "OPTIONS");
}

test_parse_hex_cases() `test(exclude: "wasm32") {
  assert(_parse_hex("ff") == 255, "lowercase ff");
  assert(_parse_hex("FF") == 255, "uppercase FF");
  assert(_parse_hex("1A") == 26, "uppercase mixed");
  assert(_parse_hex("1a") == 26, "lowercase mixed");
  assert(_parse_hex("0") == 0, "zero");
  assert(_parse_hex("10") == 16, "sixteen");
}

test_parse_decimal_cases() `test(exclude: "wasm32") {
  assert(_parse_decimal("0") == 0, "zero");
  assert(_parse_decimal("123") == 123, "basic");
  assert(_parse_decimal("8080") == 8080, "port");
  assert(_parse_decimal("65535") == 65535, "large");
}

test_decode_chunked_with_extension() `test(exclude: "wasm32") {
  u8[] data = "5;ext=val\r\nHello\r\n0\r\n\r\n".bytes();
  u8[] result = _decode_chunked(data);
  assert(string.from_bytes(result) == "Hello", "chunked with extension");
}

// ── body_bytes getter ───────────────────────────────────────────────────────

test_body_bytes() `test(exclude: "wasm32", timeout: "10s") {
  net.TcpListener listener = net.TcpListener.bind("127.0.0.1", 0)?!;
  int port = listener.local_port;

  go {
    Response resp = http_get("http://127.0.0.1:" + port.to_string() + "/")?!;
    u8[] bytes = resp.body_bytes;
    assert(bytes.len == 3, "3 bytes");
    assert(bytes[0] == 65, "A");
    assert(bytes[1] == 66, "B");
    assert(bytes[2] == 67, "C");
  };

  _serve_once(listener, "HTTP/1.1 200 OK\r\nContent-Length: 3\r\nConnection: close\r\n\r\nABC")?!;
  listener.close()?!;
  sleep(Duration.from_millis(100));
}

