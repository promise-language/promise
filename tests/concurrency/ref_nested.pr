// Ref[Ref[T]] and nested Arc/Mutex tests — T0273
arc_nested_basic() `test {
  inner := Ref[int](42);
  outer := Ref[Ref[int]](inner);
  assert(outer.borrow.borrow == 42, "nested arc borrow");
}

arc_nested_triple() `test {
  a := Ref[int](7);
  b := Ref[Ref[int]](a);
  c := Ref[Ref[Ref[int]]](b);
  assert(c.borrow.borrow.borrow == 7, "triple nested");
}

arc_nested_clone() `test {
  inner := Ref[int](99);
  outer := Ref[Ref[int]](inner);
  outer2 := outer.clone();
  assert(outer.borrow.borrow == 99, "original nested");
  assert(outer2.borrow.borrow == 99, "cloned nested");
}

arc_nested_string() `test {
  inner := Ref[string]("hello");
  outer := Ref[Ref[string]](inner);
  assert(outer.borrow.borrow == "hello", "nested arc string");
}

mutex_arc_cross() `test {
  a := Ref[int](10);
  m := Mutex[Ref[int]](a);
  guard := m.lock();
  assert(guard.borrow.borrow == 10, "mutex wrapping arc");
}

arc_mutex_cross() `test {
  m := Mutex[int](5);
  a := Ref[Mutex[int]](m);
  guard := a.borrow.lock();
  assert(guard.borrow == 5, "arc wrapping mutex");
}

// T0273 coverage: Non-ident expressions passed to Arc/Mutex constructors
// Exercises claimStringTemp/claimEnvTemp paths when arg is not an IdentExpr
get_value() int {
  return 77;
}

arc_from_call_result() `test {
  a := Ref[int](get_value());
  assert(a.borrow == 77, "arc from function call");
}

arc_from_string_literal() `test {
  a := Ref[string]("literal");
  assert(a.borrow == "literal", "arc from string literal");
}

mutex_from_string_literal() `test {
  m := Mutex[string]("mutex-str");
  use g := m.lock();
  assert(g.borrow == "mutex-str", "mutex from string literal");
}

// T0273 coverage: Vector moved into Arc (claimHeapTemp for vector)
arc_vector_moved() `test {
  v := [10, 20, 30];
  a := Ref[int[]](v);
  assert(a.borrow.len == 3, "arc vector length");
  assert(a.borrow[1] == 20, "arc vector element");
}

// T0273 coverage: MutexGuard captured in lambda (analyzeEnvCaptureDrop MutexGuard branch)
lambda_captures_mutex_guard() `test {
  m := Mutex[int](123);
  guard := m.lock();
  f := move || -> int {
    return guard.borrow;
  };
  result := f();
  assert(result == 123, "mutex guard capture in lambda");
}

// T0273 coverage: Nested Arc with clone and independent drop
arc_nested_clone_independence() `test {
  inner := Ref[int](50);
  outer1 := Ref[Ref[int]](inner);
  outer2 := outer1.clone();
  // Both should independently refer to the same inner Arc
  assert(outer1.borrow.borrow == 50, "outer1 borrow");
  assert(outer2.borrow.borrow == 50, "outer2 borrow");
  // After outer1 drops, outer2 should still be valid (shared inner)
}
