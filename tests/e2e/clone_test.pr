// Tests for `clone meta annotation (T0154)
// --- Basic clone with string + int fields ---
type Document `clone {
  string title;
  int pages;
}

test_clone_basic() `test {
  d := Document(title: "Hello", pages: 42);
  d2 := d.clone();
  assert(d2.title == "Hello", "clone preserves title");
  assert(d2.pages == 42, "clone preserves pages");
}

test_clone_independence() `test {
  // Cloned string fields must be independent — modifying one shouldn't affect the other.
  d := Document(title: "Original", pages: 10);
  d2 := d.clone();
  // Verify they have the same values
  assert(d.title == "Original", "original title");
  assert(d2.title == "Original", "cloned title");
  assert(d.pages == 10, "original pages");
  assert(d2.pages == 10, "cloned pages");
}

// --- Clone with vector fields ---

type Library `clone {
  string name;
  string[] books;
}

test_clone_vector_field() `test {
  lib := Library(name: "Main", books: ["A", "B", "C"]);
  lib2 := lib.clone();
  assert(lib2.name == "Main", "name");
  assert(lib2.books.len == 3, "books len");
  assert(lib2.books[0] == "A", "book 0");
  assert(lib2.books[1] == "B", "book 1");
  assert(lib2.books[2] == "C", "book 2");
}

// --- Clone with only copy fields ---

type Point `clone {
  int x;
  int y;
}

test_clone_copy_fields() `test {
  p := Point(x: 3, y: 4);
  p2 := p.clone();
  assert(p2.x == 3, "x");
  assert(p2.y == 4, "y");
}

// --- Clone with mixed copy + non-copy fields ---

type Config `clone {
  string label;
  int value;
  bool active;
}

test_clone_mixed_fields() `test {
  c := Config(label: "test", value: 99, active: true);
  c2 := c.clone();
  assert(c2.label == "test", "label");
  assert(c2.value == 99, "value");
  assert(c2.active, "active");
}

// --- Clone with nested cloneable types ---

type Wrapper `clone {
  Document doc;
}

test_clone_nested() `test {
  w := Wrapper(doc: Document(title: "Nested", pages: 5));
  w2 := w.clone();
  assert(w2.doc.title == "Nested", "nested title");
  assert(w2.doc.pages == 5, "nested pages");
}

// --- Explicit clone() method takes precedence ---

type Custom {
  int x;

  clone() Self `public {
    return Custom(x: this.x * 2);
  }
}

test_explicit_clone() `test {
  c := Custom(x: 5);
  c2 := c.clone();
  assert(c2.x == 10, "explicit clone doubles x");
}

// --- String clone directly ---

test_string_clone() `test {
  s := "hello world";
  s2 := s.clone();
  assert(s2 == "hello world", "string clone eq");
  assert(s2.len == 11, "string clone len");
}

test_empty_string_clone() `test {
  s := "";
  s2 := s.clone();
  assert(s2 == "", "empty string clone");
  assert(s2.len == 0, "empty string clone len");
}

// --- Vector clone ---

test_int_vector_clone() `test {
  v := [10, 20, 30];
  v2 := v.clone();
  assert(v2.len == 3, "len");
  assert(v2[0] == 10, "0");
  assert(v2[1] == 20, "1");
  assert(v2[2] == 30, "2");
}

test_string_vector_clone() `test {
  v := ["hello", "world"];
  v2 := v.clone();
  assert(v2.len == 2, "len");
  assert(v2[0] == "hello", "0");
  assert(v2[1] == "world", "1");
}

test_empty_vector_clone() `test {
  int[] v = [];
  v2 := v.clone();
  assert(v2.len == 0, "empty vector clone len");
}

// --- Clone with optional string field ---

type OptDoc `clone {
  string? subtitle;
  string title;
}

test_clone_optional_some() `test {
  d := OptDoc(subtitle: "Sub", title: "Main");
  d2 := d.clone();
  assert(d2.title == "Main", "title");
  if s := d2.subtitle {
    assert(s == "Sub", "subtitle value");
  } else {
    assert(false, "subtitle should be some");
  }
}

test_clone_optional_none() `test {
  d := OptDoc(subtitle: none, title: "Main");
  d2 := d.clone();
  assert(d2.title == "Main", "title");
  if _ := d2.subtitle {
    assert(false, "subtitle should be none");
  }
}

// --- string.to_string() uses clone (B0255 fix) ---

test_to_string_clone() `test {
  s := "test";
  s2 := s.to_string();
  assert(s2 == "test", "to_string returns equal string");
}

// --- Clone with inherited fields ---

type Base `clone {
  string name;
}

type Child is Base `clone {
  int age;
}

test_clone_inherited_fields() `test {
  c := Child(name: "Alice", age: 30);
  c2 := c.clone();
  assert(c2.name == "Alice", "inherited name");
  assert(c2.age == 30, "own age");
}

// --- Generic type with clone ---

type Box[T] `clone {
  T value;
  string label;
}

test_clone_generic_copy_elem() `test {
  b := Box[int](value: 42, label: "num");
  b2 := b.clone();
  assert(b2.value == 42, "value");
  assert(b2.label == "num", "label");
}

// --- B0275: Vector.clone() of heap user types ---

type Item `clone {
  string name;
  int count;
}

test_vector_clone_heap_type() `test {
  Item[] v = [Item(name: "a", count: 1), Item(name: "b", count: 2)];
  Item[] v2 = v.clone();
  assert(v2.len == 2, "len");
  assert(v2[0].name == "a", "0.name");
  assert(v2[0].count == 1, "0.count");
  assert(v2[1].name == "b", "1.name");
  assert(v2[1].count == 2, "1.count");
}

test_vector_clone_heap_type_independence() `test {
  Item[] v = [Item(name: "x", count: 10)];
  Item[] v2 = v.clone();
  // Both should have the same values
  assert(v[0].name == "x", "orig name");
  assert(v2[0].name == "x", "clone name");
  // Push to clone shouldn't affect original
  v2.push(Item(name: "y", count: 20));
  assert(v.len == 1, "orig len unchanged");
  assert(v2.len == 2, "clone len grew");
}

// Custom clone that doubles count — verifies clone() is actually called per element
type Doubler {
  int value;

  clone() Self `public {
    return Doubler(value: this.value * 2);
  }
}

test_vector_clone_calls_element_clone() `test {
  Doubler[] v = [Doubler(value: 3), Doubler(value: 5)];
  Doubler[] v2 = v.clone();
  assert(v2[0].value == 6, "element 0 cloned via clone()");
  assert(v2[1].value == 10, "element 1 cloned via clone()");
  // Original should be unchanged
  assert(v[0].value == 3, "orig 0");
  assert(v[1].value == 5, "orig 1");
}

// --- Map clone (T0172) ---

test_map_clone_int_keys() `test {
  map[int, int] m = map[int, int]();
  m[1] = 10;
  m[2] = 20;
  m[3] = 30;
  map[int, int] m2 = m.clone();
  assert(m2.len == 3, "len");
  assert(m2.get_or(1, 0) == 10, "key 1");
  assert(m2.get_or(2, 0) == 20, "key 2");
  assert(m2.get_or(3, 0) == 30, "key 3");
}

test_map_clone_string_keys() `test {
  map[string, int] m = map[string, int]();
  m["a"] = 1;
  m["b"] = 2;
  map[string, int] m2 = m.clone();
  assert(m2.len == 2, "len");
  assert(m2.get_or("a", 0) == 1, "key a");
  assert(m2.get_or("b", 0) == 2, "key b");
}

test_map_clone_string_values() `test {
  map[int, string] m = map[int, string]();
  m[1] = "hello";
  m[2] = "world";
  map[int, string] m2 = m.clone();
  assert(m2.len == 2, "len");
  assert(m2.get_or(1, "") == "hello", "val 1");
  assert(m2.get_or(2, "") == "world", "val 2");
}

test_map_clone_empty() `test {
  map[int, int] m = map[int, int]();
  map[int, int] m2 = m.clone();
  assert(m2.len == 0, "empty clone len");
  assert(m2.is_empty, "empty clone is_empty");
}

test_map_clone_independence() `test {
  map[string, int] m = map[string, int]();
  m["x"] = 42;
  map[string, int] m2 = m.clone();
  m2["y"] = 99;
  assert(m.len == 1, "original len unchanged");
  assert(m2.len == 2, "clone has new entry");
  assert(!m.contains("y"), "original lacks new key");
  assert(m2.contains("y"), "clone has new key");
}

// --- Set clone (T0172) ---

test_set_clone_int() `test {
  Set[int] s = Set[int]();
  s.add(1);
  s.add(2);
  s.add(3);
  Set[int] s2 = s.clone();
  assert(s2.len == 3, "len");
  assert(s2.contains(1), "has 1");
  assert(s2.contains(2), "has 2");
  assert(s2.contains(3), "has 3");
}

test_set_clone_string() `test {
  Set[string] s = Set[string]();
  s.add("hello");
  s.add("world");
  Set[string] s2 = s.clone();
  assert(s2.len == 2, "len");
  assert(s2.contains("hello"), "has hello");
  assert(s2.contains("world"), "has world");
}

test_set_clone_empty() `test {
  Set[int] s = Set[int]();
  Set[int] s2 = s.clone();
  assert(s2.len == 0, "empty clone len");
  assert(s2.is_empty, "empty clone is_empty");
}

test_set_clone_independence() `test {
  Set[int] s = Set[int]();
  s.add(10);
  Set[int] s2 = s.clone();
  s2.add(20);
  assert(s.len == 1, "original len unchanged");
  assert(s2.len == 2, "clone has new elem");
  assert(!s.contains(20), "original lacks new elem");
  assert(s2.contains(20), "clone has new elem");
}

test_map_clone_string_keys_and_values() `test {
  map[string, string] m = map[string, string]();
  m["greeting"] = "hello";
  m["farewell"] = "goodbye";
  map[string, string] m2 = m.clone();
  assert(m2.len == 2, "len");
  assert(m2.get_or("greeting", "") == "hello", "greeting");
  assert(m2.get_or("farewell", "") == "goodbye", "farewell");
}

test_map_clone_after_remove() `test {
  map[int, int] m = map[int, int]();
  m[1] = 10;
  m[2] = 20;
  m[3] = 30;
  m.remove(2);
  map[int, int] m2 = m.clone();
  assert(m2.len == 2, "len after remove");
  assert(m2.get_or(1, 0) == 10, "key 1");
  assert(m2.get_or(3, 0) == 30, "key 3");
  assert(!m2.contains(2), "removed key absent");
}

test_set_clone_after_remove() `test {
  Set[int] s = Set[int]();
  s.add(1);
  s.add(2);
  s.add(3);
  s.remove(2);
  Set[int] s2 = s.clone();
  assert(s2.len == 2, "len after remove");
  assert(s2.contains(1), "has 1");
  assert(!s2.contains(2), "removed absent");
  assert(s2.contains(3), "has 3");
}

// --- Clone annotation with Map/Set fields (T0172) ---

type Registry `clone {
  string name;
  map[string, int] scores;
}

test_clone_type_with_map_field() `test {
  Registry r = Registry(name: "test", scores: map[string, int]());
  r.scores["alice"] = 95;
  r.scores["bob"] = 87;
  Registry r2 = r.clone();
  assert(r2.name == "test", "name");
  assert(r2.scores.len == 2, "scores len");
  assert(r2.scores.get_or("alice", 0) == 95, "alice score");
  assert(r2.scores.get_or("bob", 0) == 87, "bob score");
}

type Group `clone {
  string label;
  Set[int] members;
}

test_clone_type_with_set_field() `test {
  Group g = Group(label: "team", members: Set[int]());
  g.members.add(1);
  g.members.add(2);
  Group g2 = g.clone();
  assert(g2.label == "team", "label");
  assert(g2.members.len == 2, "members len");
  assert(g2.members.contains(1), "has 1");
  assert(g2.members.contains(2), "has 2");
}

// --- Enum clone (T0173) ---

enum Color `clone {
  Red,
  Green,
  Blue,
}

test_clone_enum_fieldless() `test {
  c := Color.Red;
  c2 := c.clone();
  match c2 {
    Color.Red => {
    },
    _ => assert(false, "expected Red"),
  }
}

test_clone_enum_all_variants() `test {
  Color[] colors = [Color.Red, Color.Green, Color.Blue];
  int i = 0;
  for color in colors {
    c2 := color.clone();
    match c2 {
      Color.Red => assert(i == 0, "Red at 0"),
      Color.Green => assert(i == 1, "Green at 1"),
      Color.Blue => assert(i == 2, "Blue at 2"),
    }
    i = i + 1;
  }
}

enum Expr `clone {
  Lit(int value),
  Add(string left, string right),
  None,
}

test_clone_enum_with_copy_fields() `test {
  e := Expr.Lit(value: 42);
  e2 := e.clone();
  match e2 {
    Expr.Lit(v) => assert(v == 42, "lit value"),
    _ => assert(false, "expected Lit"),
  }
}

test_clone_enum_with_string_fields() `test {
  e := Expr.Add(left: "a", right: "b");
  e2 := e.clone();
  match e2 {
    Expr.Add(l, r) => {
      assert(l == "a", "left");
      assert(r == "b", "right");
    },
    _ => assert(false, "expected Add"),
  }
}

test_clone_enum_fieldless_variant() `test {
  e := Expr.None;
  e2 := e.clone();
  match e2 {
    Expr.None => {
    },
    _ => assert(false, "expected None"),
  }
}

// Enum with nested cloneable type fields
type Tag `clone {
  string label;
}

enum Entry `clone {
  Empty,
  Tagged(Tag tag, int id),
}

test_clone_enum_nested_cloneable() `test {
  e := Entry.Tagged(tag: Tag(label: "x"), id: 7);
  e2 := e.clone();
  match e2 {
    Entry.Tagged(t, i) => {
      assert(t.label == "x", "tag label");
      assert(i == 7, "id");
    },
    _ => assert(false, "expected Tagged"),
  }
}

// Explicit enum clone method takes precedence
enum Dir `clone {
  North,
  South,

  clone() Dir {
    return Dir.North;
  }
}

test_clone_enum_explicit() `test {
  d := Dir.South;
  d2 := d.clone();
  match d2 {
    Dir.North => {
    },
    _ => assert(false, "explicit clone always returns North"),
  }
}

// Cloneable structural interface is auto-imported from std/clone.pr
