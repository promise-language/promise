// T0559 / T0545 / T0616: Vector.clone() on single-owner native handle elements.
//
// T0545 made Vector[Task|Mutex|MutexGuard].clone() (and nested
// Vector[Vector[Mutex]]) a clean *sema error* at direct call sites. T0616
// closes the residual generic-indirection hole: a generic helper that calls
// .clone() inside its body is now rejected at the call site when instantiated
// with a single-owner handle, via deferred cloneability requirements
// propagated across generic call chains. The codegen-side T0559 runtime panic
// and T0545 backstop remain as defense-in-depth but are unreachable for
// well-formed user code. Compile-fail cases live in sema_test.go
// (TestT0545_* / TestT0616_*) since they cannot be batch tests.
//
// This file keeps the still-valid positive cases: refcounted handles (Arc /
// Weak / Channel) ARE duplicable and must NOT be gated. Zero leaks (T0067).
test_arc_clone_nonempty() `test {
  v := Vector[Ref[int]]();
  v.push(Ref[int](1));
  v.push(Ref[int](2));
  v2 := v.clone();
  assert(v2.len == 2, "arc clone len");
}

test_weak_clone_nonempty() `test {
  a := Ref[int](7);
  v := Vector[Weak[int]]();
  v.push(a.downgrade());
  v2 := v.clone();
  assert(v2.len == 1, "weak clone len");
}

test_channel_clone_nonempty() `test {
  v := Vector[Channel[int]]();
  v.push(Channel[int]());
  v2 := v.clone();
  assert(v2.len == 1, "channel clone len");
}

// (A `clone struct with a Vector[Mutex[T]] field is itself non-cloneable
// under T0545 — the synthesized clone would call the gated
// Vector[Mutex].clone() — so the former struct-field clone test is removed;
// that rejection is the coherent extension of the non-cloneable rule.)
//
// (The former generic-indirection empty-Mutex-vector test is removed:
// T0616 now rejects `dup[Mutex[int]](v)` at sema, so the path that test
// pinned — running through the codegen backstop — is unreachable. The kept
// backstops (T0559 length-guarded runtime panic, isSingleOwnerHandleType
// early-returns in cloneHeapElement/dupHeapValue) stay as defense-in-depth.)
