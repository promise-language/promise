// T0649: binding the result of a method/operator with a borrowed-reference
// return type (`T&` / `T~`) to a local leaked 1 allocation.
//
// Root cause: `at(int i) string& { return this.d[i]; }` lowered to a body that
// strdup'd the element (B0189 string return-dup in genReturnStmt) and returned
// the fresh owned copy despite the `string&` return type. The call site then
// temp-tracked that dup as an owned string (extractNamed unwraps SharedRef →
// TypString); on binding, claimStringTemp cleared the stmt-temp flag while
// isBorrowedExpr cleared the LHS drop flag — leaving the dup with no owner.
//
// Fix (two parts): (1) genReturnStmt skips the B0189 string dup and the sibling
// enum-clone for `!isRefType(retType)`; (2) the CallExpr post-call tracking and
// trackUserIndexResult skip tracking when the static result type is a borrow.
// A `&`/`~` return now hands back the real reference (no allocation) and the
// caller treats it as a non-owned alias (no track, no free); the actual owner
// (the receiver's field/vector) frees the data exactly once.
//
// Every test is a batch test — the harness fails on ANY leaked allocation
// (zero-tolerance). Temp-use, bind, and non-ref control are each exercised.
// ---------- core repro: plain method returning string& ----------
type PureRef {
  string[] d;
  at(int i) string & {
    return this.d[i];
  }
}

test_t0649_method_temp() `test {
  r := PureRef(d: ["aa" + "x", "bbb" + "y"]);
  assert(r.at(0).len == 3, "string& temporary use");
}

test_t0649_method_bind() `test {
  r := PureRef(d: ["aa" + "x", "bbb" + "y"]);
  x := r.at(1);
  assert(x.len == 4, "string& result bound to local");
}

test_t0649_method_bind_then_use() `test {
  r := PureRef(d: ["one", "three" + "!"]);
  a := r.at(0);
  b := r.at(1);
  assert(a.len == 3, "first borrow bound");
  assert(b.len == 6, "second borrow bound");
}

// ---------- string~ (MutRef) method return ----------
type MutPureRef {
  string[] d;
  at(int i) string ~ {
    return this.d[i];
  }
}

test_t0649_mutref_temp() `test {
  r := MutPureRef(d: ["pp" + "q", "rr"]);
  assert(r.at(0).len == 3, "string~ temporary use");
}

test_t0649_mutref_bind() `test {
  r := MutPureRef(d: ["pp" + "q", "rrrr" + "s"]);
  x := r.at(1);
  assert(x.len == 5, "string~ result bound to local");
}

// ---------- non-ref control (must stay 0-leak) ----------
type OwnedRet {
  string[] d;
  at(int i) string {
    return this.d[i];
  }
}

test_t0649_nonref_control_bind() `test {
  r := OwnedRet(d: ["aa" + "x", "bbb" + "y"]);
  x := r.at(1);
  assert(x.len == 4, "non-ref return bound to local (control)");
}

test_t0649_nonref_control_temp() `test {
  r := OwnedRet(d: ["aa" + "x", "bbb" + "y"]);
  assert(r.at(0).len == 3, "non-ref return temporary use (control)");
}

// ---------- user-defined [] operator returning string& ----------
type IdxRef {
  string[] d;
  [](int i) string & {
    return this.d[i];
  }
  at(int i) string & {
    return this.d[i];
  }
}

test_t0649_index_ref_temp() `test {
  s := IdxRef(d: ["a", "bb" + "b"]);
  assert(s[1].len == 3, "[]&  operator temporary use");
  assert(s.at(0).len == 1, "method& baseline temp");
}

test_t0649_index_ref_bind() `test {
  s := IdxRef(d: ["a", "bb" + "b"]);
  x := s[1];
  assert(x.len == 3, "[]& operator result bound to local");
  y := s.at(0);
  assert(y.len == 1, "method& result bound to local (parity)");
}

take_str(string v) int {
  return v.len;
}

test_t0649_index_ref_fn_arg() `test {
  s := IdxRef(d: ["hello", "hi"]);
  assert(take_str(s[0]) == 5, "[]& result passed as fn arg");
  assert(take_str(s.at(1)) == 2, "method& result passed as fn arg");
}

// ---------- user-defined [] operator returning a vector borrow ----------
type RowsRef {
  string[][] rows;
  [](int i) string[] & {
    return this.rows[i];
  }
}

test_t0649_index_vec_ref_temp() `test {
  m := RowsRef(rows: [["a", "bb"], ["ccc"]]);
  assert(m[0].len == 2, "vector& operator temporary use");
}

test_t0649_index_vec_ref_bind() `test {
  m := RowsRef(rows: [["a" + "x", "bb"], ["ccc"]]);
  row := m[0];
  assert(row.len == 2, "vector& operator result bound to local");
  assert(row[0].len == 2, "borrowed row element access");
}

// ---------- method returning a vector borrow from a vector index ----------
type GridRef {
  int[][] g;
  row(int i) int[] & {
    return this.g[i];
  }
}

test_t0649_method_vec_ref_bind() `test {
  gr := GridRef(g: [[1, 2, 3], [4, 5]]);
  r := gr.row(0);
  assert(r.len == 3, "int[]& method result bound to local");
  r2 := gr.row(1);
  assert(r2.len == 2, "second int[]& borrow bound");
}

// ---------- consistency hardening: droppable-enum element borrow ----------
// Mirrors the B0189 sibling enum-clone block (cloneEnumValue for a droppable
// enum loaded from a vector index). Returning `MyEnum&`/`MyEnum~` from such a
// `return vec[i]` previously would clone the enum and leak it at a binding
// call site (latent — no prior test).
//
// The `clone annotation is LOAD-BEARING, do not remove it: cloneEnumValue
// only emits a clone when a synthesized `Tagged.clone` exists. A bare enum
// has no synthesized clone, so the enum-clone block is inert and the
// `!isRefType` guard is never exercised (the test would pass with OR without
// the Part 1 enum-clone fix — a false-green). With `clone the clone is
// genuinely reachable: pre-fix it fires and is orphaned at the binding site
// (leak); post-fix the guard suppresses it. Only then does the
// zero-tolerance leak gate actually regression-test the enum-clone guard.
enum Tagged `clone {
  Empty,
  Named(string s),
  size(this) int {
    match this {
      Empty => {
        return 0;
      },
      Named(n) => {
        return n.len;
      },
    }
  }
}

type EnumVecRef {
  Tagged[] items;
  at(int i) Tagged & {
    return this.items[i];
  }
  at_mut(int i) Tagged ~ {
    return this.items[i];
  }
}

test_t0649_enum_ref_temp() `test {
  ev := EnumVecRef(items: [Tagged.Named("ab" + "c"), Tagged.Empty]);
  assert(ev.at(0).size() == 3, "enum& temporary use");
  assert(ev.at(1).size() == 0, "enum& empty variant temp");
}

test_t0649_enum_ref_bind() `test {
  ev := EnumVecRef(items: [Tagged.Named("ab" + "cd"), Tagged.Empty]);
  e := ev.at(0);
  assert(e.size() == 4, "enum& result bound to local");
}

test_t0649_enum_mutref_bind() `test {
  ev := EnumVecRef(items: [Tagged.Named("hello" + "!"), Tagged.Empty]);
  e := ev.at_mut(0);
  assert(e.size() == 6, "enum~ result bound to local");
}

test_t0649_enum_ref_bind_then_use() `test {
  ev := EnumVecRef(items: [Tagged.Named("ab" + "c"), Tagged.Named("de" + "fg")]);
  a := ev.at(0);
  b := ev.at(1);
  assert(a.size() == 3, "first droppable-enum borrow bound");
  assert(b.size() == 4, "second droppable-enum borrow bound (both alive)");
}

// ---------- borrow under a ~ / & receiver ----------
pureref_idx_mut(PureRef ~s) int {
  return s.at(1).len;
}
pureref_idx_shared(PureRef s) int {
  x := s.at(0);
  return x.len;
}

test_t0649_ref_params() `test {
  assert(pureref_idx_mut(PureRef(d: ["q", "wer"])) == 3, "string& via ~ receiver (temp)");
  assert(pureref_idx_shared(PureRef(d: ["zzzz", "y"])) == 4, "string& via & receiver (bind)");
}

// ---------- generic container with element-borrow accessor ----------
// Exercises the substitution path: c.currentRetType is `SharedRef(TypeParam
// T)` and only resolves to `SharedRef(string)` after types.Substitute under
// the mono subst — the concrete-type cases above never hit that. Highly
// idiomatic (a Vector[T]-like wrapper handing back element borrows).
type GBox[T] {
  T[] d;
  at(int i) T & {
    return this.d[i];
  }
  get_mut(int i) T ~ {
    return this.d[i];
  }
}

test_t0649_generic_string_ref_bind() `test {
  b := GBox[string](d: ["aa" + "x", "bbb" + "y"]);
  x := b.at(1);
  assert(x.len == 4, "generic T& (string) bound to local");
  y := b.get_mut(0);
  assert(y.len == 3, "generic T~ (string) bound to local");
}

test_t0649_generic_string_ref_temp() `test {
  b := GBox[string](d: ["aa" + "x", "bbb" + "y"]);
  assert(b.at(0).len == 3, "generic T& (string) temp use");
}

test_t0649_generic_int_ref_bind() `test {
  b := GBox[int](d: [10, 20, 30]);
  v := b.at(2);
  assert(v == 30, "generic T& (int) bound to local");
}

// ---------- generic container of a droppable `clone enum (gate × subst) ----------
// The intersection the concrete-enum and generic-string cases each miss: the
// enum-clone B0189 sibling block reached on a *substituted* retType
// (SharedRef(TypeParam T) → SharedRef(Tag) under the GBox[GTag] mono subst).
// The `clone annotation is load-bearing here for the same reason as the
// concrete enum above — without a synthesized GTag.clone the enum-clone block
// is inert and the guard is a false-green. Verified via the revert experiment:
// without the Part 1 enum-clone !isRefType guard, the bind forms LEAK while
// temp-use stays clean.
enum GTag `clone {
  Nil,
  Val(string s),
  size(this) int {
    match this {
      Nil => {
        return 0;
      },
      Val(n) => {
        return n.len;
      },
    }
  }
}

test_t0649_generic_enum_ref_bind() `test {
  b := GBox[GTag](d: [GTag.Val("ab" + "c"), GTag.Nil]);
  e := b.at(0);
  assert(e.size() == 3, "generic T& (droppable `clone enum) bound to local");
}

test_t0649_generic_enum_ref_temp() `test {
  b := GBox[GTag](d: [GTag.Val("xy" + "zw"), GTag.Nil]);
  assert(b.at(0).size() == 4, "generic T& (droppable `clone enum) temp use");
}

test_t0649_generic_enum_mutref_bind() `test {
  b := GBox[GTag](d: [GTag.Val("hello" + "!"), GTag.Nil]);
  e := b.get_mut(0);
  assert(e.size() == 6, "generic T~ (droppable `clone enum) bound to local");
}

// ---------- T0660: borrowed enum receiver must NOT drop the synth temp -------
// A droppable `clone enum returned by `&`/`~` from a Vector, then used as the
// receiver of an enum method/generic-method/getter call, synthesized an
// `enum.this`/`enum.getter` receiver temp that was DROPPED post-call —
// @T0660Tag.drop freed the `Named(string)` payload that the vector still owns,
// so the scope-exit Vector.drop freed it AGAIN: `fatal: invalid free (bad
// header magic)` / segfault. T0649 fixed the call-site temp-track and the
// method-body return-clone but missed this third, independent
// enum-receiver-drop mechanism (genEnumMethodCall /
// genGenericEnumMethodCall / genEnumGetterAccess).
//
// The single-read T0649 enum forms above are heap-layout false-greens in
// isolation. Reading the SAME borrowed element MULTIPLE times forces the
// pre-fix free-then-reuse: pre-fix these segfault deterministically; post-fix
// they pass with the zero-tolerance leak gate green. All three modified
// codegen sites + the substituted-generic path + `&`/`~` are covered.
enum T0660Tag `clone {
  Empty,
  Named(string s),
  size(this) int {
    match this {
      Empty => {
        return 0;
      },
      Named(n) => {
        return n.len;
      },
    }
  }
  // site 1: generic enum method (genGenericEnumMethodCall)
  scaled[U](this, U _marker, int extra) int {
    match this {
      Empty => {
        return extra;
      },
      Named(n) => {
        return n.len + extra;
      },
    }
  }
  // site 2: enum getter (genEnumGetterAccess)
  get tag_len int {
    match this {
      Empty => {
        return 0;
      },
      Named(n) => {
        return n.len;
      },
    }
  }
}

type T0660Vec {
  T0660Tag[] items;
  at(int i) T0660Tag & {
    return this.items[i];
  }
  at_mut(int i) T0660Tag ~ {
    return this.items[i];
  }
  // owned by-value accessor → T0649 owned-return path clones the element, so
  // the caller holds an INDEPENDENT droppable enum with no other owner. The
  // synthesized receiver temp of a method/getter call on `ev.at_own(0)` MUST
  // be dropped (the cloned `Named(string)` payload has no other owner). This
  // is the precision/leak direction of T0660: if the `!isBorrowedExpr` gate
  // were over-broad it would suppress this drop and the zero-tolerance leak
  // gate would fail. Pairs the IR precision controls
  // (TestT0660_Owned*ReceiverStillDrops) with a runtime 0-leak check.
  at_own(int i) T0660Tag {
    return this.items[i];
  }
}

// site 3: non-generic method on a concrete enum, `&` receiver
test_t0660_borrowed_enum_recv_no_double_free() `test {
  ev := T0660Vec(items: [T0660Tag.Named("ab" + "c"), T0660Tag.Empty]);
  a := ev.at(0).size();
  b := ev.at(0).size(); // pre-fix: UAF on the already-freed payload
  c := ev.at(0).size();
  assert(a == 3 && b == 3 && c == 3, "borrowed enum& receiver must not be dropped");
  assert(ev.at(1).size() == 0, "empty-variant borrow still valid after re-reads");
}

// site 3: non-generic method on a concrete enum, `~` receiver
test_t0660_borrowed_enum_mutref_recv_no_double_free() `test {
  ev := T0660Vec(items: [T0660Tag.Named("hello" + "!"), T0660Tag.Empty]);
  a := ev.at_mut(0).size();
  b := ev.at_mut(0).size();
  c := ev.at_mut(0).size();
  assert(a == 6 && b == 6 && c == 6, "borrowed enum~ receiver must not be dropped");
}

// site 1: generic enum method on a borrowed `&` receiver
test_t0660_borrowed_enum_generic_method_no_double_free() `test {
  ev := T0660Vec(items: [T0660Tag.Named("ab" + "cd"), T0660Tag.Empty]);
  a := ev.at(0).scaled[int](0, 10);
  b := ev.at(0).scaled[int](0, 10);
  c := ev.at(0).scaled[int](0, 10);
  assert(a == 14 && b == 14 && c == 14, "borrowed receiver of generic enum method must not be dropped");
}

// site 2: enum getter on a borrowed `&` receiver
test_t0660_borrowed_enum_getter_no_double_free() `test {
  ev := T0660Vec(items: [T0660Tag.Named("xy" + "zzz"), T0660Tag.Empty]);
  a := ev.at(0).tag_len;
  b := ev.at(0).tag_len;
  c := ev.at(0).tag_len;
  assert(a == 5 && b == 5 && c == 5, "borrowed enum getter receiver must not be dropped");
}

// generic container (substituted SharedRef path) of a droppable `clone enum
type T0660GBox[T] {
  T[] d;
  at(int i) T & {
    return this.d[i];
  }
  get_mut(int i) T ~ {
    return this.d[i];
  }
}

// site 3 under substitution: SharedRef(TypeParam T) → SharedRef(T0660Tag), `&`
test_t0660_generic_borrowed_enum_recv_no_double_free() `test {
  b := T0660GBox[T0660Tag](d: [T0660Tag.Named("ab" + "c"), T0660Tag.Empty]);
  x := b.at(0).size();
  y := b.at(0).size();
  z := b.at(0).size();
  assert(x == 3 && y == 3 && z == 3, "generic borrowed enum& receiver must not be dropped");
}

// site 3 under substitution, `~` receiver
test_t0660_generic_borrowed_enum_mutref_recv_no_double_free() `test {
  b := T0660GBox[T0660Tag](d: [T0660Tag.Named("hello" + "!"), T0660Tag.Empty]);
  x := b.get_mut(0).size();
  y := b.get_mut(0).size();
  z := b.get_mut(0).size();
  assert(x == 6 && y == 6 && z == 6, "generic borrowed enum~ receiver must not be dropped");
}

// ---------- T0660 precision/leak direction: OWNED receiver MUST drop --------
// The tests above pin the borrow direction (suppress the receiver-temp drop).
// These pin the inverse: an OWNED (by-value, cloned) droppable-enum receiver
// of a method/generic-method/getter call MUST still drop the synthesized
// receiver temp. Pre-T0660 these already worked; their value is regression
// protection against the gate becoming over-broad — over-suppression here
// leaks the cloned `Named(string)` payload and the zero-tolerance leak gate
// fails. They give site 1 (genGenericEnumMethodCall) its first runtime
// owned-receiver coverage (the IR if-true body was count-0 across the whole
// codegen suite before the matching Go controls).

// site 3 owned: non-generic method on a fresh owned concrete enum
test_t0660_owned_enum_recv_drops_no_leak() `test {
  ev := T0660Vec(items: [T0660Tag.Named("ab" + "c"), T0660Tag.Empty]);
  a := ev.at_own(0).size();
  b := ev.at_own(0).size();
  assert(a == 3 && b == 3, "owned enum receiver method result");
  assert(ev.at_own(1).size() == 0, "owned empty-variant receiver");
}

// site 1 owned: generic enum method on a fresh owned concrete enum
test_t0660_owned_enum_generic_method_drops_no_leak() `test {
  ev := T0660Vec(items: [T0660Tag.Named("ab" + "cd"), T0660Tag.Empty]);
  a := ev.at_own(0).scaled[int](0, 10);
  b := ev.at_own(0).scaled[int](0, 10);
  assert(a == 14 && b == 14, "owned receiver of generic enum method result");
}

// site 2 owned: enum getter on a fresh owned concrete enum
test_t0660_owned_enum_getter_drops_no_leak() `test {
  ev := T0660Vec(items: [T0660Tag.Named("xy" + "zzz"), T0660Tag.Empty]);
  a := ev.at_own(0).tag_len;
  b := ev.at_own(0).tag_len;
  assert(a == 5 && b == 5, "owned enum getter receiver result");
}
