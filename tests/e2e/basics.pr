main() `test(expected: """42
-7
3.14
true
false
hello world
30
foobar
x < y
10
45
5
7""") {
  // Integers
  print_line(42);
  print_line(-7);

  // Float
  print_line(3.14);

  // Bool
  print_line(true);
  print_line(false);

  // String
  print_line("hello world");

  // Variables and arithmetic
  int x = 10;
  int y = 20;
  print_line(x + y);

  // String concat
  string a = "foo";
  string b = "bar";
  print_line(a + b);

  // If/else
  if x < y {
    print_line("x < y");
  } else {
    print_line("x >= y");
  }

  // While loop
  int i = 0;
  int sum = 0;
  while i < 5 {
    sum += i;
    i += 1;
  }
  print_line(sum);

  // For range
  int total = 0;
  for n in 0..10 {
    total += n;
  }
  print_line(total);

  // Increment/decrement
  int c = 0;
  for j := 0; j < 5; j++ {
    c++;
  }
  print_line(c);

  int d = 10;
  d--;
  d--;
  d--;
  print_line(d);
}
