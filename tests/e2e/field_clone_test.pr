// B0341: Reading non-Copy, non-auto-dup fields from droppable owners requires .clone().
// This test verifies that cloned fields produce independent copies.
type Inner {
  map[string, string] headers;
}

type Outer {
  map[string, string] headers;
}

test_clone_map_field() `test {
  map[string, string] h = map[string, string]();
  h["a"] = "b";
  Inner inner = Inner(headers: h);
  // inner.headers requires .clone() — ownership checker rejects bare field read
  Outer outer = Outer(headers: inner.headers.clone());
  assert(outer.headers.len == 1, "outer has 1 entry");
  assert(outer.headers.contains("a"), "outer has key a");
  // Mutate the clone — original must be unaffected
  outer.headers["c"] = "d";
  assert(inner.headers.len == 1, "inner still has 1 entry after clone mutation");
}

test_clone_string_field_no_clone_needed() `test {
  // Strings are auto-dup'd in codegen — no .clone() required.
  Inner2 inner = Inner2(name: "hello");
  string s = inner.name;
  assert(s == "hello", "string field read works without clone");
}

type Inner2 {
  string name;
}

test_clone_vector_field_no_clone_needed() `test {
  // Vectors are auto-dup'd in codegen — no .clone() required.
  VecHolder holder = VecHolder(items: [1, 2, 3]);
  int[] v = holder.items;
  assert(v.len == 3, "vector field read works without clone");
}

type VecHolder {
  int[] items;
}

// T0473: generic owner with a non-Optional TypeParam field instantiated with a
// droppable concrete type. Sema's fieldTypeHasDrop returns false for TypeParam,
// but codegen synthesizes a drop for `GenHolder[map[string,string]]` — without
// the ownership fix, `m = h.value` would double-free at runtime.
type GenHolder[T] {
  T value;
}

test_clone_generic_typeparam_field() `test {
  map[string, string] src = map[string, string]();
  src["a"] = "b";
  GenHolder[map[string, string]] h = GenHolder[map[string, string]](value: src);
  // h.value requires .clone() — ownership rejects bare field read on the
  // droppable instantiation. Cloned copy is independent.
  map[string, string] cloned = h.value.clone();
  assert(cloned.len == 1, "clone has 1 entry");
  assert(cloned.contains("a"), "clone has key a");
  // Mutate the clone — original must be unaffected.
  cloned["c"] = "d";
  assert(h.value.len == 1, "owner field still has 1 entry after clone mutation");
}

// Generic owner with non-droppable TypeArg — no .clone() needed.
type GenHolderOpt[T] {
  T? value;
}

test_generic_optional_field_non_droppable_ok() `test {
  GenHolderOpt[int] h = GenHolderOpt[int](value: 7);
  if y := h.value {
    assert(y == 7, "got 7");
  }
}

// T0505: generic owner with a tuple field whose element is a TypeParam,
// instantiated with a droppable concrete type. Sema's fieldTypeHasDrop returns
// false for the TypeParam-containing tuple, but codegen's monoTypeHasDroppable
// recurses into tuple elems and synthesizes a drop for
// `GenTupHolder[map[string,string]]`. Without the ownership Tuple-case fix, a
// bare field move would double-free; here we only let the owner go out of
// scope, exercising the codegen-side synth drop end-to-end.
type GenTupHolder[T] {
  (T, int) pair;
}

test_generic_tuple_field_drop_only() `test {
  map[string, string] m = map[string, string]();
  m["a"] = "b";
  GenTupHolder[map[string, string]] h = GenTupHolder[map[string, string]](pair: (m, 2));
  // No bare move of h.pair — let h drop at scope exit; the synthesized drop
  // must recurse into the tuple and free the inner map without crashing.
}

// T0505: destructure-decl from an IndexExpr source on a vector of droppable
// tuples. checkDestructureVarDecl skips the field-move check for IndexExpr
// sources (parallel to the MemberExpr borrow path) because codegen treats the
// destructured locals as non-owning borrows. The parent vector retains
// ownership of its elements, so no double-free occurs at scope exit.
test_destructure_indexexpr_droppable_tuple() `test {
  (string, int)[] v = [("a" + "b", 10), ("c" + "d", 20)];
  (s, n) := v[0];
  assert(s == "ab", "destructured string borrow");
  assert(n == 10, "destructured int");
}

// T0506: generic owner whose field is a generic enum instance with a TypeParam
// variant payload, instantiated with a droppable concrete type. Sema's
// fieldTypeHasDrop returns false for the TypeParam-containing enum field, but
// codegen synthesizes a drop for the substituted enum via
// monoEnumInstNeedsSynthDrop. Without the ownership Enum-origin branch a
// bare `m = c.m;` would slip through sema and double-free at runtime; the
// new branch rejects it at compile time (verified by
// TestFieldMoveGenericEnumDroppableError in the ownership unit tests). This
// e2e test exercises the codegen-side synth drop end-to-end: build the
// holder with an inline constructor and let it drop at scope exit. The
// construction temp's enum drop must fire and drop the inner droppable
// without crashing.
type _BoxDropT0506 {
  int n;
  drop(~this) {
  }
}

enum MaybeBox[T] {
  Just(T val),
  Nothing,
}

type MaybeBoxHolder[T] {
  MaybeBox[T] m;
}

test_generic_enum_field_drop_only() `test {
  MaybeBoxHolder[_BoxDropT0506] c = MaybeBoxHolder[_BoxDropT0506](m: MaybeBox[_BoxDropT0506].Just(_BoxDropT0506(n: 42)));
  // Let c drop at scope exit — the construction temp's enum drop must fire
  // and drop the inner _BoxDropT0506 without crashing or leaking.
}

// T0552: same shape as T0506's inline test, but with named-variable
// construction. The inline form happens to drop the construction temp
// (since the move into the field doesn't clear that temp's flag), masking
// the bug. The named-variable form below clears `j`'s drop flag on the
// move, so cleanup must come from the holder's synth drop. monoTypeHasDroppable
// needs to recurse into the generic enum Instance (gap 1) AND emitFieldDropsFor
// needs to emit the enum field's drop call (gap 2). Memory-leak enforcement
// fails this test if either gap is open.
test_generic_enum_field_drop_named_var() `test {
  MaybeBox[_BoxDropT0506] j = MaybeBox[_BoxDropT0506].Just(_BoxDropT0506(n: 42));
  MaybeBoxHolder[_BoxDropT0506] c = MaybeBoxHolder[_BoxDropT0506](m: j);
  // Let c drop at scope exit — HolderL[_BoxDropT0506]'s synth drop must call
  // MaybeL[_BoxDropT0506].drop, which in turn drops the inner _BoxDropT0506.
}

// T0552: user-defined new() with an enum-typed move param. The new() path
// in genConstructorCallMono also needs to clear enum ctor temps after the
// move arg is evaluated — otherwise the inline form double-frees (caller's
// ctor temp drop fires AND new() stores the enum into a field that the
// owner's synth drop now also handles).
type _MaybeBoxHolderNewT0552[T] {
  MaybeBox[T] m;
  new(~this, ~MaybeBox[T] m) {
    this.m = m;
  }
}

test_generic_enum_field_drop_inline_userctor() `test {
  _MaybeBoxHolderNewT0552[_BoxDropT0506] c = _MaybeBoxHolderNewT0552[_BoxDropT0506](m: MaybeBox[_BoxDropT0506].Just(_BoxDropT0506(n: 1)));
}

test_generic_enum_field_drop_named_var_userctor() `test {
  MaybeBox[_BoxDropT0506] j = MaybeBox[_BoxDropT0506].Just(_BoxDropT0506(n: 2));
  _MaybeBoxHolderNewT0552[_BoxDropT0506] c = _MaybeBoxHolderNewT0552[_BoxDropT0506](m: j);
}

// T0552: non-generic holder with non-generic enum field. The plan noted that
// Gap 2's fix (emitFieldDropsFor enum-field branch) "incidentally repairs"
// this case — sema sets NeedsSynthDrop=true on the holder because the concrete
// enum's HasDrop is observable, but before T0552 the synth drop body silently
// skipped the enum field. Both forms (named-var move + inline ctor temp) must
// drop the inner _BoxDropT0506 without leaking or double-freeing.
enum _MaybePlainT0552 {
  Just(_BoxDropT0506 val),
  Nothing,
}

type _HolderPlainT0552 {
  _MaybePlainT0552 m;
}

test_nongen_enum_field_drop_named_var() `test {
  _MaybePlainT0552 j = _MaybePlainT0552.Just(_BoxDropT0506(n: 11));
  _HolderPlainT0552 c = _HolderPlainT0552(m: j);
}

test_nongen_enum_field_drop_inline() `test {
  _HolderPlainT0552 c = _HolderPlainT0552(m: _MaybePlainT0552.Just(_BoxDropT0506(n: 13)));
}

// T0552: holder with TWO droppable generic-enum fields. Exercises the loop in
// emitFieldDropsFor across multiple enum-typed fields and a non-droppable field
// in between, ensuring the iteration order and per-field GEP computation are
// correct. Regressions in field-index computation or loop early-exit would
// leak one (or both) inner _BoxDropT0506 values.
type _Holder2T0552[T] {
  MaybeBox[T] a;
  int x;
  MaybeBox[T] b;
}

test_generic_enum_field_drop_two_fields() `test {
  MaybeBox[_BoxDropT0506] j1 = MaybeBox[_BoxDropT0506].Just(_BoxDropT0506(n: 21));
  MaybeBox[_BoxDropT0506] j2 = MaybeBox[_BoxDropT0506].Just(_BoxDropT0506(n: 22));
  _Holder2T0552[_BoxDropT0506] c = _Holder2T0552[_BoxDropT0506](a: j1, x: 0, b: j2);
}

// T0549: plain Named field with no drop method and only primitive fields.
// Sema's fieldTypeHasDrop / codegen's monoTypeHasDroppable apply the B0192
// catch-all (non-value, non-structural, non-copy Named is droppable because
// codegen `pal_free`s it at drop time), but prior to T0549 ownership's
// `isDroppableType` returned false for such types, letting a bare field move
// slip through and double-free at runtime. The new B0192 catch-all in
// ownership now rejects the move at compile time; `.clone()` is the documented
// workaround. This e2e test verifies the clone produces an independent copy
// and that no double-free occurs.
type _PlainT0549 `clone {
  int n;
}

type _OuterPlainT0549 {
  _PlainT0549 inner;
  drop(~this) {
  }
}

test_clone_plain_named_field() `test {
  _OuterPlainT0549 o = _OuterPlainT0549(inner: _PlainT0549(n: 1));
  _PlainT0549 p = o.inner.clone();
  assert(p.n == 1, "cloned plain field value");
}

// Companion: build the owner, never read the field. Confirms codegen's
// synth drop fires cleanly on the owner without crashing or leaking when
// the inner plain Named stays inside.
test_plain_named_field_drop_only() `test {
  _OuterPlainT0549 o = _OuterPlainT0549(inner: _PlainT0549(n: 2));
  // Let o drop at scope exit — synth drop pal_free's the inner plain.
}

// T0549: parallel e2e for the generic-Instance variant. `_PlainGenT0549[U]`
// with a primitive U field is, when instantiated as `_PlainGenT0549[int]`,
// a heap user type whose origin is non-value, non-structural, non-Copy.
// The Instance-branch B0192 catch-all in ownership rejects the bare move;
// `.clone()` is the workaround. Verifies the cloned copy is independent
// and that the owner's synth drop fires cleanly when the field stays in.
type _PlainGenT0549[U] `clone {
  U n;
}

type _OuterPlainGenT0549 {
  _PlainGenT0549[int] inner;
  drop(~this) {
  }
}

test_clone_generic_plain_named_field() `test {
  _OuterPlainGenT0549 o = _OuterPlainGenT0549(inner: _PlainGenT0549[int](n: 1));
  _PlainGenT0549[int] p = o.inner.clone();
  assert(p.n == 1, "cloned generic plain field value");
}

test_generic_plain_named_field_drop_only() `test {
  _OuterPlainGenT0549 o = _OuterPlainGenT0549(inner: _PlainGenT0549[int](n: 2));
  // Let o drop at scope exit — synth drop pal_free's the inner _PlainGenT0549[int].
}

// T0548: destructure-from-field produces borrows that escape parent's lifetime.
// Prior to T0548 the destructured locals were tracked as Owned, so consuming
// the parent before the locals' last use silently UAF/double-freed at runtime.
// The fix registers a shared borrow on the parent so consume-then-read is now
// a compile-time error; consume-AFTER-last-use is allowed via T0164 NLL.
type _BoxStrT0548 {
  string s;
}

type _HolderT0548 {
  (_BoxStrT0548, int) pair;
}

// Positive: destructure, read both locals (last uses), then let the parent
// drop at scope exit. The parent retains ownership of the inner _BoxStrT0548
// throughout — its synth drop fires once at scope exit with no double-free.
test_destructure_member_read_then_scope_drop() `test {
  _HolderT0548 h = _HolderT0548(pair: (_BoxStrT0548(s: "hello" + " world"), 7));
  (b, n) := h.pair;
  assert(b.s == "hello world", "b.s");
  assert(n == 7, "n");
}

// Positive: destructure, finish reading destructured locals, THEN move the
// parent into a consuming function. T0164 NLL borrow narrowing expires the
// borrow at the locals' last use, so the consume is legal.
test_destructure_member_consume_after_last_use() `test {
  _HolderT0548 h = _HolderT0548(pair: (_BoxStrT0548(s: "ab" + "cd"), 5));
  (b, n) := h.pair;
  assert(b.s == "abcd", "b.s");
  assert(n == 5, "n");
  consume_holder_t0548(h);
}

consume_holder_t0548(~_HolderT0548 h) {
  (b2, n2) := h.pair;
  assert(b2.s == "abcd", "b2.s after consume");
  assert(n2 == 5, "n2 after consume");
}

// T0570: destructure source wrapped in ParenExpr — `(b, n) := (h.pair);` —
// bypassed the T0548 borrow-tracking fix (both ownership-side borrow
// registration and codegen-side srcOwned short-circuit only matched bare
// MemberExpr / IndexExpr). Without paren peeling, the destructured locals
// got their own drop bindings → double-free with the parent at scope exit
// (segfault), and consume-of-parent was permitted → runtime UAF.
type _BoxStrT0570 {
  string s;
}

type _HolderT0570 {
  (_BoxStrT0570, int) pair;
}

// Positive: paren-wrapped source, read both locals, then scope-drop the
// parent. No double-free, no leak.
test_destructure_member_paren_read_then_scope_drop() `test {
  _HolderT0570 h = _HolderT0570(pair: (_BoxStrT0570(s: "hello" + " world"), 7));
  (b, n) := (h.pair);
  assert(b.s == "hello world", "b.s");
  assert(n == 7, "n");
}

// Positive: paren-wrapped source, read both locals, then move parent into a
// consumer. T0164 NLL narrowing (extended for ParenExpr in T0570) expires
// the borrow at the locals' last use, so the consume is legal.
test_destructure_member_paren_consume_after_last_use() `test {
  _HolderT0570 h = _HolderT0570(pair: (_BoxStrT0570(s: "ab" + "cd"), 5));
  (b, n) := (h.pair);
  assert(b.s == "abcd", "b.s");
  assert(n == 5, "n");
  consume_holder_t0570(h);
}

consume_holder_t0570(~_HolderT0570 h) {
  (b2, n2) := (h.pair);
  assert(b2.s == "abcd", "b2.s after consume");
  assert(n2 == 5, "n2 after consume");
}

// T0570: coverage — paren-wrapped IndexExpr source. Exercises the Site 1
// `dupTupleFieldAccess` and Site 2 `srcOwned` codegen switches for the
// IndexExpr arm at runtime; without paren peeling, the tuple would be
// dup'd into a temp AND the destructured locals would receive their own
// drop bindings → double-free with the vector's element drop at scope
// exit.
test_destructure_paren_index_read_then_scope_drop() `test {
  Vector[(_BoxStrT0570, int)] arr = [];
  arr.push((_BoxStrT0570(s: "ab" + "cd"), 11));
  (b, n) := (arr[0]);
  assert(b.s == "abcd", "b.s");
  assert(n == 11, "n");
}

// T0570: coverage — paren-wrapped IdentExpr source. Exercises Site 3
// (clearDropFlag uses the paren-peeled expression). Without the fix, the
// tuple variable's drop flag would not be cleared after destructure → the
// tuple-walk at scope exit would double-free the inner string while the
// destructured `b` also owns it.
test_destructure_paren_ident_owned_tuple() `test {
  (_BoxStrT0570, int) tup = (_BoxStrT0570(s: "xy" + "zw"), 22);
  (b, n) := (tup);
  assert(b.s == "xyzw", "b.s");
  assert(n == 22, "n");
}
