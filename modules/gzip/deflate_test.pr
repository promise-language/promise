_try_inflate(~u8[] data) bool {
  u8[] _v = inflate(data)? e {
    return true;
  };
  return false;
}

inflate_reserved_btype_test() `test {
  // Single byte 0x07 = BFINAL=1, BTYPE=11 (reserved) — must raise.
  int[] raw = int[]();
  raw.push(0x07);
  assert(_try_inflate(_bytes(raw)), "reserved BTYPE raises");
}

inflate_truncated_test() `test {
  // Truncated stream: BFINAL=1, BTYPE=01, then EOF mid-symbol.
  int[] raw = int[]();
  raw.push(0x03);
  assert(_try_inflate(_bytes(raw)), "truncated stream raises");
}
