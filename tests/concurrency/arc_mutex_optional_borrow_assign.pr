  int? init = 11;
  Ref[int?] a = Ref[int?](init);
  int? z = none;
  vec := [z, z];
  vec[0] = a.borrow;
  assert(vec[0]! == 11, "arc vec assign some");
}

arc_optional_vec_assign_none() `test {
  int? init = none;
  Ref[int?] a = Ref[int?](init);
  int? z = 55;
  vec := [z, z];
  vec[0] = a.borrow;
  got := false;
  if x := vec[0] {
    got = true;
  }
  assert(!got, "arc vec assign none");
