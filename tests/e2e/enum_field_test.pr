// Tests for enum types used as fields in user types, map values, and nested enums.
// Regression tests for map[K, Enum] codegen panic in wrapOptional.
enum Color {
  Red, Green, Blue,
}

enum Shape {
  Circle(f64 radius),
  Rect(f64 w, f64 h),
  Point,
}

type Wrapper {
  Color c;
}

type ShapeHolder {
  Shape s;
  string label;
}

// --- Fieldless enum as map value ---

test_map_fieldless_enum_lookup() `test {
  map[string, Color] m = {
    "r": Color.Red, "g": Color.Green, "b": Color.Blue
  };
  if c := m["r"] {
    match c {
      Color.Red => {
      },
      _ => assert(false, "expected Red"),
    }
  } else {
    assert(false, "key 'r' not found");
  }
}

test_map_fieldless_enum_missing() `test {
  map[string, Color] m = {
    "r": Color.Red
  };
  if c := m["x"] {
    assert(false, "should not find 'x'");
  }
}

test_map_fieldless_enum_all_values() `test {
  map[string, Color] m = {
    "r": Color.Red, "g": Color.Green, "b": Color.Blue
  };
  Color r = m["r"]!;
  Color g = m["g"]!;
  Color b = m["b"]!;
  match r {
    Color.Red => {
    }, _ => assert(false, "expected Red"),
  }
  match g {
    Color.Green => {
    }, _ => assert(false, "expected Green"),
  }
  match b {
    Color.Blue => {
    }, _ => assert(false, "expected Blue"),
  }
}

test_map_fieldless_enum_overwrite() `test {
  map[string, Color] m = {
    "x": Color.Red
  };
  m["x"] = Color.Blue;
  Color c = m["x"]!;
  match c {
    Color.Blue => {
    }, _ => assert(false, "expected Blue after overwrite"),
  }
}

test_map_fieldless_enum_remove() `test {
  map[string, Color] m = {
    "a": Color.Red
  };
  assert(m.remove("a"), "remove should succeed");
  assert(m["a"] is absent, "should be absent after remove");
}

test_map_fieldless_enum_contains() `test {
  map[string, Color] m = {
    "a": Color.Red
  };
  assert(m.contains("a"), "should contain 'a'");
  assert(!m.contains("b"), "should not contain 'b'");
}

test_map_fieldless_enum_keys_values() `test {
  map[string, Color] m = {
    "r": Color.Red, "g": Color.Green
  };
  string[] keys = m.keys();
  Color[] vals = m.values();
  assert(keys.len == 2, "expected 2 keys");
  assert(vals.len == 2, "expected 2 values");
}

test_map_fieldless_enum_iteration() `test {
  map[string, Color] m = {
    "r": Color.Red, "g": Color.Green, "b": Color.Blue
  };
  int count = 0;
  for k, v in m {
    count += 1;
  }
  assert(count == 3, "expected 3 entries");
}

// --- Data enum as map value ---

test_map_data_enum_lookup() `test {
  map[string, Shape] m = {
    "c": Shape.Circle(radius: 3.14)
  };
  if s := m["c"] {
    match s {
      Shape.Circle(r) => assert(r > 3.0, "radius should be > 3"),
      _ => assert(false, "expected Circle"),
    }
  } else {
    assert(false, "key 'c' not found");
  }
}

test_map_data_enum_multiple_variants() `test {
  map[string, Shape] m = {
    "c": Shape.Circle(radius: 1.0),
    "r": Shape.Rect(w: 2.0, h: 3.0),
    "p": Shape.Point,
  };
  Shape circle = m["c"]!;
  Shape rect = m["r"]!;
  Shape point = m["p"]!;

  match circle {
    Shape.Circle(r) => assert(r == 1.0, "circle radius"),
    _ => assert(false, "expected Circle"),
  }
  match rect {
    Shape.Rect(w, h) => {
      assert(w == 2.0, "rect width");
      assert(h == 3.0, "rect height");
    },
    _ => assert(false, "expected Rect"),
  }
  match point {
    Shape.Point => {
    },
    _ => assert(false, "expected Point"),
  }
}

test_map_data_enum_overwrite() `test {
  map[string, Shape] m = {
    "s": Shape.Point
  };
  m["s"] = Shape.Circle(radius: 5.0);
  Shape s = m["s"]!;
  match s {
    Shape.Circle(r) => assert(r == 5.0, "expected overwritten Circle"),
    _ => assert(false, "expected Circle"),
  }
}

test_map_data_enum_pop() `test {
  map[string, Shape] m = {
    "x": Shape.Circle(radius: 7.0)
  };
  Shape? popped = m.pop("x");
  assert(m.is_empty, "map should be empty after pop");
  if s := popped {
    match s {
      Shape.Circle(r) => assert(r == 7.0, "popped circle radius"),
      _ => assert(false, "expected Circle"),
    }
  } else {
    assert(false, "pop should return value");
  }
}

test_map_data_enum_get_or() `test {
  map[string, Shape] m = {
    "a": Shape.Point
  };
  Shape s = m.get_or("missing", Shape.Point);
  match s {
    Shape.Point => {
    },
    _ => assert(false, "expected default Point"),
  }
}

// --- Enum as field in user type ---

test_enum_field_in_struct() `test {
  Wrapper w = Wrapper(c: Color.Green);
  match w.c {
    Color.Green => {
    },
    _ => assert(false, "expected Green"),
  }
}

test_enum_field_modification() `test {
  Wrapper w = Wrapper(c: Color.Red);
  w.c = Color.Blue;
  match w.c {
    Color.Blue => {
    },
    _ => assert(false, "expected Blue after modification"),
  }
}

test_data_enum_field_in_struct() `test {
  ShapeHolder h = ShapeHolder(s: Shape.Circle(radius: 2.5), label: "circle");
  assert(h.label == "circle", "label");
  match h.s {
    Shape.Circle(r) => assert(r == 2.5, "radius"),
    _ => assert(false, "expected Circle"),
  }
}

test_data_enum_field_modification() `test {
  ShapeHolder h = ShapeHolder(s: Shape.Point, label: "p");
  h.s = Shape.Rect(w: 10.0, h: 20.0);
  match h.s {
    Shape.Rect(w, hh) => {
      assert(w == 10.0, "width");
      assert(hh == 20.0, "height");
    },
    _ => assert(false, "expected Rect"),
  }
}

// --- Enum in map with int keys ---

test_map_int_key_enum_value() `test {
  map[int, Color] m = {
    1: Color.Red, 2: Color.Green, 3: Color.Blue
  };
  Color c = m[2]!;
  match c {
    Color.Green => {
    }, _ => assert(false, "expected Green"),
  }
}

test_map_int_key_data_enum() `test {
  map[int, Shape] m = {
    0: Shape.Point, 1: Shape.Circle(radius: 1.0)
  };
  Shape s = m[1]!;
  match s {
    Shape.Circle(r) => assert(r == 1.0, "radius"),
    _ => assert(false, "expected Circle"),
  }
}

// --- Enum-in-enum nesting ---

enum Outer {
  Wrapped(Color inner),
  Plain,
}

test_enum_containing_enum() `test {
  Outer o = Outer.Wrapped(inner: Color.Blue);
  match o {
    Outer.Wrapped(c) => {
      match c {
        Color.Blue => {
        }, _ => assert(false, "expected Blue"),
      }
    },
    Outer.Plain => assert(false, "expected Wrapped"),
  }
}

enum NestedData {
  Item(Shape shape, int id),
  Empty,
}

test_data_enum_containing_data_enum() `test {
  NestedData nd = NestedData.Item(shape: Shape.Circle(radius: 9.0), id: 42);
  match nd {
    NestedData.Item(s, id) => {
      assert(id == 42, "id");
      match s {
        Shape.Circle(r) => assert(r == 9.0, "radius"),
        _ => assert(false, "expected Circle"),
      }
    },
    NestedData.Empty => assert(false, "expected Item"),
  }
}

// --- Forward enum reference (A declared before B, A has field of type B) ---

enum ForwardA {
  Wrap(ForwardB inner, int id),
  None,
}

enum ForwardB {
  Circle(f64 radius),
  Point,
}

test_forward_enum_reference() `test {
  ForwardA a = ForwardA.Wrap(inner: ForwardB.Circle(radius: 5.0), id: 99);
  match a {
    ForwardA.Wrap(b, id) => {
      assert(id == 99, "id");
      match b {
        ForwardB.Circle(r) => assert(r == 5.0, "radius"),
        ForwardB.Point => assert(false, "expected Circle"),
      }
    },
    ForwardA.None => assert(false, "expected Wrap"),
  }
}

test_forward_enum_in_map() `test {
  map[string, ForwardA] m = {
    "x": ForwardA.Wrap(inner: ForwardB.Point, id: 7),
  };
  ForwardA a = m["x"]!;
  match a {
    ForwardA.Wrap(b, id) => {
      assert(id == 7, "id");
      match b {
        ForwardB.Point => {
        },
        _ => assert(false, "expected Point"),
      }
    },
    ForwardA.None => assert(false, "expected Wrap"),
  }
}

// --- Map with enum keys --- (enums need Hashable + Equal; skipped for now)

// --- Vector of enums (sanity check) ---

test_vector_of_fieldless_enum() `test {
  Color[] colors = [Color.Red, Color.Green, Color.Blue];
  assert(colors.len == 3, "len");
  match colors[0] {
    Color.Red => {
    }, _ => assert(false, "expected Red"),
  }
  match colors[2] {
    Color.Blue => {
    }, _ => assert(false, "expected Blue"),
  }
}

test_vector_of_data_enum() `test {
  Shape[] shapes = [Shape.Point, Shape.Circle(radius: 1.0)];
  assert(shapes.len == 2, "len");
  match shapes[1] {
    Shape.Circle(r) => assert(r == 1.0, "radius"),
    _ => assert(false, "expected Circle"),
  }
}

// --- Map methods with enum values ---

test_map_enum_merge() `test {
  map[string, Color] m1 = {
    "a": Color.Red
  };
  map[string, Color] m2 = {
    "b": Color.Green, "c": Color.Blue
  };
  m1.merge(m2);
  assert(m1.len == 3, "merged len");
  match m1["b"]! {
    Color.Green => {
    }, _ => assert(false, "expected Green"),
  }
}

test_map_enum_clear() `test {
  map[string, Color] m = {
    "a": Color.Red, "b": Color.Green
  };
  m.clear();
  assert(m.is_empty, "should be empty after clear");
  assert(m["a"] is absent, "should be absent after clear");
}

test_map_enum_update() `test {
  map[string, Color] m = {
    "x": Color.Red
  };
  assert(m.update("x", Color.Blue), "update should succeed");
  assert(!m.update("y", Color.Green), "update non-existing should fail");
  match m["x"]! {
    Color.Blue => {
    }, _ => assert(false, "expected Blue"),
  }
}

test_map_enum_entries() `test {
  map[string, Color] m = {
    "a": Color.Red, "b": Color.Green
  };
  (string, Color)[] ents = m.entries();
  assert(ents.len == 2, "entries len");
}

// --- Large map with enum values (triggers rehash) ---

test_map_enum_rehash() `test {
  map[int, Color] m = {
    0: Color.Red
  };
  m.remove(0);
  for i in 0..100 {
    if i % 3 == 0 {
      m[i] = Color.Red;
    } else if i % 3 == 1 {
      m[i] = Color.Green;
    } else {
      m[i] = Color.Blue;
    }
  }
  assert(m.len == 100, "len after filling");
  match m[0]! {
    Color.Red => {
    }, _ => assert(false, "expected Red at 0"),
  }
  match m[1]! {
    Color.Green => {
    }, _ => assert(false, "expected Green at 1"),
  }
  match m[2]! {
    Color.Blue => {
    }, _ => assert(false, "expected Blue at 2"),
  }
}

test_map_data_enum_rehash() `test {
  map[int, Shape] m = {
    0: Shape.Point
  };
  m.remove(0);
  for i in 0..50 {
    m[i] = Shape.Circle(radius: 1.0);
  }
  assert(m.len == 50, "len");
  Shape s = m[25]!;
  match s {
    Shape.Circle(r) => assert(r == 1.0, "radius at key 25"),
    _ => assert(false, "expected Circle"),
  }
}

// T0442: heap user type wrapped in Optional/Tuple as enum variant fields.
// The enum-variant-data layout function `llvmTypeForEnumFieldFromPromise`
// previously fell through to plain `llvmType` for these structural wrappers,
// emitting bare `i8*` for the heap user type instead of the `{i8*, i8*}`
// value struct. This caused a layout-vs-resolveType mismatch that panicked
// in `wrapOptional`. Fix in `compiler/internal/codegen/types.go` adds
// Tuple/Optional/Array recursion symmetric to T0420's `instanceFieldLLVMType`.
type _T0442EnumRow {
  string name;
}

// T0442: Optional<UserType> as enum variant field. Locks in the Optional
// recursion path. Match arm consumes the variant (no synth-drop walk over
// the unmatched Optional, which is a separate drop-synth gap tracked
// elsewhere).
enum _T0442OptWrapper {
  Empty,
  Some(_T0442EnumRow? value),
}

test_t0442_optional_user_type_in_enum_field() `test {
  _T0442EnumRow? r = _T0442EnumRow(name: "opt".to_string());
  w := _T0442OptWrapper.Some(r);
  match w {
    _T0442OptWrapper.Some(opt) => {
      if row := opt {
        assert(row.name == "opt", "row.name");
      } else {
        assert(false, "should have value");
      }
    },
    _T0442OptWrapper.Empty => assert(false, "should not be empty"),
  }
}

// T0442: tuple containing Optional<UserType> as enum variant field — locks
// in the nested Tuple→Optional recursion in `llvmTypeForEnumFieldFromPromise`.
enum _T0442TupOptWrapper {
  None,
  Both(_T0442EnumRow? first, int second),
}

test_t0442_tuple_with_optional_user_in_enum_field() `test {
  _T0442EnumRow? r = _T0442EnumRow(name: "tup_opt".to_string());
  p := _T0442TupOptWrapper.Both(r, 13);
  match p {
    _T0442TupOptWrapper.Both(opt, n) => {
      assert(n == 13, "second int");
      if row := opt {
        assert(row.name == "tup_opt", "row.name");
      } else {
        assert(false, "should have value");
      }
    },
    _T0442TupOptWrapper.None => assert(false, "should not be None"),
  }
}

// T0442: Optional<(UserType, int)> as enum variant field — locks in the
// nested Optional→Tuple recursion. The enum-variant data must lay out
// the inner tuple's user-type as `{i8*, i8*}`, not bare `i8*`.
enum _T0442OptTupWrapper {
  Empty,
  Some((_T0442EnumRow, int)? pair),
}

test_t0442_optional_tuple_user_in_enum_field() `test {
  (_T0442EnumRow, int)? t = (_T0442EnumRow(name: "opt_tup".to_string()), 19);
  w := _T0442OptTupWrapper.Some(t);
  match w {
    _T0442OptTupWrapper.Some(opt) => {
      if pair := opt {
        (row, n) := pair;
        assert(n == 19, "inner int");
        assert(row.name == "opt_tup", "row.name");
      } else {
        assert(false, "should have value");
      }
    },
    _T0442OptTupWrapper.Empty => assert(false, "should not be empty"),
  }
}

// T0485: enum variant drop must walk Optional<HeapUserType> variant fields.
// Before T0485, the synth enum drop's variantFieldNeedsDrop / emitVariantFieldDrop
// pair only had a Tuple branch — Optional fell through to extractNamed (nil) and
// the inner heap type leaked when the variant was dropped without a consuming match.
type _T0485Row {
  string name;
}

enum _T0485OptWrapper {
  Empty,
  Some(_T0485Row? value),
}

test_t0485_optional_user_in_enum_synth_drop() `test {
  _T0485Row? r = _T0485Row(name: "synth_drop".to_string());
  w := _T0485OptWrapper.Some(r);
  // No match — synth drop must walk the Optional and drop the inner Row.
}

// T0485: enum variant drop must walk Array<HeapUserType> variant fields.
// Before T0485, sema's fieldTypeHasDrop didn't recurse into *types.Array,
// so the enum was never marked NeedsSynthDrop and no drop function was generated.
enum _T0485ArrHolder {
  Empty,
  ThreeRows(_T0485Row[3] arr),
}

test_t0485_array_user_in_enum_synth_drop() `test {
  _T0485Row[3] rs = [_T0485Row(name: "x".to_string()), _T0485Row(name: "y".to_string()), _T0485Row(name: "z".to_string())];
  h := _T0485ArrHolder.ThreeRows(rs);
  // No match — synth drop must walk each array element.
}

test_t0485_array_user_in_enum_with_match() `test {
  _T0485Row[3] rs = [_T0485Row(name: "a".to_string()), _T0485Row(name: "b".to_string()), _T0485Row(name: "c".to_string())];
  h := _T0485ArrHolder.ThreeRows(rs);
  match h {
    _T0485ArrHolder.ThreeRows(arr) => {
      assert(arr[0].name == "a", "first");
      assert(arr[1].name == "b", "second");
      assert(arr[2].name == "c", "third");
    },
    _T0485ArrHolder.Empty => assert(false, "should not be empty"),
  }
}

// T0485: Optional<(HeapUser, int)> as enum variant field — locks in the
// tuple-inner branch added to emitOptionalValueDrop. Without it, dropping an
// unmatched _T0485OptTupWrapper.Some leaks the inner Row + its string.
enum _T0485OptTupWrapper {
  Empty,
  Some((_T0485Row, int)? pair),
}

test_t0485_optional_tuple_user_in_enum_synth_drop() `test {
  (_T0485Row, int)? t = (_T0485Row(name: "ot".to_string()), 7);
  w := _T0485OptTupWrapper.Some(t);
  // No match — Optional<Tuple> branch must walk the tuple and drop the Row.
}

// T0485: Array of tuples as enum variant field — locks in the variant Array
// branch with a tuple element type.
enum _T0485ArrTup {
  Empty,
  Pairs((_T0485Row, int)[3] pairs),
}

test_t0485_array_tuple_user_in_enum_synth_drop() `test {
  (_T0485Row, int)[3] ps = [(_T0485Row(name: "a".to_string()), 1),
  (_T0485Row(name: "b".to_string()), 2),
  (_T0485Row(name: "c".to_string()), 3),
  ];
  w := _T0485ArrTup.Pairs(ps);
}

// T0485: borrow markers added by match destructure must not leak past the
// arm. If the same name is later reused for an owned Optional, an in-arm
// reassignment must drop the old inner correctly without UAF on the binding.
test_t0485_borrow_marker_arm_scoped() `test {
  _T0485Row? r1 = _T0485Row(name: "first".to_string());
  e := _T0485OptWrapper.Some(r1);
  match e {
    _T0485OptWrapper.Some(opt) => {
      // opt is a borrowed match-binding (variant data owns inner).
      if r := opt {
        assert(r.name == "first", "first");
      } else {
        assert(false, "expected Some");
      }
    },
    _T0485OptWrapper.Empty => assert(false, "expected Some"),
  }

  // Same name 'opt' as match binding above; declared as an owned Optional.
  // Borrow marker must have been cleared at arm end.
  _T0485Row? opt = _T0485Row(name: "second".to_string());
  if r := opt {
    assert(r.name == "second", "second");
  } else {
    assert(false, "expected Some");
  }
}

// T0485: nested Optional in enum variant — Some(Row?? value). Exercises the
// emitOptionalValueDrop nested-Optional branch reached via the new
// emitVariantFieldDrop Optional branch, and borrowInnerHasDrop's Optional
// recursion in matchBindingIsBorrow.
enum _T0485NestedOptWrapper {
  Empty,
  Some(_T0485Row?? value),
}

test_t0485_nested_optional_in_enum_synth_drop() `test {
  _T0485Row? inner = _T0485Row(name: "nested".to_string());
  _T0485Row?? outer = inner;
  w := _T0485NestedOptWrapper.Some(outer);
  // No match — synth drop walks Optional<Optional<Row>> and frees inner Row.
}

// T0485: Optional<[N]Row> in enum variant — exercises the new Array branch
// added to emitOptionalValueDrop (compiler.go), plus borrowInnerHasDrop's
// Array recursion via Optional in matchBindingIsBorrow.
enum _T0485OptArrWrapper {
  Empty,
  Some(_T0485Row[3]? arr),
}

test_t0485_optional_array_in_enum_synth_drop() `test {
  _T0485Row[3] rs = [_T0485Row(name: "x".to_string()),
  _T0485Row(name: "y".to_string()),
  _T0485Row(name: "z".to_string())];
  _T0485Row[3]? opt = rs;
  w := _T0485OptArrWrapper.Some(opt);
  // No match — synth drop walks Optional<[3]Row> and frees each Row.
}

// T0485: [N]Row? in enum variant — fixed-size array of Optionals. Exercises
// emitVariantFieldDrop's Array branch with an Optional element type, and
// borrowInnerHasDrop's recursion through Array → Optional → leaf.
enum _T0485ArrOptHolder {
  Empty,
  Multiples(_T0485Row?[3] arr),
}

test_t0485_array_of_optional_in_enum_synth_drop() `test {
  _T0485Row? r1 = _T0485Row(name: "p".to_string());
  _T0485Row? r2 = _T0485Row(name: "q".to_string());
  _T0485Row? r3 = _T0485Row(name: "r".to_string());
  _T0485Row?[3] rs = [r1, r2, r3];
  h := _T0485ArrOptHolder.Multiples(rs);
  // No match — synth drop walks [3]Row? and frees each Some inner.
}

// T0485: [M][N]Row in enum variant — array of arrays. Exercises
// emitVariantFieldDrop's Array branch recursing into another Array,
// and borrowInnerHasDrop's Array → Array recursion.
enum _T0485ArrArrHolder {
  Empty,
  Grid(_T0485Row[2][2] grid),
}

test_t0485_array_of_array_in_enum_synth_drop() `test {
  _T0485Row[2] row1 = [_T0485Row(name: "a".to_string()), _T0485Row(name: "b".to_string())];
  _T0485Row[2] row2 = [_T0485Row(name: "c".to_string()), _T0485Row(name: "d".to_string())];
  _T0485Row[2][2] grid = [row1, row2];
  h := _T0485ArrArrHolder.Grid(grid);
  // No match — synth drop walks [2][2]Row and frees all 4 Rows.
}

// T0485: match destructure on the new compound types — confirms the borrow
// marker keeps the binding from transferring ownership while the synth drop
// still walks the variant data correctly.
test_t0485_optional_array_in_enum_with_match() `test {
  _T0485Row[3] rs = [_T0485Row(name: "j".to_string()),
  _T0485Row(name: "k".to_string()),
  _T0485Row(name: "l".to_string())];
  _T0485Row[3]? opt = rs;
  w := _T0485OptArrWrapper.Some(opt);
  match w {
    _T0485OptArrWrapper.Some(arr_opt) => {
      // arr_opt is Optional<[3]Row>; variant data still owns the inner array.
      if a := arr_opt {
        assert(a[0].name == "j", "first");
        assert(a[1].name == "k", "second");
        assert(a[2].name == "l", "third");
      } else {
        assert(false, "expected Some");
      }
    },
    _T0485OptArrWrapper.Empty => assert(false, "expected Some"),
  }
}

// T0512: nested if-let on a borrowed Optional<Optional<HeapUser>> from a match
// destructure. The outer `if first := opt_opt` propagates opt_opt's borrow
// marker to `first`, so the inner `if r := first` does NOT transfer ownership
// — the synth enum drop's nested-Optional walk frees the Row exactly once
// (before the fix this double-freed → SIGSEGV at 0x0).
test_t0512_nested_optional_match() `test {
  _T0485Row? inner = _T0485Row(name: "deep".to_string());
  _T0485Row?? outer = inner;
  w := _T0485NestedOptWrapper.Some(outer);
  match w {
    _T0485NestedOptWrapper.Some(opt_opt) => {
      if first := opt_opt {
        if r := first {
          assert(r.name == "deep", "deep");
        }
      }
    },
    _T0485NestedOptWrapper.Empty => assert(false, "expected Some"),
  }
}

// T0512: same nested unwrap but with else branches on both if-lets. The borrow
// marker for the unwrapped binding is reverted before the else block is
// generated, so the else path is unaffected.
test_t0512_nested_optional_if_else() `test {
  _T0485Row? inner = _T0485Row(name: "deep2".to_string());
  _T0485Row?? outer = inner;
  w := _T0485NestedOptWrapper.Some(outer);
  match w {
    _T0485NestedOptWrapper.Some(opt_opt) => {
      if first := opt_opt {
        if r := first {
          assert(r.name == "deep2", "deep2");
        } else {
          assert(false, "inner expected Some");
        }
      } else {
        assert(false, "outer expected Some");
      }
    },
    _T0485NestedOptWrapper.Empty => assert(false, "expected Some"),
  }
}

// T0512: symmetric while-let path through genWhileUnwrapStmt. The outer
// `while first := opt_opt` propagates the borrow marker to `first`; the inner
// while-let / if-let on `first` must not transfer ownership.
test_t0512_nested_optional_while_let() `test {
  _T0485Row? inner = _T0485Row(name: "deep3".to_string());
  _T0485Row?? outer = inner;
  w := _T0485NestedOptWrapper.Some(outer);
  match w {
    _T0485NestedOptWrapper.Some(opt_opt) => {
      int iters = 0;
      while first := opt_opt {
        while r := first {
          assert(r.name == "deep3", "deep3 wl");
          break;
        }
        if r2 := first {
          assert(r2.name == "deep3", "deep3 if");
        }
        iters = iters + 1;
        break;
      }
      assert(iters == 1, "looped once");
    },
    _T0485NestedOptWrapper.Empty => assert(false, "expected Some"),
  }
}
