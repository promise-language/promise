// Test uint arithmetic, comparisons, bitwise, range, and unary operators
test_addition() `test {
  uint a = 1 + 2;
  assert(a == 3, "1 + 2 == 3");
  uint b = 0 + 0;
  assert(b == 0, "0 + 0 == 0");
  uint c = 100 + 200;
  assert(c == 300, "100 + 200 == 300");
}

test_subtraction() `test {
  uint a = 5 - 3;
  assert(a == 2, "5 - 3 == 2");
  uint b = 10 - 10;
  assert(b == 0, "10 - 10 == 0");
}

test_multiplication() `test {
  uint a = 3 * 4;
  assert(a == 12, "3 * 4 == 12");
  uint b = 0 * 100;
  assert(b == 0, "0 * 100 == 0");
  uint c = 7 * 1;
  assert(c == 7, "7 * 1 == 7");
}

test_division() `test {
  uint a = 10 / 2;
  assert(a == 5, "10 / 2 == 5");
  uint b = 7 / 3;
  assert(b == 2, "7 / 3 == 2 (integer division)");
  uint c = 0 / 5;
  assert(c == 0, "0 / 5 == 0");
}

test_modulo() `test {
  uint a = 10 % 3;
  assert(a == 1, "10 % 3 == 1");
  uint b = 15 % 5;
  assert(b == 0, "15 % 5 == 0");
  uint c = 7 % 2;
  assert(c == 1, "7 % 2 == 1");
}

test_comparisons() `test {
  uint a = 1;
  uint b = 2;
  assert(a < b, "1 < 2");
  assert(!(b < a), "!(2 < 1)");
  assert(b > a, "2 > 1");
  assert(!(a > b), "!(1 > 2)");
  uint c = 1;
  assert(a <= c, "1 <= 1");
  assert(a <= b, "1 <= 2");
  assert(b >= b, "2 >= 2");
  uint d = 3;
  assert(d >= a, "3 >= 1");
}

test_equality() `test {
  uint a = 42;
  assert(a == 42, "42 == 42");
  assert(!(a == 1), "!(42 == 1)");
  assert(a != 1, "42 != 1");
  uint b = 5;
  assert(!(b != 5), "!(5 != 5)");
}

test_increment_decrement() `test {
  uint x = 5;
  x++;
  assert(x == 6, "x++ makes 6");
  x--;
  assert(x == 5, "x-- makes 5");
  x--;
  assert(x == 4, "x-- makes 4");
}

test_compound_assignment() `test {
  uint x = 10;
  x += 5;
  assert(x == 15, "+= 5");
  x -= 3;
  assert(x == 12, "-= 3");
  x *= 2;
  assert(x == 24, "*= 2");
  x /= 4;
  assert(x == 6, "/= 4");
  x %= 4;
  assert(x == 2, "%= 4");
}

test_bitwise_and() `test {
  uint a = 12 & 10;
  assert(a == 8, "12 & 10 == 8");
  uint b = 0xFF & 0x0F;
  assert(b == 0x0F, "0xFF & 0x0F == 0x0F");
  uint c = 0 & 100;
  assert(c == 0, "0 & x == 0");
  uint d = 7 & 7;
  assert(d == 7, "x & x == x");
}

test_bitwise_or() `test {
  uint a = 5 | 3;
  assert(a == 7, "5 | 3 == 7");
  uint b = 0 | 42;
  assert(b == 42, "0 | x == x");
  uint c = 0xF0 | 0x0F;
  assert(c == 0xFF, "0xF0 | 0x0F == 0xFF");
}

test_bitwise_xor() `test {
  uint a = 12 ^ 10;
  assert(a == 6, "12 ^ 10 == 6");
  uint b = 0xFF ^ 0xFF;
  assert(b == 0, "x ^ x == 0");
  uint c = 0 ^ 42;
  assert(c == 42, "0 ^ x == x");
}

test_left_shift() `test {
  uint a = 1 << 0;
  assert(a == 1, "1 << 0 == 1");
  uint b = 1 << 4;
  assert(b == 16, "1 << 4 == 16");
  uint c = 3 << 2;
  assert(c == 12, "3 << 2 == 12");
  uint d = 1 << 10;
  assert(d == 1024, "1 << 10 == 1024");
}

test_right_shift() `test {
  // Logical right shift: fills with zeros (no sign extension)
  uint a = 16 >> 2;
  assert(a == 4, "16 >> 2 == 4");
  uint b = 1024 >> 10;
  assert(b == 1, "1024 >> 10 == 1");
  uint c = 255 >> 4;
  assert(c == 15, "255 >> 4 == 15");
}

test_bitwise_not() `test {
  // ~0 for uint gives max uint (all bits set)
  uint a = ~0;
  uint b = ~a;
  assert(b == 0, "~~0 == 0");
  uint c = 42;
  assert(~~c == 42, "~~x == x");
}

test_bitwise_precedence() `test {
  // Shift binds tighter than additive
  uint a = 1 + 1 << 2;
  assert(a == 1 + 4, "1 + (1 << 2) == 5");
  // Bitwise binds tighter than comparison
  uint b = 3 & 1;
  assert(b == 1, "(3 & 1) == 1");
  // Bitwise ops are same precedence, left-to-right
  assert((5 | 3) & 6 == 6, "(5|3) & 6 == 6");
}

// --- Hash ---

test_hash() `test {
  uint a = 42;
  uint b = 42;
  assert(a.hash == b.hash, "same uint same hash");
  uint c = 99;
  assert(a.hash != c.hash, "different uint different hash");
  int h = a.hash;
  assert(h == b.hash, "hash via variable");
}

// --- Fixed-width unsigned types ---

test_u8() `test {
  u8 a = 255;
  u8 b = 0;
  assert(a > b, "u8 255 > 0");
  u8 c = 100;
  u8 d = 50;
  assert(c + d == 150, "u8 100 + 50 == 150");
}

test_u16() `test {
  u16 a = 1000;
  u16 b = 500;
  assert(a - b == 500, "u16 1000 - 500");
  assert(a > b, "u16 1000 > 500");
}

test_u32() `test {
  u32 a = 100000;
  u32 b = 100000;
  assert(a == b, "u32 equality");
  assert(a * 2 == 200000, "u32 multiplication");
}

test_u64() `test {
  u64 a = 999999;
  u64 b = 1;
  assert(a + b == 1000000, "u64 large addition");
  assert(a > b, "u64 comparison");
}

// --- Range operators ---

test_uint_range() `test {
  uint a = 0;
  uint b = 5;
  uint sum = 0;
  for i in a..b {
    sum += i;
  }
  uint expected = 10;
  assert(sum == expected, "uint range: 0..5 sum == 10");
}

test_uint_range_inclusive() `test {
  uint a = 0;
  uint b = 5;
  uint sum = 0;
  for i in a..=b {
    sum += i;
  }
  uint expected = 15;
  assert(sum == expected, "uint range: 0..=5 sum == 15");
}
