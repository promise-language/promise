// T1012: `if x is V(field) { … }` destructure binding of a heap variant field
// must not use-after-free when the binding escapes the narrowing scope. The
// bound heap payload is deep-cloned so it escapes safely, while in-scope
// bindings remain correct and numeric/value payloads stay zero-copy.
enum Msg {
  Text(string body), Code(int n),
}
enum Items {
  List(int[] xs), Empty,
}
enum Pair {
  Both(string s, int n), None,
}

// --- Return escape (the reported repro) ---

return_escape_impl() string {
  Msg m = Msg.Text(body: "a" + "b"); // m owns the heap string
  if m is Text(body) {
    return body;
  }
  // body escapes; m dropped at scope exit
  return "";
}

return_escape() `test {
  assert(return_escape_impl() == "ab", "returned heap payload survives");
}

// --- Store-to-outer escape ---

store_to_outer() `test {
  Msg m = Msg.Text(body: "x" + "y");
  string out = "";
  if m is Text(body) {
    out = body;
  }
  assert(out == "xy", "stored-to-outer payload survives");
}

// --- Consuming-arg escape (~string param) ---

consume(string move s) string {
  return s + "!";
}

consuming_arg() `test {
  Msg m = Msg.Text(body: "h" + "i");
  string r = "";
  if m is Text(body) {
    r = consume(move body);
  }
  assert(r == "hi!", "payload moved into consuming param");
}

// --- Constructor-field escape ---

type Wrapper {
  string held;
}

constructor_field() `test {
  Msg m = Msg.Text(body: "w" + "z");
  string r = "";
  if m is Text(body) {
    Wrapper w = Wrapper(held: move body);
    r = w.held;
  }
  assert(r == "wz", "payload moved into constructor field");
}

// --- Vector payload escape by return ---

vec_escape_impl() int[] {
  int[] base = [1, 2, 3];
  Items it = Items.List(xs: move base);
  if it is List(xs) {
    return xs;
  }
  return[];
}

vec_escape() `test {
  int[] v = vec_escape_impl();
  assert(v.len == 3, "vector length preserved");
  assert(v[0] == 1 && v[1] == 2 && v[2] == 3, "vector contents preserved");
}

// --- In-scope only: subject stays intact (not nulled) after the `if` ---

in_scope_no_escape() `test {
  Msg m = Msg.Text(body: "a" + "bc");
  if m is Text(body) {
    assert(body.len == 3, "in-scope read");
  }
  // Subject must still be usable after the borrow-narrowing `if`.
  if m is Text(again) {
    assert(again == "abc", "subject intact after if");
  }
}

// --- Multi-field variant: per-field dup selection (heap + numeric) ---

multi_field_impl() string {
  Pair p = Pair.Both(s: "k" + "v", n: 42);
  if p is Both(s, n) {
    assert(n == 42, "numeric field zero-copy");
    return s;
  }
  return "";
}

multi_field() `test {
  assert(multi_field_impl() == "kv", "heap field of multi-field variant escapes");
}

// --- Numeric-only payload: no clone, correct value ---

code_escape_impl() int {
  Msg m = Msg.Code(n: 7);
  if m is Code(n) {
    return n;
  }
  return 0;
}

code_escape() `test {
  assert(code_escape_impl() == 7, "numeric payload correct");
}

// --- Optional / fixed-array heap payloads: T0485 borrow-mark path ---
// A variant field whose type is Optional-of-heap or fixed-Array-of-heap is
// NOT dup'd by T1012; instead bindIsDestructureEnum marks the binding
// match-borrowed (matchBindingIsBorrow / borrowInnerHasDrop). The binding
// aliases the subject's payload, which is sound as long as the read stays
// in-scope (the subject outlives the `if`). These pin that in-scope path.
// T1170 (fixed): escaping such a binding (return / store-to-escaping-outer /
// consuming arg / constructor field) now deep-clones on the read/escape side
// (genIdentExpr / genArrayIndex, gated on matchBorrowedIdents + the dup flag the
// owning sink sets), so the escaped value is independently owned and the subject's
// synth enum drop still frees the original exactly once. The escape cases live in
// the "T1170 escape" section below. In-scope reads (no dup flag) stay zero-copy.
// Optional[heap-user-type] escape (e.g. `Row?`) is the sibling fix T1174 — see
// the T1174 section at the end of this file. Out-of-scope (tracked separately):
// whole fixed-array-VALUE escape `return a`/`x = a` (T1173).

enum OptBox {
  Has(string? maybe), Nothing,
}
enum ArrHolder {
  Pair(string[2] a), Empty,
}

// Optional heap payload unwrapped in-scope (subject still alive).
opt_payload_unwrap() `test {
  OptBox b = OptBox.Has(maybe: "x" + "y");
  if b is Has(maybe) {
    if s := maybe {
      assert(s == "xy", "unwrapped optional payload in scope");
    } else {
      assert(false, "expected some");
    }
  }
}

// Optional heap payload copied to a same-scope local, read while subject alive.
opt_payload_store_inscope() `test {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  string? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  // `b` (the subject) is still alive here, so the alias is valid.
  if s := out {
    assert(s == "pq", "optional payload readable while subject alive");
  } else {
    assert(false, "expected some");
  }
}

// none-valued optional payload: elvis fallback, no unwrap.
opt_payload_none() `test {
  string? empty = none;
  OptBox b = OptBox.Has(maybe: move empty);
  if b is Has(maybe) {
    string got = maybe ?: "fallback";
    assert(got == "fallback", "none optional payload uses fallback");
  }
}

// Fixed-array heap payload read in-scope.
arr_payload_inscope() `test {
  ArrHolder h = ArrHolder.Pair(a: ["p" + "1", "q" + "2"]);
  if h is Pair(a) {
    assert(a[0] == "p1" && a[1] == "q2", "fixed-array heap payload in-scope read");
  }
}

// ============================================================================
// T1170: ESCAPING an Optional-of-heap or fixed-array-element match-borrowed
// payload out of the narrowing scope. The read/escape-side dup deep-clones so
// the escaped value survives the subject's synth enum drop. Covers BOTH `if is`
// and `match` (shared matchBorrowedIdents path). Each impl drops the subject at
// function exit; the caller reads the escaped value AFTER, so an un-cloned alias
// would be a use-after-free. Zero leaks are enforced by the batch-test policy.
// ============================================================================

type OptWrapper {
  string? held;
}
enum VecBox {
  Has(int[]? maybe), Nothing,
}

opt_unwrap(string? move s) string {
  if x := s {
    return x;
  }
  return "<none>";
}
opt_consume(string? move s) string {
  if x := s {
    return x + "!";
  }
  return "!";
}
vec_len(int[]? move v) int {
  if xs := v {
    return xs.len;
  }
  return -1;
}

// --- Optional[string] escape: store-to-outer, if is ---
opt_store_is_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  string? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  return out; // b dropped here; out must own an independent clone
}
opt_store_is() `test {
  assert(opt_unwrap(opt_store_is_impl()) == "pq", "opt[string] store-to-outer escape (if is)");
}

// --- Optional[string] escape: return, if is ---
opt_ret_is_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  if b is Has(maybe) {
    return maybe;
  }
  return none;
}
opt_ret_is() `test {
  assert(opt_unwrap(opt_ret_is_impl()) == "pq", "opt[string] return escape (if is)");
}

// --- Optional[string] escape: return + store, match ---
opt_ret_match_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  match b {
    Has(maybe) => {
      return maybe;
    }, Nothing => {
      return none;
    },
  }
}
opt_ret_match() `test {
  assert(opt_unwrap(opt_ret_match_impl()) == "pq", "opt[string] return escape (match)");
}
opt_store_match_impl() string? {
  OptBox b = OptBox.Has(maybe: "p" + "q");
  string? out = none;
  match b {
    Has(maybe) => {
      out = maybe;
    }, Nothing => {
    },
  }
  return out;
}
opt_store_match() `test {
  assert(opt_unwrap(opt_store_match_impl()) == "pq", "opt[string] store-to-outer escape (match)");
}

// --- Optional[string] escape: consuming (~) arg ---
opt_consume_impl() string {
  OptBox b = OptBox.Has(maybe: "h" + "i");
  string r = "";
  if b is Has(maybe) {
    r = opt_consume(move maybe);
  }
  return r;
}
opt_consume_escape() `test {
  assert(opt_consume_impl() == "hi!", "opt[string] moved into consuming param");
}

// --- Optional[string] escape: constructor field (escapes via returned wrapper) ---
opt_ctor_impl() OptWrapper {
  OptBox b = OptBox.Has(maybe: "w" + "z");
  OptWrapper result = OptWrapper(held: none);
  if b is Has(maybe) {
    result = OptWrapper(held: maybe);
  }
  return result; // b dropped; result.held must be an independent clone
}
opt_ctor_escape() `test {
  OptWrapper w = opt_ctor_impl();
  if x := w.held {
    assert(x == "wz", "opt[string] moved into constructor field");
  } else {
    assert(false, "expected some");
  }
}

// --- fixed-array element escape: store-to-outer + return, if is ---
arr_elem_store_impl() string {
  ArrHolder h = ArrHolder.Pair(a: ["x" + "1", "y" + "2"]);
  string out = "";
  if h is Pair(a) {
    out = a[0];
  }
  return out; // h dropped; out must own an independent clone of a[0]
}
arr_elem_store() `test {
  assert(arr_elem_store_impl() == "x1", "string[N] element store-to-outer escape (if is)");
}
arr_elem_ret_impl() string {
  ArrHolder h = ArrHolder.Pair(a: ["x" + "1", "y" + "2"]);
  if h is Pair(a) {
    return a[1];
  }
  return "";
}
arr_elem_ret() `test {
  assert(arr_elem_ret_impl() == "y2", "string[N] element return escape (if is)");
}

// --- fixed-array element escape: match ---
arr_elem_match_impl() string {
  ArrHolder h = ArrHolder.Pair(a: ["x" + "1", "y" + "2"]);
  string out = "";
  match h {
    Pair(a) => {
      out = a[0];
    }, Empty => {
    },
  }
  return out;
}
arr_elem_match() `test {
  assert(arr_elem_match_impl() == "x1", "string[N] element store-to-outer escape (match)");
}

// --- Optional[Vector] escape: store-to-outer + return ---
vec_store_impl() int[]? {
  VecBox b = VecBox.Has(maybe: [1, 2, 3]);
  int[]? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  return out;
}
vec_store_escape() `test {
  assert(vec_len(vec_store_impl()) == 3, "opt[Vector] store-to-outer escape");
}
vec_ret_impl() int[]? {
  VecBox b = VecBox.Has(maybe: [4, 5]);
  match b {
    Has(maybe) => {
      return maybe;
    }, Nothing => {
      return none;
    },
  }
}
vec_ret_escape() `test {
  assert(vec_len(vec_ret_impl()) == 2, "opt[Vector] return escape (match)");
}

// --- T1174: Optional[heap-user-type] variant payload escaping if-is / match ---
// Sibling to T1170 (string?/Array). An `Optional[heap-user]` variant field (e.g.
// `Row?`) bound via `if is`/`match` is match-borrowed (matchBindingIsBorrow →
// borrowInnerHasDrop): it aliases the subject's variant payload. In-scope reads
// are sound (subject outlives the narrowing), but escaping the binding out of the
// scope was a use-after-free (SIGSEGV) — the subject's synth enum drop freed the
// payload at scope exit. The fix (dupBorrowedHeapUserPayload) deep-clones the
// inner heap value at each escape site so the destination owns an independent
// copy while the subject's drop still frees the original exactly once. In-scope
// bindings stay zero-copy (the dup is gated to explicit escape sites, not a
// read-side flag — preserving the T0512 nested-Optional invariant).
type T1174Row {
  string name;
}
enum T1174Box {
  Has(T1174Row? maybe), Nothing,
}
type T1174Wrap {
  T1174Row? held;
}

t1174_name(T1174Row? move r) string {
  if row := r {
    return row.name;
  }
  return "none";
}

// if-is: return escape (the reported repro).
t1174_ret_ifis_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "a" + "b"));
  if b is Has(maybe) {
    return maybe; // out aliases b's payload; b dropped at scope exit
  }
  return none;
}
t1174_ret_ifis() `test {
  assert(t1174_name(t1174_ret_ifis_impl()) == "ab", "if-is return escape survives");
}

// if-is: store-to-escaping-outer.
t1174_store_ifis_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "c" + "d"));
  T1174Row? out = none;
  if b is Has(maybe) {
    out = maybe;
  }
  return out;
}
t1174_store_ifis() `test {
  assert(t1174_name(t1174_store_ifis_impl()) == "cd", "if-is store-to-outer escape survives");
}

// match: return escape.
t1174_ret_match_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "e" + "f"));
  match b {
    Has(maybe) => {
      return maybe;
    },
    Nothing => {
      return none;
    },
  }
}
t1174_ret_match() `test {
  assert(t1174_name(t1174_ret_match_impl()) == "ef", "match return escape survives");
}

// match: store-to-escaping-outer.
t1174_store_match_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "g" + "h"));
  T1174Row? out = none;
  match b {
    Has(maybe) => {
      out = maybe;
    },
    Nothing => {
    },
  }
  return out;
}
t1174_store_match() `test {
  assert(t1174_name(t1174_store_match_impl()) == "gh", "match store-to-outer escape survives");
}

// Consuming-arg escape (~ move param).
t1174_consume(T1174Row? move r) string {
  if row := r {
    return row.name;
  }
  return "none";
}
t1174_consume_arg_impl() string {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "i" + "j"));
  if b is Has(maybe) {
    return t1174_consume(move maybe);
  }
  return "none";
}
t1174_consuming_arg() `test {
  assert(t1174_consume_arg_impl() == "ij", "payload moved into consuming param");
}

// Constructor-field escape: the borrowed payload is stored into an owned field.
// Reading an Optional[heap-user] field back out is a partial-move (rejected by
// sema), so the assertion here is drop-safety: the wrapper's field drop and the
// subject's synth enum drop must not free the same allocation (double-free /
// leak). Without the constructor-arg dup this SIGSEGVs; the leak checker also
// guards against an aliasing regression.
t1174_ctor_field_impl() bool {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "k" + "l"));
  bool ok = false;
  if b is Has(maybe) {
    T1174Wrap w = T1174Wrap(held: maybe);
    ok = true;
    // w and b both drop at scope exit — must be independent copies.
  }
  return ok;
}
t1174_constructor_field() `test {
  assert(t1174_ctor_field_impl(), "payload copied into constructor field (drop-safe)");
}

// In-scope guard: no escape → zero-copy borrow, correct value, no leak. An
// over-eager dup here would be caught by the leak checker.
t1174_inscope() `test {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "m" + "n"));
  if b is Has(maybe) {
    if r := maybe {
      assert(r.name == "mn", "in-scope Optional[heap-user] read");
    } else {
      assert(false, "expected some");
    }
  }
  // Subject still usable after the borrow-narrowing `if`.
  if b is Has(again) {
    if r := again {
      assert(r.name == "mn", "subject intact after if");
    }
  }
}

// Vector-push escape: `v.push(maybe)` moves the borrowed Optional[heap-user]
// payload into a vector (sema treats the destructure binding as owned, so the
// push type-checks). The push path is a native special-case that bypasses the
// escape-site dups above — it must deep-clone the Optional[heap-user] element
// itself (maybeDupPushElement's Optional branch) or the vector slot aliases the
// subject's payload → double-free when both drop.
t1174_push_ifis_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "o" + "p"));
  T1174Row?[] v = [];
  if b is Has(maybe) {
    v.push(maybe);
  }
  T1174Row? out = none;
  if v.len > 0 {
    out = v[0];
  }
  return out;
}
t1174_push_ifis() `test {
  assert(t1174_name(t1174_push_ifis_impl()) == "op", "vec push escape survives");
}

// Vector[Optional[heap-user]] slice: `v[a:b]` copies each element slot. Without
// the same Optional[heap-user] element dup, the sliced vector's slot aliases the
// source vector's payload → double-free at drop. (Pre-existing, independent of
// if-is; shares maybeDupPushElement's Optional branch.)
t1174_slice_impl() T1174Row?[] {
  T1174Row?[] v = [];
  v.push(T1174Row(name: "q" + "r"));
  v.push(T1174Row(name: "s" + "t"));
  return v[0:1];
}
t1174_slice() `test {
  T1174Row?[] s = t1174_slice_impl();
  assert(s.len == 1, "sliced length");
  if r := s[0] {
    assert(r.name == "qr", "sliced Optional[heap-user] element intact");
  } else {
    assert(false, "expected some in slice");
  }
}

// --- T1174 coverage gaps: member/index assign targets + no-drop heap-user ---
// The escape-site dup in genAssignStmt runs on `val` before dispatch to
// genMemberAssign / genIndexAssign, so a member- or index-target assignment of a
// match-borrowed Optional[heap-user] payload must be as drop-safe as the plain
// ident-target case above. And optionalHeapDupElem admits BOTH droppable heap
// user types (T1174Row, via isDroppableHeapUserType) AND no-drop-but-heap types
// (via isHeapUserNoDropPalFree); the tests above only exercise the droppable
// branch. These pin the remaining branches.

// no-drop heap user type: all-scalar field → heap-allocated but no drop/synth-drop
// (isHeapUserNoDropPalFree). Escaping `P?` must still deep-clone (pal_free path),
// else the returned alias is freed by the subject's synth enum drop → UAF.
type T1174P {
  int x;
}
enum T1174PBox {
  Has(T1174P? maybe), Nothing,
}
t1174_p_value(T1174P? move r) int {
  if p := r {
    return p.x;
  }
  return -1;
}
t1174_nodrop_ret_impl() T1174P? {
  T1174PBox b = T1174PBox.Has(maybe: T1174P(x: 41 + 1));
  if b is Has(maybe) {
    return maybe;
  }
  return none;
}
t1174_nodrop_ret() `test {
  assert(t1174_p_value(t1174_nodrop_ret_impl()) == 42, "no-drop heap-user return escape survives");
}

// member-target assign: `hold.h = maybe` stores the borrowed payload into an owned
// field. genMemberAssign drops the old field value and takes the fresh clone; the
// subject's synth enum drop still frees the original once. Drop-safety (no
// double-free / leak) is the invariant — reading an Optional[heap-user] field back
// out is a partial move (sema-rejected), so we assert via a scalar sibling field.
type T1174Hold {
  T1174Row? h;
  int tag;
}
t1174_member_impl() int {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "u" + "v"));
  T1174Hold hold = T1174Hold(h: none, tag: 0);
  if b is Has(maybe) {
    hold.h = maybe; // drops old `none`, takes independent clone
    hold.tag = 7;
  }
  return hold.tag;
}
t1174_member_target() `test {
  assert(t1174_member_impl() == 7, "member-target Optional[heap-user] assign escape drop-safe");
}

// index-target assign: `v[0] = maybe` overwrites a vector slot. genIndexAssign
// drops the old slot value and stores the fresh clone; the sliced/read-back value
// is an independent copy, and both the vector and subject drop exactly once.
t1174_index_impl() T1174Row? {
  T1174Box b = T1174Box.Has(maybe: T1174Row(name: "w" + "x"));
  T1174Row?[] v = [];
  v.push(none);
  if b is Has(maybe) {
    v[0] = maybe;
  }
  T1174Row? out = none;
  if v.len > 0 {
    out = v[0];
  }
  return out;
}
t1174_index_target() `test {
  assert(t1174_name(t1174_index_impl()) == "wx", "index-target Optional[heap-user] assign escape survives");
}

// --- T1171: whole fixed-Array-of-heap-user variant payload escaping if-is / match ---
// Sibling to T1174 (Optional[heap-user]) and T1170/T1173 (string[N]/container arrays).
// A `Row[N]` variant field bound via `if is`/`match` is match-borrowed: the
// [N x {vtable,instance}] aggregate merely ALIASES the subject's N inner heap
// instances. In-scope reads are sound, but escaping the whole array out of the
// scope was a use-after-free (SIGSEGV) — the subject's synth enum drop freed each
// element at scope exit while the escaped copy still pointed into it. The fix
// (dupBorrowedHeapUserPayload's Array branch → arrayHeapDupElem) element-wise
// deep-clones the aggregate at each escape site so the destination owns
// independent instances; the subject's drop still frees the originals once.
// In-scope bindings stay zero-copy (gated to explicit escape sites).
type T1171Row {
  string name;
}
enum T1171Box {
  Some(T1171Row[2] value), Empty,
}
type T1171Wrap {
  T1171Row[2] rows;
  int tag;
}

// if-is: return escape (the reported repro).
t1171_ret_ifis_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  if w is Some(value) {
    return value; // value aliases w's payload; w dropped at scope exit
  }
  return[T1171Row(name: "BAD"), T1171Row(name: "BAD2")];
}
t1171_ret_ifis() `test {
  T1171Row[2] r = t1171_ret_ifis_impl();
  assert(r[0].name == "deep", "if-is return escape survives (elem 0)");
  assert(r[1].name == "xx", "if-is return escape survives (elem 1)");
}

// match: return escape.
t1171_ret_match_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  match w {
    Some(value) => {
      return value;
    },
    Empty => {
      return[T1171Row(name: "BAD"), T1171Row(name: "BAD2")];
    },
  }
}
t1171_ret_match() `test {
  T1171Row[2] r = t1171_ret_match_impl();
  assert(r[0].name == "deep", "match return escape survives (elem 0)");
  assert(r[1].name == "xx", "match return escape survives (elem 1)");
}

// if-is: store-to-escaping-outer.
t1171_store_ifis_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] out = [T1171Row(name: "D0"), T1171Row(name: "D1")];
  if w is Some(value) {
    out = value; // drops old default array, takes independent clone
  }
  return out;
}
t1171_store_ifis() `test {
  T1171Row[2] r = t1171_store_ifis_impl();
  assert(r[0].name == "deep", "if-is store-to-outer escape survives");
}

// match: store-to-escaping-outer.
t1171_store_match_impl() T1171Row[2] {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] out = [T1171Row(name: "D0"), T1171Row(name: "D1")];
  match w {
    Some(value) => {
      out = value;
    },
    Empty => {
    },
  }
  return out;
}
t1171_store_match() `test {
  T1171Row[2] r = t1171_store_match_impl();
  assert(r[0].name == "deep", "match store-to-outer escape survives");
}

// Consuming-arg escape (~ move param): the whole array is moved into a consuming
// param after the store escape.
t1171_consume(T1171Row[2] move r) string {
  return r[0].name;
}
t1171_consume_arg_impl() string {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] out = [T1171Row(name: "D0"), T1171Row(name: "D1")];
  if w is Some(value) {
    out = value;
  }
  return t1171_consume(move out);
}
t1171_consuming_arg() `test {
  assert(t1171_consume_arg_impl() == "deep", "array moved into consuming param");
}

// Constructor-field escape: the borrowed array is stored into an owned field.
// Reading a whole heap-user array field back out is a separate escape sink
// (field-access-of-array, out of scope for T1171), so — as with T1174's
// constructor-field test — the invariant here is drop-safety: the wrapper's
// field drop and the subject's synth enum drop must not free the same
// allocation (double-free / leak). We assert via a scalar sibling field.
t1171_ctor_field_impl() int {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  int tag = 0;
  if w is Some(value) {
    T1171Wrap wr = T1171Wrap(rows: value, tag: 9); // wr and w both drop — independent copies
    tag = wr.tag;
  }
  return tag;
}
t1171_constructor_field() `test {
  assert(t1171_ctor_field_impl() == 9, "array copied into constructor field (drop-safe)");
}

// In-scope guard: no escape → zero-copy borrow, correct value, no leak. An
// over-eager dup here would be caught by the leak checker.
t1171_inscope() `test {
  T1171Box w = T1171Box.Some(value: [T1171Row(name: "m" + "n"), T1171Row(name: "o" + "p")]);
  if w is Some(value) {
    assert(value[0].name == "mn", "in-scope Array[heap-user] read");
  }
  // Subject still usable after the borrow-narrowing `if`.
  if w is Some(again) {
    assert(again[1].name == "op", "subject intact after if");
  }
}

// no-drop element parity: arrayHeapDupElem admits BOTH droppable heap-user
// elements (T1171Row, via isDroppableHeapUserType) AND no-drop-but-heap elements
// (via isHeapUserNoDropPalFree) — the tests above only exercise the droppable
// branch. An all-scalar-field element type is heap-allocated but has no
// drop/synth-drop, so it takes the pal_free clone path (the T0484-caveated one).
// Escaping the array must still element-wise deep-clone, else the returned
// aggregate aliases the subject's payload → freed by the subject's synth enum
// drop → UAF. Mirror of t1174_nodrop_ret for the fixed-Array shape.
type T1171P {
  int x;
}
enum T1171PBox {
  Has(T1171P[2] cells), Nothing,
}
t1171_nodrop_ret_impl() T1171P[2] {
  T1171PBox b = T1171PBox.Has(cells: [T1171P(x: 41 + 1), T1171P(x: 7)]);
  if b is Has(cells) {
    return cells;
  }
  return[T1171P(x: -1), T1171P(x: -2)];
}
t1171_nodrop_ret() `test {
  T1171P[2] r = t1171_nodrop_ret_impl();
  assert(r[0].x == 42, "no-drop heap-user array return escape survives (elem 0)");
  assert(r[1].x == 7, "no-drop heap-user array return escape survives (elem 1)");
}

// Generic / monomorphized context: the array-of-heap-user payload lives in a
// GENERIC enum `GBox[T]` whose variant field type is `T[2]`. Inside the
// monomorphized `gesc[Row]`, the escape sink resolves the element type through
// c.typeSubst (T → Row) — both in dupBorrowedHeapUserPayload (t = Substitute(...))
// and in arrayHeapDupElem (elem = Substitute(arr.Elem(), ...)). Without those
// substitutions the recognizer would miss the array shape and the escaped
// aggregate would alias the moved-in subject's payload → UAF. This is the only
// case that exercises the typeSubst branches of both helpers.
enum T1171GBox[T] {
  Some(T[2] value), Empty,
}
t1171_gesc[T](T1171GBox[T] move b, T[2] fallback) T[2] {
  if b is Some(value) {
    return value;
  }
  return fallback;
}
t1171_generic() `test {
  T1171GBox[T1171Row] b = T1171GBox[T1171Row].Some(value: [T1171Row(name: "de" + "ep"), T1171Row(name: "x" + "x")]);
  T1171Row[2] fb = [T1171Row(name: "BAD"), T1171Row(name: "BAD2")];
  T1171Row[2] r = t1171_gesc(move b, fb);
  assert(r[0].name == "deep", "generic array-of-heap-user escape survives (elem 0)");
  assert(r[1].name == "xx", "generic array-of-heap-user escape survives (elem 1)");
}

// T1178: single-clone invariant for the variant-payload Array[heap-user] escape
// with a DEEP droppable sub-field. T1176 regressed T1171 by letting BOTH the
// read-side (dupHeapFieldForEscape array branch) AND the sink
// (dupBorrowedHeapUserPayload) clone the escaping array — the second clone's
// elements were never dropped → leak. A stronger leak signal than the flat
// t1171_* rows (`string name`): each element here owns a Vector sub-field, so a
// double-clone orphans BOTH the element instance AND its Vector buffer. The leak
// checker flags any over-clone; the asserts confirm the SINGLE clone is a correct
// deep copy that survives the subject enum's synth drop at scope exit. Mirror of
// test_t1176_deep_subfield_clone_escape (struct-field) for the variant path.
type T1178Cell {
  Vector[int] xs;
  drop(~this) {
  }
}
enum T1178Holder {
  Pair(T1178Cell[2] cells), Empty,
}
t1178_deep_ret_impl() T1178Cell[2] {
  Vector[int] a = Vector[int]();
  a.push(1);
  a.push(2);
  Vector[int] b = Vector[int]();
  b.push(9);
  T1178Holder h = T1178Holder.Pair(cells: [T1178Cell(xs: move a), T1178Cell(xs: move b)]);
  if h is Pair(cells) {
    return cells; // aliases h's payload; h dropped at scope exit → must deep-clone once
  }
  return[T1178Cell(xs: Vector[int]()), T1178Cell(xs: Vector[int]())];
}
t1178_deep_ret() `test {
  T1178Cell[2] r = t1178_deep_ret_impl();
  assert(r[0].xs.len == 2, "deep variant if-is: cell 0 vector length independent");
  assert(r[0].xs[0] == 1, "deep variant if-is: cell 0 elem 0");
  assert(r[0].xs[1] == 2, "deep variant if-is: cell 0 elem 1");
  assert(r[1].xs[0] == 9, "deep variant if-is: cell 1 elem 0");
}
t1178_deep_match_impl() T1178Cell[2] {
  Vector[int] a = Vector[int]();
  a.push(7);
  Vector[int] b = Vector[int]();
  b.push(8);
  b.push(9);
  T1178Holder h = T1178Holder.Pair(cells: [T1178Cell(xs: move a), T1178Cell(xs: move b)]);
  match h {
    Pair(cells) => {
      return cells;
    },
    Empty => {
      return[T1178Cell(xs: Vector[int]()), T1178Cell(xs: Vector[int]())];
    },
  }
}
t1178_deep_match() `test {
  T1178Cell[2] r = t1178_deep_match_impl();
  assert(r[0].xs[0] == 7, "deep variant match: cell 0 elem 0");
  assert(r[1].xs.len == 2, "deep variant match: cell 1 vector length independent");
  assert(r[1].xs[1] == 9, "deep variant match: cell 1 elem 1");
}

// T1179: A plain var-decl that binds a whole match-borrowed enum-variant payload
// (a fixed Array[heap-user] or an Optional[heap-user]) to a NEW owned local must
// deep-clone the borrowed payload exactly once — otherwise the new local's owning
// drop and the enum's synthesized drop free the same instances → double-free/UAF
// (previously: `fatal: segmentation fault at 0x0`).
//
// Covers the matrix: {if…is, match} × {typed, inferred} × {Array, Optional}.
// Every function is leak-clean (the clone is independently owned and dropped).
type Row {
  string name;
}

enum Box {
  Some(Row[2] value), Empty,
}

enum Opt {
  Present(Row? value), Absent,
}

// ---------------------------------------------------------------------------
// Array payload — if…is
// ---------------------------------------------------------------------------

test_if_is_array_typed() `test {
  Box w = Box.Some(value: [Row(name: "de" + "ep"), Row(name: "x" + "y")]);
  if w is Some(value) {
    Row[2] copy = value;
    assert(copy[0].name == "deep", "typed if-is copy[0]");
    assert(copy[1].name == "xy", "typed if-is copy[1]");
  } else {
    assert(false, "should match Some");
  }
}

test_if_is_array_inferred() `test {
  Box w = Box.Some(value: [Row(name: "aa" + "bb"), Row(name: "cc" + "dd")]);
  if w is Some(value) {
    copy := value;
    assert(copy[0].name == "aabb", "inferred if-is copy[0]");
    assert(copy[1].name == "ccdd", "inferred if-is copy[1]");
  } else {
    assert(false, "should match Some");
  }
}

// ---------------------------------------------------------------------------
// Array payload — match
// ---------------------------------------------------------------------------

test_match_array_typed() `test {
  Box w = Box.Some(value: [Row(name: "he" + "llo"), Row(name: "wor" + "ld")]);
  match w {
    Some(value) => {
      Row[2] copy = value;
      assert(copy[0].name == "hello", "typed match copy[0]");
      assert(copy[1].name == "world", "typed match copy[1]");
    },
    Empty => {
      assert(false, "should match Some");
    },
  }
}

test_match_array_inferred() `test {
  Box w = Box.Some(value: [Row(name: "f" + "oo"), Row(name: "b" + "ar")]);
  match w {
    Some(value) => {
      copy := value;
      assert(copy[0].name == "foo", "inferred match copy[0]");
      assert(copy[1].name == "bar", "inferred match copy[1]");
    },
    Empty => {
      assert(false, "should match Some");
    },
  }
}

// ---------------------------------------------------------------------------
// Optional payload — if…is
// ---------------------------------------------------------------------------

test_if_is_optional_typed() `test {
  Opt o = Opt.Present(value: Row(name: "op" + "t"));
  if o is Present(value) {
    Row? copy = value;
    assert(copy!.name == "opt", "typed if-is optional copy");
  } else {
    assert(false, "should match Present");
  }
}

test_if_is_optional_inferred() `test {
  Opt o = Opt.Present(value: Row(name: "in" + "f"));
  if o is Present(value) {
    copy := value;
    assert(copy!.name == "inf", "inferred if-is optional copy");
  } else {
    assert(false, "should match Present");
  }
}

// ---------------------------------------------------------------------------
// Optional payload — match
// ---------------------------------------------------------------------------

test_match_optional_typed() `test {
  Opt o = Opt.Present(value: Row(name: "ma" + "t"));
  match o {
    Present(value) => {
      Row? copy = value;
      assert(copy!.name == "mat", "typed match optional copy");
    },
    Absent => {
      assert(false, "should match Present");
    },
  }
}

test_match_optional_inferred() `test {
  Opt o = Opt.Present(value: Row(name: "mi" + "n"));
  match o {
    Present(value) => {
      copy := value;
      assert(copy!.name == "min", "inferred match optional copy");
    },
    Absent => {
      assert(false, "should match Present");
    },
  }
}

// ---------------------------------------------------------------------------
// Independence: mutating the clone must not corrupt the still-live enum data,
// and every element must be independently cloned.
// ---------------------------------------------------------------------------

test_clone_is_independent() `test {
  Box w = Box.Some(value: [Row(name: "or" + "ig0"), Row(name: "or" + "ig1")]);
  if w is Some(value) {
    Row[2] copy = value;
    // Both clone elements survive with their own strings.
    assert(copy[0].name == "orig0", "clone elem 0 survives");
    assert(copy[1].name == "orig1", "clone elem 1 survives");
    // The original enum payload is still readable (its own instances).
    assert(value[0].name == "orig0", "source elem 0 intact");
    assert(value[1].name == "orig1", "source elem 1 intact");
  } else {
    assert(false, "should match Some");
  }
}

// ---------------------------------------------------------------------------
// Marker scoping: the match-borrow marker set inside `if…is` must be reverted
// at the end of the then-block (genIfDestructureIsStmt). If it leaked, a later
// statement in the SAME function that reuses the binding name for a genuine
// OWNED local would inherit the stale borrow marker — the whole-array var-decl
// move (`moved = value`) would be wrongly deep-cloned while `value`'s drop flag
// is cleared as if moved, leaking the original array's Row instances.
// (Verified: without the revert this leaks 4 allocations.)
// ---------------------------------------------------------------------------

test_borrow_marker_does_not_leak_across_name_reuse() `test {
  Box w = Box.Some(value: [Row(name: "a" + "0"), Row(name: "a" + "1")]);
  if w is Some(value) {
    Row[2] copy = value;
    assert(copy[0].name == "a0", "borrowed copy inside if-is");
  } else {
    assert(false, "should match Some");
  }
  // `value` here is an unrelated OWNED local reusing the name. The move below
  // must be a plain move (no clone) so the original is not leaked.
  Row[2] value = [Row(name: "b" + "0"), Row(name: "b" + "1")];
  Row[2] moved = value;
  assert(moved[0].name == "b0", "owned move after if-is, elem 0");
  assert(moved[1].name == "b1", "owned move after if-is, elem 1");
}

// Same guard for the Optional payload shape.
test_optional_borrow_marker_does_not_leak_across_reuse() `test {
  Opt o = Opt.Present(value: Row(name: "p" + "re"));
  if o is Present(value) {
    Row? copy = value;
    assert(copy!.name == "pre", "borrowed optional copy inside if-is");
  } else {
    assert(false, "should match Present");
  }
  Row? value = Row(name: "ow" + "n");
  Row? moved = value;
  assert(moved!.name == "own", "owned optional move after if-is");
}

// ============================================================================
// T1173: whole fixed-Array-VALUE escape of a match-borrowed variant payload
// whose element aliases heap (string[N] / Vector[T][N]). `return a` / `x = a`
// copy the [N x T] aggregate by value, aliasing the subject's variant payload
// element pointers; the subject's synth enum drop frees them at scope exit → the
// escaped copy is a UAF (string/heap) or double-free (container). The escape sink
// (dupBorrowedHeapUserPayload → dupArrayValueForEscape) element-wise deep-clones
// so the escaped array owns independent elements and the subject frees the
// originals exactly once. Sibling of T1171 (Array[heap-user]) / T1174
// (Optional[heap-user]). Covers both `if is` and `match`, all four escape sinks,
// plus the struct-field whole-array escape (T1176 parity for string). Results are
// bound to a local (bindingDropArray) so the aggregate frees cleanly — an inline
// `func()[i]` use would leak the unbound array temp, which is the unrelated
// pre-existing bug T1181, not this borrow-escape path. Zero leaks enforced by the
// batch-test policy; an un-cloned alias would double-free / UAF.
// ============================================================================

enum T1173StrArr {
  Pair(string[2] a), Empty,
}
enum T1173VecArr {
  Two(int[][2] a), Nada,
}
type T1173Wrap {
  string[2] d;
}
type T1173Sink {
  string[2] held;
}

// --- string[2]: return escape, if is + match ---
t1173_str_return_ifis_impl() string[2] {
  T1173StrArr h = T1173StrArr.Pair(a: ["x" + "1", "y" + "2"]);
  if h is Pair(a) {
    return a;
  }
  return["", ""];
}
t1173_str_return_ifis() `test {
  string[2] r = t1173_str_return_ifis_impl();
  assert(r[0] == "x1", "if-is return string[2] elem 0");
  assert(r[1] == "y2", "if-is return string[2] elem 1");
}

t1173_str_return_match_impl() string[2] {
  T1173StrArr h = T1173StrArr.Pair(a: ["m" + "1", "m" + "2"]);
  match h {
    Pair(a) => {
      return a;
    },
    Empty => {
      return["", ""];
    },
  }
}
t1173_str_return_match() `test {
  string[2] r = t1173_str_return_match_impl();
  assert(r[0] == "m1", "match return string[2] elem 0");
  assert(r[1] == "m2", "match return string[2] elem 1");
}

// --- string[2]: store-to-escaping-outer, if is + match ---
t1173_str_store_ifis_impl() string[2] {
  T1173StrArr h = T1173StrArr.Pair(a: ["s" + "1", "s" + "2"]);
  string[2] out = ["z" + "0", "z" + "9"];
  if h is Pair(a) {
    out = a;
  }
  return out;
}
t1173_str_store_ifis() `test {
  string[2] r = t1173_str_store_ifis_impl();
  assert(r[0] == "s1", "if-is store string[2] elem 0");
  assert(r[1] == "s2", "if-is store string[2] elem 1");
}

t1173_str_store_match_impl() string[2] {
  T1173StrArr h = T1173StrArr.Pair(a: ["t" + "1", "t" + "2"]);
  string[2] out = ["z" + "0", "z" + "9"];
  match h {
    Pair(a) => {
      out = a;
    },
    Empty => {
      out = ["", ""];
    },
  }
  return out;
}
t1173_str_store_match() `test {
  string[2] r = t1173_str_store_match_impl();
  assert(r[0] == "t1", "match store string[2] elem 0");
  assert(r[1] == "t2", "match store string[2] elem 1");
}

// --- string[2]: consuming (~) param escape ---
t1173_consume(string[2] ~x) string {
  return x[0] + x[1];
}
t1173_str_consume_ifis_impl() string {
  T1173StrArr h = T1173StrArr.Pair(a: ["c" + "1", "c" + "2"]);
  if h is Pair(a) {
    return t1173_consume(a);
  }
  return "";
}
t1173_str_consume_ifis() `test {
  assert(t1173_str_consume_ifis_impl() == "c1c2", "if-is consuming-param string[2]");
}

t1173_str_consume_match_impl() string {
  T1173StrArr h = T1173StrArr.Pair(a: ["d" + "1", "d" + "2"]);
  match h {
    Pair(a) => {
      return t1173_consume(a);
    },
    Empty => {
      return "";
    },
  }
}
t1173_str_consume_match() `test {
  assert(t1173_str_consume_match_impl() == "d1d2", "match consuming-param string[2]");
}

// --- string[2]: constructor field escape ---
t1173_str_ctor_ifis_impl() string[2] {
  T1173StrArr h = T1173StrArr.Pair(a: ["k" + "1", "k" + "2"]);
  if h is Pair(a) {
    T1173Sink sk = T1173Sink(held: a);
    return sk.held;
  }
  return["", ""];
}
t1173_str_ctor_ifis() `test {
  string[2] r = t1173_str_ctor_ifis_impl();
  assert(r[0] == "k1", "if-is ctor-field string[2] elem 0");
  assert(r[1] == "k2", "if-is ctor-field string[2] elem 1");
}

// --- struct-field whole-array escape (T1176 parity for string) ---
t1173_wrap_field_impl() string[2] {
  T1173Wrap w = T1173Wrap(d: ["f" + "1", "f" + "2"]);
  return w.d;
}
t1173_wrap_field() `test {
  string[2] r = t1173_wrap_field_impl();
  assert(r[0] == "f1", "struct-field return string[2] elem 0");
  assert(r[1] == "f2", "struct-field return string[2] elem 1");
}

// --- Vector[int][2]: whole-array escape (double-free case), if is + match ---
t1173_vec_return_ifis_impl() int[][2] {
  T1173VecArr h = T1173VecArr.Two(a: [[1, 2, 3], [4, 5]]);
  if h is Two(a) {
    return a;
  }
  int[] e = [];
  return[e.clone(), e.clone()];
}
t1173_vec_return_ifis() `test {
  int[][2] r = t1173_vec_return_ifis_impl();
  assert(r[0].len == 3, "if-is return int[][2] len 0");
  assert(r[0][2] == 3, "if-is return int[][2] elem 0[2]");
  assert(r[1].len == 2, "if-is return int[][2] len 1");
  assert(r[1][0] == 4, "if-is return int[][2] elem 1[0]");
}

t1173_vec_store_match_impl() int[][2] {
  T1173VecArr h = T1173VecArr.Two(a: [[7, 8], [9]]);
  int[] e = [];
  int[][2] out = [e.clone(), e.clone()];
  match h {
    Two(a) => {
      out = a;
    },
    Nada => {
    },
  }
  return out;
}
t1173_vec_store_match() `test {
  int[][2] r = t1173_vec_store_match_impl();
  assert(r[0][1] == 8, "match store int[][2] elem 0[1]");
  assert(r[1].len == 1, "match store int[][2] len 1");
  assert(r[1][0] == 9, "match store int[][2] elem 1[0]");
}

// --- Vector[int][2]: remaining two sinks (consuming ~ param + constructor field)
// and struct-field parity. The container/double-free half of T1173 is the more
// dangerous one (an un-cloned alias frees the SAME buffer twice); string above
// covers all four sinks, so pin the container path across the two sinks the
// string cases exercise but the two Vector cases above (return/store) do not, plus
// the T1176-parity whole-array struct-field escape. ---
type T1173VecSink {
  int[][2] held;
}
type T1173VecWrap {
  int[][2] d;
}

t1173_vec_consume(int[][2] ~x) int {
  return x[0].len + x[1][0];
}
t1173_vec_consume_ifis_impl() int {
  T1173VecArr h = T1173VecArr.Two(a: [[1, 2], [30, 40]]);
  if h is Two(a) {
    return t1173_vec_consume(a);
  }
  return -1;
}
t1173_vec_consume_ifis() `test {
  // x[0].len (2) + x[1][0] (30) == 32
  assert(t1173_vec_consume_ifis_impl() == 32, "if-is consuming-param int[][2]");
}

t1173_vec_ctor_ifis_impl() int[][2] {
  T1173VecArr h = T1173VecArr.Two(a: [[5, 6, 7], [8]]);
  if h is Two(a) {
    T1173VecSink sk = T1173VecSink(held: a);
    return sk.held;
  }
  int[] e = [];
  return[e.clone(), e.clone()];
}
t1173_vec_ctor_ifis() `test {
  int[][2] r = t1173_vec_ctor_ifis_impl();
  assert(r[0].len == 3, "if-is ctor-field int[][2] len 0");
  assert(r[0][2] == 7, "if-is ctor-field int[][2] elem 0[2]");
  assert(r[1][0] == 8, "if-is ctor-field int[][2] elem 1[0]");
}

t1173_vec_wrap_field_impl() int[][2] {
  T1173VecWrap w = T1173VecWrap(d: [[11, 12], [13, 14, 15]]);
  return w.d;
}
t1173_vec_wrap_field() `test {
  int[][2] r = t1173_vec_wrap_field_impl();
  assert(r[0][1] == 12, "struct-field return int[][2] elem 0[1]");
  assert(r[1].len == 3, "struct-field return int[][2] len 1");
  assert(r[1][2] == 15, "struct-field return int[][2] elem 1[2]");
}

// --- Optional[heap-user][2]: the third recognized element shape. The broadened
// arrayElemNeedsEscapeDup routes Optional[heap-user] elements through
// pushElemNeedsDup's optionalHeapDupElem (deep-cloning the Some payload), so a
// whole-array escape of a Row?[2] variant payload owns independent instances —
// distinct from the Optional[string]/Optional[container] element shapes still
// uncovered as T1183. An un-cloned alias would UAF the inner heap instance. ---
type T1173ORow {
  string name;
}
enum T1173OArr {
  Two(T1173ORow?[2] a), Nada,
}
t1173_opt_return_ifis_impl() T1173ORow?[2] {
  T1173ORow? p0 = T1173ORow(name: "p" + "1");
  T1173ORow? p1 = T1173ORow(name: "p" + "2");
  T1173OArr h = T1173OArr.Two(a: [p0, p1]);
  if h is Two(a) {
    return a;
  }
  T1173ORow? n0 = none;
  T1173ORow? n1 = none;
  return[n0, n1];
}
t1173_opt_return_ifis() `test {
  T1173ORow?[2] r = t1173_opt_return_ifis_impl();
  // bind index results to locals before optional-chaining — inline `r[0]!.name`
  // hits the unrelated unbound index-temp bug (T1181 family), not this escape path.
  T1173ORow? e0 = r[0];
  T1173ORow? e1 = r[1];
  assert(e0!.name == "p1", "if-is return Optional[heap-user][2] elem 0");
  assert(e1!.name == "p2", "if-is return Optional[heap-user][2] elem 1");
}

// --- T1183: whole fixed-Array-VALUE escape of a match-borrowed variant payload
// whose element is Optional[string] / Optional[Vector] — the inner string/vector
// aliases heap even though the element is not a heap-user type. T1173's escape
// recognizer (arrayElemNeedsEscapeDup -> pushElemNeedsDup) only saw
// Optional[heap-user] via optionalHeapDupElem, so Optional[string][N] /
// Optional[Vector][N] whole-array escapes stayed aliased -> the subject's synth
// enum drop freed the inner strings/buffers at scope exit -> UAF/double-free in
// the caller. Fixed by optionalPushElemNeedsDup (deep-cloning the Some payload).
// NOTE: Optional[heap-user][N] escape is covered above (t1173_opt_return_ifis). ---
enum T1183OptStrArr {
  Pair(string?[2] a), Empty,
}

t1183_optstr_return_ifis_impl() string?[2] {
  string? a0 = "x" + "1";
  string? a1 = "z" + "2";
  T1183OptStrArr h = T1183OptStrArr.Pair(a: [a0, a1]);
  if h is Pair(a) {
    return a;
  }
  string? y0 = none;
  string? y1 = none;
  return[y0, y1];
}
t1183_optstr_return_ifis() `test {
  string?[2] r = t1183_optstr_return_ifis_impl();
  assert(r[0]! == "x1", "if-is return Optional[string][2] elem 0");
  assert(r[1]! == "z2", "if-is return Optional[string][2] elem 1");
}

t1183_optstr_return_match_impl() string?[2] {
  string? a0 = "m" + "1";
  string? a1 = "m" + "2";
  T1183OptStrArr h = T1183OptStrArr.Pair(a: [a0, a1]);
  match h {
    Pair(a) => {
      return a;
    },
    Empty => {
      string? z0 = none;
      string? z1 = none;
      return[z0, z1];
    },
  }
}
t1183_optstr_return_match() `test {
  string?[2] r = t1183_optstr_return_match_impl();
  assert(r[0]! == "m1", "match return Optional[string][2] elem 0");
  assert(r[1]! == "m2", "match return Optional[string][2] elem 1");
}

t1183_optstr_store_ifis_impl() string?[2] {
  string? a0 = "t" + "1";
  string? a1 = "t" + "2";
  T1183OptStrArr h = T1183OptStrArr.Pair(a: [a0, a1]);
  string? s0 = none;
  string? s1 = none;
  string?[2] out = [s0, s1];
  if h is Pair(a) {
    out = a;
  }
  return out;
}
t1183_optstr_store_ifis() `test {
  string?[2] r = t1183_optstr_store_ifis_impl();
  assert(r[0]! == "t1", "if-is store Optional[string][2] elem 0");
  assert(r[1]! == "t2", "if-is store Optional[string][2] elem 1");
}

// --- T1183: Optional[Vector[int]][2] whole-array escape (return + store) ---
enum T1183OptVecArr {
  Pair(int[]?[2] a), Empty,
}

t1183_optvec_return_ifis_impl() int[]?[2] {
  int[]? a0 = [1, 2, 3];
  int[]? a1 = [4, 5];
  T1183OptVecArr h = T1183OptVecArr.Pair(a: [a0, a1]);
  if h is Pair(a) {
    return a;
  }
  int[]? z0 = none;
  int[]? z1 = none;
  return[z0, z1];
}
t1183_optvec_return_ifis() `test {
  int[]?[2] r = t1183_optvec_return_ifis_impl();
  int[]? e0 = r[0];
  int[]? e1 = r[1];
  assert(e0!.len == 3, "if-is return Optional[Vector][2] elem 0 len");
  assert(e0![2] == 3, "if-is return Optional[Vector][2] elem 0 value");
  assert(e1!.len == 2, "if-is return Optional[Vector][2] elem 1 len");
  assert(e1![0] == 4, "if-is return Optional[Vector][2] elem 1 value");
}

t1183_optvec_store_match_impl() int[]?[2] {
  int[]? a0 = [7, 8];
  int[]? a1 = [9];
  T1183OptVecArr h = T1183OptVecArr.Pair(a: [a0, a1]);
  int[]? s0 = none;
  int[]? s1 = none;
  int[]?[2] out = [s0, s1];
  match h {
    Pair(a) => {
      out = a;
    },
    Empty => {
      int[]? z0 = none;
      int[]? z1 = none;
      out = [z0, z1];
    },
  }
  return out;
}
t1183_optvec_store_match() `test {
  int[]?[2] r = t1183_optvec_store_match_impl();
  int[]? e0 = r[0];
  int[]? e1 = r[1];
  assert(e0!.len == 2, "match store Optional[Vector][2] elem 0 len");
  assert(e1![0] == 9, "match store Optional[Vector][2] elem 1 value");
}

// --- T1183 push-path coverage: Vector[Optional[string]].push of an index-read
// source aliases the source's inner string unless deep-cloned. Assert the
// destination is correct AND the source is intact after the destination drops. ---
t1183_optstr_push_intact() `test {
  string?[] src = [];
  src.push("h" + "1");
  src.push("h" + "2");
  {
    string?[] dst = [];
    dst.push(src[0]);
    dst.push(src[1]);
    assert(dst[0]! == "h1", "push Optional[string] dst elem 0");
    assert(dst[1]! == "h2", "push Optional[string] dst elem 1");
  }
  // dst dropped above; src must still own independent strings (no UAF).
  assert(src[0]! == "h1", "push Optional[string] src intact elem 0");
  assert(src[1]! == "h2", "push Optional[string] src intact elem 1");
}

// --- T1183: Optional[droppable-enum][N] whole-array escape. optionalPushElemNeedsDup
// recognizes Optional[enum] (via pushElemNeedsDup's enum branch), so the escape/push
// paths route it into dupOptionalVectorElem. That switch originally had NO enum case
// and silently passed the Some payload through (shallow alias) -> the subject's synth
// enum drop freed the inner variant fields while the escaped array still pointed at
// them -> double-free/segfault. Fixed by dupOptionalVectorElem's enum branch (clone-fn
// or in-place variant-field dup). Covers return (if-is + match) and Vector-push. ---
enum T1183Inner {
  Has(string s), Nothing,
}

enum T1183OptEnumArr {
  Pair(T1183Inner?[2] a), Empty,
}

t1183_optenum_return_ifis_impl() T1183Inner?[2] {
  T1183Inner? a0 = T1183Inner.Has(s: "x" + "1");
  T1183Inner? a1 = T1183Inner.Has(s: "z" + "2");
  T1183OptEnumArr h = T1183OptEnumArr.Pair(a: [a0, a1]);
  if h is Pair(a) {
    return a;
  }
  T1183Inner? y0 = none;
  T1183Inner? y1 = none;
  return[y0, y1];
}
t1183_optenum_return_ifis() `test {
  T1183Inner?[2] r = t1183_optenum_return_ifis_impl();
  match r[0]! {
    Has(s) => {
      assert(s == "x1", "if-is return Optional[enum][2] elem 0");
    },
    Nothing => {
      assert(false, "if-is return Optional[enum][2] elem 0 should be Has");
    },
  }
  match r[1]! {
    Has(s) => {
      assert(s == "z2", "if-is return Optional[enum][2] elem 1");
    },
    Nothing => {
      assert(false, "if-is return Optional[enum][2] elem 1 should be Has");
    },
  }
}

t1183_optenum_return_match_impl() T1183Inner?[2] {
  T1183Inner? a0 = T1183Inner.Has(s: "m" + "1");
  T1183Inner? a1 = T1183Inner.Has(s: "m" + "2");
  T1183OptEnumArr h = T1183OptEnumArr.Pair(a: [a0, a1]);
  match h {
    Pair(a) => {
      return a;
    },
    Empty => {
      T1183Inner? z0 = none;
      T1183Inner? z1 = none;
      return[z0, z1];
    },
  }
}
t1183_optenum_return_match() `test {
  T1183Inner?[2] r = t1183_optenum_return_match_impl();
  match r[0]! {
    Has(s) => {
      assert(s == "m1", "match return Optional[enum][2] elem 0");
    },
    Nothing => {
      assert(false, "match return Optional[enum][2] elem 0 should be Has");
    },
  }
  match r[1]! {
    Has(s) => {
      assert(s == "m2", "match return Optional[enum][2] elem 1");
    },
    Nothing => {
      assert(false, "match return Optional[enum][2] elem 1 should be Has");
    },
  }
}

// Vector[Optional[enum]].push of an index-read source must deep-clone the Some
// payload so dst and src own independent enum variant fields (no UAF after dst drop).
t1183_optenum_push_intact() `test {
  T1183Inner?[] src = [];
  src.push(T1183Inner.Has(s: "h" + "1"));
  {
    T1183Inner?[] dst = [];
    dst.push(src[0]);
    match dst[0]! {
      Has(s) => {
        assert(s == "h1", "push Optional[enum] dst elem 0");
      },
      Nothing => {
        assert(false, "push Optional[enum] dst should be Has");
      },
    }
  }
  // dst dropped above; src must still own an independent enum payload.
  match src[0]! {
    Has(s) => {
      assert(s == "h1", "push Optional[enum] src intact");
    },
    Nothing => {
      assert(false, "push Optional[enum] src should be Has");
    },
  }
}

// --- T1183: Optional[cloneable-enum][N] whole-array escape exercises the OTHER
// sub-path of dupOptionalVectorElem's enum branch: when the inner enum has a
// synthesized clone (`clone), the Some payload is deep-copied via the clone
// function (@T1183CloneInner.clone) rather than the in-place variant-field dup.
// Without a clone here the escaped array would alias the subject's variant fields
// -> double-free once the subject's synth enum drop ran. Covers return + push. ---
enum T1183CloneInner `clone {
  Has(string s), Nothing,
}

enum T1183OptCloneEnumArr {
  Pair(T1183CloneInner?[2] a), Empty,
}

t1183_optcloneenum_return_ifis_impl() T1183CloneInner?[2] {
  T1183CloneInner? a0 = T1183CloneInner.Has(s: "x" + "1");
  T1183CloneInner? a1 = T1183CloneInner.Has(s: "z" + "2");
  T1183OptCloneEnumArr h = T1183OptCloneEnumArr.Pair(a: [a0, a1]);
  if h is Pair(a) {
    return a;
  }
  T1183CloneInner? y0 = none;
  T1183CloneInner? y1 = none;
  return[y0, y1];
}
t1183_optcloneenum_return_ifis() `test {
  T1183CloneInner?[2] r = t1183_optcloneenum_return_ifis_impl();
  match r[0]! {
    Has(s) => {
      assert(s == "x1", "if-is return Optional[cloneable-enum][2] elem 0");
    },
    Nothing => {
      assert(false, "if-is return Optional[cloneable-enum][2] elem 0 should be Has");
    },
  }
  match r[1]! {
    Has(s) => {
      assert(s == "z2", "if-is return Optional[cloneable-enum][2] elem 1");
    },
    Nothing => {
      assert(false, "if-is return Optional[cloneable-enum][2] elem 1 should be Has");
    },
  }
}

// Vector[Optional[cloneable-enum]].push of an index-read source must deep-clone
// the Some payload via the clone function so dst and src stay independent.
t1183_optcloneenum_push_intact() `test {
  T1183CloneInner?[] src = [];
  src.push(T1183CloneInner.Has(s: "h" + "1"));
  {
    T1183CloneInner?[] dst = [];
    dst.push(src[0]);
    match dst[0]! {
      Has(s) => {
        assert(s == "h1", "push Optional[cloneable-enum] dst elem 0");
      },
      Nothing => {
        assert(false, "push Optional[cloneable-enum] dst should be Has");
      },
    }
  }
  // dst dropped above; src must still own an independent enum payload.
  match src[0]! {
    Has(s) => {
      assert(s == "h1", "push Optional[cloneable-enum] src intact");
    },
    Nothing => {
      assert(false, "push Optional[cloneable-enum] src should be Has");
    },
  }
}
