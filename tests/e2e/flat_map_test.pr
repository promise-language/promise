// B0243: flat_map with non-_FnIter concrete types behind Optional[Iterator[T]]
// must not segfault during cleanup (was crashing because __promise_iter_cleanup
// assumed _FnIter layout for all structural interface instances).
type Counter is Iterator[int] {
  int current;
  int limit;

  next() int? {
    if this.current >= this.limit {
      return none;
    }
    int val = this.current;
    this.current = this.current + 1;
    return val;
  }
}

test_flat_map_basic() `test {
  int[] v = [1, 2, 3];
  int[] result = v.iter().flat_map[int](|int x| -> Iterator[int] {
    return Counter(current: 0, limit: x);
  }).collect();
  // 1->[0], 2->[0,1], 3->[0,1,2]
  assert(result.len == 6, "flat_map len=6");
  assert(result[0] == 0, "r[0]=0");
  assert(result[1] == 0, "r[1]=0");
  assert(result[2] == 1, "r[2]=1");
  assert(result[3] == 0, "r[3]=0");
  assert(result[4] == 1, "r[4]=1");
  assert(result[5] == 2, "r[5]=2");
}

test_flat_map_empty_inner() `test {
  int[] v = [0, 0, 0];
  int[] result = v.iter().flat_map[int](|int x| -> Iterator[int] {
    return Counter(current: 0, limit: x);
  }).collect();
  assert(result.len == 0, "flat_map with all empty inners = empty");
}

test_flat_map_empty_outer() `test {
  int[] v = [];
  int[] result = v.iter().flat_map[int](|int x| -> Iterator[int] {
    return Counter(current: 0, limit: x);
  }).collect();
  assert(result.len == 0, "flat_map on empty = empty");
}

test_flat_map_single() `test {
  int[] v = [3];
  int[] result = v.iter().flat_map[int](|int x| -> Iterator[int] {
    return Counter(current: 0, limit: x);
  }).collect();
  assert(result.len == 3, "flat_map single = 3 elements");
}
