// T0101: Optional fields wrapping heap types should drop the inner value.
// Tests that types with optional string fields properly free them in synthesized drops.
type Wrapper {
  string? opt_name;
}

type MultiField {
  string name;
  string? extra;
}

// --- Optional string field in type: dynamic string should not leak ---

test_optional_field_dynamic() `test {
  Wrapper w = Wrapper(opt_name: "hello" + " world");
  // Wrapper.drop frees the inner string via optfield.drop
  assert(true, "dynamic string in optional field is freed");
}

test_optional_field_none() `test {
  Wrapper w = Wrapper(opt_name: none);
  // Wrapper.drop checks has-value flag, skips drop for none
  assert(true, "none field is safe");
}

test_optional_field_literal() `test {
  Wrapper w = Wrapper(opt_name: "static");
  // Static strings have literal flag — promise_string_drop skips them
  assert(true, "literal in optional field is safe");
}

// --- Multiple fields including optional ---

test_multi_field_both() `test {
  MultiField m = MultiField(name: "main", extra: "extra" + " data");
  assert(m.name == "main", "regular field");
  // Both name and extra are cleaned up by MultiField.drop
}

test_multi_field_none() `test {
  MultiField m = MultiField(name: "main", extra: none);
  assert(m.name == "main", "regular field with none optional");
}

// --- B0181: Optional field access + unwrap must dup to prevent double-free ---

test_optional_field_unwrap_no_double_free() `test {
  Wrapper w = Wrapper(opt_name: "hello" + " world");
  string val = w.opt_name!;
  assert(val == "hello world", "unwrapped value matches");
}

test_optional_field_unwrap_owner_still_valid() `test {
  Wrapper w = Wrapper(opt_name: "abc" + "def");
  string val = w.opt_name!;
  assert(val == "abcdef", "unwrapped value matches");
  // w is still alive — its field and val should both be valid (independent copies)
  assert(w.opt_name! == "abcdef", "original field still valid after unwrap");
}

test_optional_field_unwrap_multi_field() `test {
  MultiField m = MultiField(name: "main" + "!", extra: "extra" + " data");
  string val = m.extra!;
  assert(val == "extra data", "unwrapped optional matches");
  assert(m.name == "main!", "non-optional field still valid");
}

// --- B0190: Inline optional unwrap must not track field string as temp ---

test_inline_optional_unwrap_dynamic() `test {
  Wrapper w = Wrapper(opt_name: "abc" + "def");
  assert(w.opt_name! == "abcdef", "inline unwrap dynamic string");
}

test_inline_optional_unwrap_field_access() `test {
  Wrapper w = Wrapper(opt_name: "hello" + " world");
  int len = w.opt_name!.len;
  assert(len == 11, "inline unwrap field access");
}

test_inline_optional_unwrap_concat() `test {
  Wrapper w = Wrapper(opt_name: "hello" + " ");
  string result = w.opt_name! + "world";
  assert(result == "hello world", "inline unwrap in concat");
}

// B0190: Ensure optionalFieldString flag doesn't leak across statements.
// A field access on one statement must not suppress temp tracking on the next.
make_string() string! {
  return "hello" + " world";
}

test_field_access_then_failable_unwrap() `test {
  Wrapper w = Wrapper(opt_name: "abc");
  string? maybe = w.opt_name;
  string val = make_string()!;
  assert(val == "hello world", "failable unwrap after field access");
}
