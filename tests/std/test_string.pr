// Test string operations: concat, equality, methods
//
// TODO: test comparisons (<, >, <=, >=) — blocked on codegen (string operator "<" not yet implemented)
test_concat() `test {
  assert("hello" + " " + "world" == "hello world", "string concat");
  assert("" + "a" == "a", "empty + a");
  assert("a" + "" == "a", "a + empty");
}

test_equality() `test {
  assert("hello" == "hello", "equal strings");
  assert(!("hello" == "world"), "different strings not equal");
  assert("hello" != "world", "!= different");
  assert(!("abc" != "abc"), "!= same");
  assert("" == "", "empty strings equal");
  assert("" != "a", "empty != non-empty");
}

test_len() `test {
  assert("hello".len == 5, "hello len 5");
  assert("".len == 0, "empty len 0");
  assert("ab".len == 2, "ab len 2");
}

test_is_empty() `test {
  assert("".is_empty, "empty is_empty");
  assert(!"hello".is_empty, "hello not is_empty");
}

test_contains() `test {
  assert("hello world".contains("world"), "contains world");
  assert("hello world".contains("hello"), "contains hello");
  assert(!"hello".contains("xyz"), "not contains xyz");
  assert("abc".contains(""), "contains empty");
  assert("abc".contains("abc"), "contains full string");
  assert(!"hi".contains("longer"), "sub longer than string");
}

test_starts_with() `test {
  assert("hello world".starts_with("hello"), "starts_with hello");
  assert(!"hello world".starts_with("world"), "not starts_with world");
  assert("abc".starts_with(""), "starts_with empty");
  assert("abc".starts_with("abc"), "starts_with full string");
  assert(!"hi".starts_with("hello"), "prefix longer than string");
}

test_ends_with() `test {
  assert("hello world".ends_with("world"), "ends_with world");
  assert(!"hello world".ends_with("hello"), "not ends_with hello");
  assert("abc".ends_with(""), "ends_with empty");
  assert("abc".ends_with("abc"), "ends_with full string");
  assert(!"hi".ends_with("hello"), "suffix longer than string");
}

test_index_of() `test {
  if idx := "hello world".index_of("world") {
    assert(idx == 6, "index_of world == 6");
  } else {
    assert(false, "should find world");
  }

  assert("hello".index_of("xyz") is absent, "index_of xyz not found");

  // Empty sub returns 0
  if idx2 := "hello".index_of("") {
    assert(idx2 == 0, "index_of empty == 0");
  } else {
    assert(false, "should find empty");
  }

  // Sub at position 0
  if idx3 := "hello".index_of("hel") {
    assert(idx3 == 0, "index_of at start == 0");
  } else {
    assert(false, "should find hel at start");
  }

  // Sub equals full string
  if idx4 := "abc".index_of("abc") {
    assert(idx4 == 0, "index_of full string == 0");
  } else {
    assert(false, "should find full string");
  }

  // Sub longer than string
  assert("hi".index_of("longer") is absent, "index_of sub longer than string");
}

test_trim() `test {
  assert("  hello  ".trim() == "hello", "trim spaces");
  assert("hello".trim() == "hello", "trim no-op");
  assert("   ".trim() == "", "trim all spaces");
}

test_split() `test {
  string[] parts = "a,b,c".split(",");
  assert(parts.len == 3, "split len 3");
  assert(parts[0] == "a", "split[0] == a");
  assert(parts[1] == "b", "split[1] == b");
  assert(parts[2] == "c", "split[2] == c");
}

test_indexing() `test {
  assert("hello"[0] == 'h', "s[0] == h");
  assert("hello"[1] == 'e', "s[1] == e");
  assert("hello"[4] == 'o', "s[4] == o");
  assert("abc"[2] == 'c', "abc[2] == c");

  string s = "world";
  assert(s[0] == 'w', "var s[0] == w");
  assert(s[4] == 'd', "var s[4] == d");

  // Variable index
  int i = 2;
  assert("abcde"[i] == 'c', "variable index");

  // Last byte of string
  string t = "xyz";
  assert(t[t.len - 1] == 'z', "last byte");
}

test_interpolation() `test {
  int x = 42;
  assert("{x}" == "42", "int interpolation");
  string name = "world";
  assert("hello {name}" == "hello world", "string interpolation");
  assert("{1 + 2}" == "3", "expr interpolation");
}

// --- Slicing ---

test_slice_range() `test {
  assert("hello world"[0:5] == "hello", "slice [0:5]");
  assert("hello world"[6:11] == "world", "slice [6:11]");
  assert("abcdef"[2:4] == "cd", "slice [2:4]");
}

test_slice_from_start() `test {
  assert("hello"[:3] == "hel", "slice [:3]");
  assert("hello"[:0] == "", "slice [:0] empty");
  assert("hello"[:5] == "hello", "slice [:5] full");
}

test_slice_to_end() `test {
  assert("hello"[3:] == "lo", "slice [3:]");
  assert("hello"[0:] == "hello", "slice [0:] full");
  assert("hello"[5:] == "", "slice [5:] empty");
}

test_slice_full() `test {
  assert("hello"[:] == "hello", "slice [:] full copy");
  assert(""[:] == "", "slice [:] empty string");
}

test_slice_empty() `test {
  assert("hello"[2:2] == "", "slice [2:2] empty");
  assert("hello"[0:0] == "", "slice [0:0] empty");
}

test_slice_single_char() `test {
  assert("hello"[1:2] == "e", "slice [1:2] single char");
}

test_slice_variable() `test {
  string s = "hello world";
  int start = 6;
  string sub = s[start:];
  assert(sub == "world", "slice with variable start");
}

// --- Hash ---

test_hash_consistent() `test {
  assert("hello".hash == "hello".hash, "same string same hash");
  assert("world".hash == "world".hash, "world hash consistent");
  assert("".hash == "".hash, "empty hash consistent");
}

test_hash_different() `test {
  assert("hello".hash != "world".hash, "different strings different hash");
  assert("abc".hash != "xyz".hash, "abc != xyz hash");
  assert("".hash != "hello".hash, "empty != hello hash");
}

test_hash_variable() `test {
  string s = "hello";
  int h = s.hash;
  assert(h == "hello".hash, "variable hash matches literal hash");
}

test_hash_type() `test {
  int h = "test".hash;
  assert(h == h, "hash is int");
}
