// Test cooperative preemption: a CPU-bound goroutine with a tight loop
// should not starve other goroutines. The sysmon thread sets G.preempt=1
// on long-running Gs, and yield checks at loop back-edges cause them
// to yield. Without preemption, the result channel receive would hang.

main() `test(expected: "done") {
  ch := channel[int](capacity: 1);

  // Launch a CPU-bound goroutine with a tight loop
  go {
    int x = 0;
    for i in 0..1000000 {
      x = x + 1;
    }
    ch.send(x);
  };

  // Launch another goroutine that should complete despite the busy one
  done := channel[string](capacity: 1);
  go {
    // Wait for the busy goroutine to finish
    r := <-ch;
    done.send("done");
  };

  r := <-done;
  if v := r { println(v); }
}
