// T0494: Getters returning droppable values (string/vector/map/user heap type)
// must register cleanup at the call site so the cloned/owned return value is
// freed once the temp goes out of scope. Before T0494, only string getters
// were tracked (B0290). This test exercises the for-in iterable, method-chain
// receiver, and standalone-expression positions for vectors, maps, and user
// heap types — all four scenarios leaked memory (or crashed) prior to the fix.
type Inner {
  string _name;
  drop(~this) {
  }
  ok(&this) bool {
    return true;
  }
}

type Outer {
  Inner _inner;

  get inner Inner `public => Inner(_name: this._inner._name);
}

type Holder {
  map[string, string] _data;
  string[] _tags;

  get data map[string, string] `public => this._data.clone();
  get tags string[] `public => this._tags.clone();
  data_method() map[string, string] `public {
    return this._data.clone();
  }
}

setup_holder() Holder {
  Holder h = Holder(_data: map[string, string](), _tags: ["red", "blue", "green"]);
  h._data["a"] = "1";
  h._data["b"] = "2";
  return h;
}

// Map getter in for-in iterable position — the original repro from T0494.
test_map_getter_for_in() `test {
  Holder h = setup_holder();
  int n = 0;
  for k, v in h.data {
    n = n + 1;
  }
  assert(n == 2, "map getter for-in count");
}

// Map getter in method-chain receiver position — second case from T0494.
test_map_getter_chain() `test {
  Holder h = setup_holder();
  assert(h.data.contains("a"), "map getter chain contains");
}

// Method form (kept here as the reference: this never leaked).
test_map_method_for_in() `test {
  Holder h = setup_holder();
  int n = 0;
  for k, v in h.data_method() {
    n = n + 1;
  }
  assert(n == 2, "map method for-in count");
}

// Vector getter in for-in iterable position — generalized leak case.
test_vector_getter_for_in() `test {
  Holder h = setup_holder();
  int n = 0;
  for t in h.tags {
    n = n + 1;
  }
  assert(n == 3, "vector getter for-in count");
}

// Vector getter in method-chain receiver position.
test_vector_getter_chain() `test {
  Holder h = setup_holder();
  assert(h.tags.contains("red"), "vector getter chain contains");
}

// User heap type getter in method-chain receiver position.
test_user_heap_getter_chain() `test {
  Outer o = Outer(_inner: Inner(_name: "hi"));
  assert(o.inner.ok(), "user heap getter chain ok");
}

// Vector getter as a standalone-expression statement (drop at stmt end only).
test_vector_getter_expression_stmt() `test {
  Holder h = setup_holder();
  h.tags;
  assert(true, "no leak from discarded vector getter result");
}

// Map getter as a standalone-expression statement.
test_map_getter_expression_stmt() `test {
  Holder h = setup_holder();
  h.data;
  assert(true, "no leak from discarded map getter result");
}

type StringBox {
  string _content;

  get content string `public => this._content + "!";
}

// String getter result used in for-in iterable position. Without the lifetime
// extension fix in genForInStmt's string path, the cloned string would be
// freed by the body's first stmt-end cleanup and subsequent iterations would
// read freed memory.
test_string_getter_for_in() `test {
  StringBox b = StringBox(_content: "abc");
  int n = 0;
  for c in b.content {
    n = n + 1;
  }
  assert(n == 4, "string getter for-in char count");
}

// Generic owner type with getter returning T[]: exercises trackGetterResult's
// typeSubst path. When `for x in this.items` is generated inside a method body
// of the monomorphized Box[int], c.typeSubst = {T->int} is set so the
// getter's T[] return type substitutes to int[] before tracking — without
// substitution the type-shape check would see TypeParam, miss the Vector,
// and leak.
type Box[T] {
  T[] _items;

  get items T[] `public => this._items.clone();

  count() int `public {
    int n = 0;
    for x in this.items {
      n = n + 1;
    }
    return n;
  }
}

test_generic_getter_for_in_inside_method() `test {
  Box[int] b = Box[int](_items: [10, 20, 30]);
  assert(b.count() == 3, "generic getter for-in count from inside method");
}

// Generic owner type with getter returning Map[K,V] used in chain receiver
// position. Exercises the heap-user-type branch of trackGetterResult under
// monomorphization (typeSubst is set in trackHeapUserTypeResult's lookup of
// c.info.Types[expr]).
type Cache[V] {
  map[string, V] _entries;

  get entries map[string, V] `public => this._entries.clone();
}

test_generic_map_getter_chain() `test {
  Cache[int] c = Cache[int](_entries: map[string, int]());
  c._entries["a"] = 1;
  c._entries["b"] = 2;
  assert(c.entries.contains("a"), "generic map getter chain contains");
}

// Virtual dispatch path: abstract base with concrete impl whose getter returns
// a Vector[T]. Exercises trackGetterResult through genVirtualGetterCall (the
// other call site of trackGetterResult, distinct from genGetterCall).
type ItemSource {
  get items string[] `public `abstract;
}

type ItemImpl is ItemSource {
  string[] _items;

  get items string[] `public => this._items.clone();
}

test_virtual_getter_vector_for_in() `test {
  ItemSource src = ItemImpl(_items: ["a", "b", "c", "d"]);
  int n = 0;
  for x in src.items {
    n = n + 1;
  }
  assert(n == 4, "virtual getter vector for-in count");
}

// Virtual dispatch with map result in chain receiver position.
type DataSource {
  get data map[string, string] `public `abstract;
}

type DataImpl is DataSource {
  map[string, string] _data;

  get data map[string, string] `public => this._data.clone();
}

test_virtual_getter_map_chain() `test {
  DataImpl impl = DataImpl(_data: map[string, string]());
  impl._data["k"] = "v";
  DataSource src = impl;
  assert(src.data.contains("k"), "virtual getter map chain contains");
}

// Virtual dispatch with user heap type return.
type HeapItem {
  string _label;

  drop(~this) {
  }

  ok(&this) bool `public {
    return true;
  }
}

type HeapSource {
  get item HeapItem `public `abstract;
}

type HeapImpl is HeapSource {
  HeapItem _item;

  get item HeapItem `public => HeapItem(_label: this._item._label);
}

test_virtual_getter_heap_chain() `test {
  HeapSource src = HeapImpl(_item: HeapItem(_label: "x"));
  assert(src.item.ok(), "virtual getter heap chain ok");
}

// T0486: Arc[T]/Channel[T]/Weak[T]/Mutex[T] getter results also own a heap
// allocation; before T0486 these container types fell through trackGetterResult
// (only String/Vector/heap-user-type were dispatched) and leaked at stmt end.

type ABox {
  drop(~this) {
  }

  get fresh Arc[int] `public => Arc[int](42);
}

type CBox {
  drop(~this) {
  }

  get fresh channel[int] `public => channel[int](2);
}

type WBox {
  drop(~this) {
  }

  // Method-body form so the Arc local is dropped at end of getter body. The
  // returned Weak still owns +1 weak count; trackGetterResult must register
  // that as a temp at the call site so the allocation is freed.
  // Avoids both the chain-intermediate Arc-temp leak (T0499) and the
  // field-read-dup × clone double-increment that field-based Weak getters hit.
  get fresh Weak[int] `public {
    Arc[int] inner = Arc[int](42);
    return inner.downgrade();
  }
}

type MBox {
  drop(~this) {
  }

  get fresh Mutex[int] `public => Mutex[int](42);
}

// Arc getter as discarded expression statement — the cloned Arc must drop at
// stmt end (decrement strong count to zero, free the allocation).
test_arc_getter_expression_stmt() `test {
  ABox a = ABox();
  a.fresh;
  assert(true, "no leak from discarded arc getter result");
}

// Arc getter in method-chain receiver position — `.borrow` returns the inner
// int value, but the Arc temp from `a.fresh` itself must drop at stmt end.
test_arc_getter_chain() `test {
  ABox a = ABox();
  assert(a.fresh.borrow == 42, "arc getter chain borrow");
}

// Channel getter as discarded expression statement — the cloned channel
// (buffer + mutex + 2 cond vars + struct) must drop at stmt end.
test_channel_getter_expression_stmt() `test {
  CBox c = CBox();
  c.fresh;
  assert(true, "no leak from discarded channel getter result");
}

// Weak getter as discarded expression statement — the returned Weak temp
// must drop at stmt end (decrement weak count to zero, free the allocation
// that the getter body's local Arc dropped strong on).
test_weak_getter_expression_stmt() `test {
  WBox w = WBox();
  w.fresh;
  assert(true, "no leak from discarded weak getter result");
}

// Mutex getter as discarded expression statement — the Mutex (lock + inner
// value) must drop at stmt end.
test_mutex_getter_expression_stmt() `test {
  MBox m = MBox();
  m.fresh;
  assert(true, "no leak from discarded mutex getter result");
}

// Generic owner type with Arc[T] getter exercises the typeSubst path: the
// getter's Arc[T] return type is substituted to Arc[int] under monomorphization,
// and types.AsArc on the substituted Instance returns the post-subst element.
type ArcCell[T] {
  T _value;

  get fresh Arc[T] `public => Arc[T](this._value);
}

test_generic_arc_getter_chain() `test {
  ArcCell[int] c = ArcCell[int](_value: 99);
  assert(c.fresh.borrow == 99, "generic arc getter chain borrow");
}

// Generic Arc[T] with non-Copy T (string) — exercises owner-type substitution
// in trackGetterResult so getOrCreateArcDrop is called with the concrete
// element type (string) and the generated Arc[string].drop function correctly
// drops the inner string. Without owner-subst, getOrCreateArcDrop would be
// called with TypeParam T and produce a wrong Arc[T].drop fn that skips inner
// string drop, leaking the cloned-string allocation.
type StrCell[T] {
  T _value;

  get fresh Arc[T] `public => Arc[T](this._value);
}

test_generic_arc_string_chain() `test {
  StrCell[string] c = StrCell[string](_value: "hello");
  assert(c.fresh.borrow == "hello", "generic arc string getter chain borrow");
}

// Virtual dispatch path: abstract base with Arc[int] getter, exercising the
// genVirtualGetterCall side of trackGetterResult.
type ArcSource {
  get fresh Arc[int] `public `abstract;
}

type ArcImpl is ArcSource {
  get fresh Arc[int] `public => Arc[int](7);
}

test_virtual_arc_getter_chain() `test {
  ArcSource src = ArcImpl();
  assert(src.fresh.borrow == 7, "virtual arc getter chain borrow");
}

// Getter called from inside another method body — exercises the
// tempTrackingEnabled gating (true for user method bodies) so the Arc temp
// produced by the inner call is tracked just like at the test top level.
type ArcRoom {
  drop(~this) {
  }

  get item Arc[int] `public => Arc[int](100);

  use_item(&this) bool `public {
    return this.item.borrow == 100;
  }
}

test_arc_getter_does_not_leak_inside_method() `test {
  ArcRoom r = ArcRoom();
  assert(r.use_item(), "arc getter chain inside method body");
}

// T0501: Binding a getter result to a local (var-decl) used to leak. Before the
// fix, the var-decl path's "RHS is a borrow" branch ran clearDropFlag(s.Name) on
// `local.getter` because isGetterCall only matched top-level or module getters,
// not MemberExprs on locals. claimStringTemp already transferred the temp's
// ownership into the LHS, but clearing the LHS drop flag immediately after
// orphaned the allocation.
//
// Uses ArcCell[T] (no drop on the owner) because sema currently rejects the
// var-decl form for types with explicit drop methods returning Arc — that
// rejection is a separate sema-level diagnostic mistake noted in T0501's
// plan and is out of scope here.

// Inferred form: `s := c.fresh;` with Arc[int] getter on a local owner.
test_var_decl_inferred_arc_getter() `test {
  ArcCell[int] c = ArcCell[int](_value: 42);
  s := c.fresh;
  assert(s.borrow == 42, "arc var-decl inferred borrow");
}

// Typed form: `Arc[int] s = c.fresh;` — same root cause, separate codepath
// (genTypedVarDecl vs genInferredVarDecl).
test_var_decl_typed_arc_getter() `test {
  ArcCell[int] c = ArcCell[int](_value: 42);
  Arc[int] s = c.fresh;
  assert(s.borrow == 42, "arc var-decl typed borrow");
}

// Channel[T] getter result bound to a local — uses a drop-less owner because
// isStringFieldDup returns HasDrop() for member exprs, so a CBox-style owner
// (with drop) would short-circuit the borrow-RHS branch entirely and mask the
// T0501 bug. ChCell has no drop → the buggy branch was reachable.
type ChCell {
  get fresh channel[int] `public => channel[int](2);
}

test_var_decl_inferred_channel_getter() `test {
  ChCell c = ChCell();
  s := c.fresh;
  assert(true, "channel var-decl inferred no leak");
}

test_var_decl_typed_channel_getter() `test {
  ChCell c = ChCell();
  channel[int] s = c.fresh;
  assert(true, "channel var-decl typed no leak");
}

// Virtual dispatch: abstract base's getter bound to a local. LookupGetter walks
// the parent chain so the inherited getter is found via the static target type.
test_var_decl_inferred_virtual_arc_getter() `test {
  ArcSource src = ArcImpl();
  s := src.fresh;
  assert(s.borrow == 7, "virtual arc var-decl inferred borrow");
}

test_var_decl_typed_virtual_arc_getter() `test {
  ArcSource src = ArcImpl();
  Arc[int] s = src.fresh;
  assert(s.borrow == 7, "virtual arc var-decl typed borrow");
}

// Chained-target var-decl: `s := outer.field.getter` where `outer.field` is
// itself a MemberExpr (not an IdentExpr). The pre-T0501 module-getter check
// looks for an IdentExpr target that resolves to a module name, so chained
// targets never matched. The new isGetterCallExpr matches on any MemberExpr
// whose target's static type has the named getter — so chains work uniformly.
// Without the fix, the cloned Arc allocation leaks because clearDropFlag still
// fires on the LHS after claimStringTemp transferred ownership.
type ArcOuter {
  ArcCell[int] _inner;
}

test_var_decl_inferred_chain_target_arc_getter() `test {
  ArcOuter o = ArcOuter(_inner: ArcCell[int](_value: 77));
  s := o._inner.fresh;
  assert(s.borrow == 77, "chain target arc var-decl inferred borrow");
}

test_var_decl_typed_chain_target_arc_getter() `test {
  ArcOuter o = ArcOuter(_inner: ArcCell[int](_value: 77));
  Arc[int] s = o._inner.fresh;
  assert(s.borrow == 77, "chain target arc var-decl typed borrow");
}

// Mutex[T] getter var-decl — same root cause as Arc/Channel; the Mutex
// allocation (lock + inner value) leaks 3 allocations without the T0501 fix.
// Drop-less owner so the buggy borrow-RHS branch is reachable.
type MCell {
  get fresh Mutex[int] `public => Mutex[int](42);
}

test_var_decl_inferred_mutex_getter() `test {
  MCell c = MCell();
  s := c.fresh;
  assert(true, "mutex var-decl inferred no leak");
}

test_var_decl_typed_mutex_getter() `test {
  MCell c = MCell();
  Mutex[int] s = c.fresh;
  assert(true, "mutex var-decl typed no leak");
}

// Weak[T] getter var-decl. The getter uses a method body form (not lambda-expr)
// to set up an Arc, downgrade it, and let the Arc drop at the end of the body,
// leaving only the Weak ref alive. Without T0501, binding that Weak to a local
// leaks the underlying Arc-state allocation (weak count was the last keeper).
// Drop-less owner so the buggy branch is reachable. (Lambda-expr form `=>
// inner.downgrade()` is rejected by sema with the same diagnostic mistake
// noted in T0501's plan.)
type WCell {
  get fresh Weak[int] `public {
    Arc[int] inner = Arc[int](42);
    return inner.downgrade();
  }
}

test_var_decl_inferred_weak_getter() `test {
  WCell c = WCell();
  s := c.fresh;
  assert(true, "weak var-decl inferred no leak");
}

// Heap-allocated string getter var-decl. With a drop-less owner (no synth drop),
// isStringFieldDup returns false, so the borrow-RHS branch is reachable. The
// getter returns a runtime-concatenated string (not a .rodata literal — bit 63
// would make Vector/String drop a no-op and mask the bug). Without T0501 the
// allocation leaks.
fresh_str_t0501(int n) string {
  return "x" + n.to_string();
}

type StringSCell {
  get fresh string `public => fresh_str_t0501(42);
}

test_var_decl_inferred_string_getter() `test {
  StringSCell c = StringSCell();
  s := c.fresh;
  assert(s == "x42", "string var-decl inferred");
}

test_var_decl_typed_string_getter() `test {
  StringSCell c = StringSCell();
  string s = c.fresh;
  assert(s == "x42", "string var-decl typed");
}

// Heap-allocated vector getter var-decl. Drop-less owner + non-literal element
// (so it can't be a .rodata static vector — T0062's bit-63 flag would mask the
// leak). Returns a fresh Vector[int] from a helper, ensuring real pal_alloc'd
// storage.
fresh_vec_t0501(int n) int[] {
  int[] v = [n];
  return v;
}

type VectorSCell {
  get fresh int[] `public => fresh_vec_t0501(42);
}

test_var_decl_inferred_vector_getter() `test {
  VectorSCell c = VectorSCell();
  s := c.fresh;
  assert(s.len == 1, "vector var-decl inferred");
  assert(s[0] == 42, "vector var-decl inferred value");
}

test_var_decl_typed_vector_getter() `test {
  VectorSCell c = VectorSCell();
  int[] s = c.fresh;
  assert(s.len == 1, "vector var-decl typed");
  assert(s[0] == 42, "vector var-decl typed value");
}

// T0502: for-in over a getter result of channel[T] type leaked the channel's
// 5 allocations (struct + buffer + mutex + 2 cond vars). The vector/string
// branches of genForInStmt promote a tracked stmt temp to a scope binding
// (T0494); the channel branch did not, so the temp's drop never fired and the
// channel was leaked. The fix mirrors the vector/string promotion pattern in
// stmt.go's channel branch.
type ChanCBox {
  drop(~this) {
  }

  get empty channel[int] `public {
    ch := channel[int](2);
    ch.close();
    return ch;
  }

  get full channel[int] `public {
    ch := channel[int](3);
    ch.send(1);
    ch.send(2);
    ch.send(3);
    ch.close();
    return ch;
  }
}

// Empty closed channel from a getter — the exact repro from the bug.
test_channel_getter_for_in_empty() `test {
  ChanCBox c = ChanCBox();
  int n = 0;
  for v in c.empty {
    n = n + 1;
  }
  assert(n == 0, "empty channel for-in count");
}

// Non-empty channel from a getter — the body actually iterates and the
// channel is still dropped at end of scope.
test_channel_getter_for_in_nonempty() `test {
  ChanCBox c = ChanCBox();
  int sum = 0;
  for v in c.full {
    sum = sum + v;
  }
  assert(sum == 6, "non-empty channel for-in sum");
}

// Generic owner — exercises monomorphized method/getter lookup on the for-in
// channel iterable path.
type ChanCell[T] {
  get empty channel[T] `public {
    ch := channel[T](1);
    ch.close();
    return ch;
  }
}

test_generic_channel_getter_for_in() `test {
  ChanCell[int] c = ChanCell[int]();
  int n = 0;
  for v in c.empty {
    n = n + 1;
  }
  assert(n == 0, "generic channel for-in");
}

// Virtual dispatch — abstract base with channel getter, concrete subtype
// returns the channel. Exercises the virtual-getter side of trackGetterResult.
type ChanSrc {
  get empty channel[int] `public `abstract;
}

type ChanImpl is ChanSrc {
  get empty channel[int] `public {
    ch := channel[int](1);
    ch.close();
    return ch;
  }
}

test_virtual_channel_getter_for_in() `test {
  ChanSrc src = ChanImpl();
  int n = 0;
  for v in src.empty {
    n = n + 1;
  }
  assert(n == 0, "virtual channel for-in");
}

// For-in inside a method body with `this.getter` — mirrors
// `test_generic_getter_for_in_inside_method` for the channel branch. This
// exercises the path where the for-in is generated inside a user method body
// (which is when `tempTrackingEnabled` is set), and the iterable target is
// `this` rather than a top-level local. Without T0502, the cloned channel
// from `this.empty` would leak when the method runs.
type ChanRoom {
  drop(~this) {
  }

  get empty channel[int] `public {
    ch := channel[int](2);
    ch.send(10);
    ch.send(20);
    ch.close();
    return ch;
  }

  count_items(&this) int `public {
    int n = 0;
    for v in this.empty {
      n = n + 1;
    }
    return n;
  }
}

test_channel_getter_for_in_inside_method() `test {
  ChanRoom r = ChanRoom();
  assert(r.count_items() == 2, "channel for-in inside method body count");
}

// Chained-target getter (`outer._inner.empty`) — exercises the MemberExpr
// chain path. The static type of `outer._inner` is the inner type, and the
// getter is then looked up on that. Without T0502 the cloned channel from
// the chained getter call would leak.
type ChanOuter {
  ChanCBox _inner;
}

test_chain_target_channel_getter_for_in() `test {
  ChanOuter o = ChanOuter(_inner: ChanCBox());
  int sum = 0;
  for v in o._inner.full {
    sum = sum + v;
  }
  assert(sum == 6, "chain-target channel for-in sum");
}

// Early break out of channel for-in — verifies the scope-binding promotion
// added by T0502 cleans up on the break exit path, not just on normal
// fall-through. Channel is closed before the for-in starts (via `full`
// getter) so breaking out without draining the buffer is safe.
test_channel_getter_for_in_break() `test {
  ChanCBox c = ChanCBox();
  int n = 0;
  for v in c.full {
    n = n + 1;
    if n == 2 {
      break;
    }
  }
  assert(n == 2, "channel for-in break count");
}
