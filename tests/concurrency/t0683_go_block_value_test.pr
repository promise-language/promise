// T0683: a value-returning `go { …; <expr> }` block bound to a variable and
// awaited via `<-x` overflowed the stack at runtime. Root cause: genGoBlock
// only ever emitted a void coroutine — it discarded the trailing-expression
// value and stored the void sentinel 0x1 into G.result_ptr; `<-x` on the
// sema-typed task[T] then loaded from address 0x1 (SIGSEGV, mislabeled
// "fatal: stack overflow" by the macOS signal handler). The fix stores the
// trailing value into a caller-allocated result buffer.
//
// Batch tests with NO `exclude: wasm` — `<-task` await works under the WASM
// cooperative scheduler (same join path as task_drop_wasm_test). Zero-leak
// enforcement applies on the host AND `--target wasm32-wasi`.
// (1) The exact reported repro: int value block awaited.
t0683_basic_int() `test {
  task[int] x = go {
    42
  };
  r := <-x;
  assert(r == 42, "value block int result");
}

// (2) Multi-statement block with locals — the trailing expression is the
// block value; preceding statements are run for effect.
t0683_multi_stmt_locals() `test {
  task[int] x = go {
    a := 20;
    b := 22;
    a + b
  };
  assert((<-x) == 42, "multi-statement value block");
}

// (3) Heap (string) result — exercises ownership transfer of the result into
// G.result_ptr (claimStringTemp) and the receiver taking ownership. A leak
// here would fail the zero-tolerance policy.
t0683_string_result() `test {
  task[string] x = go {
    "he" + "llo"
  };
  string r = <-x;
  assert(r == "hello", "value block string result");
}

// (4) Block capturing an outer variable, then producing a value from it.
t0683_capture_outer() `test {
  base := 40;
  task[int] x = go {
    base + 2
  };
  assert((<-x) == 42, "value block over captured var");
}

// (5) Nested value block: an inner value block awaited inside an outer one.
t0683_nested_value_block() `test {
  task[int] outer = go {
    task[int] inner = go {
      21
    };
    (<-inner) * 2
  };
  assert((<-outer) == 42, "nested value blocks");
}

// (6) Other result types for breadth.
t0683_bool_result() `test {
  task[bool] x = go {
    1 + 1 == 2
  };
  assert(<-x, "value block bool result");
}

t0683_float_result() `test {
  task[f64] x = go {
    1.5 + 2.0
  };
  f64 r = <-x;
  assert(r == 3.5, "value block f64 result");
}

// (7) Void block awaited still works alongside the value path (regression).
t0683_void_block_awaited() `test {
  task[void] v = go {
    int n = 10;
  };
  <-v;
  assert(true, "void block still awaitable");
}

// (8) Fire-and-forget value block as a bare statement — value discarded.
// Must not crash and must not leak: the void genBlock path drops a heap
// trailing value via per-statement cleanup; the caller allocates no buffer.
t0683_fire_and_forget_value() `test {
  go {
    1
  };
  go {
    "discarded" + " heap string"
  };
  go {
    a := 7;
    a * 6
  };
  assert(true, "fire-and-forget value blocks: no crash, no leak");
}

// (9) The behavior the fix actually changed: a non-void value block bound to
// a variable but NEVER awaited (dropped at scope exit). Before T0683 this
// stored the void sentinel 0x1 (Task[T].drop freed G only); after the fix it
// stores a real pal_alloc buffer that Task[T].drop's free_after_done path
// (defineTaskFreeAfterDoneBody) must free. Zero-tolerance leak regression
// guard — int (trivial drop) and string (heap drop of the result T).
t0683_value_block_dropped_int() `test {
  task[int] t = go {
    42
  };
  assert(true, "int value-block task dropped, not awaited: no leak");
}

t0683_value_block_dropped_string() `test {
  task[string] t = go {
    "heap" + " result"
  };
  assert(true, "string value-block task dropped, not awaited: no leak");
}

// (10) Many dropped value-block tasks in a loop — exercises the drop path
// repeatedly; a per-iteration buffer/G leak would trip the alloc-delta check.
t0683_value_block_dropped_loop() `test {
  i := 0;
  while i < 30 {
    task[int] n = go {
      i * 2
    };
    task[string] s = go {
      "x" + "y"
    };
    i = i + 1;
  }
  assert(i == 30, "many value-block tasks dropped in loop: no leak");
}

// (11) Value-block tasks stored in a Vector and never awaited — container
// scope-exit drop routes each element through Task[T].drop. Confirms the
// real result buffer is freed via the container-drop path, not just the
// direct-variable path.
t0683_value_block_in_vector_dropped() `test {
  ts := Task[int][]();
  ts.push(go {
    1
  });
  ts.push(go {
    2
  });
  ts.push(go {
    3
  });
  assert(ts.len == 3, "value-block tasks in vector, none awaited: no leak");
}

// (12) Mixed: value-block tasks in a Vector, all awaited via for-in. The
// receive nulls each slot so the container's element drop no-ops — confirms
// the await + slot-null interplay produces the right sum and no double-free.
t0683_value_block_in_vector_all_awaited() `test {
  ts := Task[int][]();
  ts.push(go {
    10
  });
  ts.push(go {
    20
  });
  ts.push(go {
    12
  });
  total := 0;
  for t in ts {
    total = total + (<-t);
  }
  assert(total == 42, "value-block tasks in vector, all awaited via for-in");
}

// (13) Enum result — a value-block result type with variant/tag layout,
// distinct from the primitive/string/bool/f64 results above (none of which
// exercised an enum). Covers genGoBlock's resolveType / result-buffer
// sizing for an enum value struct.
enum T0683Color {
  Red,
  Green,
  Blue,
}

t0683_enum_result() `test {
  task[T0683Color] x = go {
    T0683Color.Green
  };
  c := <-x;
  ok := match c {
    T0683Color.Green => true,
    _ => false,
  };
  assert(ok, "value block enum result");
}

// (14) Generic pure value-type result — `Point[int]` (all-`value` fields,
// embedded Value layout, no heap, no drop) as the value-block result.
// Distinct layout/typeSize path from primitives and enums.
t0683_value_type_result() `test {
  task[Point[int]] x = go {
    Point[int](x: 3, y: 4)
  };
  p := <-x;
  assert(p.x == 3 && p.y == 4, "value block value-type (Point) result");
}

// (15) Generic function builds the value-block task and returns it; the
// caller awaits it in the top-level test G. Exercises genGoBlock's
// `c.typeSubst` monomorphization Substitute branch (the plan's key symmetry
// with genReceiveTask so the buffer/store type matches the receive side).
// Non-heap T — the generic-mono shape that is safe across host + wasm.
t0683_mk_int[T](T v) Task[T] {
  return go {
    v
  };
}

t0683_generic_returned_task_int() `test {
  task[int] x = t0683_mk_int[int](42);
  assert((<-x) == 42, "generic-fn-built value-block task, int, awaited in test G");
}

// (16) Value-block capturing a heap LOCAL string as its trailing value,
// awaited in the same scope — the ownership-safe sibling of the captured
// case: confirms claimStringTemp + the B0354 outer-drop-flag clear
// correctly transfer the captured local's buffer with no leak / no
// double-free. (t0683_capture_outer above only captures an int.)
t0683_capture_local_string() `test {
  s := "he" + "llo";
  task[string] x = go {
    s
  };
  string r = <-x;
  assert(r == "hello", "value block returning captured heap local string");
}

// T0688: the bug T0683 missed — a value-block whose trailing expression is a
// bare reference to a captured BORROWED heap parameter, with the task
// `return`ed out of the defining function and awaited by the caller.
// Without the fix, the caller's stmt-temp for `"a" + "b"` was dropped
// immediately after the call returned, freeing the buffer before the
// goroutine resumed; the body then loaded a dangling pointer into
// G.result_ptr and the receiver double-freed it. The fix dups the borrowed
// value at spawn time (in the spawning function, while the param is still
// valid) and passes the dup as the capture, so the goroutine owns its own
// copy.
t0688_ngmake_string(string v) Task[string] {
  return go {
    v
  };
}

t0688_bare_string_param() `test {
  task[string] x = t0688_ngmake_string("a" + "b");
  string r = <-x;
  assert(r == "ab", "bare borrowed-string param returned via task");
}

// T0688: same pattern under a loop — catches any per-iteration leak that
// would slip past a single-call test.
t0688_loop_no_leak() `test {
  i := 0;
  while i < 50 {
    task[string] x = t0688_ngmake_string("x" + "y");
    string r = <-x;
    assert(r == "xy", "loop iteration");
    i = i + 1;
  }
}

// T0688: heap user type variant. Before the fix, this crashed with
// `fatal: segmentation fault at 0x0` (the borrowed instance pointer
// freed by the caller's stmt-temp before the goroutine resumed,
// then re-loaded into G.result_ptr). The fix dispatches via
// dupHeapValue, which deep-copies the instance + nested droppable
// sub-fields (the inner string).
type T0688Box {
  string name;
  int value;
}

t0688_ngmake_box(T0688Box b) Task[T0688Box] {
  return go {
    b
  };
}

t0688_bare_heap_user_type_param() `test {
  task[T0688Box] x = t0688_ngmake_box(T0688Box(name: "hello", value: 42));
  T0688Box r = <-x;
  assert(r.value == 42, "box value");
  assert(r.name == "hello", "box nested string");
}

// T0688: regression guard — Copy-type param (int) needs no dup; the fix
// must skip the dup so we don't bloat the IR with no-ops.
t0688_ngmake_int(int v) Task[int] {
  return go {
    v
  };
}

t0688_int_param_control() `test {
  task[int] x = t0688_ngmake_int(7);
  assert((<-x) == 7, "Copy-type param: no dup, no UAF");
}

// T0688: regression guard — derived trailing expression (`v + "!"`) builds
// a fresh allocation inside the coroutine, so no spawn-side dup is needed.
// (The fresh result is owned by the goroutine and transferred to the
// receiver via the existing T0683 path.)
t0688_ngmake_derived(string v) Task[string] {
  return go {
    v + "!"
  };
}

t0688_derived_trailing_param() `test {
  task[string] x = t0688_ngmake_derived("hi");
  string r = <-x;
  assert(r == "hi!", "derived trailing skips dup");
}

// T0688: regression guard — captured heap LOCAL with an outer drop binding
// must still take the T0683 ownership-transfer path (B0354), NOT the new
// spawn-side dup path. Adding a dup here would leak the original local.
t0688_ngmake_local() Task[string] {
  s := "ab" + "cd";
  return go {
    s
  };
}

t0688_local_string_no_extra_dup() `test {
  task[string] x = t0688_ngmake_local();
  string r = <-x;
  assert(r == "abcd", "captured local still works after T0688 fix");
}

// T0688: Vector[T] param variant. Trips two distinct codegen paths in the
// dup dispatch: (a) element-size computation for the dup'd data buffer
// (without this, dupVector would allocate header-only and the elements
// would be garbage) and (b) per-element deep clone when the element type is
// itself heap (string here) — otherwise the dup'd vector's element pointers
// would alias the original and the receiver's drop would double-free each
// element.
t0688_ngmake_vec_int(Vector[int] v) Task[Vector[int]] {
  return go {
    v
  };
}

t0688_bare_vec_int_param() `test {
  task[Vector[int]] x = t0688_ngmake_vec_int([1, 2, 3]);
  Vector[int] r = <-x;
  assert(r.len == 3, "vec[int] len");
  assert(r[0] == 1 && r[1] == 2 && r[2] == 3, "vec[int] elements");
}

t0688_ngmake_vec_string(Vector[string] v) Task[Vector[string]] {
  return go {
    v
  };
}

t0688_bare_vec_string_param() `test {
  task[Vector[string]] x = t0688_ngmake_vec_string(["a" + "b", "c" + "d"]);
  Vector[string] r = <-x;
  assert(r.len == 2, "vec[string] len");
  assert(r[0] == "ab" && r[1] == "cd", "vec[string] elements (deep clone)");
}

// T0732: the gap T0688 missed — Map[K,V] and Set[T] are heap user types
// excluded from the T0688 eligibility predicate by T0440's early returns in
// isDroppableHeapUserType / isHeapUserNoDropPalFree. So a bare-captured
// borrowed Map/Set param returned via a task crashed with
// `fatal: segmentation fault at 0x0`: the caller's stmt-temp was dropped
// immediately after the spawning function returned, the awaiter loaded the
// dangling instance pointer into G.result_ptr, and the receiver double-freed.
// The fix recognizes Map/Set via isMapOrSetType and deep-dups them at spawn
// time through dupHeapValue — Map deep-copies its _buckets vector of Slot
// enums (key+value) via dupEnumElementInPlace; Set recurses through its nested
// Map[T,bool]. dupHeapValue (memcpy + field-wise dup), not the Promise clone()
// method, so the T0440 shallow-clone gating does not apply here.
//
// The map arguments are built by factory functions (the idiomatic "factory
// returning a task[Map] computed from its argument" pattern from the bug
// report) rather than passing a map literal directly: a map literal used
// directly as an rvalue argument hits an ORTHOGONAL pre-existing leak (its
// stmt-temp gets no drop binding) tracked separately as T0735 — unrelated to
// the go-block dup this test covers.
t0688_mkmap_si() Map[string, int] {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  return m;
}

t0688_ngmake_map(Map[string, int] m) Task[Map[string, int]] {
  return go {
    m
  };
}

t0688_bare_map_param() `test {
  task[Map[string, int]] x = t0688_ngmake_map(t0688_mkmap_si());
  Map[string, int] r = <-x;
  if v := r["a"] {
    assert(v == 1, "map a");
  }
  if v := r["b"] {
    assert(v == 2, "map b");
  }
}

// T0732: Map with heap VALUE type (string) — exercises dupEnumElementInPlace
// deep-cloning both the heap key and the heap value of each Slot. Without the
// deep clone the dup'd map's value-string pointers would alias the original
// and the receiver's drop would double-free them.
//
// The factory builds the map via the []= setter (not a map literal): a map
// literal with a heap value, e.g. `{"k": "va" + "lue"}`, double-frees the
// value — an orthogonal pre-existing bug tracked as T0736, unrelated to the
// go-block dup this test covers.
t0688_mkmap_ss() Map[string, string] {
  Map[string, string] m = Map[string, string]();
  string v = "va" + "lue";
  m["k"] = v;
  return m;
}

t0688_ngmake_map_str(Map[string, string] m) Task[Map[string, string]] {
  return go {
    m
  };
}

t0688_bare_map_heap_val_param() `test {
  task[Map[string, string]] x = t0688_ngmake_map_str(t0688_mkmap_ss());
  Map[string, string] r = <-x;
  if v := r["k"] {
    assert(v == "value", "map[string,string] heap value deep clone");
  }
}

// T0732: Set[int] — the factory pattern from the bug report. Set is a wrapper
// around Map[T,bool]; dupHeapValue recurses through the nested _map field.
t0688_mkset_int() Set[int] {
  Set[int] s = Set[int]();
  s.add(1);
  s.add(2);
  s.add(3);
  return s;
}

t0688_ngmake_set(Set[int] s) Task[Set[int]] {
  return go {
    s
  };
}

t0688_bare_set_param() `test {
  task[Set[int]] x = t0688_ngmake_set(t0688_mkset_int());
  Set[int] r = <-x;
  assert(r.contains(1) && r.contains(2) && r.contains(3), "set[int] contains");
}

// T0732: Set with heap element type (string) — the nested Map[string,bool]'s
// Slot keys are heap strings, deep-cloned via dupEnumElementInPlace through
// the recursive dupHeapValue path.
t0688_mkset_string() Set[string] {
  Set[string] s = Set[string]();
  s.add("a" + "b");
  s.add("c" + "d");
  return s;
}

t0688_ngmake_set_str(Set[string] s) Task[Set[string]] {
  return go {
    s
  };
}

t0688_bare_set_string_param() `test {
  task[Set[string]] x = t0688_ngmake_set_str(t0688_mkset_string());
  Set[string] r = <-x;
  assert(r.contains("ab") && r.contains("cd"), "set[string] contains (deep clone)");
}

// T0732: 50-iteration leak guards — a per-iteration buffer/instance leak in
// the Map/Set dup path would trip the zero-tolerance alloc-delta check.
t0688_loop_map_no_leak() `test {
  i := 0;
  while i < 50 {
    task[Map[string, int]] x = t0688_ngmake_map(t0688_mkmap_si());
    Map[string, int] r = <-x;
    if v := r["a"] {
      assert(v == 1, "loop map iteration");
    }
    i = i + 1;
  }
}

t0688_loop_set_no_leak() `test {
  i := 0;
  while i < 50 {
    task[Set[int]] x = t0688_ngmake_set(t0688_mkset_int());
    Set[int] r = <-x;
    assert(r.contains(2), "loop set iteration");
    i = i + 1;
  }
}

// T0732 (coverage): Map with a heap-CONTAINER value (Vector[int]) — exercises a
// distinct branch of the Slot deep-clone. The committed Map tests use a scalar
// value (int) or a heap-scalar value (string), both of which hit the dupString
// path in emitVariantFieldDup; a Vector value instead hits the dupVector +
// emitVectorElementCloneLoop branch (compiler.go). Without the deep clone the
// dup'd map's value-vector buffers would alias the original and the receiver's
// drop would double-free them.
//
// Built via the []= setter (not a map literal with a Vector value, which would
// hit the T0735 map-literal stmt-temp leak), mirroring t0688_mkmap_ss.
t0688_mkmap_sv() Map[string, Vector[int]] {
  Map[string, Vector[int]] m = Map[string, Vector[int]]();
  Vector[int] a = [1, 2, 3];
  m["a"] = a;
  Vector[int] b = [4, 5];
  m["b"] = b;
  return m;
}

t0688_ngmake_map_vec(Map[string, Vector[int]] m) Task[Map[string, Vector[int]]] {
  return go {
    m
  };
}

t0688_bare_map_vec_val_param() `test {
  task[Map[string, Vector[int]]] x = t0688_ngmake_map_vec(t0688_mkmap_sv());
  Map[string, Vector[int]] r = <-x;
  if v := r["a"] {
    assert(v.len == 3 && v[0] == 1 && v[2] == 3, "map[string,vec] a deep clone");
  }
  if v := r["b"] {
    assert(v.len == 2 && v[0] == 4 && v[1] == 5, "map[string,vec] b deep clone");
  }
}

// T0732 (coverage): dropped-not-awaited cleanup invariant for the spawn-side
// dup. The factory dups the borrowed Map/Set into the goroutine's result; if
// the task is dropped WITHOUT `<-`, Task[T].drop must free that dup exactly
// once — no leak, no double-free. The existing dropped tests
// (t0683_value_block_dropped_string) use a DIRECT trailing value with no
// spawn-side dup, so they don't exercise the dupBorrowedCaptureForResult path.
t0688_dropped_map_no_await() `test {
  task[Map[string, int]] t = t0688_ngmake_map(t0688_mkmap_si());
  assert(true, "dropped map task (spawn-side dup), not awaited: no leak");
}

t0688_dropped_set_no_await() `test {
  task[Set[int]] t = t0688_ngmake_set(t0688_mkset_int());
  assert(true, "dropped set task (spawn-side dup), not awaited: no leak");
}

// Loop variant — a per-iteration leak in the dropped-dup cleanup path would
// trip the zero-tolerance alloc-delta check.
t0688_dropped_map_set_loop_no_leak() `test {
  i := 0;
  while i < 30 {
    task[Map[string, int]] m = t0688_ngmake_map(t0688_mkmap_si());
    task[Set[int]] s = t0688_ngmake_set(t0688_mkset_int());
    i = i + 1;
  }
  assert(i == 30, "dropped map/set tasks in loop: no leak");
}

// T0686: the T0683 regression a /coverage audit found — a value-returning
// `go { Box(...) }` whose result is a HEAP user-struct (Instance layout +
// generated drop), awaited via `<-x`, emitted malformed IR (`load i1, i1* %0`
// where %0 is the coro.id token) and failed `opt` verification on every WASM
// function and in host `main()`. Root cause: genGoBlock's value path isolated
// stmtTemps but NOT heapTemps (unlike genBlock, which isolates heapTemps via
// T0088), so the trailing constructor's heap temp — whose alloca/dropFlag
// belong to the coroutine fn — leaked into the OUTER (awaiting) presplit-
// coroutine, where its cleanupHeapTemps loaded from the unnumbered %0 token.
// The fix saves/resets/restores heapTemps around the coroutine body and claims
// the result so the body's own cleanup doesn't free the transferred struct.
//
// Batch tests with NO `exclude: wasm` — every WASM function is a presplit-
// coroutine, so the WASM run is the host-equivalent regression guard (a host
// batch `` `test `` wrapper is NOT a presplitcoroutine, so the bug was benign
// there; the host `main()` snapshot in t0686_*_main_test.pr covers that path).
// Zero-leak on host AND `--target wasm32-wasi`.
type T0686Box {
  int v;
  string s;
}

// (a) The exact reported repro: heap struct with a string field, awaited.
t0686_struct_string_field_result() `test {
  task[T0686Box] x = go {
    T0686Box(v: 1, s: "a" + "b")
  };
  b := <-x;
  assert(b.v == 1, "struct int field");
  assert(b.s == "ab", "struct heap string field");
}

// (b) All-int heap struct — no heap field, but still an Instance layout with a
// generated drop flag (the minimal trigger per the bug's matrix).
type T0686P {
  int a;
  int b;
}

t0686_all_int_struct_result() `test {
  task[T0686P] x = go {
    T0686P(a: 40, b: 2)
  };
  p := <-x;
  assert(p.a == 40 && p.b == 2, "all-int struct result");
}

// (c) Multi-statement value block whose trailing expression builds a heap
// struct from heap locals — preceding statements run for effect, the trailing
// constructor consumes the locals (exercises coroutine-body heap cleanup).
t0686_multi_stmt_struct_result() `test {
  task[T0686Box] x = go {
    n := 21;
    label := "v" + "al";
    T0686Box(v: n * 2, s: label)
  };
  b := <-x;
  assert(b.v == 42, "multi-stmt struct int field");
  assert(b.s == "val", "multi-stmt struct string field");
}

// (d) Nested struct-from-struct — the trailing expression builds a heap struct
// whose field is itself a heap struct (nested instance + nested string). The
// result transfer + ownership must handle the nested heap case with no leak /
// no double-free.
type T0686Nested {
  T0686Box inner;
  int tag;
}

t0686_nested_struct_result() `test {
  task[T0686Nested] x = go {
    T0686Nested(inner: T0686Box(v: 7, s: "hi" + "!"), tag: 9)
  };
  n := <-x;
  assert(n.tag == 9, "nested outer field");
  assert(n.inner.v == 7, "nested inner int field");
  assert(n.inner.s == "hi!", "nested inner string field");
}

// (e) Loop variant — a per-iteration buffer/instance/string leak in the new
// heapTemps isolation path would trip the zero-tolerance alloc-delta check.
t0686_struct_result_loop_no_leak() `test {
  i := 0;
  total := 0;
  while i < 30 {
    task[T0686Box] x = go {
      T0686Box(v: i, s: "x" + "y")
    };
    b := <-x;
    total = total + b.v;
    assert(b.s == "xy", "loop struct string field");
    i = i + 1;
  }
  assert(total == 435, "sum 0..29 == 435; no leak across iterations");
}

// (f) Dropped-not-awaited heap-struct result — the same genGoBlock defect fires
// regardless of await (the outer statement cleanup runs either way; on WASM the
// outer fn is a presplitcoroutine so the bad token-load broke compilation).
// Additionally exercises Task[T].drop's free_after_done path freeing the result
// buffer AND dropping the contained struct (its nested string) exactly once.
t0686_struct_result_dropped_no_await() `test {
  task[T0686Box] t = go {
    T0686Box(v: 5, s: "drop" + "me")
  };
  assert(true, "heap-struct value-block task dropped, not awaited: no leak");
}

// T0686 (follow-up /coverage audit): the (a)-(f) tests above only exercise the
// USER-STRUCT heap-temp drop path (`cleanupHeapTemps` with `elemType == nil` →
// a single `dropFunc` call). But `genGoBlock`'s heapTemps isolation bug fired
// for ANY trailing expression that registers a heap temp — and the heap-temp
// machinery has other drop paths the struct tests never reach. Each case below
// was confirmed to FAIL `opt` (the `%0` coro.id token-load) with the fix
// reverted, and the trailing expression must be a FRESH heap allocation (a bare
// variable reference like `v := [..]; v` claims a drop binding instead of
// registering a heap temp, so it never triggered the bug). NO `exclude: wasm` —
// the WASM run is the presplitcoroutine regression guard. Zero-leak both targets.
type T0686GBox[T] {
  T v;
  string tag;
}

// (g) Vector LITERAL with non-const int elements as the trailing expression.
// Routes through the T0369 vector heap-temp path (`elemType != nil`), which is a
// DIFFERENT branch of `cleanupHeapTemps` than the struct `dropFunc` path: it
// runs `emitVectorElementDropLoop` before freeing the buffer. int elements have
// no per-element drop, so this isolates the element-walk plumbing itself.
t0686_vector_int_literal_result() `test {
  n := 3;
  task[int[]] x = go {
    [n, n + 1, n + 2]
  };
  r := <-x;
  assert(r.len == 3, "vec<int> literal len");
  assert(r[0] == 3 && r[1] == 4 && r[2] == 5, "vec<int> literal values");
}

// (h) Vector LITERAL with non-const STRING elements — the FULL T0369 path: the
// element-walk drops each heap string before freeing the buffer. If the vector
// heap temp leaked into the outer fn (the bug), the per-element string drops
// would run there too; the receiver also owns + drops the result, so any
// mismatch shows up as a leak or double-free under the zero-tolerance check.
t0686_vector_string_literal_result() `test {
  a := "a";
  b := "b";
  task[string[]] x = go {
    [a + "1", b + "2"]
  };
  r := <-x;
  assert(r.len == 2, "vec<string> literal len");
  assert(r[0] == "a1" && r[1] == "b2", "vec<string> literal values");
}

// (i) GENERIC struct constructor as the trailing expression — the heap temp is a
// monomorphized `T0686GBox__int` (Instance layout + generated drop synthesized
// per-instantiation). Confirms the isolation works on the mono codegen path, not
// just for non-generic user structs.
t0686_generic_struct_result() `test {
  task[T0686GBox[int]] x = go {
    T0686GBox[int](v: 42, tag: "t" + "g")
  };
  b := <-x;
  assert(b.v == 42, "generic struct int field");
  assert(b.tag == "tg", "generic struct string field");
}

// (j) Map produced by a FRESH `.clone()` call as the trailing expression — a
// container heap temp whose drop frees both the buckets vector and the Map
// instance. Exercises the heap-temp isolation for a stdlib generic container
// result (distinct from the user-struct and vector cases above).
t0686_map_clone_result() `test {
  map[string, int] base = {
    "k": 7
  };
  task[map[string, int]] x = go {
    base.clone()
  };
  r := <-x;
  assert(r.len == 1, "map clone len");
  if v := r["k"] {
    assert(v == 7, "map clone value");
  }
}

// (k) Enum variant carrying a HEAP (string) payload as the trailing expression.
// Complements (g)-(j): this routes through the enumCtorTemps path (B0267, reset
// unconditionally in genGoBlock — independent of the T0686 heapTemps fix, since
// an enum instance is RTTI-only and registers no heap temp) PLUS the string
// payload's stmtTemp (T0683). The (13) `t0683_enum_result` test above only used
// a PAYLOAD-LESS variant (`Color.Green`); a droppable payload was previously
// only verified ad-hoc with no persistent guard. The payload string must be
// transferred into the result and dropped exactly once (no leak / no double-free).
enum T0686EnumPayload {
  Wrapped(string s),
  Empty,
}

t0686_enum_heap_payload_result() `test {
  task[T0686EnumPayload] x = go {
    T0686EnumPayload.Wrapped(s: "hi" + "!")
  };
  e := <-x;
  ok := match e {
    T0686EnumPayload.Wrapped(s) => s == "hi!",
    T0686EnumPayload.Empty => false,
  };
  assert(ok, "enum heap-payload value-block result");
}

// (l) Loop variant of (k) — a per-iteration leak of the payload string, the
// result buffer, or the enum data would trip the zero-tolerance alloc-delta
// check. Also covers the dropped-then-awaited lifecycle across iterations.
t0686_enum_heap_payload_loop_no_leak() `test {
  i := 0;
  matched := 0;
  while i < 30 {
    task[T0686EnumPayload] x = go {
      T0686EnumPayload.Wrapped(s: "v" + "al")
    };
    e := <-x;
    match e {
      T0686EnumPayload.Wrapped(s) => {
        if s == "val" {
          matched = matched + 1;
        }
      },
      T0686EnumPayload.Empty => {
      },
    }
    i = i + 1;
  }
  assert(matched == 30, "enum heap-payload loop: all matched, no leak");
}

// ===========================================================================
// T0739: capturing-closure trailing value — the envTemps sibling of the T0686
// heapTemps bug. genGoBlock's value path (genBlockValue) saved/reset/restored
// stmtTemps (T0683) and heapTemps (T0686) but NOT envTemps. A capturing closure
// as the trailing value (`go { || -> base + 2 }`) heap-allocates an env struct
// and registers an env temp whose alloca/dropFlag belong to the *coroutine*;
// without isolation it leaked into the outer (awaiting/dropping) fn's env-temp
// cleanup and serialized as `%0` (the coro.id token) → `opt` rejected it on
// WASM (every WASM fn is a presplitcoroutine). The fix isolates envTemps in
// genGoBlock (edits 1-4) AND teaches emitVariantFieldDrop to drop a closure
// (edit 5) so the dropped-not-awaited form frees the env via Task[T].drop.
//
// These batch tests have NO `exclude: wasm`: the WASM batch run is the
// empirically-confirmed compile-failure regression guard (it fails `opt` on
// regression), and zero-leak enforcement on host AND `--target wasm32-wasi`
// guards edit 5. These tests await + drop the closure without calling it; the
// value correctness of a called closure is covered by the T0740 tests below
// (T0740 fixed the wrong-captured-value defect — the trailing closure can now
// be called and value-asserted).

// (m) Capturing closure value-block AWAITED, then closure dropped at scope exit
// (env freed via the awaited variable's bindingFreeEnv). The exact `%0`
// compile-failure shape on WASM before edits 1-4.
t0739_closure_capture_awaited() `test {
  base := 40;
  task[() -> int] x = go {
    || -> base + 2
  };
  f := <-x;
  assert(true, "capturing-closure value-block awaited + dropped at scope exit");
}

// (n) Capturing closure value-block DROPPED-not-awaited (the bug report's exact
// repro). Task[() -> int].drop must free the closure's heap env via edit 5's
// new *types.Signature case — without it, host + WASM leak 1 allocation.
t0739_closure_capture_dropped() `test {
  base := 40;
  task[() -> int] x = go {
    || -> base + 2
  };
  assert(true, "capturing-closure value-block dropped-not-awaited");
}

// (o) No-capture closure value-block (null env). Guards the null-env branch of
// both claimEnvTemp (fat-pointer extract) and edit 5's null-check: a no-capture
// closure has a null env ptr and must NOT be freed. Dropped + awaited.
t0739_closure_nocapture() `test {
  task[() -> int] dropped = go {
    || -> 42
  };
  task[() -> int] x = go {
    || -> 7
  };
  f := <-x;
  assert(true, "no-capture closure value-block, dropped + awaited (null env)");
}

// (p) Heap-capture closure: `move || -> s.len` move-captures a string into the
// env. Edit 5 → emitEnvDropOrFree loads the env's field-0 drop fn (non-null
// because the env holds a droppable string) and deep-drops the captured string
// before freeing the env. A shallow pal_free would leak the string. Dropped +
// awaited.
t0739_closure_heap_capture() `test {
  s1 := "hello" + " world";
  task[() -> int] dropped = go {
    move || -> s1.len
  };
  s2 := "second" + " string";
  task[() -> int] x = go {
    move || -> s2.len
  };
  f := <-x;
  assert(true, "heap-capture (string) closure deep-drops env, dropped + awaited");
}

// (q) Multi-capture closure dropped — several copy captures in one env struct.
t0739_closure_multi_capture() `test {
  a := 10;
  b := 20;
  c := 12;
  task[() -> int] x = go {
    || -> a + b + c
  };
  assert(true, "multi-capture closure value-block dropped");
}

// (r) 30-iteration loop leak guard: dropped + awaited capturing closures. A
// per-iteration leak of the env, the result buffer, or the captured value would
// trip the zero-tolerance alloc-delta check.
t0739_closure_loop_no_leak() `test {
  i := 0;
  while i < 30 {
    base := i;
    task[() -> int] dropped = go {
      || -> base + 1
    };
    task[() -> int] x = go {
      || -> base + 2
    };
    f := <-x;
    i = i + 1;
  }
  assert(i == 30, "capturing-closure loop: 30 iterations, no leak");
}

// (s) Edit 5 generalizes beyond Task[T].drop: a closure stored in ANY container
// that routes drops through emitVariantFieldDrop was a latent leak before this
// fix. A Vector[() -> int] of capturing closures, dropped, reaches the new
// *types.Signature case via emitVectorElementDropLoop (a different route into
// emitVariantFieldDrop than Task[T].drop) — each element's env must be freed.
t0739_vector_of_closures_dropped() `test {
  base := 5;
  v := [|| -> base + 1, || -> base + 2, || -> base + 3];
  assert(v.len == 3, "vector of capturing closures dropped, no leak");
}

// (t) Vector of move-string-capturing closures dropped — each element's env
// holds a droppable string, so emitEnvDropOrFree must deep-drop the captured
// string per element (a shallow pal_free would leak every captured string).
t0739_vector_of_heap_closures_dropped() `test {
  s1 := "a" + "x";
  s2 := "b" + "y";
  v := [move || -> s1.len, move || -> s2.len];
  assert(v.len == 2, "vector of heap-capturing closures dropped, no leak");
}

// ===========================================================================
// T0739 (coverage, found in /coverage): edit 5's *types.Signature case in
// emitVariantFieldDrop generalizes beyond Task[T].drop. emitVariantFieldDrop's
// Tuple and Array branches recurse *unconditionally* into each element, so a
// closure nested in a tuple/array that is dropped via emitVariantFieldDrop
// (e.g. a Vector element) reaches the Signature case and frees its env. These
// tests lock that in. NO `exclude: wasm`; zero-leak on host + wasm.
//
// NOTE: closures nested in an *enum* payload or an *optional*, and plain struct
// closure *fields* with heap captures, are NOT correctly dropped — they route
// through paths that lack a Signature case (variantFieldNeedsDrop /
// emitOptionalValueDrop) or shallow-free the env (emitFuncFieldEnvFree). Those
// are pre-existing leaks/dangling-pointer bugs tracked in T0741 (edit 5's
// comment overclaims enum/optional). Tests for those land with the T0741 fix.

// (u) Tuple element closure: a Vector[(int, () -> int)] dropped routes each
// element through emitVariantFieldDrop's tuple branch (unconditional recursion)
// -> Signature case. Heap-capture (move string) so a missed drop would leak the
// captured string, not just the env — a stronger guard.
t0739_vector_of_tuple_closures_dropped() `test {
  s := "tup" + "le";
  v := [(1, move || -> s.len)];
  assert(v.len == 1, "vector of (int, closure) tuples dropped, no leak");
}

// (v) Local fixed-array of capturing closures, dropped at scope exit. A leak
// guard for the local-array path (closures freed via stmt-end env cleanup). The
// container-nested fixed-array path (array as a struct field / Vector element)
// is the latent case tracked in T0741.
t0739_local_array_of_closures_dropped() `test {
  base := 5;
  (() -> int)[2] arr = [|| -> base + 1, || -> base + 2];
  assert(true, "local fixed array of capturing closures dropped, no leak");
}

// (w) Local fixed-array of heap-capturing (move string) closures — guards that
// the per-element env deep-drops its captured string (a shallow free would leak
// each string).
t0739_local_array_of_heap_closures_dropped() `test {
  s1 := "arr" + " one";
  s2 := "arr" + " two";
  (() -> int)[2] arr = [move || -> s1.len, move || -> s2.len];
  assert(true, "local fixed array of heap-capturing closures dropped, no leak");
}

// ===========================================================================
// T0740: a value-returning `go { ... }` block whose trailing value is a
// *capturing closure* read any outer variable referenced ONLY inside that
// closure as zero. Root cause: collectBlockIdents (the walk that gathers which
// outer locals a go-block must thread into its coroutine arg pack) skipped
// lambda bodies — true for a lambda in an ordinary function (the enclosing fn
// already holds the var) but false inside `go { }`, because the coroutine is a
// *separate* function. The fix consults sema's per-lambda capture set
// (transitively including nested-lambda captures) and adds those outer-local
// names to the coroutine's captures. These tests CALL the received closure and
// value-assert the result (the T0739 tests above only await + drop it).
//
// NO `exclude: wasm`: zero-leak enforcement applies on host AND wasm32-wasi,
// and the go-block coroutine path is exercised on both.

// (a) The exact bug repro, value-asserted: `base` is referenced only inside the
// nested closure, so before the fix it was captured as 0 and f() returned 2.
t0740_capture_value() `test {
  base := 40;
  task[() -> int] x = go {
    || -> base + 2
  };
  f := <-x;
  assert(f() == 42, "outer var used only inside closure captures real value");
}

// (b) Multiple outer vars referenced only inside the closure.
t0740_multiple_captures() `test {
  a := 5;
  b := 10;
  task[() -> int] x = go {
    || -> a * b
  };
  f := <-x;
  assert(f() == 50, "multiple outer vars threaded into coroutine");
}

// (c) Nested lambda-within-lambda: the outer (trailing) lambda has a block body
// containing a named inner lambda that captures `base`. Exercises sema's
// transitive capture propagation (checkLambdaExpr) flowing through the outer
// lambda's capture set into the coroutine. Named-inner form (not an IIFE — see
// T0751).
t0740_nested_lambda_capture() `test {
  base := 40;
  task[() -> int] x = go {
    || -> int {
      g := || -> base + 2;
      return g();
    }
  };
  f := <-x;
  assert(f() == 42, "nested lambda transitive capture into coroutine");
}

// (d) Move-captured heap string referenced only inside the closure. Exercises
// the droppable-capture transfer into the coroutine plus zero-leak: the env
// holds an owned string and must be deep-dropped when the closure is dropped.
t0740_move_string_capture() `test {
  s := "hello" + " world";
  task[() -> int] x = go {
    move || -> s.len
  };
  f := <-x;
  assert(f() == 11, "move-captured heap string captured into coroutine, no leak");
}

// (e) No-capture closure value-block (null env) — guards that the fix does not
// disturb the null-env path: the closure captures nothing and f() returns 7.
t0740_no_capture() `test {
  task[() -> int] x = go {
    || -> 7
  };
  f := <-x;
  assert(f() == 7, "no-capture closure value-block unaffected");
}

// (f) Lambda captures a MIX of an outer-function local (`base`) and a
// block-local declared inside the `go { }` (`inner`). The outer local must be
// threaded into the coroutine arg pack; the block-local must NOT (it is already
// a coroutine local, in scope inside the coroutine). This locks the
// `outerLocals` filter on the new lambda path: if the filter were absent,
// `inner` would be both a coroutine parameter and a block-local declaration —
// the (a)-(e) tests never have the lambda capture a block-local, so only this
// test exercises that boundary. Verified to fail (f() == 100) without the fix.
t0740_mixed_outer_and_block_local() `test {
  base := 40;
  task[() -> int] x = go {
    inner := 100;
    || -> base + inner
  };
  f := <-x;
  assert(f() == 140, "outer threaded into coroutine, block-local resolved in-coroutine");
}

// (g) The closure is INVOKED inside the coroutine and the block returns a plain
// `int` (task[int], not task[() -> int]) — a distinct result shape from (a)-(f),
// which all return the closure itself. `base` is referenced only inside the
// lambda `g`, so it must still be threaded into the coroutine for the in-coroutine
// call to see the real value. Verified to fail (returns 2) without the fix.
t0740_closure_invoked_in_coroutine() `test {
  base := 40;
  task[int] x = go {
    g := || -> base + 2;
    g()
  };
  r := <-x;
  assert(r == 42, "closure invoked inside coroutine sees real captured value");
}
