// Basic select test: one channel is ready, the other is not.
// The select should pick the ready case.
main() `test(expected: "42") {
  ch1 := channel[int](capacity: 1);
  ch2 := channel[int](capacity: 1);

  // Only send on ch1
  ch1.send(42);

  select {
    v := <-ch1:
      if val := v {
        print_line(val);
      }
    v := <-ch2:
      print_line(0);
  }
}
