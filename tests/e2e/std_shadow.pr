use std;

// User-defined min shadows std min
min(int a, int b) int {
  return 999;
}

// User-defined print_line shadows std print_line
print_line(Format f) {
  std.print_line(0);
}

main() `test(expected: """999
3
0
via std
2.72
true""") {
  // Use std.print_line to bypass shadow, verify user min vs std min
  std.print_line(min(3, 7));
  std.print_line(std.min(3, 7));

  // User print_line (prints 0), then std.print_line (prints the string)
  print_line("ignored");
  std.print_line("via std");

  // Verify std.print_line works with f64 and bool via std namespace
  std.print_line(2.72);
  std.print_line(true);
}
