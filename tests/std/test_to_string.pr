// Tests for to_string() on primitive types and string.from_bytes

test_int_to_string() `test {
    assert(42.to_string() == "42", "42");
    assert((-17).to_string() == "-17", "-17");
    assert(0.to_string() == "0", "0");
}

test_bool_to_string() `test {
    assert(true.to_string() == "true", "true");
    assert(false.to_string() == "false", "false");
}

test_string_to_string() `test {
    assert("hello".to_string() == "hello", "string identity");
}

test_from_bytes() `test {
    u8[] bytes = "hello".bytes();
    string s = string.from_bytes(bytes);
    assert(s == "hello", "from_bytes hello");
}

test_from_bytes_empty() `test {
    u8[] bytes = "".bytes();
    string s = string.from_bytes(bytes);
    assert(s == "", "from_bytes empty");
}

test_from_bytes_roundtrip() `test {
    string original = "Hello, World! 123";
    u8[] bytes = original.bytes();
    string result = string.from_bytes(bytes);
    assert(result == original, "roundtrip");
}

test_char_to_string() `test {
    assert('A'.to_string() == "A", "char A");
    assert('0'.to_string() == "0", "char 0");
}

test_bytes_content() `test {
    u8[] bytes = "AB".bytes();
    assert(bytes.len == 2, "len 2");
    assert((bytes[0] as! int) == 65, "A = 65");
    assert((bytes[1] as! int) == 66, "B = 66");
}

test_byte_at() `test {
    string s = "hello";
    u8 b = s.byte_at(0);
    assert((b as! int) == 104, "h = 104");
    u8 b2 = s.byte_at(4);
    assert((b2 as! int) == 111, "o = 111");
}
