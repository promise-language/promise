int_key_map_encode_test() `test {
  IntKeyMap m = IntKeyMap(data: map[int, string]());
  m.data[42] = "answer";
  json.JsonEncoder enc = json.JsonEncoder();
  m.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"answer\""), "int key encode: has value");
}

int_key_map_round_trip_test() `test {
  IntKeyMap m1 = IntKeyMap(data: map[int, string]());
  m1.data[100] = "hundred";
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  IntKeyMap m2 = IntKeyMap.decode(dec)!;
}

// ── Mixed array + map in same type ──────────────────────────────────────────

mixed_array_and_map_test() `test(allow_leaks: true) {
  Dashboard d1 = Dashboard(title: "main", labels: ["a", "b"], metrics: map[string, int]());
  d1.metrics["total"] = 42;
  json.JsonEncoder enc = json.JsonEncoder();
  d1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Dashboard d2 = Dashboard.decode(dec)!;
  assert(d2.title == "main", "mixed: title");
  assert(d2.labels.len == 2, "mixed: labels count");
  assert(d2.labels[0] == "a", "mixed: label 0");
}

// ── Generic serializable types ──────────────────────────────────────────────

generic_wrapper_int_test() `test {
  GoodWrapper[int] w = GoodWrapper[int](value: 42, label: "answer");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"value\":42"), "generic int: value");
  assert(s.contains("\"label\":\"answer\""), "generic int: label");
}

generic_wrapper_string_test() `test {
  GoodWrapper[string] w = GoodWrapper[string](value: "hello", label: "greet");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"value\":\"hello\""), "generic string: value");
}

generic_wrapper_round_trip_test() `test {
  GoodWrapper[int] w1 = GoodWrapper[int](value: 99, label: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[int] w2 = GoodWrapper[int].decode(dec)!;
  assert(w2.value == 99, "generic rt: value");
  assert(w2.label == "test", "generic rt: label");
}

skip_wrapper_test() `test {
  SkipWrapper[int] w = SkipWrapper[int](value: 42, label: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"label\":\"test\""), "skip wrapper: label");
  assert(!s.contains("\"value\""), "skip wrapper: value skipped");
}

generic_wrapper_user_type_test() `test {
  GoodWrapper[Point] w1 = GoodWrapper[Point](value: Point(x: 1, y: 2), label: "pt");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[Point] w2 = GoodWrapper[Point].decode(dec)!;
  assert(w2.value.x == 1, "generic user type: x");
  assert(w2.value.y == 2, "generic user type: y");
  assert(w2.label == "pt", "generic user type: label");
}

generic_wrapper_bool_test() `test {
  GoodWrapper[bool] w1 = GoodWrapper[bool](value: true, label: "flag");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[bool] w2 = GoodWrapper[bool].decode(dec)!;
  assert(w2.value == true, "generic bool: value");
}

generic_wrapper_f64_test() `test {
  GoodWrapper[f64] w1 = GoodWrapper[f64](value: 3.14, label: "pi");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[f64] w2 = GoodWrapper[f64].decode(dec)!;
  assert(w2.value == 3.14, "generic f64: value");
}

// ── Field annotations ───────────────────────────────────────────────────────

key_annotation_test() `test {
  User u = User(name: "Alice", age: 30, _internal: "secret");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"user_name\":"), "key: has user_name");
  assert(!s.contains("\"name\":"), "key: no raw name");
}

skip_annotation_test() `test {
  User u = User(name: "Bob", age: 25, _internal: "hidden");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(!s.contains("internal"), "skip: no internal field");
  assert(!s.contains("hidden"), "skip: no hidden value");
}

optional_omit_none_test() `test {
  User u = User(name: "Carol", age: 28, _internal: "x");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(!s.contains("email"), "optional none: email omitted");
}

optional_present_test() `test {
  User u = User(name: "Dave", age: 35, email: "d@test.com", _internal: "x");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"email\":\"d@test.com\""), "optional present: email included");
}

include_none_test() `test {
  WithIncludeNone w = WithIncludeNone(name: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"tag\":null"), "include_none: tag is null");
}

include_none_present_test() `test {
  WithIncludeNone w = WithIncludeNone(name: "test", tag: "hello");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"tag\":\"hello\""), "include_none present: tag has value");
}

// ── Multiple optional fields ────────────────────────────────────────────────

multiple_optionals_none_test() `test {
  WithOptionals w = WithOptionals(name: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(!s.contains("bio"), "multi opt: bio omitted");
  assert(!s.contains("level"), "multi opt: level omitted");
}

multiple_optionals_some_test() `test {
  WithOptionals w = WithOptionals(name: "test", bio: "hello", level: 5);
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"bio\":\"hello\""), "multi opt: bio present");
  assert(s.contains("\"level\":5"), "multi opt: level present");
}

multiple_optionals_round_trip_test() `test {
  WithOptionals w1 = WithOptionals(name: "test", level: 3);
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  WithOptionals w2 = WithOptionals.decode(dec)!;
  assert(w2.name == "test", "multi opt rt: name");
  assert(w2.bio is absent, "multi opt rt: bio absent");
  assert(w2.level is present, "multi opt rt: level present");
}

// ── Decode with optional fields ─────────────────────────────────────────────

decode_optional_present_test() `test {
  User u1 = User(name: "Eve", age: 40, email: "eve@test.com", _internal: "s");
  json.JsonEncoder enc = json.JsonEncoder();
  u1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  User u2 = User.decode(dec)!;
  assert(u2.name == "Eve", "decode opt present: name");
  assert(u2.age == 40, "decode opt present: age");
  assert(u2.email is present, "decode opt present: email exists");
}

decode_optional_missing_test() `test {
  User u1 = User(name: "Frank", age: 50, _internal: "s");
  json.JsonEncoder enc = json.JsonEncoder();
  u1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  User u2 = User.decode(dec)!;
  assert(u2.name == "Frank", "decode opt missing: name");
  assert(u2.age == 50, "decode opt missing: age");
  assert(u2.email is absent, "decode opt missing: email absent");
}

// ── String escaping in field values ─────────────────────────────────────────

string_escape_round_trip_test() `test {
  MixedFields m1 = MixedFields(label: "has \"quotes\" and\nnewlines", count: 1, score: 0.0, active: true);
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  MixedFields m2 = MixedFields.decode(dec)!;
  assert(m2.label == "has \"quotes\" and\nnewlines", "escape rt: label preserved");
}

// ── Edge cases ──────────────────────────────────────────────────────────────

zero_values_test() `test {
  MixedFields m1 = MixedFields(label: "", count: 0, score: 0.0, active: false);
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  MixedFields m2 = MixedFields.decode(dec)!;
  assert(m2.label == "", "zero: empty string");
  assert(m2.count == 0, "zero: count");
  assert(m2.active == false, "zero: bool false");
}

negative_values_test() `test {
  Point p1 = Point(x: -42, y: -1);
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Point p2 = Point.decode(dec)!;
  assert(p2.x == -42, "negative: x");
  assert(p2.y == -1, "negative: y");
}

large_values_test() `test {
  Point p1 = Point(x: 1000000, y: -999999);
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Point p2 = Point.decode(dec)!;
  assert(p2.x == 1000000, "large: x");
  assert(p2.y == -999999, "large: y");
}

// ── Custom encode override ──────────────────────────────────────────────────

custom_encode_test() `test {
  CustomEncode c = CustomEncode(value: 42);
  json.JsonEncoder enc = json.JsonEncoder();
  c.encode(enc)!;
  string s = enc.to_string();
  assert(s == "\"custom:42\"", "custom encode: " + s);
}

// ── Decode with key renaming ────────────────────────────────────────────────

decode_with_key_test() `test {
  User u1 = User(name: "Grace", age: 28, _internal: "x");
  json.JsonEncoder enc = json.JsonEncoder();
  u1.encode(enc)!;
  // The encoded JSON uses "user_name" not "name" — decode must match.
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  User u2 = User.decode(dec)!;
  assert(u2.name == "Grace", "decode key: name via user_name");
  assert(u2.age == 28, "decode key: age");
}

// ── Module-qualified generic convenience functions (T0005) ──────────────────

encode_string_point_test() `test {
  string s = json.encode_string[Point](Point(x: 1, y: 2))!;
  assert(s.contains("\"x\":1"), "encode_string point x");
  assert(s.contains("\"y\":2"), "encode_string point y");
}

decode_string_point_test() `test {
  string data = "\{\"x\":10,\"y\":20}";
  Point p = json.decode_string[Point](data)!;
  assert(p.x == 10, "decode_string point x");
  assert(p.y == 20, "decode_string point y");
}

encode_decode_round_trip_test() `test {
  MixedFields orig = MixedFields(label: "test", count: 42, score: 3.14, active: true);
  string s = json.encode_string[MixedFields](orig)!;
  MixedFields copy = json.decode_string[MixedFields](s)!;
  assert(copy.label == "test", "round trip label");
  assert(copy.count == 42, "round trip count");
  assert(copy.score > 3.13 && copy.score < 3.15, "round trip score");
  assert(copy.active == true, "round trip active");
}

encode_string_pretty_test() `test {
  string s = json.encode_string_pretty[Point](Point(x: 1, y: 2))!;
  assert(s.contains("\n"), "pretty has newlines");
  assert(s.contains("  \"x\""), "pretty has indented key");
}

// Round-trip with optional fields
encode_decode_optionals_test() `test {
  // present optional
  WithOptionals w1 = WithOptionals(name: "Alice", bio: "hi", level: 5);
  string s1 = json.encode_string[WithOptionals](w1)!;
  WithOptionals c1 = json.decode_string[WithOptionals](s1)!;
  assert(c1.name == "Alice", "opt rt: name");
  assert(c1.bio is present, "opt rt: bio present");
  if b := c1.bio {
    assert(b == "hi", "opt rt: bio value");
  }
  assert(c1.level is present, "opt rt: level present");

  // absent optionals
  WithOptionals w2 = WithOptionals(name: "Bob");
  string s2 = json.encode_string[WithOptionals](w2)!;
  WithOptionals c2 = json.decode_string[WithOptionals](s2)!;
  assert(c2.name == "Bob", "opt rt absent: name");
  assert(c2.bio is absent, "opt rt absent: bio");
  assert(c2.level is absent, "opt rt absent: level");
}

// Round-trip with nested serializable type
encode_decode_nested_test() `test {
  Person p = Person(name: "Eve", age: 25, address: Address(street: "123 Main", city: "NYC"));
  string s = json.encode_string[Person](p)!;
  assert(s.contains("\"name\":\"Eve\""), "nested enc: name");
  assert(s.contains("\"street\":\"123 Main\""), "nested enc: street");
  Person p2 = json.decode_string[Person](s)!;
  assert(p2.name == "Eve", "nested dec: name");
  assert(p2.age == 25, "nested dec: age");
  assert(p2.address.street == "123 Main", "nested dec: street");
  assert(p2.address.city == "NYC", "nested dec: city");
}

// Round-trip with array fields
encode_decode_array_field_test() `test(allow_leaks: true) {
  TaggedItem item = TaggedItem(name: "widget", tags: ["red", "small"]);
  string s = json.encode_string[TaggedItem](item)!;
  assert(s.contains("\"tags\":[\"red\",\"small\"]"), "array field enc");
  TaggedItem item2 = json.decode_string[TaggedItem](s)!;
  assert(item2.name == "widget", "array field dec: name");
  assert(item2.tags.len == 2, "array field dec: tags len");
  assert(item2.tags[0] == "red", "array field dec: tag 0");
  assert(item2.tags[1] == "small", "array field dec: tag 1");
}

// Round-trip with key remapping
encode_decode_key_remap_test() `test {
  User u = User(name: "Grace", age: 28, _internal: "x");
  string s = json.encode_string[User](u)!;
  assert(s.contains("\"user_name\":\"Grace\""), "key remap enc: user_name");
  assert(!s.contains("\"name\""), "key remap enc: no bare name key");
  User u2 = json.decode_string[User](s)!;
  assert(u2.name == "Grace", "key remap dec: name");
  assert(u2.age == 28, "key remap dec: age");
}

// Pretty encode round-trip (pretty output is valid JSON)
encode_string_pretty_round_trip_test() `test {
  Person p = Person(name: "Zoe", age: 30, address: Address(street: "456 Oak", city: "LA"));
  string pretty = json.encode_string_pretty[Person](p)!;
  assert(pretty.contains("\n"), "pretty rt: has newlines");
  // Pretty output should be parseable back
  Person p2 = json.decode_string[Person](pretty)!;
  assert(p2.name == "Zoe", "pretty rt: name");
  assert(p2.address.city == "LA", "pretty rt: city");
}

// ── Flatten field annotation ─────────────────────────────────────────────────

type Metadata `serializable {
  string author;
  int version;
}

type FlatDoc `serializable {
  string title;
  Metadata meta `flatten;
}

type Coords `serializable {
  f64 lat;
  f64 lon;
}

type Location `serializable {
  string name;
  Coords position `flatten;
  string? description;
}

type WithOptionalFields `serializable {
  string label;
  WithOptionals inner `flatten;
}

type KeyedInner `serializable {
  string first_name `key("firstName");
  string last_name `key("lastName");
}

type FlatKeyed `serializable {
  int id;
  KeyedInner details `flatten;
}

type SkipInner `serializable {
  string visible;
  string hidden `skip;
}

type FlatWithSkip `serializable {
  int code;
  SkipInner info `flatten;
}

flatten_encode_test() `test {
  FlatDoc doc = FlatDoc(title: "Hello", meta: Metadata(author: "Alice", version: 2));
  string s = json.encode_string[FlatDoc](doc)!;
  assert(s.contains("\"title\":\"Hello\""), "flatten enc: title");
  assert(s.contains("\"author\":\"Alice\""), "flatten enc: author inlined");
  assert(s.contains("\"version\":2"), "flatten enc: version inlined");
  assert(!s.contains("\"meta\""), "flatten enc: no wrapper key");
}

flatten_decode_test() `test {
  // Decode from flat JSON — keys are at the top level
  string data = "\{\"title\":\"Doc\",\"author\":\"Bob\",\"version\":3}";
  FlatDoc doc = json.decode_string[FlatDoc](data)!;
  assert(doc.title == "Doc", "flatten dec: title");
  assert(doc.meta.author == "Bob", "flatten dec: author");
  assert(doc.meta.version == 3, "flatten dec: version");
}

flatten_round_trip_test() `test {
  FlatDoc doc1 = FlatDoc(title: "RT", meta: Metadata(author: "Carol", version: 1));
  string s = json.encode_string[FlatDoc](doc1)!;
  FlatDoc doc2 = json.decode_string[FlatDoc](s)!;
  assert(doc2.title == "RT", "flatten rt: title");
  assert(doc2.meta.author == "Carol", "flatten rt: author");
  assert(doc2.meta.version == 1, "flatten rt: version");
}

flatten_with_optional_sibling_test() `test {
  Location loc1 = Location(name: "Park", position: Coords(lat: 37.7749, lon: -122.4194), description: "Nice park");
  string s = json.encode_string[Location](loc1)!;
  assert(s.contains("\"name\":\"Park\""), "flatten opt: name");
  assert(s.contains("\"lat\":"), "flatten opt: lat inlined");
  assert(s.contains("\"lon\":"), "flatten opt: lon inlined");
  assert(s.contains("\"description\":\"Nice park\""), "flatten opt: description");
  assert(!s.contains("\"position\""), "flatten opt: no wrapper key");

  Location loc2 = json.decode_string[Location](s)!;
  assert(loc2.name == "Park", "flatten opt dec: name");
  assert(loc2.position.lat > 37.77, "flatten opt dec: lat");
  assert(loc2.description is present, "flatten opt dec: description present");
}

flatten_with_optional_subfields_test() `test {
  // Inner type has optional fields
  WithOptionalFields w1 = WithOptionalFields(label: "test", inner: WithOptionals(name: "Alice", bio: "hi", level: 5));
  string s = json.encode_string[WithOptionalFields](w1)!;
  assert(s.contains("\"label\":\"test\""), "flatten opt sub: label");
  assert(s.contains("\"name\":\"Alice\""), "flatten opt sub: name inlined");
  assert(s.contains("\"bio\":\"hi\""), "flatten opt sub: bio inlined");
  assert(s.contains("\"level\":5"), "flatten opt sub: level inlined");

  WithOptionalFields w2 = json.decode_string[WithOptionalFields](s)!;
  assert(w2.label == "test", "flatten opt sub dec: label");
  assert(w2.inner.name == "Alice", "flatten opt sub dec: name");
  assert(w2.inner.bio is present, "flatten opt sub dec: bio present");
  assert(w2.inner.level is present, "flatten opt sub dec: level present");
}

flatten_with_absent_optional_subfields_test() `test {
  // Inner optional fields absent — should omit from JSON
  WithOptionalFields w1 = WithOptionalFields(label: "minimal", inner: WithOptionals(name: "Bob"));
  string s = json.encode_string[WithOptionalFields](w1)!;
  assert(!s.contains("\"bio\""), "flatten absent: bio omitted");
  assert(!s.contains("\"level\""), "flatten absent: level omitted");

  WithOptionalFields w2 = json.decode_string[WithOptionalFields](s)!;
  assert(w2.inner.name == "Bob", "flatten absent dec: name");
  assert(w2.inner.bio is absent, "flatten absent dec: bio absent");
  assert(w2.inner.level is absent, "flatten absent dec: level absent");
}

flatten_with_key_annotation_test() `test {
  FlatKeyed fk1 = FlatKeyed(id: 42, details: KeyedInner(first_name: "John", last_name: "Doe"));
  string s = json.encode_string[FlatKeyed](fk1)!;
  assert(s.contains("\"id\":42"), "flatten key: id");
  assert(s.contains("\"firstName\":\"John\""), "flatten key: firstName (remapped)");
  assert(s.contains("\"lastName\":\"Doe\""), "flatten key: lastName (remapped)");
  assert(!s.contains("\"first_name\""), "flatten key: no raw name");
  assert(!s.contains("\"details\""), "flatten key: no wrapper");

  FlatKeyed fk2 = json.decode_string[FlatKeyed](s)!;
  assert(fk2.id == 42, "flatten key dec: id");
  assert(fk2.details.first_name == "John", "flatten key dec: first_name");
  assert(fk2.details.last_name == "Doe", "flatten key dec: last_name");
}

flatten_with_skip_subfield_test() `test {
  FlatWithSkip fw1 = FlatWithSkip(code: 200, info: SkipInner(visible: "ok", hidden: "secret"));
  string s = json.encode_string[FlatWithSkip](fw1)!;
  assert(s.contains("\"code\":200"), "flatten skip: code");
  assert(s.contains("\"visible\":\"ok\""), "flatten skip: visible inlined");
  assert(!s.contains("\"hidden\""), "flatten skip: hidden skipped");
  assert(!s.contains("\"secret\""), "flatten skip: hidden value absent");
  assert(!s.contains("\"info\""), "flatten skip: no wrapper");

  FlatWithSkip fw2 = json.decode_string[FlatWithSkip](s)!;
  assert(fw2.code == 200, "flatten skip dec: code");
  assert(fw2.info.visible == "ok", "flatten skip dec: visible");
  assert(fw2.info.hidden == "", "flatten skip dec: hidden default");
}

type Dimensions `serializable {
  int width;
  int height;
}

type Style `serializable {
  string color;
  bool bold;
}

type MultiFlat `serializable {
  string name;
  Dimensions size `flatten;
  Style style `flatten;
}

flatten_multiple_test() `test {
  MultiFlat mf1 = MultiFlat(name: "box",
  size: Dimensions(width: 100, height: 50),
  style: Style(color: "red", bold: true));
  string s = json.encode_string[MultiFlat](mf1)!;
  assert(s.contains("\"name\":\"box\""), "multi flatten: name");
  assert(s.contains("\"width\":100"), "multi flatten: width inlined");
  assert(s.contains("\"height\":50"), "multi flatten: height inlined");
  assert(s.contains("\"color\":\"red\""), "multi flatten: color inlined");
  assert(s.contains("\"bold\":true"), "multi flatten: bold inlined");
  assert(!s.contains("\"size\""), "multi flatten: no size wrapper");
  assert(!s.contains("\"style\""), "multi flatten: no style wrapper");

  MultiFlat mf2 = json.decode_string[MultiFlat](s)!;
  assert(mf2.name == "box", "multi flatten dec: name");
  assert(mf2.size.width == 100, "multi flatten dec: width");
  assert(mf2.size.height == 50, "multi flatten dec: height");
  assert(mf2.style.color == "red", "multi flatten dec: color");
  assert(mf2.style.bold == true, "multi flatten dec: bold");
}

// Decode error: malformed JSON
decode_string_error_test() `test {
  (p, err) := json.decode_string[Point]("not json");
  assert(err is present, "decode malformed: should error");
}

// Decode error: missing required field
decode_string_missing_field_test() `test(allow_leaks: true) {
  (p, err) := json.decode_string[Point]("\{\"x\":1}");
  // y is required (int, no default) — should still decode with zero value
  // since JSON decode fills missing fields with zero
  if err is absent {
    assert(p.x == 1, "missing field: x");
    assert(p.y == 0, "missing field: y defaults to 0");
  }
}
