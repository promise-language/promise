// T0271: Lambda env drop correctly handles Arc/Weak/Mutex captures.
// These types are i8* pointers that need envDropCallFn, not envDropUserValueDrop.
lambda_captures_arc() `test {
  a := Ref[int](42);
  f := move || -> int {
    return a.borrow;
  };
  result := f();
  assert(result == 42, "arc capture value");
}

lambda_captures_arc_clone_before() `test {
  a := Ref[int](10);
  b := a.clone();
  f := move || -> int {
    return a.borrow;
  };
  result := f();
  assert(result == 10, "arc capture after clone");
  assert(b.borrow == 10, "clone still valid");
}

lambda_captures_weak() `test {
  a := Ref[int](99);
  w := a.downgrade();
  f := move || -> bool {
    if upgraded := w.upgrade() {
      return upgraded.borrow == 99;
    }
    return false;
  };
  result := f();
  assert(result, "weak upgrade in lambda");
}

lambda_captures_mutex() `test {
  m := Mutex[int](7);
  f := move || -> int {
    use g := m.lock();
    return g.borrow;
  };
  result := f();
  assert(result == 7, "mutex capture value");
}

lambda_captures_arc_and_weak() `test {
  a := Ref[int](55);
  w := a.downgrade();
  f := move || -> bool {
    if upgraded := w.upgrade() {
      return upgraded.borrow == a.borrow;
    }
    return false;
  };
  result := f();
  assert(result, "arc and weak in same lambda");
}

lambda_captures_arc_drop_only() `test {
  a := Ref[int](100);
  f := move || {
  };
  f();
}

// T0426: lambda with explicit `string&` return type, borrowing from a
// move-captured Ref[string]. Before T0426, the ownership pass used the
// outer fn's signature inside lambda bodies, falsely rejecting this legit
// pattern. After the fix the lambda's own signature is used and captures
// are treated as parameter-like for return-ref checks.
lambda_returns_string_ref() `test {
  a := Ref[string]("hello");
  f := move || -> string & {
    return a.borrow;
  };
  s := f();
  assert(s == "hello", "lambda string ref return");
}

// T0426: nested lambdas — outer lambda returns string& by delegating to an
// inner identity lambda that takes a string& param. Each lambda has its own
// signature; the save/restore in checkLambdaExpr must work through nesting
// without polluting either level's params/curSig/returnOrigins state.
lambda_nested_returns_string_ref() `test {
  a := Ref[string]("nested");
  outer := move || -> string & {
    inner := |string s| -> string & {
      return s;
    };
    return inner(a.borrow);
  };
  result := outer();
  assert(result == "nested", "nested lambda ref return");
}
