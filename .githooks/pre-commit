#!/bin/sh
# Reject commits that include compiled binaries.

BLOCKED_FILES="compiler/promise bin/promise"

for f in $BLOCKED_FILES; do
    if git diff --cached --name-only | grep -qx "$f"; then
        echo "ERROR: staged file '$f' is a compiled binary — remove it from the commit."
        echo "  git reset HEAD $f"
        exit 1
    fi
done
