// Test Vector (slice) operations: push, pop, contains, remove, indexing
//
test_literal_and_len() `test {
  int[] nums = [1, 2, 3];
  assert(nums.len == 3, "literal len 3");
  assert(nums[0] == 1, "[0] == 1");
  assert(nums[1] == 2, "[1] == 2");
  assert(nums[2] == 3, "[2] == 3");
}

test_push() `test {
  int[] nums = [1, 2];
  nums.push(3);
  nums.push(4);
  assert(nums.len == 4, "after push len 4");
  assert(nums[2] == 3, "[2] == 3");
  assert(nums[3] == 4, "[3] == 4");
}

test_pop() `test {
  int[] nums = [10, 20, 30];
  if val := nums.pop() {
    assert(val == 30, "pop returns 30");
  } else {
    assert(false, "pop should return value");
  }
  assert(nums.len == 2, "after pop len 2");
}

test_pop_empty() `test {
  int[] empty = [];
  bool got_none = true;
  if _ := empty.pop() {
    got_none = false;
  }
  assert(got_none, "pop on empty returns none");
}

test_contains() `test {
  int[] nums = [1, 2, 3, 4, 5];
  assert(nums.contains(3), "contains 3");
  assert(!nums.contains(99), "not contains 99");
}

test_contains_empty() `test {
  int[] empty = [];
  assert(!empty.contains(1), "empty contains returns false");
}

test_contains_single() `test {
  int[] nums = [42];
  assert(nums.contains(42), "single element found");
  assert(!nums.contains(99), "single element not found");
}

test_contains_first_last() `test {
  int[] nums = [10, 20, 30, 40, 50];
  assert(nums.contains(10), "contains first element");
  assert(nums.contains(50), "contains last element");
}

test_contains_duplicates() `test {
  int[] nums = [5, 5, 5];
  assert(nums.contains(5), "contains duplicate element");
}

test_contains_strings() `test {
  string[] words = ["hello", "world"];
  assert(words.contains("hello"), "contains hello");
  assert(!words.contains("nope"), "not contains nope");
  assert(!words.contains(""), "not contains empty string");
  assert(!words.contains("hello world"), "not contains longer string");
}

test_remove() `test {
  int[] nums = [10, 20, 30, 40];
  nums.remove(1);
  assert(nums.len == 3, "after remove len 3");
  assert(nums[0] == 10, "[0] == 10");
  assert(nums[1] == 30, "[1] == 30 (shifted)");
  assert(nums[2] == 40, "[2] == 40");
}

test_remove_first() `test {
  int[] nums = [10, 20, 30];
  nums.remove(0);
  assert(nums.len == 2, "after remove first len 2");
  assert(nums[0] == 20, "[0] == 20 (shifted from [1])");
  assert(nums[1] == 30, "[1] == 30 (shifted from [2])");
}

test_remove_last() `test {
  int[] nums = [10, 20, 30];
  nums.remove(2);
  assert(nums.len == 2, "after remove last len 2");
  assert(nums[0] == 10, "[0] == 10");
  assert(nums[1] == 20, "[1] == 20");
}

test_remove_single_element() `test {
  int[] nums = [99];
  nums.remove(0);
  assert(nums.len == 0, "remove single leaves empty");
  assert(nums.is_empty, "is_empty after single remove");
}

test_remove_sequential() `test {
  int[] nums = [1, 2, 3, 4, 5];
  nums.remove(2);
  assert(nums.len == 4, "after first remove len 4");
  assert(nums[2] == 4, "[2] == 4 after removing 3");
  nums.remove(0);
  assert(nums.len == 3, "after second remove len 3");
  assert(nums[0] == 2, "[0] == 2 after removing 1");
}

test_contains_after_remove() `test {
  int[] nums = [1, 2, 3];
  nums.remove(1);
  assert(nums.contains(1), "contains 1 after remove");
  assert(nums.contains(3), "contains 3 after remove");
  assert(!nums.contains(2), "2 removed, not contained");
}

test_remove_all_elements() `test {
  int[] nums = [10, 20, 30];
  nums.remove(0);
  nums.remove(0);
  nums.remove(0);
  assert(nums.len == 0, "all removed len 0");
  assert(nums.is_empty, "all removed is_empty");
  assert(!nums.contains(10), "10 not in empty vec");
}

test_is_empty() `test {
  int[] empty = [];
  assert(empty.is_empty, "empty is_empty");
  int[] nums = [1];
  assert(!nums.is_empty, "non-empty not is_empty");
}

test_index_assign() `test {
  int[] nums = [1, 2, 3];
  nums[1] = 20;
  assert(nums[1] == 20, "index assign");
}

test_compound_index_assign() `test {
  int[] nums = [10, 20, 30];
  nums[0] += 5;
  assert(nums[0] == 15, "compound index assign");
}

test_default_capacity_constructor() `test {
  v := Vector[int]();
  assert(v.len == 0, "empty after default constructor");
  v.push(1);
  v.push(2);
  v.push(3);
  assert(v.len == 3, "len 3 after pushes");
  assert(v[0] == 1, "[0] == 1");
  assert(v[1] == 2, "[1] == 2");
  assert(v[2] == 3, "[2] == 3");
}

test_explicit_capacity_positional() `test {
  v := Vector[int](4);
  assert(v.len == 0, "empty after explicit capacity");
  v.push(10);
  v.push(20);
  v.push(30);
  v.push(40);
  assert(v.len == 4, "len 4 after pushes");
  assert(v[3] == 40, "[3] == 40");
}

test_explicit_capacity_named() `test {
  v := Vector[string](capacity: 8);
  assert(v.len == 0, "empty after named capacity");
  v.push("hello");
  v.push("world");
  assert(v.len == 2, "len 2 after pushes");
  assert(v[0] == "hello", "[0] == hello");
  assert(v[1] == "world", "[1] == world");
}

test_grow_beyond_default_capacity() `test {
  v := Vector[int]();
  // Push 20 items — exceeds default capacity of 16
  int i = 0;
  while i < 20 {
    v.push(i);
    i = i + 1;
  }
  assert(v.len == 20, "len 20 after growing past capacity");
  assert(v[0] == 0, "[0] == 0");
  assert(v[19] == 19, "[19] == 19");
}

test_grow_beyond_explicit_capacity() `test {
  v := Vector[int](2);
  // Push 10 items — exceeds explicit capacity of 2
  int i = 0;
  while i < 10 {
    v.push(i * 10);
    i = i + 1;
  }
  assert(v.len == 10, "len 10 after growing");
  assert(v[0] == 0, "[0] == 0");
  assert(v[9] == 90, "[9] == 90");
}

// --- Slicing ---

test_slice_range() `test {
  int[] nums = [10, 20, 30, 40, 50];
  int[] sub = nums[1:4];
  assert(sub.len == 3, "slice [1:4] len 3");
  assert(sub[0] == 20, "[0] == 20");
  assert(sub[1] == 30, "[1] == 30");
  assert(sub[2] == 40, "[2] == 40");
}

test_slice_from_start() `test {
  int[] nums = [10, 20, 30, 40, 50];
  int[] sub = nums[:3];
  assert(sub.len == 3, "slice [:3] len 3");
  assert(sub[0] == 10, "[0] == 10");
  assert(sub[2] == 30, "[2] == 30");
}

test_slice_to_end() `test {
  int[] nums = [10, 20, 30, 40, 50];
  int[] sub = nums[2:];
  assert(sub.len == 3, "slice [2:] len 3");
  assert(sub[0] == 30, "[0] == 30");
  assert(sub[2] == 50, "[2] == 50");
}

test_slice_full() `test {
  int[] nums = [10, 20, 30];
  int[] sub = nums[:];
  assert(sub.len == 3, "slice [:] len 3");
  assert(sub[0] == 10, "[0] == 10");
  assert(sub[2] == 30, "[2] == 30");
}

test_slice_empty_range() `test {
  int[] nums = [10, 20, 30];
  int[] sub = nums[2:2];
  assert(sub.len == 0, "slice [2:2] empty");
}

test_slice_single() `test {
  int[] nums = [10, 20, 30];
  int[] sub = nums[1:2];
  assert(sub.len == 1, "slice [1:2] len 1");
  assert(sub[0] == 20, "[0] == 20");
}

test_slice_is_copy() `test {
  int[] nums = [10, 20, 30];
  int[] sub = nums[0:2];
  sub[0] = 99;
  assert(nums[0] == 10, "original unchanged");
  assert(sub[0] == 99, "copy modified");
}

// --- Slice assignment ---

test_slice_assign() `test {
  int[] nums = [10, 20, 30, 40, 50];
  nums[1:4] = [200, 300, 400];
  assert(nums[0] == 10, "[0] unchanged");
  assert(nums[1] == 200, "[1] == 200");
  assert(nums[2] == 300, "[2] == 300");
  assert(nums[3] == 400, "[3] == 400");
  assert(nums[4] == 50, "[4] unchanged");
}

test_slice_assign_from_start() `test {
  int[] nums = [10, 20, 30];
  nums[:2] = [100, 200];
  assert(nums[0] == 100, "[0] == 100");
  assert(nums[1] == 200, "[1] == 200");
  assert(nums[2] == 30, "[2] unchanged");
}

test_slice_assign_partial() `test {
  // Assigning fewer values than range — only overwrites what's provided
  int[] nums = [10, 20, 30, 40, 50];
  nums[1:4] = [200];
  assert(nums[0] == 10, "[0] unchanged");
  assert(nums[1] == 200, "[1] == 200");
  assert(nums[2] == 30, "[2] unchanged (not enough values)");
  assert(nums[3] == 40, "[3] unchanged");
}

// B0313: slice assign must free the source vector's backing array
test_slice_assign_string_no_leak() `test {
  string[] src = ["hello"];
  string[] v = ["a", "b", "c"];
  v[0:1] = src;
  assert(v[0] == "hello", "copied");
  assert(v[1] == "b", "unchanged");
  assert(v[2] == "c", "unchanged");
}

// B0313: source with more elements than target range
test_slice_assign_string_partial_source() `test {
  string[] src = ["x", "y", "z"];
  string[] v = ["a", "b", "c", "d"];
  v[1:3] = src;
  assert(v[0] == "a", "[0] unchanged");
  assert(v[1] == "x", "[1] from src");
  assert(v[2] == "y", "[2] from src");
  assert(v[3] == "d", "[3] unchanged");
}
