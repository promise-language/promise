// E2E regression tests for T0766: coercing a user-defined type that satisfies
// the stdlib `Writer` structural interface (implements only `write!`) into a
// `Writer` view used to panic in codegen while synthesizing the view vtable —
// `panic: codegen: no method write_string on type <T>`.
//
// `Writer` has chained default methods:
//   write!(~this, u8[] ~buf) int            (abstract)
//   write_string!(~this, string s) int      (default: calls this.write(b))
//   write_line!(~this, string s)            (default: calls this.write_string(...) twice)
//
// Synthesizing `write_line` on the concrete type emits a call to the *sibling*
// default `write_string`, which is declared on the interface and not in the
// concrete type's own method table. The fix resolves such sibling-default calls
// through the interface during default-method-body synthesis.
//
// The shared `Ref[Mutex[int]]` counter lets these tests observe the byte counts
// produced by the default chain even though the writer value is moved into the
// `Writer` view (the underlying instance is otherwise unreachable afterward).
// A minimal user Writer: only `write!` is implemented; `write_string` and
// `write_line` come from the interface defaults.
type CountWriter `public `doc("Test Writer that records the total bytes passed to write().") {
  Ref[Mutex[int]] total;
  write!(~this, u8[] ~buf) int `doc("Records buf.len into the shared counter and returns it.") {
    MutexGuard[int] g = this.total.borrow.lock();
    g.borrow = g.borrow + buf.len;
    g.close();
    return buf.len;
  }
}

// write_string is a default method that converts the string to bytes and calls
// write(). Coercing the user type to a Writer view synthesizes write_string on
// the concrete type; its return value comes straight from write().
test_user_writer_write_string_default() `test {
  Ref[Mutex[int]] counter = Ref[Mutex[int]](Mutex[int](0));
  CountWriter cw = CountWriter(total: counter.clone());
  Writer w = cw;
  int n = w.write_string("hello")?!;
  assert(n == 5, "write_string default returns 5 bytes written");
  assert(counter.borrow.lock().borrow == 5, "write reached the underlying writer");
}

// write_line is a *two-level* default: it calls write_string (itself a default)
// twice — the exact chain that triggered the codegen panic. Assert the full
// "hi" + line_separator byte total landed in the underlying writer.
test_user_writer_write_line_default_chain() `test {
  Ref[Mutex[int]] counter = Ref[Mutex[int]](Mutex[int](0));
  CountWriter cw = CountWriter(total: counter.clone());
  Writer w = cw;
  w.write_line("hi")?!;
  int expected = 2 + Platform.line_separator.bytes().len;
  assert(counter.borrow.lock().borrow == expected, "write_line wrote 'hi' + line separator");
}

// Mirrors the tracker reproducer shape — a `Tracked` type whose only own method
// is `write!`, directly coerced to a `Writer` view — locking in the regression.
type Tracked `public `doc("Tracker reproducer: Writer satisfier with only write! implemented.") {
  Ref[Mutex[int]] log;
  write!(~this, u8[] ~buf) int `doc("Records buf.len and returns it.") {
    MutexGuard[int] g = this.log.borrow.lock();
    g.borrow = g.borrow + buf.len;
    g.close();
    return buf.len;
  }
}

test_tracked_reproducer_coercion() `test {
  Ref[Mutex[int]] counter = Ref[Mutex[int]](Mutex[int](0));
  Tracked t = Tracked(log: counter.clone());
  Writer w = t;
  // Exercise both default levels on the reproducer type.
  int n = w.write_string("abc")?!;
  assert(n == 3, "tracked write_string returns 3");
  w.write_line("xy")?!;
  int expected = 3 + 2 + Platform.line_separator.bytes().len;
  assert(counter.borrow.lock().borrow == expected, "tracked default chain totals match");
}

// Declaration-order regression: the calling default `emit_line` is declared
// BEFORE the sibling default `emit_str` it invokes. While synthesizing
// emit_line's body, emit_str has not been synthesized yet, so it must be
// produced fresh re-entrantly (exercising the recursion-guard stub
// registration). A locally-defined `Sink` interface is used so the ordering is
// explicit and independent of stdlib `Writer`'s declaration order.
type Sink `public `structural `doc("Test interface whose emit_line default is declared before the emit_str default it calls.") {
  emit!(~this, u8[] ~buf) int `doc("Abstract sink write.") `abstract;
  emit_line!(~this, string s) `doc("Default: writes s twice via the emit_str sibling default.") {
    this.emit_str(s);
    this.emit_str(s);
  }
  emit_str!(~this, string s) int `doc("Default: converts s to bytes and forwards to emit().") {
    u8[] b = s.bytes();
    return this.emit(b);
  }
}

type SinkWriter `public `doc("Sink satisfier that records total bytes written.") {
  Ref[Mutex[int]] total;
  emit!(~this, u8[] ~buf) int `doc("Records buf.len into the shared counter and returns it.") {
    MutexGuard[int] g = this.total.borrow.lock();
    g.borrow = g.borrow + buf.len;
    g.close();
    return buf.len;
  }
}

test_sibling_default_declared_after_caller() `test {
  Ref[Mutex[int]] counter = Ref[Mutex[int]](Mutex[int](0));
  SinkWriter sw = SinkWriter(total: counter.clone());
  Sink s = sw;
  s.emit_line("ab")?!;
  // emit_line calls emit_str twice; each emit_str writes 2 bytes ("ab").
  assert(counter.borrow.lock().borrow == 4, "emit_line wrote 'ab' twice via the later-declared sibling default");
}
