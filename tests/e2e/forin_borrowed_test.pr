// T0971: `for … in` over a borrowed container (T[]&, string&, map&, ~T[], a
// borrowed parameter) must type-check and iterate the same as the owned form.
// Reading elements through the borrow is allowed; moving a non-Copy element out
// of a container you don't own is a compile error (covered by ownership tests).
// These batch tests all compile into one binary and are leak-checked.
type Box {
  string name;
}

// --- Borrowed vector (the original repro) ----------------------------------

forin_borrowed_int_vector() `test {
  v := [10, 20, 30];
  int[] &b = v;
  total := 0;
  for x in b {
    total = total + x;
  }
  assert(total == 60, "borrowed int[] sum");
}

forin_owned_matches_borrowed() `test {
  // Owned for-in consumes its iterable, so use two equal vectors: one iterated
  // owned, one iterated through a borrow.
  owned := 0;
  for x in[1, 2, 3, 4] {
    owned = owned + x;
  }
  vb := [1, 2, 3, 4];
  int[] &b = vb;
  borrowed := 0;
  for x in b {
    borrowed = borrowed + x;
  }
  assert(owned == borrowed && owned == 10, "owned and borrowed sums agree");
}

// --- Borrowed vector via function parameter (idiomatic non-consuming pass) --

sum_borrowed(int[] &data) int {
  total := 0;
  for x in data {
    total = total + x;
  }
  return total;
}

forin_borrowed_param_called_twice() `test {
  v := [5, 5, 5];
  // The borrow does not consume `v` — the same vector can be passed again.
  a := sum_borrowed(v);
  b := sum_borrowed(v);
  assert(a == 15 && b == 15, "borrowed-param iteration repeatable");
  assert(v.len == 3, "original vector intact after borrowed iteration");
}

// --- Borrowed string vector (non-Copy elements; clone-on-read path) ---------
// Visiting all elements must not move/drop the borrowed buffer (zero leak).

total_name_len(Box[] &boxes) int {
  n := 0;
  for box in boxes {
    n = n + box.name.len;
  }
  return n;
}

forin_borrowed_box_vector_readonly() `test {
  boxes := [Box(name: "aa"), Box(name: "bbb"), Box(name: "c")];
  n := total_name_len(boxes);
  assert(n == 6, "borrowed Box[] name-length sum");
  // boxes is untouched and still owns its elements.
  assert(boxes.len == 3 && boxes[1].name == "bbb", "borrowed Box[] intact");
}

sum_string_lens(string[] &data) int {
  total := 0;
  for s in data {
    total = total + s.len;
  }
  return total;
}

forin_borrowed_string_vector() `test {
  v := ["alpha", "beta", "gamma"];
  // Iterate through a borrowed parameter so `v` is not consumed and can be
  // inspected afterwards (a `string[] &b = v` local would move `v`).
  total := sum_string_lens(v);
  assert(total == 14, "borrowed string[] length sum");
  assert(v[0] == "alpha" && v[2] == "gamma", "borrowed string[] intact");
}

// String elements are cloned per iteration, so moving the binding into a new
// owned vector is sound (the clone is independent of the borrowed buffer). This
// exercises the clone-then-move codegen path and must be leak/double-free free:
// both the borrowed source `v` and the new `copies` are dropped with no overlap.
collect_upper(string[] &data) string[] {
  copies := string[]();
  for s in data {
    copies.push(s.to_upper());
  }
  return copies;
}

forin_borrowed_string_vector_clone_move() `test {
  v := ["a", "bb", "ccc"];
  out := collect_upper(v);
  assert(out.len == 3, "borrowed string[] clone-move count");
  assert(out[0] == "A" && out[1] == "BB" && out[2] == "CCC", "clone-move values");
  // The borrowed source survives intact (independent storage).
  assert(v[0] == "a" && v[2] == "ccc", "borrowed source intact after clone-move");
}

// --- Mutable borrow (~) of a vector -----------------------------------------

sum_mut_borrowed(int[] ~data) int {
  total := 0;
  for x in data {
    total = total + x;
  }
  return total;
}

forin_mut_borrowed_vector() `test {
  v := [2, 4, 6, 8];
  // Post-type `~` is a *mutable borrow* (not a move): the callee borrows `v`
  // for the call and the caller still owns and drops it afterwards.
  total := sum_mut_borrowed(v);
  assert(total == 20, "mutable-borrowed vector sum");
  assert(v.len == 4, "mutable-borrowed vector intact after call");
}

// --- Borrowed map (two-binding iteration) -----------------------------------

sum_map_values(map[string, int] &m) int {
  total := 0;
  for k, v in m {
    total = total + v;
  }
  return total;
}

forin_borrowed_map() `test {
  map[string, int] m = {
    "a": 1, "b": 2, "c": 3
  };
  total := sum_map_values(m);
  assert(total == 6, "borrowed map value sum");
  assert(m.len == 3, "borrowed map intact");
}

// --- Borrowed string (yields char) ------------------------------------------

count_chars(string &s) int {
  n := 0;
  for ch in s {
    n = n + 1;
  }
  return n;
}

forin_borrowed_string() `test {
  s := "hello";
  string &b = s;
  assert(count_chars(b) == 5, "borrowed string char count");
}

// --- Borrowed fixed-size array ----------------------------------------------

sum_array(int[3] &a) int {
  total := 0;
  for x in a {
    total = total + x;
  }
  return total;
}

forin_borrowed_array() `test {
  int[3] a = [7, 8, 9];
  assert(sum_array(a) == 24, "borrowed array sum");
}

// --- Borrowed range ---------------------------------------------------------

sum_range(Range[int] &r) int {
  total := 0;
  for x in r {
    total = total + x;
  }
  return total;
}

forin_borrowed_range() `test {
  assert(sum_range(0..5) == 10, "borrowed range sum"); // 0+1+2+3+4
}
