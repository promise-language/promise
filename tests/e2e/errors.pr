safe_div!(int a, int b) int {
  if b == 0 {
    raise error(message: "division by zero");
  }
  return a / b;
}

compute!() int {
  // Propagate with ^
  int x = safe_div(10, 2)^;
  int y = safe_div(20, 4)^;
  return x + y;
}

main() `test(expected: """6
10""") {
  // Successful bang unwrap
  print_line(safe_div(42, 7)!);

  // Chain propagation
  print_line(compute()!);
}
