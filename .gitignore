logs/*

# Compiler: ANTLR4 tool
compiler/tools/antlr-*.jar

# Compiler: generated parser (non-Go artifacts)
compiler/internal/parser/*.interp
compiler/internal/parser/*.tokens

# bin/ holds only build artifacts — the compiler binary, hash sidecars, and all Go
# build/flow tools compiled by ./make. Nothing under bin/ is ever committed.
bin/
compiler/grammar/.antlr/PromiseLexer.interp
compiler/grammar/.antlr/PromiseLexer.java
compiler/grammar/.antlr/PromiseLexer.tokens
compiler/grammar/.antlr/PromiseParser.interp
compiler/grammar/.antlr/PromiseParser.java
compiler/grammar/.antlr/PromiseParser.tokens

# winlink import libraries (.lib) generated from the tracked def/*.def files for lld-link
tools/build/winlink/lib/

# Debug build output
.promise-build/

# Local promise home for testing
.promise-home/

# Build cache
**/.DS_Store
# Per-clone files provisioned by `workspace setup` (tracker MCP + local guidance) —
# host/clone-specific, never committed.
.claude/settings.local.json
CLAUDE.local.md
.mcp.json

# Wrangler (Cloudflare CLI) local state — created by `npx wrangler` during blob publishing
.wrangler/
# Transient Claude Code lock files (e.g. scheduled_tasks.lock) — never committed
.claude/*.lock
.runner-*
.runner.*

# Release-build output: `bin/release blobs/manifest/build` write here (bin/, blobs/,
# deps/, manifest-*.json). Scratch — produced in CI and by local runs, never committed.
/dist/

# Transient flow lease / worktree state written by the do flow when run locally.
.flow/
