  return h.value;
}

test_ctor_arg_success() `test(allow_leaks: true) {
  int r = auto_prop_ctor_arg()!;
  assert(r == 42, "failable arg to constructor succeeds");
}

auto_prop_ctor_arg_fail() int! {
  h := Holder(value: parse_int("bad"));
  return h.value;
}

try_ctor_arg_fail() bool {
  auto_prop_ctor_arg_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_ctor_arg_fail() `test(allow_leaks: true) {
  assert(try_ctor_arg_fail(), "failable arg to constructor propagates error");
}

// ============================================================
// Section 4: Multiple failable arguments
// ============================================================

add(int a, int b) int {
  return a + b;
}

auto_prop_multi_args() int! {
  return add(parse_int("42"), parse_int("7"));
}

test_multi_args_success() `test(allow_leaks: true) {
  int r = auto_prop_multi_args()!;
  assert(r == 49, "multiple failable args succeed: 42 + 7");
}

// First arg fails
auto_prop_multi_first_fail() int! {
  return add(parse_int("bad"), parse_int("7"));
}

try_multi_first_fail() bool {
  auto_prop_multi_first_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_multi_first_fail() `test(allow_leaks: true) {
  assert(try_multi_first_fail(), "first failable arg fails, propagates");
}

// Second arg fails
auto_prop_multi_second_fail() int! {
  return add(parse_int("42"), parse_int("bad"));
}

try_multi_second_fail() bool {
  auto_prop_multi_second_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_multi_second_fail() `test(allow_leaks: true) {
  assert(try_multi_second_fail(), "second failable arg fails, propagates");
}

// ============================================================
// Section 5: Failable arg with string type
// ============================================================

use_string(string s) string {
  return s;
}

auto_prop_string_arg() string! {
  return use_string(get_string(false));
}

test_string_arg_success() `test(allow_leaks: true) {
  string r = auto_prop_string_arg()!;
  assert(r == "hello", "failable string arg succeeds");
}

auto_prop_string_arg_fail() string! {
  return use_string(get_string(true));
}

try_string_arg_fail() bool {
  auto_prop_string_arg_fail()? e {
    return e.message == "no string";
  };
  return false;
}

test_string_arg_fail() `test(allow_leaks: true) {
  assert(try_string_arg_fail(), "failable string arg propagates error");
}

// ============================================================
// Section 6: Mixed failable and non-failable arguments
// ============================================================

combine(int a, int b, int c) int {
  return a + b + c;
}

auto_prop_mixed_args() int! {
  return combine(1, parse_int("42"), 100);
}

test_mixed_args_success() `test(allow_leaks: true) {
  int r = auto_prop_mixed_args()!;
  assert(r == 143, "mixed failable/literal args: 1 + 42 + 100");
}

// ============================================================
// Section 7: Failable arg in nested calls
// ============================================================

double(int x) int {
  return x * 2;
}

auto_prop_nested() int! {
  return double(use_int(parse_int("7")));
}

test_nested_failable_arg() `test(allow_leaks: true) {
  int r = auto_prop_nested()!;
  assert(r == 14, "nested calls with failable arg: double(use_int(7))");
}

// ============================================================
// Section 8: Failable call with explicit handler on arg still works
// ============================================================

test_explicit_handler_on_arg() `test(allow_leaks: true) {
  int r = use_int(parse_int("bad")? e {
    99;
  });
  assert(r == 99, "explicit handler on failable arg produces recovery value");
}

test_explicit_unwrap_on_arg() `test(allow_leaks: true) {
  int r = use_int(parse_int("42")!);
  assert(r == 42, "explicit ! unwrap on failable arg works");
}

// ============================================================
// Section 9: Failable call as variadic argument
// ============================================================

sum(...int nums) int {
  int total = 0;
  for n in nums {
    total += n;
  }
  return total;
}

auto_prop_variadic() int! {
  return sum(parse_int("42"), parse_int("7"));
}

test_variadic_args_success() `test(allow_leaks: true) {
  int r = auto_prop_variadic()!;
  assert(r == 49, "failable variadic args: 42 + 7");
}

auto_prop_variadic_fail() int! {
  return sum(parse_int("42"), parse_int("bad"));
}

try_variadic_fail() bool {
  auto_prop_variadic_fail()? e {
    return e.message == "bad: bad";
  };
  return false;
}

test_variadic_arg_fail() `test(allow_leaks: true) {
  assert(try_variadic_fail(), "failable variadic arg propagates error");
}

auto_prop_variadic_mixed() int! {
  return sum(10, parse_int("42"), 100);
}

test_variadic_mixed() `test(allow_leaks: true) {
  int r = auto_prop_variadic_mixed()!;
  assert(r == 152, "mixed variadic: 10 + 42 + 100");
}

