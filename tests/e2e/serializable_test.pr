use json;

// ── Test types ──────────────────────────────────────────────────────────────

type Point `serializable {
  int x;
  int y;
}

type User `serializable {
  string name `key("user_name");
  int age;
  string? email;
  string _internal `skip;
}

type MixedFields `serializable {
  string label;
  int count;
  f64 score;
  bool active;
}

type WithOptionals `serializable {
  string name;
  string? bio;
  int? level;
}

type Address `serializable {
  string street;
  string city;
}

type Person `serializable {
  string name;
  int age;
  Address address;
}

type TaggedItem `serializable {
  string name;
  string[] tags;
}

type Scores `serializable {
  string label;
  int[] values;
}

type Config `serializable {
  string title;
  map[string, string] settings;
}

type Route `serializable {
  string name;
  Point[] waypoints;
}

type Counters `serializable {
  map[string, int] counts;
}

type IntKeyMap `serializable {
  map[int, string] data;
}

type Dashboard `serializable {
  string title;
  string[] labels;
  map[string, int] metrics;
}

type Measurements `serializable {
  f64[] values;
}

type Flags `serializable {
  bool[] bits;
}

type GoodWrapper[T: Encodable + Decodable] `serializable {
  T value;
  string label;
}

type SkipWrapper[T] `serializable {
  T value `skip;
  string label;
}

type Located `serializable {
  string name;
  Point pos `key("position");
}

type Rect `serializable {
  Point origin;
  Point size;
}

type WithIncludeNone `serializable {
  string name;
  string? tag `include_none;
}

type CustomEncode `serializable {
  int value;

  // User-provided encode overrides the generated one.
  encode(Encoder ~e)! {
    e.encode_string("custom:" + this.value.to_string());
  }
}

// ── Basic encode/decode ─────────────────────────────────────────────────────

encode_point_test() `test {
  Point p = Point(x: 3, y: 4);
  json.JsonEncoder enc = json.JsonEncoder();
  p.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"x\":3"), "has x:3");
  assert(s.contains("\"y\":4"), "has y:4");
}

decode_point_test() `test {
  Point p1 = Point(x: 10, y: 20);
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Point p2 = Point.decode(dec)!;
  assert(p2.x == 10, "decoded x");
  assert(p2.y == 20, "decoded y");
}

round_trip_point_test() `test {
  Point p1 = Point(x: 42, y: 99);
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Point p2 = Point.decode(dec)!;
  assert(p2.x == p1.x, "round trip x");
  assert(p2.y == p1.y, "round trip y");
}

// ── Mixed field types ───────────────────────────────────────────────────────

mixed_fields_encode_test() `test {
  MixedFields m = MixedFields(label: "test", count: 5, score: 3.14, active: true);
  json.JsonEncoder enc = json.JsonEncoder();
  m.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"label\":\"test\""), "mixed: label");
  assert(s.contains("\"count\":5"), "mixed: count");
  assert(s.contains("\"active\":true"), "mixed: active");
  assert(s.contains("\"score\":"), "mixed: score present");
}

mixed_fields_round_trip_test() `test {
  MixedFields m1 = MixedFields(label: "hello", count: 0, score: 2.5, active: false);
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  MixedFields m2 = MixedFields.decode(dec)!;
  assert(m2.label == "hello", "rt label");
  assert(m2.count == 0, "rt count zero");
  assert(m2.score == 2.5, "rt score");
  assert(m2.active == false, "rt active false");
}

// ── Nested serializable types ────────────────────────────────────────────────

nested_encode_test() `test {
  Person p = Person(name: "Alice", age: 30, address: Address(street: "123 Main", city: "NYC"));
  json.JsonEncoder enc = json.JsonEncoder();
  p.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"name\":\"Alice\""), "nested encode: name");
  assert(s.contains("\"age\":30"), "nested encode: age");
  assert(s.contains("\"street\":\"123 Main\""), "nested encode: street");
  assert(s.contains("\"city\":\"NYC\""), "nested encode: city");
}

nested_decode_test() `test {
  Person p1 = Person(name: "Bob", age: 25, address: Address(street: "456 Oak", city: "LA"));
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Person p2 = Person.decode(dec)!;
  assert(p2.name == "Bob", "nested decode: name");
  assert(p2.age == 25, "nested decode: age");
  assert(p2.address.street == "456 Oak", "nested decode: street");
  assert(p2.address.city == "LA", "nested decode: city");
}

nested_round_trip_test() `test {
  Person p1 = Person(name: "Carol", age: 40, address: Address(street: "789 Elm", city: "SF"));
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Person p2 = Person.decode(dec)!;
  assert(p2.name == p1.name, "nested rt: name");
  assert(p2.age == p1.age, "nested rt: age");
  assert(p2.address.street == "789 Elm", "nested rt: street");
  assert(p2.address.city == "SF", "nested rt: city");
}

deep_nested_round_trip_test() `test {
  // 3 levels: uses Address → reuses existing types, but tests depth
  Person p1 = Person(name: "Deep", age: 1, address: Address(street: "A St", city: "B"));
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Person p2 = Person.decode(dec)!;
  assert(p2.address.street == "A St", "deep nested: street");
  assert(p2.address.city == "B", "deep nested: city");
}

nested_with_key_test() `test {
  Located l1 = Located(name: "X", pos: Point(x: 3, y: 4));
  json.JsonEncoder enc = json.JsonEncoder();
  l1.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"position\":"), "nested key: uses wire name");
  assert(!s.contains("\"pos\":"), "nested key: no raw name");
  json.JsonDecoder dec = json.JsonDecoder(data: s);
  Located l2 = Located.decode(dec)!;
  assert(l2.pos.x == 3, "nested key decode: x");
  assert(l2.pos.y == 4, "nested key decode: y");
}

multiple_nested_fields_test() `test {
  Rect r1 = Rect(origin: Point(x: 0, y: 0), size: Point(x: 100, y: 50));
  json.JsonEncoder enc = json.JsonEncoder();
  r1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Rect r2 = Rect.decode(dec)!;
  assert(r2.origin.x == 0, "multi nested: origin x");
  assert(r2.origin.y == 0, "multi nested: origin y");
  assert(r2.size.x == 100, "multi nested: size x");
  assert(r2.size.y == 50, "multi nested: size y");
}

// ── Array fields (T[]) ──────────────────────────────────────────────────────

array_encode_test() `test {
  TaggedItem item = TaggedItem(name: "bolt", tags: ["metal", "small", "round"]);
  json.JsonEncoder enc = json.JsonEncoder();
  item.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"name\":\"bolt\""), "array encode: name");
  assert(s.contains("\"metal\""), "array encode: tag metal");
  assert(s.contains("\"small\""), "array encode: tag small");
}

array_round_trip_test() `test {
  TaggedItem item1 = TaggedItem(name: "nut", tags: ["hex", "steel"]);
  json.JsonEncoder enc = json.JsonEncoder();
  item1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  TaggedItem item2 = TaggedItem.decode(dec)!;
  assert(item2.name == "nut", "array rt: name");
  assert(item2.tags.len == 2, "array rt: count");
  assert(item2.tags[0] == "hex", "array rt: 0");
  assert(item2.tags[1] == "steel", "array rt: 1");
}

array_empty_test() `test {
  TaggedItem item1 = TaggedItem(name: "bare", tags: string[]());
  json.JsonEncoder enc = json.JsonEncoder();
  item1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  TaggedItem item2 = TaggedItem.decode(dec)!;
  assert(item2.tags.len == 0, "array empty: no tags");
}

int_array_round_trip_test() `test {
  Scores s1 = Scores(label: "test", values: [10, 20, 30]);
  json.JsonEncoder enc = json.JsonEncoder();
  s1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Scores s2 = Scores.decode(dec)!;
  assert(s2.values.len == 3, "int array: count");
  assert(s2.values[0] == 10, "int array: 0");
  assert(s2.values[2] == 30, "int array: 2");
}

// ── Map fields (map[string, V]) ─────────────────────────────────────────────

map_encode_test() `test {
  Config cfg = Config(title: "app", settings: map[string, string]());
  cfg.settings["color"] = "blue";
  cfg.settings["mode"] = "dark";
  json.JsonEncoder enc = json.JsonEncoder();
  cfg.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"title\":\"app\""), "map encode: title");
  assert(s.contains("\"color\":\"blue\""), "map encode: color");
}

map_round_trip_test() `test {
  Config cfg1 = Config(title: "web", settings: map[string, string]());
  cfg1.settings["port"] = "8080";
  json.JsonEncoder enc = json.JsonEncoder();
  cfg1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Config cfg2 = Config.decode(dec)!;
  assert(cfg2.title == "web", "map rt: title");
}

map_empty_test() `test {
  Config cfg1 = Config(title: "empty", settings: map[string, string]());
  json.JsonEncoder enc = json.JsonEncoder();
  cfg1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Config cfg2 = Config.decode(dec)!;
  assert(cfg2.title == "empty", "map empty: title");
}

// ── Array of user types ─────────────────────────────────────────────────────

array_of_user_types_test() `test {
  Route r1 = Route(name: "trail", waypoints: [Point(x: 0, y: 0), Point(x: 10, y: 5), Point(x: 20, y: 10)]);
  json.JsonEncoder enc = json.JsonEncoder();
  r1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Route r2 = Route.decode(dec)!;
  assert(r2.name == "trail", "user type array: name");
  assert(r2.waypoints.len == 3, "user type array: count");
  assert(r2.waypoints[1].x == 10, "user type array: pt 2 x");
  assert(r2.waypoints[2].y == 10, "user type array: pt 3 y");
}

f64_array_test() `test {
  Measurements m1 = Measurements(values: [1.5, 2.5, 3.5]);
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Measurements m2 = Measurements.decode(dec)!;
  assert(m2.values.len == 3, "f64 array: count");
  assert(m2.values[0] == 1.5, "f64 array: 0");
}

bool_array_test() `test {
  Flags f1 = Flags(bits: [true, false, true]);
  json.JsonEncoder enc = json.JsonEncoder();
  f1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Flags f2 = Flags.decode(dec)!;
  assert(f2.bits.len == 3, "bool array: count");
  assert(f2.bits[0] == true, "bool array: 0");
  assert(f2.bits[1] == false, "bool array: 1");
}

single_element_array_test() `test {
  Flags f1 = Flags(bits: [true]);
  json.JsonEncoder enc = json.JsonEncoder();
  f1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Flags f2 = Flags.decode(dec)!;
  assert(f2.bits.len == 1, "single elem: count");
}

// ── Map with non-string values ──────────────────────────────────────────────

map_string_int_test() `test {
  Counters c1 = Counters(counts: map[string, int]());
  c1.counts["views"] = 100;
  c1.counts["clicks"] = 5;
  json.JsonEncoder enc = json.JsonEncoder();
  c1.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"views\":100"), "map int: views");
}

// ── Map with non-string keys ────────────────────────────────────────────────

int_key_map_encode_test() `test {
  IntKeyMap m = IntKeyMap(data: map[int, string]());
  m.data[42] = "answer";
  json.JsonEncoder enc = json.JsonEncoder();
  m.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"answer\""), "int key encode: has value");
}

int_key_map_round_trip_test() `test {
  IntKeyMap m1 = IntKeyMap(data: map[int, string]());
  m1.data[100] = "hundred";
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  IntKeyMap m2 = IntKeyMap.decode(dec)!;
}

// ── Mixed array + map in same type ──────────────────────────────────────────

mixed_array_and_map_test() `test {
  Dashboard d1 = Dashboard(title: "main", labels: ["a", "b"], metrics: map[string, int]());
  d1.metrics["total"] = 42;
  json.JsonEncoder enc = json.JsonEncoder();
  d1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Dashboard d2 = Dashboard.decode(dec)!;
  assert(d2.title == "main", "mixed: title");
  assert(d2.labels.len == 2, "mixed: labels count");
  assert(d2.labels[0] == "a", "mixed: label 0");
}

// ── Generic serializable types ──────────────────────────────────────────────

generic_wrapper_int_test() `test {
  GoodWrapper[int] w = GoodWrapper[int](value: 42, label: "answer");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"value\":42"), "generic int: value");
  assert(s.contains("\"label\":\"answer\""), "generic int: label");
}

generic_wrapper_string_test() `test {
  GoodWrapper[string] w = GoodWrapper[string](value: "hello", label: "greet");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"value\":\"hello\""), "generic string: value");
}

generic_wrapper_round_trip_test() `test {
  GoodWrapper[int] w1 = GoodWrapper[int](value: 99, label: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[int] w2 = GoodWrapper[int].decode(dec)!;
  assert(w2.value == 99, "generic rt: value");
  assert(w2.label == "test", "generic rt: label");
}

skip_wrapper_test() `test {
  SkipWrapper[int] w = SkipWrapper[int](value: 42, label: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"label\":\"test\""), "skip wrapper: label");
  assert(!s.contains("\"value\""), "skip wrapper: value skipped");
}

generic_wrapper_user_type_test() `test {
  GoodWrapper[Point] w1 = GoodWrapper[Point](value: Point(x: 1, y: 2), label: "pt");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[Point] w2 = GoodWrapper[Point].decode(dec)!;
  assert(w2.value.x == 1, "generic user type: x");
  assert(w2.value.y == 2, "generic user type: y");
  assert(w2.label == "pt", "generic user type: label");
}

generic_wrapper_bool_test() `test {
  GoodWrapper[bool] w1 = GoodWrapper[bool](value: true, label: "flag");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[bool] w2 = GoodWrapper[bool].decode(dec)!;
  assert(w2.value == true, "generic bool: value");
}

generic_wrapper_f64_test() `test {
  GoodWrapper[f64] w1 = GoodWrapper[f64](value: 3.14, label: "pi");
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  GoodWrapper[f64] w2 = GoodWrapper[f64].decode(dec)!;
  assert(w2.value == 3.14, "generic f64: value");
}

// ── Field annotations ───────────────────────────────────────────────────────

key_annotation_test() `test {
  User u = User(name: "Alice", age: 30, _internal: "secret");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"user_name\":"), "key: has user_name");
  assert(!s.contains("\"name\":"), "key: no raw name");
}

skip_annotation_test() `test {
  User u = User(name: "Bob", age: 25, _internal: "hidden");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(!s.contains("internal"), "skip: no internal field");
  assert(!s.contains("hidden"), "skip: no hidden value");
}

optional_omit_none_test() `test {
  User u = User(name: "Carol", age: 28, _internal: "x");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(!s.contains("email"), "optional none: email omitted");
}

optional_present_test() `test {
  User u = User(name: "Dave", age: 35, email: "d@test.com", _internal: "x");
  json.JsonEncoder enc = json.JsonEncoder();
  u.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"email\":\"d@test.com\""), "optional present: email included");
}

include_none_test() `test {
  WithIncludeNone w = WithIncludeNone(name: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"tag\":null"), "include_none: tag is null");
}

include_none_present_test() `test {
  WithIncludeNone w = WithIncludeNone(name: "test", tag: "hello");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"tag\":\"hello\""), "include_none present: tag has value");
}

// ── Multiple optional fields ────────────────────────────────────────────────

multiple_optionals_none_test() `test {
  WithOptionals w = WithOptionals(name: "test");
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(!s.contains("bio"), "multi opt: bio omitted");
  assert(!s.contains("level"), "multi opt: level omitted");
}

multiple_optionals_some_test() `test {
  WithOptionals w = WithOptionals(name: "test", bio: "hello", level: 5);
  json.JsonEncoder enc = json.JsonEncoder();
  w.encode(enc)!;
  string s = enc.to_string();
  assert(s.contains("\"bio\":\"hello\""), "multi opt: bio present");
  assert(s.contains("\"level\":5"), "multi opt: level present");
}

multiple_optionals_round_trip_test() `test {
  WithOptionals w1 = WithOptionals(name: "test", level: 3);
  json.JsonEncoder enc = json.JsonEncoder();
  w1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  WithOptionals w2 = WithOptionals.decode(dec)!;
  assert(w2.name == "test", "multi opt rt: name");
  assert(w2.bio is absent, "multi opt rt: bio absent");
  assert(w2.level is present, "multi opt rt: level present");
}

// ── Decode with optional fields ─────────────────────────────────────────────

decode_optional_present_test() `test {
  User u1 = User(name: "Eve", age: 40, email: "eve@test.com", _internal: "s");
  json.JsonEncoder enc = json.JsonEncoder();
  u1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  User u2 = User.decode(dec)!;
  assert(u2.name == "Eve", "decode opt present: name");
  assert(u2.age == 40, "decode opt present: age");
  assert(u2.email is present, "decode opt present: email exists");
}

decode_optional_missing_test() `test {
  User u1 = User(name: "Frank", age: 50, _internal: "s");
  json.JsonEncoder enc = json.JsonEncoder();
  u1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  User u2 = User.decode(dec)!;
  assert(u2.name == "Frank", "decode opt missing: name");
  assert(u2.age == 50, "decode opt missing: age");
  assert(u2.email is absent, "decode opt missing: email absent");
}

// ── String escaping in field values ─────────────────────────────────────────

string_escape_round_trip_test() `test {
  MixedFields m1 = MixedFields(label: "has \"quotes\" and\nnewlines", count: 1, score: 0.0, active: true);
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  MixedFields m2 = MixedFields.decode(dec)!;
  assert(m2.label == "has \"quotes\" and\nnewlines", "escape rt: label preserved");
}

// ── Edge cases ──────────────────────────────────────────────────────────────

zero_values_test() `test {
  MixedFields m1 = MixedFields(label: "", count: 0, score: 0.0, active: false);
  json.JsonEncoder enc = json.JsonEncoder();
  m1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  MixedFields m2 = MixedFields.decode(dec)!;
  assert(m2.label == "", "zero: empty string");
  assert(m2.count == 0, "zero: count");
  assert(m2.active == false, "zero: bool false");
}

negative_values_test() `test {
  Point p1 = Point(x: -42, y: -1);
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Point p2 = Point.decode(dec)!;
  assert(p2.x == -42, "negative: x");
  assert(p2.y == -1, "negative: y");
}

large_values_test() `test {
  Point p1 = Point(x: 1000000, y: -999999);
  json.JsonEncoder enc = json.JsonEncoder();
  p1.encode(enc)!;
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  Point p2 = Point.decode(dec)!;
  assert(p2.x == 1000000, "large: x");
  assert(p2.y == -999999, "large: y");
}

// ── Custom encode override ──────────────────────────────────────────────────

custom_encode_test() `test {
  CustomEncode c = CustomEncode(value: 42);
  json.JsonEncoder enc = json.JsonEncoder();
  c.encode(enc)!;
  string s = enc.to_string();
  assert(s == "\"custom:42\"", "custom encode: " + s);
}

// ── Decode with key renaming ────────────────────────────────────────────────

decode_with_key_test() `test {
  User u1 = User(name: "Grace", age: 28, _internal: "x");
  json.JsonEncoder enc = json.JsonEncoder();
  u1.encode(enc)!;
  // The encoded JSON uses "user_name" not "name" — decode must match.
  json.JsonDecoder dec = json.JsonDecoder(data: enc.to_string());
  User u2 = User.decode(dec)!;
  assert(u2.name == "Grace", "decode key: name via user_name");
  assert(u2.age == 28, "decode key: age");
}
