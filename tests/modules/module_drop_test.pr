use mathlib "./mathlib";

// flaky leak — sometimes leaks depending on timing
test_drop_basic() `test {
  r := mathlib.Resource(id: 1);
  assert(r.id == 1, "resource id == 1");
  // r dropped at scope exit
}

test_drop_multiple() `test {
  r1 := mathlib.Resource(id: 10);
  r2 := mathlib.Resource(id: 20);
  assert(r1.id + r2.id == 30, "sum of resource ids");
  // both dropped at scope exit
}

test_drop_in_if_block() `test {
  int x = 0;
  if true {
    r := mathlib.Resource(id: 42);
    x = r.id;
    // r dropped at block exit
  }
  assert(x == 42, "resource used before drop");
}

// T0406 Site 2: module free function with droppable tuple-by-value param.
test_t0406_module_func_tuple_param() `test {
  mathlib.take_tuple_in_module(("hello".to_string(), 7));
}

// T0406 Site 3: non-generic method on module type with droppable tuple param.
test_t0406_module_method_tuple_param() `test {
  c := mathlib.TupleConsumer(last_n: 0);
  c.consume_pair(("hello".to_string(), 42));
  assert(c.last_n == 42, "consumer recorded n");
}

// T0468: generic type in a module that inherits drop from a generic parent.
// Both types live in the module, so declareMonoInheritedDrops/defineMonoInheritedDrops
// run through the c.compilingModule != "" path and register the synthesized
// drop in moduleOwnedFuncs. Without the synthesis the child's own field (label)
// would leak.
test_t0468_module_inherited_drop_no_leak() `test {
  s := "label".repeat(2);
  b := mathlib._T0468ModBox[int](val: 1, label: s);
  assert(b.val == 1, "val");
  assert(b.label == "labellabel", "label");
}

// T0507: non-generic type in a module that inherits drop from a non-generic
// parent. Exercises declareInheritedModuleDrops / defineInheritedModuleDrops
// (the module-compile variant of the T0507 synthesis). Without the synthesis
// the child's own field (label) would leak.
//
// Parent is non-heap (only an int field) to avoid T0553 (preexisting bug where
// module-defined types with empty user drop bodies don't auto-append field
// drops). When T0553 is fixed, the parent can be made heap for stronger
// coverage.
test_t0507_module_inherited_drop_no_leak() `test {
  child_l := "child".repeat(2);
  b := mathlib._T0507ModBox(marker: 42, label: child_l);
  assert(b.marker == 42, "parent marker");
  assert(b.label == "childchild", "child label");
}
