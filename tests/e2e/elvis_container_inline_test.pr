// T0935: Inline (used/discarded, not bound) elvis `?:` whose result is a
// container (Vector[T]/T[]) must drop the result with the correct, path-aware
// drop function. Previously the inline result was tracked as a *string* temp and
// dropped via promise_string_drop, which read the static flag at the wrong offset
// for a vector layout and called free() on a .rodata buffer:
//   fatal: invalid free (bad header magic)
// The fix routes the inline elvis result through Vector.drop (honors the bit-63
// static flag, walks droppable elements) with a path-dependent drop flag. T0936
// then made that flag per-operand-ownership: the result frees a path's buffer only
// when it actually owns it — the moved-out inner on the some-path, and (for a LOCAL
// default, as in t_*_none below) the transferred default on the none-path, whose
// own scope-exit drop is neutralized. A parameter/borrowed/static default keeps its
// own owner, so the result borrows it (none-path flag false) — see the generic and
// structural-default tests, whose operands are parameters.
// --- static .rodata int[] operands (the reported repro) ---
t_static_some() `test {
  int[]? a = [1, 2, 3];
  int[] b = [9];
  assert((a ?: b).len == 3, "static some");
}

t_static_none() `test {
  int[]? a = none;
  int[] b = [9];
  assert((a ?: b).len == 1, "static none");
}

// --- heap (push-built, bit-63 clear) int[] operands ---

t_heap_some() `test {
  int[] av = [];
  av.push(1);
  av.push(2);
  av.push(3);
  int[]? a = av;
  int[] b = [];
  b.push(9);
  assert((a ?: b).len == 3, "heap some");
}

t_heap_none() `test {
  int[]? a = none;
  int[] b = [];
  b.push(9);
  assert((a ?: b).len == 1, "heap none");
}

// --- string[] operands: the result drop must walk droppable elements (leak
// guard) and free exactly once (some-path) or not at all (none-path). ---

t_strvec_some() `test {
  string[] av = [];
  av.push("x" + "y");
  av.push("z" + "w");
  string[]? a = av;
  string[] b = [];
  b.push("d" + "e");
  assert((a ?: b).len == 2, "strvec some");
}

t_strvec_none() `test {
  string[]? a = none;
  string[] b = [];
  b.push("d" + "e");
  assert((a ?: b).len == 1, "strvec none");
}

// T0936 changed elvis to move-at-ownership: `a ?: b` now CONSUMES both operands,
// so reusing `b` after the elvis is a compile error (`use of moved variable 'b'`),
// not a runtime use-after-free. The former `t_reuse_none` runtime guard (which
// relied on the old borrow-on-none semantics) is replaced by the negative ownership
// tests in compiler/internal/ownership/t0936_test.go and the memory-safety matrix
// in tests/e2e/elvis_container_ownership_test.pr.

// --- T0945: borrowed (plain, non-`~`) optional-vector value parameter. The
// caller owns the param and drops it after the call, so an inline elvis inside
// the callee must NOT free its some-path inner — doing so double-frees the heap
// buffer ("bad header magic"). The none-path default is borrowed too. This is
// the non-generic analogue of t_generic_strvec_some; the bug also reproduces
// without monomorphization, directly through a borrowed param. ---

borrowed_strvec_len(string[]? a, string[] b) int {
  return (a ?: b).len;
}

t_borrowed_param_some() `test {
  string[] av = [];
  av.push("k" + "v");
  string[]? a = av;
  string[] b = [];
  b.push("d" + "e");
  assert(borrowed_strvec_len(a, b) == 1, "borrowed some");
}

t_borrowed_param_none() `test {
  string[]? a = none;
  string[] b = [];
  b.push("d" + "e");
  assert(borrowed_strvec_len(a, b) == 1, "borrowed none");
}

// --- bound form must remain correct (claims the temp; variable drop handles it) ---

t_bound() `test {
  int[]? a = [1, 2, 3];
  int[] b = [9];
  m := a ?: b;
  assert(m.len == 3, "bound");
}

// --- string inline elvis regression guard (the string path was always correct) ---

t_string_inline() `test {
  string? a = "hello";
  assert((a ?: "x").len == 5, "string inline");
}

// --- generic-function context: the inline elvis result type (T[]) is resolved
// through c.typeSubst when the generic function is monomorphized. Both paths
// must be correct and leak-free for the concrete vector type. ---

inline_len[T](T[]? a, T[] b) int {
  return (a ?: b).len;
}

t_generic_some() `test {
  int[]? a = [1, 2, 3];
  int[] b = [9];
  assert(inline_len(a, b) == 3, "generic some");
}

t_generic_none() `test {
  int[]? a = none;
  int[] b = [9];
  assert(inline_len(a, b) == 1, "generic none");
}

// generic with droppable element type (string[]): the result drop must walk
// elements via the substituted Vector.drop (leak guard across monomorphization).
t_generic_strvec_some() `test {
  string[] av = [];
  av.push("p" + "q");
  string[]? a = av;
  string[] b = [];
  b.push("r" + "s");
  assert(inline_len(a, b) == 1, "generic strvec some");
}

// --- structural-interface default-method context: the default body is
// synthesized per concrete type with c.selfSubst active. The `this.base()`
// none-path operand introduces a panic-check block, so the result-temp's
// path-flag phi takes its none-incoming from that block — exercising the
// non-elvis-labeled predecessor variant. Both paths must be leak-free. ---

type HasFallback `structural {
  base() int[] `abstract;
  resolved_len(int[]? maybe) int {
    return (maybe ?: this.base()).len;
  }
}

type Config is HasFallback {
  base() int[] {
    return[7, 8];
  }
}

t_struct_default_some() `test {
  c := Config();
  int[]? a = [1, 2, 3];
  assert(c.resolved_len(a) == 3, "struct default some");
}

t_struct_default_none() `test {
  c := Config();
  int[]? a = none;
  assert(c.resolved_len(a) == 2, "struct default none");
}

// ============================================================================
// T0937: value-struct container results (Map/Set) and heap user types. These are
// 2-word Value structs {i8* vtable, i8* instance}, not bare i8*, so they bypass
// trackElvisResultTemp (T0935's i8*-only path) and need the heapTemp path with a
// per-branch flag. The some-path inner is owned (must free exactly once); the
// none-path borrows the default (must NOT free). Source classification gates
// tracking: owned local ident → track; member/index source and borrowed param →
// owner-governed (do NOT track, else double-free); temporary optional → track.
// ============================================================================

// --- map[K,V] ident source: the reported repro. some leaks 2 / none unaffected. ---

t_map_some() `test {
  map[string, int]? a = {
    "x": 1, "y": 2
  };
  map[string, int] b = {
    "z": 9
  };
  assert((a ?: b).len == 2, "map some");
}

t_map_none() `test {
  map[string, int]? a = none;
  map[string, int] b = {
    "z": 9
  };
  assert((a ?: b).len == 1, "map none");
}

// --- Set[T] (wrapper around Map[T, bool], same {i8*,i8*} layout) ident source ---

t_set_some() `test {
  Set[int] av = Set[int]();
  av.add(1);
  av.add(2);
  av.add(3);
  Set[int]? a = av;
  Set[int] b = Set[int]();
  b.add(9);
  assert((a ?: b).len == 3, "set some");
}

t_set_none() `test {
  Set[int]? a = none;
  Set[int] b = Set[int]();
  b.add(9);
  assert((a ?: b).len == 1, "set none");
}

// --- member source: the extracted inner aliases the owned field; the container's
// own drop frees it. The elvis result must NOT be tracked (double-free guard). ---

type MBox {
  map[string, int]? m;
}

t_map_member_some() `test {
  MBox bx = MBox(m: {
    "x": 1, "y": 2
  });
  map[string, int] b = {
    "z": 9
  };
  assert((bx.m ?: b).len == 2, "map member some");
}

t_map_member_none() `test {
  MBox bx = MBox(m: none);
  map[string, int] b = {
    "z": 9
  };
  assert((bx.m ?: b).len == 1, "map member none");
}

// --- bound form: the binding claims the temp (claimHeapTemp by runtime pointer
// identity), neutralizing the path-flag so only the variable's drop fires. ---

t_map_bound() `test {
  map[string, int]? a = {
    "x": 1, "y": 2
  };
  map[string, int] b = {
    "z": 9
  };
  m := a ?: b;
  assert(m.len == 2, "map bound");
}

// --- temporary-optional source: a call result is never scope-tracked, so the
// some-path inner is orphaned and the result must own it. ---

mk_opt_map() map[string, int]? {
  return {
    "x": 1, "y": 2
  };
}

t_map_temp_some() `test {
  map[string, int] b = {
    "z": 9
  };
  assert((mk_opt_map() ?: b).len == 2, "map temp some");
}

// --- paren-ident source: proves the paren-peel at the clearDropFlag site —
// `(a) ?: b` must clear a's drop flag, else the local's drop double-frees. ---

t_map_paren_some() `test {
  map[string, int]? a = {
    "x": 1, "y": 2
  };
  map[string, int] b = {
    "z": 9
  };
  assert(((a) ?: b).len == 2, "map paren some");
}

// NB: a none-path operand-REUSE test (`x := (a ?: b).len; y := b.len`) is
// intentionally omitted. Under T0936 the elvis `?:` consumes (moves) BOTH ident
// operands — the none-path default is moved into the result — so reusing `b`
// afterward is a static use-after-move, rejected by the ownership pass (see
// compiler/internal/ownership/t0936_test.go). The none-path leak behavior is
// covered by t_map_none / t_set_none above.

// --- heap user type {i8*, i8*} (T0924 subsumption): a droppable non-value type
// used inline. some owns the moved inner; member source is owner-governed. ---

type HVal {
  string s;
}

t_huser_some() `test {
  HVal av = HVal(s: "a" + "b");
  HVal? a = av;
  HVal b = HVal(s: "c" + "d");
  assert((a ?: b).s.len == 2, "huser some");
}

t_huser_none() `test {
  HVal? a = none;
  HVal b = HVal(s: "c" + "d");
  assert((a ?: b).s.len == 2, "huser none");
}

type HBox {
  HVal? h;
}

t_huser_member_some() `test {
  HBox bx = HBox(h: HVal(s: "a" + "b"));
  HVal b = HVal(s: "c" + "d");
  assert((bx.h ?: b).s.len == 2, "huser member some");
}

// heap-user temporary-optional source: a call result is never scope-tracked, so
// the some-path inner is orphaned and the elvis result must own + free it once.
mk_opt_hval() HVal? {
  return HVal(s: "a" + "b");
}

t_huser_temp_some() `test {
  HVal b = HVal(s: "c" + "d");
  assert((mk_opt_hval() ?: b).s.len == 2, "huser temp some");
}

// heap-user bound form: the binding claims the temp by runtime pointer identity
// (claimHeapTemp on the value struct), neutralizing the path-flag so only the
// variable's own drop fires — no leak, no double-free.
t_huser_bound() `test {
  HVal av = HVal(s: "a" + "b");
  HVal? a = av;
  HVal b = HVal(s: "c" + "d");
  h := a ?: b;
  assert(h.s.len == 2, "huser bound");
}

// heap-user index source (IndexExpr arm): the extracted inner aliases the vector
// element the container's drop frees, so the result must NOT be tracked. some is
// a single free (no double-free); none borrows the default.
t_huser_index_some() `test {
  (HVal?)[] v = [];
  v.push(HVal(s: "a" + "b"));
  HVal b = HVal(s: "c" + "d");
  assert((v[0] ?: b).s.len == 2, "huser index some");
}

t_huser_index_none() `test {
  (HVal?)[] v = [];
  v.push(none);
  HVal b = HVal(s: "c" + "d");
  assert((v[0] ?: b).s.len == 2, "huser index none");
}

// heap-user borrowed-param source (T0931 gate for the value-struct path): the
// param has no local drop flag → the caller owns it. The result must NOT be
// tracked (no double-free) and the some-path must not leak (caller drops it).
borrowed_hval_len(HVal? a, HVal b) int {
  return (a ?: b).s.len;
}

t_huser_borrowed_some() `test {
  HVal av = HVal(s: "a" + "b");
  HVal? a = av;
  HVal b = HVal(s: "c" + "d");
  assert(borrowed_hval_len(a, b) == 2, "huser borrowed some");
}

t_huser_borrowed_none() `test {
  HVal? a = none;
  HVal b = HVal(s: "c" + "d");
  assert(borrowed_hval_len(a, b) == 2, "huser borrowed none");
}

// --- heap-user type WITH a vtable (has a child → needsVtable): exercises
// resolveDropFuncForTemp on a virtual-dispatch type. The inline some-path must
// own + drop the moved inner exactly once via the type's drop. ---

type Animal {
  string name;
  speak() string {
    return "base";
  }
}

type Dog is Animal {
  speak() string {
    return "woof";
  }
}

t_huser_vtable_some() `test {
  Animal av = Animal(name: "x" + "y");
  Animal? a = av;
  Animal b = Animal(name: "z" + "w");
  assert((a ?: b).speak().len == 4, "huser vtable some");
}

t_huser_vtable_none() `test {
  Animal? a = none;
  Animal b = Animal(name: "z" + "w");
  assert((a ?: b).speak().len == 4, "huser vtable none");
}

t_huser_vtable_temp_some() `test {
  Animal b = Animal(name: "z" + "w");
  assert((mk_opt_animal() ?: b).speak().len == 4, "huser vtable temp some");
}

mk_opt_animal() Animal? {
  return Animal(name: "a" + "b");
}

// --- borrowed-param source (T0931 gate): the parameter has no local drop flag,
// so the caller owns it. The elvis result must NOT be tracked (no double-free)
// and the some-path must not leak (the caller still owns and drops the original). ---

borrowed_map_len(map[string, int]? a, map[string, int] b) int {
  return (a ?: b).len;
}

t_map_borrowed_some() `test {
  map[string, int]? a = {
    "x": 1, "y": 2
  };
  map[string, int] b = {
    "z": 9
  };
  assert(borrowed_map_len(a, b) == 2, "map borrowed some");
}

t_map_borrowed_none() `test {
  map[string, int]? a = none;
  map[string, int] b = {
    "z": 9
  };
  assert(borrowed_map_len(a, b) == 1, "map borrowed none");
}

// ============================================================================
// T0937 (i8*-container gap closure): the i8* result path (trackElvisResultTemp,
// T0935) must apply the SAME orphan classifier as the value-struct path. A
// member-source or borrowed-param string[]/vector elvis aliases an allocation the
// owner already drops; the some-path inner is NOT orphaned, so tracking it as an
// owned temp double-frees. With droppable element types (string[]) this freed the
// elements twice and crashed (use-after-free / segfault). These guard that the
// inline some-path is a single free (owner drops once) — no leak, no crash.
// ============================================================================

type SVBox {
  string[]? v;
}

// member-source string[] elvis (droppable elements): the field owner (bx) drops
// the inner exactly once; the inline result must NOT also free it.
t_strvec_member_some() `test {
  string[] inner = [];
  inner.push("p" + "q");
  inner.push("r" + "s");
  SVBox bx = SVBox(v: inner);
  string[] b = [];
  b.push("x" + "y");
  assert((bx.v ?: b).len == 2, "strvec member some");
}

t_strvec_member_none() `test {
  SVBox bx = SVBox(v: none);
  string[] b = [];
  b.push("x" + "y");
  assert((bx.v ?: b).len == 1, "strvec member none");
}

// borrowed-param string[] elvis (droppable elements): the caller owns the moved-in
// vector and drops it once; the callee's inline some-path must NOT free it. Reuses
// the borrowed_strvec_len helper defined above (T0945) — same borrowed-param shape,
// exercised here with droppable elements and a 2-element source.

t_strvec_borrowed_some() `test {
  string[] av = [];
  av.push("p" + "q");
  av.push("r" + "s");
  string[]? a = av;
  string[] b = [];
  b.push("x" + "y");
  assert(borrowed_strvec_len(a, b) == 2, "strvec borrowed some");
}

t_strvec_borrowed_none() `test {
  string[]? a = none;
  string[] b = [];
  b.push("x" + "y");
  assert(borrowed_strvec_len(a, b) == 1, "strvec borrowed none");
}

// owned `~`-param string[] elvis: the consume param HAS a local drop flag, so the
// callee owns the inner. The some-path clears that flag (ownership → result), so
// the inline result MUST be tracked and freed exactly once (no leak).
consume_strvec_len(~string[]? a, string[] b) int {
  return (a ?: b).len;
}

t_strvec_consume_some() `test {
  string[] av = [];
  av.push("p" + "q");
  av.push("r" + "s");
  string[]? a = av;
  string[] b = [];
  b.push("x" + "y");
  assert(consume_strvec_len(a, b) == 2, "strvec consume some");
}

t_strvec_consume_none() `test {
  string[] b = [];
  b.push("x" + "y");
  assert(consume_strvec_len(none, b) == 1, "strvec consume none");
}

// --- bound member-source elvis (`string[] x = (bx.v ?: b)`): the variable
// binding context sets the dup-field flag, so the field read CLONES the inner —
// the clone is tracked and claimed by the variable independently of the elvis
// result. The orphan gate (which skips tracking the member-source result) must
// not regress this: the clone is freed once by the variable, the original once by
// the container's drop. Guards that the gate is inert for the bound/clone path. ---

t_strvec_bound_member_some() `test {
  string[] inner = [];
  inner.push("p" + "q");
  inner.push("r" + "s");
  SVBox bx = SVBox(v: inner);
  string[] b = [];
  b.push("x" + "y");
  string[] x = (bx.v ?: b);
  assert(x.len == 2, "strvec bound member some");
}
// NB: the bound member-source NONE variant (`SVBox(v: none)` → `string[] x =
// (bx.v ?: b)`) is intentionally NOT tested here — it triggers a pre-existing,
// unrelated crash (T0939): the binding context eagerly dup-clones the
// optional-container field, and the clone loop walks a `none` field's garbage
// inner when the element type is droppable. Independent of elvis-result tracking
// and of this fix (reproduces identically at HEAD).

// ============================================================================
// T0937 (substitution-context closure): the orphan gate added by this fix makes
// the existing `t_generic_*` / `t_struct_default_*` tests (borrowed params)
// short-circuit BEFORE the result-type substitution in the tracking functions —
// a borrowed source is not orphaned, so tracking returns at the gate. The cases
// below use an ORPHANED source (owned `~`-param or owned local) inside a generic
// function and a structural-interface default method, so tracking proceeds and
// the elvis result type is resolved through c.typeSubst (monomorphization) /
// c.selfSubst (default-body synthesis) before the drop func is chosen. Both the
// value-struct path (Map, via trackElvisResultHeap) and the i8* path (string[],
// via trackElvisResultTemp) are covered. All must be leak-free.
// ============================================================================

// --- generic `~map[K,V]?` consume: orphaned some-path → result owns the inner;
// result type resolved through typeSubst at monomorphization (value-struct path). ---

gconsume_map_len[K: Hashable + Equal, V](~map[K, V]? a, map[K, V] b) int {
  return (a ?: b).len;
}

t_gmap_consume_some() `test {
  map[string, int]? a = {
    "x": 1, "y": 2
  };
  map[string, int] b = {
    "z": 9
  };
  assert(gconsume_map_len(a, b) == 2, "gmap consume some");
}

t_gmap_consume_none() `test {
  map[string, int] b = {
    "z": 9
  };
  assert(gconsume_map_len(none, b) == 1, "gmap consume none");
}

// --- generic `~T[]?` consume: same, for the i8* container path (string[]). ---

gconsume_vec_len[T](~T[]? a, T[] b) int {
  return (a ?: b).len;
}

t_gvec_consume_some() `test {
  string[] av = [];
  av.push("p" + "q");
  av.push("r" + "s");
  string[]? a = av;
  string[] b = [];
  b.push("x" + "y");
  assert(gconsume_vec_len(a, b) == 2, "gvec consume some");
}

t_gvec_consume_none() `test {
  string[] b = [];
  b.push("x" + "y");
  assert(gconsume_vec_len(none, b) == 1, "gvec consume none");
}

// --- structural default method, owned-local map source: selfSubst active during
// per-concrete-type body synthesis. The none-path `this.base_map()` call also
// makes the result-flag phi's none-incoming a non-`elvis.none` block. ---

type HasMapFallback `structural {
  base_map() map[string, int] `abstract;
  resolved_map_len() int {
    map[string, int]? a = {
      "x": 1, "y": 2
    };
    return (a ?: this.base_map()).len;
  }
}

type MapConfig is HasMapFallback {
  base_map() map[string, int] {
    return {
      "k": 7
    };
  }
}

t_struct_map_default_some() `test {
  c := MapConfig();
  assert(c.resolved_map_len() == 2, "struct map default some");
}

// --- structural default method, owned-local vector source (i8* path). ---

type HasVecFallback `structural {
  base_vec() string[] `abstract;
  resolved_vec_len() int {
    string[] av = [];
    av.push("p" + "q");
    string[]? a = av;
    return (a ?: this.base_vec()).len;
  }
}

type VecConfig is HasVecFallback {
  base_vec() string[] {
    r := ["z" + "w"];
    return r;
  }
}

t_struct_vec_default_some() `test {
  c := VecConfig();
  assert(c.resolved_vec_len() == 1, "struct vec default some");
}

// --- index source (`v[i] ?: b`): the IndexExpr arm of elvisSomeInnerOrphaned —
// the extracted inner aliases a container element the container's drop frees, so
// the result must NOT be tracked (double-free guard), and the some-path must be a
// single free. Covered for both the value-struct (map) and i8* (string[]) paths
// with droppable contents. ---

t_index_map_some() `test {
  (map[string, int]?)[] v = [];
  v.push( {
    "x": 1, "y": 2
  });
  map[string, int] b = {
    "z": 9
  };
  assert((v[0] ?: b).len == 2, "index map some");
}

t_index_map_none() `test {
  (map[string, int]?)[] v = [];
  v.push(none);
  map[string, int] b = {
    "z": 9
  };
  assert((v[0] ?: b).len == 1, "index map none");
}

t_index_strvec_some() `test {
  (string[]?)[] v = [];
  string[] inner = [];
  inner.push("p" + "q");
  inner.push("r" + "s");
  v.push(inner);
  string[] b = [];
  b.push("x" + "y");
  assert((v[0] ?: b).len == 2, "index strvec some");
}

// ============================================================================
// T0951: single-owner native handle results (Arc/Channel/Mutex/Weak/Task). These
// are bare i8* handles, not Vector/string (trackElvisResultTemp's only resolved
// types) and not 2-word {i8*,i8*} value structs (trackElvisResultHeap's shape), so
// an inline orphaned-source elvis result had no drop path in EITHER tracker → leak
// (Arc/Weak/Channel each leaked their inner allocation; Mutex leaked 3, Task 2).
// The fix (elvisResultHandleDrop) resolves the handle's native drop — Arc.drop /
// Channel.drop / Mutex.drop / Weak.drop / Task drop — and registers it with the
// SAME per-branch flag the other representations use: owned on the orphaned
// some-path, borrowed on the none-path (the default keeps its own owner). Source
// classification gates tracking exactly as for the other classes — owned local /
// temporary optional → track; borrowed param → owner-governed (do NOT track, else
// double-free). A bound use claims the temp (stmt.go handle-claim path), so only
// the variable's binding drops it.
// ============================================================================

// --- Ref[T] ident source: the reported repro. some leaked 1 alloc at HEAD. ---

t_arc_some() `test {
  Ref[int]? a = Ref[int](7);
  Ref[int] b = Ref[int](9);
  assert((a ?: b).borrow == 7, "arc some");
}

t_arc_none() `test {
  Ref[int]? a = none;
  Ref[int] b = Ref[int](9);
  assert((a ?: b).borrow == 9, "arc none");
}

// temporary-optional source: a call result is never scope-tracked, so the some-path
// inner is orphaned and the result must own + free it once.
mk_opt_arc() Ref[int]? {
  return Ref[int](7);
}

t_arc_temp_some() `test {
  Ref[int] b = Ref[int](9);
  assert((mk_opt_arc() ?: b).borrow == 7, "arc temp some");
}

// bound form: the variable claims the handle temp; only its scope binding drops it.
t_arc_bound() `test {
  Ref[int]? a = Ref[int](7);
  Ref[int] b = Ref[int](9);
  x := a ?: b;
  assert(x.borrow == 7, "arc bound");
}

// borrowed-param source: the caller owns and drops both operands; the some-path
// inner is NOT orphaned, so the orphan gate skips tracking (no double-free, no leak).
borrowed_arc_val(Ref[int]? a, Ref[int] b) int {
  return (a ?: b).borrow;
}

t_arc_borrowed_some() `test {
  Ref[int]? a = Ref[int](7);
  Ref[int] b = Ref[int](9);
  assert(borrowed_arc_val(a, b) == 7, "arc borrowed some");
}

t_arc_borrowed_none() `test {
  Ref[int]? a = none;
  Ref[int] b = Ref[int](9);
  assert(borrowed_arc_val(a, b) == 9, "arc borrowed none");
}

// --- Channel[T] ident source: discarded close() on the inline result (bare i8*,
// Channel.drop walks any buffered items then frees). Channel works single-threaded
// so no wasm exclusion is needed. ---

t_chan_some() `test {
  Channel[int]? a = Channel[int](1);
  Channel[int] b = Channel[int](1);
  (a ?: b).close();
}

t_chan_none() `test {
  Channel[int]? a = none;
  Channel[int] b = Channel[int](1);
  (a ?: b).close();
}

mk_opt_chan() Channel[int]? {
  return Channel[int](1);
}

t_chan_temp_some() `test {
  Channel[int] b = Channel[int](1);
  (mk_opt_chan() ?: b).close();
}

t_chan_bound() `test {
  Channel[int]? a = Channel[int](1);
  Channel[int] b = Channel[int](1);
  x := a ?: b;
  x.close();
}

borrowed_chan_close(Channel[int]? a, Channel[int] b) {
  (a ?: b).close();
}

t_chan_borrowed_some() `test {
  Channel[int]? a = Channel[int](1);
  Channel[int] b = Channel[int](1);
  borrowed_chan_close(a, b);
  assert(true, "chan borrowed some");
}

// --- Mutex[T] ident source: `.lock()` promotes the inline handle temp to a scope
// binding (T0655) so it outlives the guard. The promotion now stores the temp's
// per-branch flag instead of a hardcoded 1 — on the none-path the borrowed default
// must NOT be force-dropped (its own binding drops it → would double-free). ---

t_mutex_some() `test {
  Mutex[int]? a = Mutex[int](7);
  Mutex[int] b = Mutex[int](9);
  g := (a ?: b).lock();
  assert(g.borrow == 7, "mutex some");
  g.close();
}

t_mutex_none() `test {
  Mutex[int]? a = none;
  Mutex[int] b = Mutex[int](9);
  g := (a ?: b).lock();
  assert(g.borrow == 9, "mutex none");
  g.close();
}

mk_opt_mutex() Mutex[int]? {
  return Mutex[int](7);
}

t_mutex_temp_some() `test {
  Mutex[int] b = Mutex[int](9);
  g := (mk_opt_mutex() ?: b).lock();
  assert(g.borrow == 7, "mutex temp some");
  g.close();
}

// bound some: the variable claims the Mutex handle temp; its scope binding drops it.
t_mutex_bound() `test {
  Mutex[int]? a = Mutex[int](7);
  Mutex[int] b = Mutex[int](9);
  m := a ?: b;
  g := m.lock();
  assert(g.borrow == 7, "mutex bound");
  g.close();
}

// borrowed-param: orphan gate skips tracking → the `.lock()` promotion is a no-op
// (the receiver is not a tracked temp). Caller owns and drops both mutexes.
borrowed_mutex_val(Mutex[int]? a, Mutex[int] b) int {
  g := (a ?: b).lock();
  r := g.borrow;
  g.close();
  return r;
}

t_mutex_borrowed_some() `test {
  Mutex[int]? a = Mutex[int](7);
  Mutex[int] b = Mutex[int](9);
  assert(borrowed_mutex_val(a, b) == 7, "mutex borrowed some");
}

t_mutex_borrowed_none() `test {
  Mutex[int]? a = none;
  Mutex[int] b = Mutex[int](9);
  assert(borrowed_mutex_val(a, b) == 9, "mutex borrowed none");
}

// --- Weak[T] ident source: the inline elvis result is a Weak[int]; `.upgrade()`
// borrows it (returning Ref[int]?) and the Weak temp must be dropped after. The
// `?: Ref[int](0)` second elvis yields the Arc whose .borrow is read. ---

t_weak_some() `test {
  Ref[int] keep = Ref[int](7);
  Weak[int]? a = keep.downgrade();
  Weak[int] b = keep.downgrade();
  assert(((a ?: b).upgrade() ?: Ref[int](0)).borrow == 7, "weak some");
}

t_weak_none() `test {
  Ref[int] keep = Ref[int](7);
  Weak[int]? a = none;
  Weak[int] b = keep.downgrade();
  assert(((a ?: b).upgrade() ?: Ref[int](0)).borrow == 7, "weak none");
}

mk_opt_weak(Ref[int] &src) Weak[int]? {
  return src.downgrade();
}

t_weak_temp_some() `test {
  Ref[int] keep = Ref[int](7);
  Weak[int] b = keep.downgrade();
  assert(((mk_opt_weak(keep) ?: b).upgrade() ?: Ref[int](0)).borrow == 7, "weak temp some");
}

t_weak_bound() `test {
  Ref[int] keep = Ref[int](7);
  Weak[int]? a = keep.downgrade();
  Weak[int] b = keep.downgrade();
  w := a ?: b;
  assert((w.upgrade() ?: Ref[int](0)).borrow == 7, "weak bound");
}

borrowed_weak_val(Weak[int]? a, Weak[int] b) int {
  return ((a ?: b).upgrade() ?: Ref[int](0)).borrow;
}

t_weak_borrowed_some() `test {
  Ref[int] keep = Ref[int](7);
  Weak[int]? a = keep.downgrade();
  Weak[int] b = keep.downgrade();
  assert(borrowed_weak_val(a, b) == 7, "weak borrowed some");
}

// --- MutexGuard[T] ident source: the inline elvis result is a MutexGuard[int] (the
// value `.lock()` returns), used inline via `.borrow`. This is the one handle class
// whose drop is a single non-parameterized function (`c.funcs["MutexGuard.drop"]`,
// the `named == TypMutexGuard` arm of elvisResultHandleDrop), distinct from the
// per-instantiation getOrCreate*Drop the other handles use. The orphaned some-path
// guard must be released exactly once — at HEAD t_guard_some / t_guard_temp_some
// each leaked 1 allocation (the guard had no drop path in either tracker). ---

t_guard_some() `test {
  Mutex[int] m1 = Mutex[int](7);
  Mutex[int] m2 = Mutex[int](9);
  MutexGuard[int]? a = m1.lock();
  MutexGuard[int] b = m2.lock();
  assert((a ?: b).borrow == 7, "guard some");
}

t_guard_none() `test {
  Mutex[int] m1 = Mutex[int](7);
  Mutex[int] m2 = Mutex[int](9);
  MutexGuard[int]? a = none;
  MutexGuard[int] b = m2.lock();
  assert((a ?: b).borrow == 9, "guard none");
}

// temporary-optional source: the guard must outlive the Mutex it locks, so the
// helper borrows the Mutex (`&m`) rather than owning a local one (which would be
// dropped at return, dangling the guard).
mk_opt_guard(Mutex[int] &m) MutexGuard[int]? {
  return m.lock();
}

t_guard_temp_some() `test {
  Mutex[int] m1 = Mutex[int](7);
  Mutex[int] m2 = Mutex[int](9);
  MutexGuard[int] b = m2.lock();
  assert((mk_opt_guard(m1) ?: b).borrow == 7, "guard temp some");
}

// bound form: the variable claims the guard temp; only its scope binding drops it
// (releasing m1's lock). `g.close()` is the explicit guard release.
t_guard_bound() `test {
  Mutex[int] m1 = Mutex[int](7);
  Mutex[int] m2 = Mutex[int](9);
  MutexGuard[int]? a = m1.lock();
  MutexGuard[int] b = m2.lock();
  g := a ?: b;
  assert(g.borrow == 7, "guard bound");
  g.close();
}

// borrowed-param source: the caller owns and releases both guards; the orphan gate
// skips tracking so the inline result borrows (no double-free, no leak).
borrowed_guard_val(MutexGuard[int]? a, MutexGuard[int] b) int {
  return (a ?: b).borrow;
}

t_guard_borrowed_some() `test {
  Mutex[int] m1 = Mutex[int](7);
  Mutex[int] m2 = Mutex[int](9);
  MutexGuard[int]? a = m1.lock();
  MutexGuard[int] b = m2.lock();
  assert(borrowed_guard_val(a, b) == 7, "guard borrowed some");
}

t_guard_borrowed_none() `test {
  Mutex[int] m1 = Mutex[int](7);
  Mutex[int] m2 = Mutex[int](9);
  MutexGuard[int]? a = none;
  MutexGuard[int] b = m2.lock();
  assert(borrowed_guard_val(a, b) == 9, "guard borrowed none");
}

// --- generic-context handle elvis: the inline elvis result type is `Channel[T]`
// (TypeParam T); elvisResultHandleDrop must substitute it to the concrete
// `Channel[int]` before resolving the element type, else the drop resolves against
// an unbound TypeParam. Locks the typeSubst arm at runtime — the orphaned some-path
// channel inside the monomorphized body must be freed exactly once. ---

pick_chan_close[T](T seed) {
  Channel[T]? a = Channel[T](1);
  Channel[T] b = Channel[T](1);
  (a ?: b).close();
}

t_generic_handle_elvis() `test {
  pick_chan_close(7);
  pick_chan_close(true);
  assert(true, "generic handle elvis");
}

// --- Task[T] ident source: discarded `(a ?: b);` is the leak repro (the handle is
// neither awaited nor bound). The await form `<-(a ?: b)` already consumes the
// handle, so only the discarded form leaked at HEAD. Tasks need the scheduler →
// `exclude: wasm`. cleanupStmtTemps routes the Task drop through the cooperative
// join automatically. ---

get_42() int {
  return 42;
}

t_task_some() `test(exclude: wasm) {
  Task[int]? a = go get_42();
  Task[int] b = go get_42();
  (a ?: b);
}

t_task_none() `test(exclude: wasm) {
  Task[int]? a = none;
  Task[int] b = go get_42();
  (a ?: b);
}

mk_opt_task() Task[int]? {
  return go get_42();
}

t_task_temp_some() `test(exclude: wasm) {
  Task[int] b = go get_42();
  (mk_opt_task() ?: b);
}

t_task_bound() `test(exclude: wasm) {
  Task[int]? a = go get_42();
  Task[int] b = go get_42();
  t := a ?: b;
  assert((<-t) == 42, "task bound");
}

// await form, SOME path only: `<-(a ?: b)` consumes the handle (already correct at
// HEAD); guards that handle tracking does not double-free the awaited handle. On the
// some-path genElvis clears the source ident's drop flag, so the awaited orphaned
// inner has no other owner. The NONE-path analog (`a = none`, owned-local default
// `b`) double-frees `b` — the await joins+frees b's G and b's scope binding frees it
// again — and crashes at HEAD independent of this fix; filed as T0954
// (await-on-elvis-none-path-owned-default double-free), so no `t_task_await_none`.
t_task_await_some() `test(exclude: wasm) {
  Task[int]? a = go get_42();
  Task[int] b = go get_42();
  assert((<-(a ?: b)) == 42, "task await some");
}

// borrowed-param: the orphan gate skips tracking, so the discarded inline result
// borrows the selected task and the caller owns + joins both. (The await form
// `<-(a ?: b)` is NOT used here — awaiting consumes the handle, which a borrowed
// source must not do. T0953 (resolved) now makes that form a compile-time ownership
// error — `cannot await borrowed task ...` — rather than the HEAD SEGV, so it can no
// longer be a runtime test; the rejection is covered by the Go ownership tests
// (TestT0953_*). This discard form stays as the runtime test for the legal
// non-consuming borrowed-source path.)
borrowed_task_discard(Task[int]? a, Task[int] b) {
  (a ?: b);
}

t_task_borrowed_some() `test(exclude: wasm) {
  Task[int]? a = go get_42();
  Task[int] b = go get_42();
  borrowed_task_discard(a, b);
  assert(true, "task borrowed some");
}
