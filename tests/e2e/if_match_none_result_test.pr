// T0496: `if cond { h.opt_field } else { none }` as a block-result expression.
//
// When one arm reads an `Optional[Vector|Channel|Arc|Weak]` field from a
// droppable owner and the other arm is `none`, the `none` literal used to lower
// to a bare `i1 0` (void-optional fallback) instead of a zero value of the
// shared Optional result type, producing a malformed phi: one incoming had the
// Optional struct type `{ i1, ptr }` and the other was `i1`. The fix propagates
// the if/match result type as the contextual target type for each arm so `none`
// lowers to the correct Optional shape. Leak detection (on by default) guards
// the none-zero / field-dup interaction against any double-free or leak.
type Holder {
  int[]? items;
  drop(~this) {
  }
}

_make_dynamic_vec() int[] {
  v := int[]();
  for i := 0; i < 10; i++ {
    v.push(i);
  }
  return v;
}

// Exact item repro: Optional[Vector] field from a droppable owner, then arm.
if_none_vector_then_selected() `test {
  h := Holder(items: _make_dynamic_vec());
  flag := true;
  vopt := if flag {
    h.items
  } else {
    none
  };
  if v := vopt {
    assert(v.len == 10, "then arm forwards the field's vector");
  } else {
    assert(false, "then arm should be selected");
  }
}

// `none` arm selected — must be a well-formed empty Optional.
if_none_vector_else_selected() `test {
  h := Holder(items: _make_dynamic_vec());
  flag := false;
  vopt := if flag {
    h.items
  } else {
    none
  };
  matched := false;
  if v := vopt {
    matched = true;
    assert(v.len >= 0, "unreachable");
  }
  assert(!matched, "none arm yields an empty optional");
}

// match equivalent: `match flag { true => h.items, _ => none }`.
match_none_vector_then_selected() `test {
  h := Holder(items: _make_dynamic_vec());
  flag := true;
  vopt := match flag {
    true => h.items, _ => none,
  };
  if v := vopt {
    assert(v.len == 10, "match true arm forwards the field's vector");
  } else {
    assert(false, "match true arm should be selected");
  }
}

match_none_vector_else_selected() `test {
  h := Holder(items: _make_dynamic_vec());
  flag := false;
  vopt := match flag {
    true => h.items, _ => none,
  };
  matched := false;
  if v := vopt {
    matched = true;
    assert(v.len >= 0, "unreachable");
  }
  assert(!matched, "match none arm yields an empty optional");
}

// Non-droppable payload breadth: Optional[int] confirms the zero-value shape
// across payload types (plain scalar, no heap dup involved).
type IntBox {
  int? value;
}

if_none_int_payload() `test {
  b := IntBox(value: 7);
  flag := true;
  iopt := if flag {
    b.value
  } else {
    none
  };
  if v := iopt {
    assert(v == 7, "then arm forwards the int field");
  } else {
    assert(false, "then arm should be selected");
  }

  jopt := if false {
    b.value
  } else {
    none
  };
  matched := false;
  if v := jopt {
    matched = true;
    assert(v == 7, "unreachable");
  }
  assert(!matched, "none arm yields an empty optional");
}

// Optional[string] payload — heap-droppable scalar field, distinct from vector.
type StrBox {
  string? name;
}

match_none_string_payload() `test {
  s := StrBox(name: "hello");
  iopt := match true {
    true => s.name, _ => none,
  };
  if v := iopt {
    assert(v == "hello", "match true arm forwards the string field");
  } else {
    assert(false, "match true arm should be selected");
  }
}

// Enum subject — exercises genEnumMatch (the bool matches above are value
// matches). A `_ => none` arm whose sibling reads an `int?` field must still
// lower to the Optional zero value.
enum Tag {
  First, Second,
}

enum_match_none_first_selected() `test {
  b := IntBox(value: 7);
  opt := match Tag.First {
    Tag.First => b.value, _ => none,
  };
  if v := opt {
    assert(v == 7, "enum First arm forwards the int field");
  } else {
    assert(false, "enum First arm should be selected");
  }
}

enum_match_none_else_selected() `test {
  b := IntBox(value: 7);
  opt := match Tag.Second {
    Tag.First => b.value, _ => none,
  };
  matched := false;
  if v := opt {
    matched = true;
    assert(v == 0, "unreachable");
  }
  assert(!matched, "enum none arm yields an empty optional");
}

// Enum subject reading a droppable Optional[Vector] field — leak guard for the
// none-zero / field-dup interaction on the genEnumMatch path.
enum_match_none_vector_droppable() `test {
  h := Holder(items: _make_dynamic_vec());
  vopt := match Tag.First {
    Tag.First => h.items, _ => none,
  };
  if v := vopt {
    assert(v.len == 10, "enum arm forwards the field's vector");
  } else {
    assert(false, "enum First arm should be selected");
  }
}

// T1189: the sibling arm is a BARE non-optional value (a fresh `D(x:..)` or scalar
// literal), not an already-Optional field read. Sema now unifies `none` + `T` to
// `T?` and codegen wraps the bare arm to `{ i1, T }`. Pre-fix, a `none`-first arm
// produced a malformed `i64` phi (`opt` rejected the module) and a `none`-second
// arm silently miscompiled the none path to `Some(zero)` → segfault. Both arm
// orderings and both selected paths are asserted below (via `?:` elvis + field
// read), across value-match, enum-match, and if-expr. Leak detection guards the
// none-zero / value-arm interaction.
type D {
  int x;
}

_vm_a(int k) D? {
  return match k {
    0 => none, _ => D(x: 1),
  };
}

_vm_b(int k) D? {
  return match k {
    0 => D(x: 1), _ => none,
  };
}

value_match_bare_user_type() `test {
  assert((_vm_a(0) ?: D(x: 42)).x == 42, "none-first: none path yields empty optional");
  assert((_vm_a(1) ?: D(x: 42)).x == 1, "none-first: value path yields D(x:1)");
  assert((_vm_b(0) ?: D(x: 99)).x == 1, "none-second: value path yields D(x:1)");
  assert((_vm_b(1) ?: D(x: 99)).x == 99, "none-second: none path yields empty optional");
}

_if_pick(int k) D? {
  return if k == 0 {
    none
  } else {
    D(x: 7)
  };
}

_if_pick_swapped(int k) D? {
  return if k == 0 {
    D(x: 7)
  } else {
    none
  };
}

if_expr_bare_user_type() `test {
  assert((_if_pick(0) ?: D(x: 5)).x == 5, "if none-then: none path yields empty optional");
  assert((_if_pick(1) ?: D(x: 5)).x == 7, "if none-then: value path yields D(x:7)");
  assert((_if_pick_swapped(0) ?: D(x: 5)).x == 7, "if none-else: value path yields D(x:7)");
  assert((_if_pick_swapped(1) ?: D(x: 5)).x == 5, "if none-else: none path yields empty optional");
}

_em_a(Tag t) D? {
  return match t {
    Tag.First => none, _ => D(x: 1),
  };
}

_em_b(Tag t) D? {
  return match t {
    Tag.First => D(x: 1), _ => none,
  };
}

enum_match_bare_user_type() `test {
  assert((_em_a(Tag.First) ?: D(x: 42)).x == 42, "enum none-first: none path empty");
  assert((_em_a(Tag.Second) ?: D(x: 42)).x == 1, "enum none-first: value path D(x:1)");
  assert((_em_b(Tag.First) ?: D(x: 99)).x == 1, "enum none-second: value path D(x:1)");
  assert((_em_b(Tag.Second) ?: D(x: 99)).x == 99, "enum none-second: none path empty");
}

// Scalar inner payload — `int?` from a bare literal arm (no heap dup involved).
_scalar_pick(int k) int? {
  return match k {
    0 => none, _ => 5,
  };
}

value_match_bare_scalar() `test {
  assert((_scalar_pick(0) ?: 100) == 100, "scalar none path yields empty optional");
  assert((_scalar_pick(1) ?: 100) == 5, "scalar value path yields 5");
}

// T1189: the sibling of a `none` arm is itself ALREADY an Optional value (`int?`),
// not a bare inner `int`. joinBranchTypes must unify `none + T?` to `T?` (not
// double-wrap to `T??`) and pass the optional arm through unwrapped — so passing
// an already-`none` optional through the value arm must stay empty, and a present
// optional must flow through intact. Both arm orderings across match/if/enum.
_opt_arm_match(int k, int? e) int? {
  return match k {
    0 => none, _ => e,
  };
}

_opt_arm_match_swapped(int k, int? e) int? {
  return match k {
    0 => e, _ => none,
  };
}

_opt_arm_if(int k, int? e) int? {
  return if k == 0 {
    none
  } else {
    e
  };
}

_opt_arm_enum(Tag t, int? e) int? {
  return match t {
    Tag.First => none, _ => e,
  };
}

none_arm_with_optional_sibling() `test {
  // Value arm carries a present optional through unchanged.
  assert((_opt_arm_match(1, 7) ?: 100) == 7, "match: present optional flows through value arm");
  assert((_opt_arm_match(0, 7) ?: 100) == 100, "match: none arm yields empty optional");
  // Value arm carries an EMPTY optional through — must stay empty (no re-wrap to Some(none)).
  assert((_opt_arm_match(1, none) ?: 100) == 100, "match: empty optional stays empty through value arm");
  // Swapped ordering (value arm first).
  assert((_opt_arm_match_swapped(0, 7) ?: 100) == 7, "match swapped: present optional flows through");
  assert((_opt_arm_match_swapped(1, 7) ?: 100) == 100, "match swapped: none arm empty");
  // if-expr.
  assert((_opt_arm_if(1, 7) ?: 100) == 7, "if: present optional flows through else arm");
  assert((_opt_arm_if(1, none) ?: 100) == 100, "if: empty optional stays empty");
  // enum-match.
  assert((_opt_arm_enum(Tag.Second, 7) ?: 100) == 7, "enum: present optional flows through");
  assert((_opt_arm_enum(Tag.First, 7) ?: 100) == 100, "enum: none arm empty");
}
