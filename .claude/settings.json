{
  "permissions": {
    "allow": [
      "Edit",
      "Bash(*)",
      "Glob",
      "WebSearch",
      "Read",
      "mcp__tracker__list",
      "mcp__tracker__create",
      "mcp__tracker__update",
      "mcp__tracker__get",
      "mcp__tracker__search",
      "mcp__tracker__heartbeat",
      "mcp__tracker__agents"
    ],
    "deny": [
      "Read(.tracker/**)",
      "Edit(.tracker/**)",
      "Write(.tracker/**)",
      "Bash(git * push *)",
      "Bash(git * reset --hard *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm * install *)",
      "Bash(pip * install *)",
      "Bash(cargo * install *)",
      "Bash(go * install *)",
      "Bash(apt * install *)",
      "Bash(apt-get * install *)",
      "Bash(rm * -rf *)",
      "Bash(* --force)"
    ],
    "additionalDirectories": [
      "/tmp",
      "~/.promise"
    ]
  }
}
