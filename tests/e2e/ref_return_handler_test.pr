// T0659: failable borrow returns (`T&`/`T~`) consumed via the unwrap forms
// (`?!`, `?^`, `? e ...`). A borrow return hands back a reference into
// storage owned elsewhere — it is never an owned temp, so the post-call
// temp-tracking branches in genExpr must NOT register the i8* as a string
// or vector temp at statement end. T0649 added the `isRefType` guard to
// the CallExpr post-call branch; this file exercises the corresponding
// guards added to *ast.ErrorPropagateExpr / *ast.ErrorPanicExpr /
// *ast.ErrorHandlerExpr so that a future change reintroducing an
// allocation on a borrow path fails closed.
//
// Today (after T0649 Part 1) the source `at!` does not allocate, so these
// would still pass without the guards — but the guards are the
// system's last line of defense and need test coverage so a future
// regression is caught immediately.
//
// T0792: the recovery-runtime handler cases below exercise a handler whose
// recovery body reads an i8* borrow source (`r.d[0]`). Before the fix,
// genBlockValue dup'd the last expr using its natural owned type (`string`)
// while the `string &`/`string ~` bind site took no ownership → 1 leaked
// alloc. The `borrowBlockResult` gate in genErrorHandlerExpr suppresses that
// dup; these tests run under the zero-leak gate and lock the fix.
type MyErr is error {
  int code;
}

type RefRet {
  string[] d;
  at!(int i) string & {
    if i < 0 {
      raise error("bad");
    }
    return this.d[i];
  }
  atm!(int i) string ~ {
    if i < 0 {
      raise error("bad");
    }
    return this.d[i];
  }
}

// --- `?!` (panic): transient and bind forms over the ErrorPanicExpr branch's
// `isRefType` guard.

at_qbang_temp() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  n := r.at(0)?!.len;
  assert(n == 3, "qbang on borrow return, transient len");
}

at_qbang_bind() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  x := r.at(0)?!;
  assert(x.len == 3, "qbang on borrow return, bound to local");
}

// --- `?^` (propagate): requires the enclosing call to be failable. Wrap in
// `_helper!()` so the guard fires on the ErrorPropagateExpr branch.

_qhat_temp_helper!() int {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  return r.at(0)?^.len;
}

_qhat_bind_helper!() int {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  string &x = r.at(0)?^;
  return x.len;
}

at_qhat_temp() `test {
  n := _qhat_temp_helper()?!;
  assert(n == 3, "qhat on borrow return, transient len");
}

at_qhat_bind() `test {
  n := _qhat_bind_helper()?!;
  assert(n == 3, "qhat on borrow return, bound to local");
}

// --- `? e {}` (handler): present-runtime exercises the ErrorHandlerExpr
// branch's `isRefType` guard on the ok-path.

at_qhandler_present_temp() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  n := (r.at(0)? e {
    r.d[0]
  }).len;
  assert(n == 3, "handler on borrow return, transient len, present");
}

at_qhandler_present_bind() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  string &x = r.at(0)? e {
    r.d[0]
  };
  assert(x.len == 3, "handler on borrow return, bound to local, present");
}

// --- `? e {}` (handler): recovery-runtime — the recovery body reads an i8*
// borrow source (`r.d[0]`). T0792: the `borrowBlockResult` gate suppresses the
// spurious dup so the borrow bind site leaves nothing leaked.

at_qhandler_recovery_temp() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  n := (r.at(-1)? e {
    r.d[0]
  }).len;
  assert(n == 3, "handler on borrow return, transient len, recovery");
}

at_qhandler_recovery_bind() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  string &x = r.at(-1)? e {
    r.d[0]
  };
  assert(x.len == 3, "handler on borrow return, bound to local, recovery");
}

at_qhandler_recovery_mut() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  string ~x = r.atm(-1)? e {
    r.d[0]
  };
  assert(x.len == 3, "handler on mut-borrow return, bound to local, recovery");
}

// --- `? e is X { } else { }` (typed handler with else): the borrow-recovery
// gate also wraps the *else* body's last expr. `at(-1)` raises a base `error`,
// which does not match `MyErr`, so the else body runs and yields the borrow
// `r.d[1]`. Before the fix this leaked exactly like the main-body case; the
// else-path `borrowBlockResult` assignment is its own code path (a distinct
// genBlockValue call from the handler body) and needs its own gate.

at_qhandler_else_borrow_bind() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  string &x = r.at(-1)? e is MyErr {
    r.d[0]
  } else {
    r.d[1]
  };
  assert(x.len == 4, "typed handler else-body borrow recovery, bound to local");
}

at_qhandler_else_borrow_temp() `test {
  r := RefRet(d: ["aa" + "x", "bbb" + "y"]);
  n := (r.at(-1)? e is MyErr {
    r.d[0]
  } else {
    r.d[1]
  }).len;
  assert(n == 4, "typed handler else-body borrow recovery, transient len");
}
