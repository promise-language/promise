// --- T0479 coverage: multi-yield with break after first yield ---

t0479_gen_multi_yield(~string s) stream[int] {
  yield 10;
  yield 20;
  yield 30;
}

test_t0479_multi_yield_break_after_first() `test {
  int seen = 0;
  for x in t0479_gen_multi_yield("m".to_string()) {
    seen = seen + 1;
    if seen == 2 {
      break;
    }
  }
  assert(seen == 2, "should iterate twice before break");
}

