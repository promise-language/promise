{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/bin/guard\" || exit 2",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill|Task|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/bin/guard\" || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|Skill|Task|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/bin/guard\" || true",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Edit",
      "Bash(*)",
      "Glob",
      "WebSearch",
      "Read",
      "mcp__tracker__list",
      "mcp__tracker__create",
      "mcp__tracker__update",
      "mcp__tracker__get",
      "mcp__tracker__search",
      "mcp__tracker__agents",
      "mcp__tracker__get_attachment",
      "mcp__tracker__is_blocked",
      "mcp__tracker__test_health_check",
      "mcp__tracker__test_health_flaky",
      "mcp__tracker__test_health_history",
      "mcp__tracker__test_health_report",
      "mcp__tracker__test_health_summary",
      "mcp__tracker__gate_list",
      "mcp__tracker__gate_results",
      "mcp__tracker__gate_run"
    ],
    "deny": [
      "Read(.tracker/**)",
      "Edit(.tracker/**)",
      "Write(.tracker/**)"
    ],
    "additionalDirectories": [
      "/tmp",
      "~/.promise"
    ]
  }
}