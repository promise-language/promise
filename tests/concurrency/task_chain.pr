// Task chaining: await one task, use result to spawn another.
make_one() int {
  return 1;
}

main() `test(expected: "16") {
  // Chain of tasks: each doubles the previous result
  t1 := go make_one();
  int v1 = <-t1;

  ch2 := channel[int](capacity: 1);
  go {
    ch2.send(v1 * 2);
  };
  int v2 = 0;
  r2 := <-ch2;
  if a := r2 {
    v2 = a;
  }

  ch3 := channel[int](capacity: 1);
  go {
    ch3.send(v2 * 2);
  };
  int v3 = 0;
  r3 := <-ch3;
  if b := r3 {
    v3 = b;
  }

  ch4 := channel[int](capacity: 1);
  go {
    ch4.send(v3 * 2);
  };
  int v4 = 0;
  r4 := <-ch4;
  if c := r4 {
    v4 = c;
  }

  ch5 := channel[int](capacity: 1);
  go {
    ch5.send(v4 * 2);
  };
  int v5 = 0;
  r5 := <-ch5;
  if d := r5 {
    v5 = d;
  }

  // 1 * 2 * 2 * 2 * 2 = 16
  print_line(v5);
}
