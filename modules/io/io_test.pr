// ── File.position / File.seek ────────────────────────────────────────────────

file_seek_test() `test(exclude: "wasm32") {
  File.write_content("/tmp/pr_iot_seek", "abcdef")!;
  File f = File.open("/tmp/pr_iot_seek")!;
  int pos0 = f.position!;
  assert(pos0 == 0, "initial position is 0");
  f.seek(3)!;
  int pos3 = f.position!;
  assert(pos3 == 3, "position after seek");
  string rest = f.read_all()!;
  assert(rest == "def", "read after seek");
  f.close()!;
  File.remove("/tmp/pr_iot_seek")!;
}

