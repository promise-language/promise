dir_list_mixed() `test(exclude: wasm) {
  // List a directory containing one file and one subdirectory.
  if Dir.exists("/tmp/pr_iot_dlmix") {
    File.remove("/tmp/pr_iot_dlmix/file.txt")? e {
    };
    Dir.remove("/tmp/pr_iot_dlmix/sub")? e {
    };
    Dir.remove("/tmp/pr_iot_dlmix")?!;
  }
  Dir.make("/tmp/pr_iot_dlmix")?!;
  File.write_content("/tmp/pr_iot_dlmix/file.txt", "x")?!;
  Dir.make("/tmp/pr_iot_dlmix/sub")?!;
  string[] entries = Dir.list("/tmp/pr_iot_dlmix")?!;
  assert(entries.len == 2, "two entries (file + subdir)");
  bool found_file = false;
  bool found_sub = false;
  int i = 0;
  while i < entries.len {
    if entries[i] == "file.txt" {
      found_file = true;
    }
    if entries[i] == "sub" {
      found_sub = true;
    }
    assert(entries[i] != ".", "no dot entry");
    assert(entries[i] != "..", "no dotdot entry");
    i += 1;
  }
  assert(found_file, "file.txt in listing");
  assert(found_sub, "sub in listing");
  File.remove("/tmp/pr_iot_dlmix/file.txt")?!;
  Dir.remove("/tmp/pr_iot_dlmix/sub")?!;
  Dir.remove("/tmp/pr_iot_dlmix")?!;
}

