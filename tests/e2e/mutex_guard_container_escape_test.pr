// T0665: pushing a MutexGuard into a container is sound ONLY when the container
// drops before its source Mutex — i.e. (LIFO) the Mutex is declared FIRST, so
// its drop runs AFTER the container's element-walking drop. The unsafe order
// (container declared before the Mutex) is rejected at compile time by the
// ownership pass; those negative cases live in the Go ownership tests
// (TestT0665_* in compiler/internal/ownership/ownership_test.go).
//
// This file is the runtime positive control for the accepted safe order: every
// case below must run and be LEAK-CLEAN (the harness enforces zero leaks). A
// guard's drop unlocks its Mutex, so a mis-ordered drop would segfault — these
// tests confirm the safe order both compiles AND executes correctly.
use std as _;

// Safe order, `move g` form: Mutex first, then the vector.
test_guard_push_move_after_mutex() `test {
  m := Mutex[int](5);
  MutexGuard[int][] v = [];
  g := m.lock();
  v.push(move g);
  assert(v.len == 1, "one guard pushed");
}

// Safe order, temporary `v.push(m.lock())` form.
test_guard_push_temp_after_mutex() `test {
  m := Mutex[int](7);
  v := Vector[MutexGuard[int]]();
  v.push(m.lock());
  assert(v.len == 1, "one guard temp pushed");
}

// Safe order, guard-to-guard alias `g2 := g` then push.
test_guard_push_alias_after_mutex() `test {
  m := Mutex[int](9);
  MutexGuard[int][] v = [];
  g := m.lock();
  g2 := g;
  v.push(move g2);
  assert(v.len == 1, "aliased guard pushed");
}

// Safe order, optional-element vector with a trailing `none`.
test_guard_push_optional_after_mutex() `test {
  m := Mutex[int](11);
  MutexGuard[int]?[] v = [];
  g := m.lock();
  v.push(move g);
  v.push(none);
  assert(v.len == 2, "guard + none pushed");
}

// Safe order, Mutex reached through a struct field: the Holder (owning the
// Mutex) is declared before the vector, so the vector's element-walking drop
// runs while the Mutex is still alive. The unsafe order (vector before the
// Holder) is a compile error — see TestT0665_GuardFieldMutex* in the Go tests.
// NOTE: the guard is bound to a variable first (`g := h.m.lock(); push move g`).
// The temporary form `v.push(h.m.lock())` currently double-frees the unclaimed
// member-rooted lock temp and segfaults — a codegen temp-claim bug (T0658
// family) tracked as T1203, independent of this ownership ordering fix.
type GuardHolder {
  Mutex[int] m;
}
test_guard_push_field_mutex_after_owner() `test {
  h := GuardHolder(m: Mutex[int](13));
  MutexGuard[int][] v = [];
  g := h.m.lock();
  v.push(move g);
  assert(v.len == 1, "field-rooted guard pushed");
}

// T0603 boundary: pushing a guard into a `~`-marked container PARAMETER (which
// escapes to the caller) is accepted ONLY when the guard's parent Mutex outlives
// the callee — i.e. the Mutex is NOT a local of the pushing function. Here the
// guard `g` arrives as a `move`-param and its parent Mutex `m` lives in the
// caller (`test_guard_push_into_ref_param`), so the guard escaping inside `vec`
// still back-points into a live Mutex. This is the accepted side of the T0603
// boundary; the rejected side — a LOCAL Mutex whose guard escapes via `~vec` —
// is a compile error covered by TestT0603_RefParamContainerLocalGuard* in the Go
// ownership tests.
push_guard_into_ref_param(Vector[MutexGuard[int]] ~vec, MutexGuard[int] move g) {
  vec.push(g);
}
test_guard_push_into_ref_param() `test {
  m := Mutex[int](17);
  v := Vector[MutexGuard[int]]();
  push_guard_into_ref_param(v, m.lock());
  assert(v.len == 1, "guard pushed into `~`-param container");
  // `v`'s element-drop unlocks the guard while `m` (the caller-owned Mutex) is
  // still alive; `m` drops afterward (LIFO). No UAF, leak-clean.
}

// T1207: the callee-hidden analogue of the case above. The lock happens INSIDE
// the callee (`vec.push(m.lock())`) on a BORROWED Mutex param, and the guard
// escapes via the `~vec` container. `m`'s last syntactic use in the caller is
// the `push_g(v, m)` call, so NLL would early-drop `m` right after it — before
// `v`'s guard-element drop unlocks the (now-freed) Mutex → UAF. The fix defers
// `m`'s drop to scope exit (after `v`), restoring the safe LIFO order.
push_g(Vector[MutexGuard[int]] ~vec, Mutex[int] m) {
  vec.push(m.lock());
}
test_hidden_lock_escape_into_ref_vec_param() `test {
  m := Mutex[int](17);
  v := Vector[MutexGuard[int]]();
  push_g(v, m);
  assert(v.len == 1, "guard hidden-locked + pushed into `~`-vec param");
}

// T1207 store-family variant: the same hidden-lock escape through a `~`-Map
// param (`mp[k] = m.lock()`). Covers the Map store path the issue calls out.
put_g(Map[int, MutexGuard[int]] ~mp, Mutex[int] m) {
  mp[1] = m.lock();
}
test_hidden_lock_escape_into_ref_map_param() `test {
  m := Mutex[int](19);
  mp := Map[int, MutexGuard[int]]();
  put_g(mp, m);
  assert(mp.len == 1, "guard hidden-locked + stored into `~`-map param");
}

// T1207 member-rooted variant: the escaping Mutex arg is a struct FIELD (`h.m`),
// not a bare local. `h`'s last syntactic use is `push_g(v, h.m)`, so NLL would
// early-drop the whole `h` (freeing `h.m`'s Mutex) before `v`'s guard element
// unlocks it → UAF. Exercises the member-chain arg path of the suppression
// (`memberChainRootName(h.m) == "h"`), deferring `h`'s drop to scope exit.
type T1207Holder {
  Mutex[int] m;
}
test_hidden_lock_escape_member_rooted_mutex() `test {
  h := T1207Holder(m: Mutex[int](23));
  v := Vector[MutexGuard[int]]();
  push_g(v, h.m);
  assert(v.len == 1, "guard hidden-locked from a struct-field Mutex + pushed into `~`-vec param");
}
