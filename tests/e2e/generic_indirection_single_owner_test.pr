// T0616: generic indirection that would otherwise bypass T0545's single-owner
// handle clone gate is rejected at the call site by sema's per-generic
// cloneability-requirement propagation. The negative cases (call site of a
// generic instantiated with Task/Mutex/MutexGuard fails at sema) live in
// sema_test.go (TestT0616_*) since compile failures cannot be batch tests.
// This file pins the *positive* runtime behavior that must keep working:
// generic helpers used with Arc/Channel (refcounted, duplicable) handles, and
// generic helpers that take handle vectors without ever cloning them. Zero
// leaks (T0067).
worker_t0616() int {
  return 42;
}

// --- Refcounted handles through generic indirection: clone is valid ---
// Vector is a reference type — pass by value, the helper clones and returns
// the new copy; caller can ignore the moved input or rebind it.

dup_vec[T](Vector[T] v) Vector[T] {
  return v.clone();
}

test_generic_dup_arc() `test {
  v := Vector[Ref[int]]();
  v.push(Ref[int](7));
  v.push(Ref[int](8));
  v2 := dup_vec[Ref[int]](v);
  assert(v2.len == 2, "generic dup arc len");
}

test_generic_dup_channel() `test {
  v := Vector[Channel[int]]();
  v.push(Channel[int]());
  v2 := dup_vec[Channel[int]](v);
  assert(v2.len == 1, "generic dup channel len");
}

// --- Generic helper that takes a vector by value (move) without cloning ---
// With T = Task, must compile and the input vector is moved into the helper
// and dropped there (T0508 move-only — flat handle vector OK).

drop_vec[T](Vector[T] v) int {
  return v.len;
}

test_generic_drop_task() `test(exclude: wasm) {
  v := Vector[Task[int]]();
  v.push(go worker_t0616());
  v.push(go worker_t0616());
  n := drop_vec[Task[int]](v);
  assert(n == 2, "drop_vec len");
}

// --- Transitive generic chains with refcounted handles stay valid ---

inner_dup[T](Vector[T] v) Vector[T] {
  return v.clone();
}
outer_dup[T](Vector[T] v) Vector[T] {
  return inner_dup[T](v);
}

test_transitive_dup_arc() `test {
  v := Vector[Ref[int]]();
  v.push(Ref[int](42));
  v2 := outer_dup[Ref[int]](v);
  assert(v2.len == 1, "transitive dup arc len");
}

// --- Plain int/string types through generic helpers still work ---

test_generic_dup_int() `test {
  v := [1, 2, 3, 4];
  v2 := dup_vec[int](v);
  assert(v2.len == 4, "generic dup int len");
}

test_generic_dup_string() `test {
  v := ["a", "b", "c"];
  v2 := dup_vec[string](v);
  assert(v2.len == 3, "generic dup string len");
}

// --- Vector[T].filled() through a generic helper, with safe T ---

fill_n[T](T item, int n) Vector[T] {
  return Vector[T].filled(item, n);
}

test_generic_fill_int() `test {
  v := fill_n[int](7, 5);
  assert(v.len == 5, "fill int len");
  assert(v[0] == 7, "fill int element");
  assert(v[4] == 7, "fill int last");
}

// --- Map clone via generic helper with safe value types ---

dup_map[K: Hashable + Equal, V](Map[K, V] m) Map[K, V] {
  return m.clone();
}

test_generic_dup_map_int() `test {
  m := Map[int, int]();
  m[0] = 10;
  m[1] = 20;
  m2 := dup_map[int, int](m);
  assert(m2.len == 2, "generic dup map len");
}

// --- Method on a generic owner type with safe TypeArg ---

type Wrapper[T] `clone {
  Vector[T] data;
}

test_method_on_generic_int() `test {
  w := Wrapper[int](data: [1, 2, 3]);
  w2 := w.clone();
  assert(w2.data.len == 3, "method on generic owner clones data");
}

test_method_on_generic_arc() `test {
  w := Wrapper[Ref[int]](data: [Ref[int](7), Ref[int](8)]);
  w2 := w.clone();
  assert(w2.data.len == 2, "Arc element through synth clone");
}

// --- T0627: method-to-method clone chain through `this` with safe T ---
// A two-level chain inside a generic type body — `outer_chain` calls
// `this.inner_chain()`, which calls `data.clone()`. Sema would previously
// allow this and T0559's codegen backstop would catch only at runtime when
// T = Task. With T = Arc (refcounted, duplicable), the chain must compile
// and run leak-free.

type Chainer[T] {
  Vector[T] data;
  inner_chain() Vector[T] {
    return this.data.clone();
  }
  outer_chain() Vector[T] {
    return this.inner_chain();
  }
}

test_method_chain_arc() `test {
  c := Chainer[Ref[int]](data: [Ref[int](1), Ref[int](2)]);
  v := c.outer_chain();
  assert(v.len == 2, "method chain arc len");
}

// --- T0629: clone-req propagation through getters and enum methods ---
// The negative cases (Task/Mutex must fail at sema) live in sema_test.go
// (TestT0629_*). These pin the positive runtime behavior with Arc
// (refcounted, duplicable): a Named getter chain, and a generic enum's
// getter + method that clone the inner vector. All must run leak-free
// (T0067 zero-leak enforcement).

type Holder[T] {
  Vector[T] data;
  get cloned Vector[T] {
    return this.data.clone();
  }
  via_getter() Vector[T] {
    return this.cloned;
  }
}

test_named_getter_chain_arc() `test {
  h := Holder[Ref[int]](data: [Ref[int](1), Ref[int](2), Ref[int](3)]);
  v := h.via_getter();
  assert(v.len == 3, "named getter chain arc len");
}

test_named_getter_concrete_arc() `test {
  h := Holder[Ref[int]](data: [Ref[int](9)]);
  v := h.cloned;
  assert(v.len == 1, "named getter concrete arc len");
}

enum Box[T] {
  Filled(Vector[T] items),
  Bare,
  get cloned Vector[T] {
    match this {
      Filled(it) => {
        return it.clone();
      },
      Bare => {
        return[];
      },
    }
  }
  copy_items() Vector[T] {
    match this {
      Filled(it) => {
        return it.clone();
      },
      Bare => {
        return[];
      },
    }
  }
  // Enum getter accessed via `this` (identity-subst path through Site C's
  // getter branch). The Task/Mutex negative is TestT0629_EnumGetterViaThis-
  // TaskError in sema_test.go; this pins the positive Arc runtime behavior.
  outer_via_getter() Vector[T] {
    return this.cloned;
  }
}

test_enum_getter_arc() `test {
  b := Box[Ref[int]].Filled([Ref[int](5), Ref[int](6)]);
  v := b.cloned;
  assert(v.len == 2, "enum getter arc len");
}

test_enum_method_arc() `test {
  b := Box[Ref[int]].Filled([Ref[int](7)]);
  v := b.copy_items();
  assert(v.len == 1, "enum method arc len");
}

test_enum_getter_bare_arc() `test {
  b := Box[Ref[int]].Bare;
  v := b.cloned;
  assert(v.len == 0, "enum getter bare arc len");
}

test_enum_getter_via_this_arc() `test {
  b := Box[Ref[int]].Filled([Ref[int](3), Ref[int](4), Ref[int](5)]);
  v := b.outer_via_getter();
  assert(v.len == 3, "enum getter via this arc len");
}

// --- T0637: inherited getter/method/setter from a generic parent ---
// The bug crashed codegen at monomorphization for any inherited getter/
// method on a generic parent. Pin the positive Arc runtime behavior for
// (a) direct inherited-getter access on a concrete instance, (b)
// inherited-getter access via `this` inside a child-owned method, (c)
// inherited-method access via `this` inside a child-owned method, and
// (d) inherited-setter mutation. All must run leak-free (T0067).

type ChildHolder[T] is Holder[T] {
}

test_getter_inherited_concrete_arc() `test {
  ch := ChildHolder[Ref[int]](data: [Ref[int](1), Ref[int](2)]);
  v := ch.cloned;
  assert(v.len == 2, "inherited getter concrete arc len");
}

type ChildHolderViaThis[T] is Holder[T] {
  via_inherited() Vector[T] {
    return this.cloned;
  }
}

test_getter_inherited_via_this_arc() `test {
  ch := ChildHolderViaThis[Ref[int]](data: [Ref[int](3), Ref[int](4), Ref[int](5)]);
  v := ch.via_inherited();
  assert(v.len == 3, "inherited getter via this arc len");
}

type MethodHolder[T] {
  Vector[T] data;
  copy_items() Vector[T] {
    return this.data.clone();
  }
}

type ChildMethodHolder[T] is MethodHolder[T] {
  via_inherited() Vector[T] {
    return this.copy_items();
  }
}

test_method_inherited_via_this_arc() `test {
  cm := ChildMethodHolder[Ref[int]](data: [Ref[int](6), Ref[int](7)]);
  v := cm.via_inherited();
  assert(v.len == 2, "inherited method via this arc len");
}

type Mutable[T] {
  T _val;
  get current T {
    return this._val;
  }
  set current(T v) {
    this._val = v;
  }
}

type ChildMutable[T] is Mutable[T] {
}

test_inherited_setter_arc() `test {
  cm := ChildMutable[int](_val: 10);
  cm.current = 20;
  got := cm.current;
  assert(got == 20, "inherited setter+getter int value");
}

// Inherited setter assigned via `this` inside a child mono method body —
// exercises the full T0637 chain (Gaps 1+2+3) plus the `isThis` branch in
// genSetterCall. Must run leak-free with int payload.
type ChildMutableViaThis[T] is Mutable[T] {
  set_via(~T v) {
    this.current = v;
  }
}

test_inherited_setter_via_this_int() `test {
  cm := ChildMutableViaThis[int](_val: 10);
  cm.set_via(99);
  got := cm.current;
  assert(got == 99, "inherited setter via this updates field");
}

// Transitive (grandparent-chain) inheritance — exercises the recursive
// branch of findMonoParentName plus Gap 2's c.typeSubst seeding when the
// via-`this` access happens inside a Child mono method body.
type MidHolder[T] is Holder[T] {
}
type GrandChildHolder[T] is MidHolder[T] {
  via_inherited() Vector[T] {
    return this.cloned;
  }
}

test_grandparent_getter_concrete_arc() `test {
  gc := GrandChildHolder[Ref[int]](data: [Ref[int](1), Ref[int](2)]);
  v := gc.cloned;
  assert(v.len == 2, "transitive inherited getter concrete arc len");
}

test_grandparent_getter_via_this_arc() `test {
  gc := GrandChildHolder[Ref[int]](data: [Ref[int](7), Ref[int](8), Ref[int](9)]);
  v := gc.via_inherited();
  assert(v.len == 3, "transitive inherited getter via this arc len");
}
