// T0270: MutexGuard borrow setter must drop old value for all droppable T types.
type Counter {
  int[] data;
  drop(~this) {
  }
}

test_borrow_set_droppable_user_type() `test {
  m := Mutex[Counter](Counter(data: [1, 2, 3]));
  use guard := m.lock();
  guard.borrow = Counter(data: [4, 5, 6]);
  assert(guard.borrow.data[0] == 4, "should be 4");
}

test_borrow_set_string() `test {
  m := Mutex[string]("hello");
  use guard := m.lock();
  guard.borrow = "world";
  assert(guard.borrow == "world", "should be world");
}

test_borrow_set_vector() `test {
  m := Mutex[int[]]([1, 2, 3]);
  use guard := m.lock();
  guard.borrow = [4, 5, 6];
  assert(guard.borrow.len == 3, "len should be 3");
  assert(guard.borrow[0] == 4, "first element should be 4");
}

test_borrow_set_arc() `test {
  a1 := Arc[int](10);
  m := Mutex[Arc[int]](a1.clone());
  use guard := m.lock();
  a2 := Arc[int](20);
  guard.borrow = a2.clone();
  assert(guard.borrow.borrow == 20, "should be 20");
}

// Synthesized drop: user type with droppable fields but no explicit drop()
type Wrapper {
  string name;
  int[] values;
}

test_borrow_set_synth_drop() `test {
  m := Mutex[Wrapper](Wrapper(name: "old", values: [1, 2]));
  use guard := m.lock();
  guard.borrow = Wrapper(name: "new", values: [3, 4, 5]);
  assert(guard.borrow.name == "new", "name should be new");
  assert(guard.borrow.values.len == 3, "values len should be 3");
}

test_borrow_set_channel() `test {
  ch1 := channel[int](1);
  m := Mutex[channel[int]](ch1);
  use guard := m.lock();
  ch2 := channel[int](2);
  guard.borrow = ch2;
}

test_borrow_set_compound_assign() `test {
  m := Mutex[int](10);
  use guard := m.lock();
  guard.borrow += 5;
  assert(guard.borrow == 15, "should be 15");
  guard.borrow *= 2;
  assert(guard.borrow == 30, "should be 30");
}

// T0274: Mutex[Weak[T]] causes stack overflow at runtime (pre-existing).
// test_borrow_set_weak skipped until T0274 is fixed.

// T0351: `g.borrow = s` with a borrowed-param `s` double-frees because the
// caller still drops the original. Sema now rejects the borrow form via
// tryMoveConsume in checkAssignStmt; the supported alternatives are `~string`
// (consume the param) or `.clone()` (preserve the caller's copy).

// T0401: similarly, `g.borrow = src.borrow` (assigning a `T&` getter result
// into the setter slot) is rejected. The setter does drop-then-store on the
// same slot, and self-aliasing or cross-mutex aliasing produces a UAF since
// the source's parent (Arc/Mutex) still owns and will drop the inner value.
// The supported alternative is `g.borrow = src.borrow.clone()` to install
// an independent owned copy.

forward_move(~Mutex[string] m, ~string s) {
  use g := m.lock();
  g.borrow = s;
  assert(g.borrow == "moved value", "moved-in value present");
}

forward_clone(~Mutex[string] m, string s) {
  use g := m.lock();
  g.borrow = s.clone();
  assert(g.borrow == "cloned value", "cloned value present");
}

test_borrow_set_move_param() `test {
  m := Mutex[string]("init");
  forward_move(m, "moved " + "value");
}

test_borrow_set_clone_borrow() `test {
  m := Mutex[string]("init");
  string heap_str = "cloned " + "value";
  forward_clone(m, heap_str);
}

// T0401: the supported recovery path — `g.borrow = src.borrow.clone()` where
// the source is another Arc/Mutex. The clone produces an independent owned
// string, so the setter's drop-then-store does not alias the source's inner
// pointer. Pins the runtime side of the rejection diagnostic in T0401.
test_borrow_set_from_arc_borrow_clone() `test {
  a := Arc[string]("source" + "");
  m := Mutex[string]("dest" + "");
  use guard := m.lock();
  guard.borrow = a.borrow.clone();
  assert(guard.borrow == "source", "should be source");
  assert(a.borrow == "source", "arc still owns original");
}

// T0401: cross-Mutex recovery — `g1.borrow = g2.borrow.clone()`. Both mutexes
// retain independent inner strings; no aliasing, no UAF.
test_borrow_set_from_mutex_borrow_clone() `test {
  m1 := Mutex[string]("a" + "");
  m2 := Mutex[string]("b" + "");
  use g1 := m1.lock();
  use g2 := m2.lock();
  g1.borrow = g2.borrow.clone();
  assert(g1.borrow == "b", "g1 should hold cloned value");
  assert(g2.borrow == "b", "g2 still owns original");
}
