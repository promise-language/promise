// Tests that ALL file/dir operations work correctly from goroutines.
// Phase 6a: ensures enter_syscall/exit_syscall wraps every PAL call.
// Uses main() form because `test annotation + goroutines is not yet supported.
use io;

main() `test(expected: """open_close ok
write_read ok
seek ok
stat_size ok
exists ok
mkdir_dir ok
error_handling ok""", exclude: wasm) {
  // Test 1: open, write_string, close, open, read_all, close
  channel[string] ch1 = channel[string](capacity: 1);
  go {
    io.File f = io.File.create("/tmp/pr_sc_ops1")?!;
    f.write_string("goroutine wrote this")?!;
    f.close()?!;
    io.File f2 = io.File.open("/tmp/pr_sc_ops1", readonly: true)?!;
    string data = f2.read_all()?!;
    f2.close()?!;
    io.File.remove("/tmp/pr_sc_ops1")?!;
    ch1.send(data);
  };
  r1 := <-ch1;
  if v1 := r1 {
    assert(v1 == "goroutine wrote this", "open/close/write/read");
  }
  print_line("open_close ok");

  // Test 2: write_content + read_content from goroutine
  channel[string] ch2 = channel[string](capacity: 1);
  go {
    io.File.write_content("/tmp/pr_sc_ops2", "content ops")?!;
    string d = io.File.read_content("/tmp/pr_sc_ops2")?!;
    io.File.remove("/tmp/pr_sc_ops2")?!;
    ch2.send(d);
  };
  r2 := <-ch2;
  if v2 := r2 {
    assert(v2 == "content ops", "write_content/read_content");
  }
  print_line("write_read ok");

  // Test 3: seek from goroutine
  channel[string] ch3 = channel[string](capacity: 1);
  go {
    io.File.write_content("/tmp/pr_sc_ops3", "abcdefgh")?!;
    io.File f = io.File.open("/tmp/pr_sc_ops3")?!;
    f.seek(4)?!;
    string rest = f.read_all()?!;
    f.close()?!;
    io.File.remove("/tmp/pr_sc_ops3")?!;
    ch3.send(rest);
  };
  r3 := <-ch3;
  if v3 := r3 {
    assert(v3 == "efgh", "seek + read_all");
  }
  print_line("seek ok");

  // Test 4: stat_size from goroutine
  channel[int] ch4 = channel[int](capacity: 1);
  go {
    io.File.write_content("/tmp/pr_sc_ops4", "12345678")?!;
    int sz = io.File.size("/tmp/pr_sc_ops4")?!;
    io.File.remove("/tmp/pr_sc_ops4")?!;
    ch4.send(sz);
  };
  r4 := <-ch4;
  if v4 := r4 {
    assert(v4 == 8, "stat_size");
  }
  print_line("stat_size ok");

  // Test 5: exists from goroutine
  channel[int] ch5 = channel[int](capacity: 1);
  go {
    io.File.write_content("/tmp/pr_sc_ops5", "x")?!;
    bool e1 = io.File.exists("/tmp/pr_sc_ops5");
    io.File.remove("/tmp/pr_sc_ops5")?!;
    bool e2 = io.File.exists("/tmp/pr_sc_ops5");
    int result = 0;
    if e1 {
      result = result + 1;
    }
    if !e2 {
      result = result + 10;
    }
    ch5.send(result);
  };
  r5 := <-ch5;
  if v5 := r5 {
    assert(v5 == 11, "exists before/after remove");
  }
  print_line("exists ok");

  // Test 6: mkdir, dir_exists, dir_remove from goroutine
  channel[int] ch6 = channel[int](capacity: 1);
  go {
    if io.Dir.exists("/tmp/pr_sc_ops6_dir") {
      io.Dir.remove("/tmp/pr_sc_ops6_dir")?!;
    }
    io.Dir.make("/tmp/pr_sc_ops6_dir")?!;
    bool de1 = io.Dir.exists("/tmp/pr_sc_ops6_dir");
    io.Dir.remove("/tmp/pr_sc_ops6_dir")?!;
    bool de2 = io.Dir.exists("/tmp/pr_sc_ops6_dir");
    int result = 0;
    if de1 {
      result = result + 1;
    }
    if !de2 {
      result = result + 10;
    }
    ch6.send(result);
  };
  r6 := <-ch6;
  if v6 := r6 {
    assert(v6 == 11, "mkdir/dir_exists/dir_remove");
  }
  print_line("mkdir_dir ok");

  // Test 7: error handling from goroutine (read nonexistent file)
  channel[string] ch7 = channel[string](capacity: 1);
  go {
    string msg = "no error";
    io.File.read_content("/tmp/pr_sc_ops_noexist_xyz")? e {
      msg = "caught";
    };
    ch7.send(msg);
  };
  r7 := <-ch7;
  if v7 := r7 {
    assert(v7 == "caught", "error from goroutine");
  }
  print_line("error_handling ok");
}
