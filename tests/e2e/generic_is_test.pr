// Tests for `is` patterns with full type expressions (B0012).
// Verifies that generic types like Box[int] work correctly with is-checks.
// --- Generic type with inheritance ---
type Container[T] {
  T value;
}

type LabeledContainer[T] is Container[T] {
  string label;
}

// Basic is-check on generic types
test_generic_is_check() `test {
  Container[int] c = LabeledContainer[int](value: 42, label: "answer");
  assert(c is LabeledContainer[int], "is LabeledContainer[int]");
  assert(c is Container[int], "is Container[int] (base)");
}

// Bare origin type still matches generic instances
test_generic_is_check_bare_origin() `test {
  Container[int] c = LabeledContainer[int](value: 1, label: "x");
  assert(c is LabeledContainer[int], "specific type args match");
  assert(c is LabeledContainer, "bare origin type matches");
}

// is-check with string type arg
test_generic_is_check_string_arg() `test {
  Container[string] c = LabeledContainer[string](value: "hello", label: "greet");
  assert(c is LabeledContainer[string], "is LabeledContainer[string]");
  assert(c is Container[string], "is Container[string] (base)");
}

// --- Generic optional is-check ---

test_generic_optional_is_check() `test {
  Container[int] lc = LabeledContainer[int](value: 10, label: "ten");
  Container[int]? opt = lc;
  Container[int]? n = none;
  assert(opt is LabeledContainer[int], "optional present is LabeledContainer[int]");
  assert(!(n is LabeledContainer[int]), "optional none is not LabeledContainer[int]");
}

// --- if x is GenericType[T] ---

type Wrapper[T] {
  T inner;
}

type TaggedWrapper[T] is Wrapper[T] {
  string tag;
}

test_generic_is_in_if() `test {
  Wrapper[int] w = TaggedWrapper[int](inner: 99, tag: "ninety-nine");
  if w is TaggedWrapper[int] {
    assert(true, "entered generic is-check branch");
  } else {
    assert(false, "should not reach else");
  }
}

test_generic_is_in_if_negative() `test {
  Wrapper[int] w = Wrapper[int](inner: 5);
  if w is TaggedWrapper[int] {
    assert(false, "should not match base type against derived");
  } else {
    assert(true, "correctly rejected non-matching type");
  }
}

// --- Multiple generic type arg ---

type Pair[A, B] {
  A first;
  B second;
}

type LabeledPair[A, B] is Pair[A, B] {
  string label;
}

test_generic_multi_arg_is() `test {
  Pair[int, string] p = LabeledPair[int, string](first: 1, second: "one", label: "pair");
  assert(p is LabeledPair[int, string], "is LabeledPair[int, string]");
  assert(p is Pair[int, string], "is Pair[int, string] (base)");
}
