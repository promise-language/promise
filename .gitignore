.agent-org-run.json
logs/*

# Compiler: ANTLR4 tool
compiler/tools/antlr-*.jar

# Compiler: generated parser (non-Go artifacts)
compiler/internal/parser/*.interp
compiler/internal/parser/*.tokens

# Compiler: binary + hash sidecar
bin/promise
bin/promise.exe
bin/promise.exe~
bin/.promise.hash
compiler/grammar/.antlr/PromiseLexer.interp
compiler/grammar/.antlr/PromiseLexer.java
compiler/grammar/.antlr/PromiseLexer.tokens
compiler/grammar/.antlr/PromiseParser.interp
compiler/grammar/.antlr/PromiseParser.java
compiler/grammar/.antlr/PromiseParser.tokens

# Debug build output
.promise-build/

# Local promise home for testing
.promise-home/

# Build cache
**/.DS_Store
.claude/settings.local.json
.runner-*
.runner.*

# Build tools (Go binaries compiled by ./make)
bin/build
bin/build.exe
bin/coverage
bin/coverage.exe
bin/format
bin/format.exe
bin/prereqs
bin/prereqs.exe
bin/setup
bin/setup.exe
bin/stress
bin/stress.exe
bin/test
bin/test.exe
bin/verify
bin/verify.exe
bin/vet
bin/vet.exe
