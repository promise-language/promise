// Match expression tests: literals (int, string, char, bool), enums,
// wildcards, name bindings, guards, nested, block arms, return match.
enum Direction {
  North, South, East, West,
}

enum Expr {
  Num(int value),
  Add(int left, int right),
  Neg(int inner),
}

// --- match on int literal ---

test_match_int_literal() `test {
  int x = 3;
  string s = match x {
    1 => "one",
    2 => "two",
    3 => "three",
    _ => "other",
  };
  assert(s == "three", "match int literal 3");
}

// --- match wildcard ---

test_match_wildcard() `test {
  int x = 999;
  string s = match x {
    0 => "zero",
    _ => "nonzero",
  };
  assert(s == "nonzero", "wildcard catches 999");
}

// --- match name binding ---

test_match_name_binding() `test {
  int x = 42;
  int r = match x {
    val => val * 2,
  };
  assert(r == 84, "name binding captures value");
}

// --- match fieldless enum ---

test_match_direction() `test {
  Direction d = Direction.North;
  string s = match d {
    Direction.North => "north",
    Direction.South => "south",
    Direction.East => "east",
    Direction.West => "west",
  };
  assert(s == "north", "match Direction.North");
}

// --- match all enum directions ---

dir_name(Direction d) string {
  return match d {
    Direction.North => "N",
    Direction.South => "S",
    Direction.East => "E",
    Direction.West => "W",
  };
}

test_match_all_directions() `test {
  assert(dir_name(Direction.North) == "N", "North -> N");
  assert(dir_name(Direction.South) == "S", "South -> S");
  assert(dir_name(Direction.East) == "E", "East -> E");
  assert(dir_name(Direction.West) == "W", "West -> W");
}

// --- match data enum destructure ---

test_match_data_enum() `test {
  Expr e = Expr.Num(42);
  int val = match e {
    Expr.Num(v) => v,
    Expr.Add(l, r) => l + r,
    Expr.Neg(n) => -n,
  };
  assert(val == 42, "destructure Num(42)");
}

test_match_data_enum_add() `test {
  Expr e = Expr.Add(10, 20);
  int val = match e {
    Expr.Num(v) => v,
    Expr.Add(l, r) => l + r,
    Expr.Neg(n) => -n,
  };
  assert(val == 30, "destructure Add(10, 20) => 30");
}

test_match_data_enum_neg() `test {
  Expr e = Expr.Neg(7);
  int val = match e {
    Expr.Num(v) => v,
    Expr.Add(l, r) => l + r,
    Expr.Neg(n) => -n,
  };
  assert(val == -7, "destructure Neg(7) => -7");
}

// --- match with wildcard on non-enum ---

test_match_int_wildcard() `test {
  int n = 42;
  string s = match n {
    0 => "zero",
    1 => "one",
    _ => "other",
  };
  assert(s == "other", "42 matches wildcard");
}

// --- match string literal ---

test_match_string() `test {
  string cmd = "quit";
  int code = match cmd {
    "help" => 0,
    "quit" => 1,
    "run" => 2,
    _ => -1,
  };
  assert(code == 1, "match quit => 1");
}

// --- match returning complex expression ---

test_match_complex_result() `test {
  int x = 5;
  int result = match x {
    1 => 100 + 1,
    5 => 200 + 50,
    _ => 0,
  };
  assert(result == 250, "match 5 => 200+50 = 250");
}

// --- match in function ---

classify(int n) string {
  return match n {
    0 => "zero",
    1 => "one",
    _ => "many",
  };
}

test_match_in_function() `test {
  assert(classify(0) == "zero", "classify 0");
  assert(classify(1) == "one", "classify 1");
  assert(classify(42) == "many", "classify 42");
  assert(classify(-1) == "many", "classify -1");
}

// --- match used in assignment ---

test_match_in_assignment() `test {
  for i in 0..4 {
    string s = match i {
      0 => "a",
      1 => "b",
      2 => "c",
      _ => "d",
    };
    if i == 0 {
      assert(s == "a", "i=0 => a");
    }
    if i == 1 {
      assert(s == "b", "i=1 => b");
    }
    if i == 2 {
      assert(s == "c", "i=2 => c");
    }
    if i == 3 {
      assert(s == "d", "i=3 => d");
    }
  }
}

// --- nested match ---

test_nested_match() `test {
  int x = 2;
  int y = 3;
  string r = match x {
    1 => "x is one",
    2 => match y {
      3 => "x=2,y=3",
      _ => "x=2,y=other",
    },
    _ => "other",
  };
  assert(r == "x=2,y=3", "nested match resolves correctly");
}

// --- B0001: match as expression in various positions ---

return_match(int x) string {
  return match x {
    1 => "one",
    2 => "two",
    _ => "other",
  };
}

test_return_match() `test {
  assert(return_match(1) == "one", "return match 1");
  assert(return_match(2) == "two", "return match 2");
  assert(return_match(99) == "other", "return match wildcard");
}

test_match_in_variable_init() `test {
  int x = 3;
  string s = match x {
    3 => "three",
    _ => "?",
  };
  assert(s == "three", "match in variable init");
}

test_match_assigned_to_inferred_var() `test {
  r := match 5 {
    5 => "five",
    _ => "other",
  };
  assert(r == "five", "match assigned to inferred var");
}

// --- B0002: block-body arms ---

test_block_arms_as_statement() `test {
  int x = 2;
  int result = 0;
  match x {
    1 => {
      result = 10;
    },
    2 => {
      result = 20;
    },
    _ => {
      result = -1;
    },
  }
  assert(result == 20, "block arm sets result");
}

test_block_arms_all_variants() `test {
  Direction d = Direction.East;
  int result = 0;
  match d {
    Direction.North => {
      result = 1;
    },
    Direction.South => {
      result = 2;
    },
    Direction.East => {
      result = 3;
    },
    Direction.West => {
      result = 4;
    },
  }
  assert(result == 3, "block arm enum East");
}

test_mixed_block_and_expr_arms() `test {
  int x = 2;
  string s = match x {
    1 => "one",
    2 => {
      string tmp = "tw";
      tmp = tmp + "o";
      tmp;
    },
    _ => "other",
  };
  assert(s == "two", "mixed arms: block computes value");
}

test_block_arm_with_multiple_statements() `test {
  int x = 1;
  int sum = 0;
  match x {
    1 => {
      sum += 10;
      sum += 20;
      sum += 30;
    },
    _ => {
      sum = -1;
    },
  }
  assert(sum == 60, "block arm executes multiple statements");
}

test_block_arm_enum_destructure() `test {
  Expr e = Expr.Add(3, 4);
  int result = match e {
    Expr.Num(v) => v,
    Expr.Add(l, r) => {
      int sum = l + r;
      sum * 2;
    },
    Expr.Neg(n) => -n,
  };
  assert(result == 14, "block arm with destructure: (3+4)*2");
}

// --- match on char literals ---

test_match_char_literal() `test {
  char c = 'b';
  string s = match c {
    'a' => "alpha",
    'b' => "bravo",
    'c' => "charlie",
    _ => "other",
  };
  assert(s == "bravo", "match char literal b");
}

test_match_char_escape() `test {
  char c = '\n';
  string s = match c {
    '\n' => "newline",
    '\t' => "tab",
    '\\' => "backslash",
    _ => "other",
  };
  assert(s == "newline", "match char escape newline");
}

test_match_char_wildcard() `test {
  char c = 'z';
  string s = match c {
    'a' => "a",
    _ => "not a",
  };
  assert(s == "not a", "match char wildcard");
}

// --- match on bool ---

test_match_bool_true() `test {
  bool b = true;
  string s = match b {
    true => "yes",
    _ => "no",
  };
  assert(s == "yes", "match bool true");
}

test_match_bool_false() `test {
  bool b = false;
  string s = match b {
    true => "yes",
    false => "no",
    _ => "?",
  };
  assert(s == "no", "match bool false");
}

// --- match with guards ---

test_match_guard_positive() `test {
  int x = 5;
  string s = match x {
    val if val > 0 => "positive",
    val if val < 0 => "negative",
    _ => "zero",
  };
  assert(s == "positive", "guard: 5 is positive");
}

test_match_guard_negative() `test {
  int x = -3;
  string s = match x {
    val if val > 0 => "positive",
    val if val < 0 => "negative",
    _ => "zero",
  };
  assert(s == "negative", "guard: -3 is negative");
}

test_match_guard_zero() `test {
  int x = 0;
  string s = match x {
    val if val > 0 => "positive",
    val if val < 0 => "negative",
    _ => "zero",
  };
  assert(s == "zero", "guard: 0 is zero");
}

test_match_guard_with_literal() `test {
  int x = 42;
  string s = match x {
    0 => "zero",
    val if val > 100 => "big",
    _ => "small",
  };
  assert(s == "small", "guard: 42 is small");
}

// --- short destructure (without enum prefix) ---

test_short_destructure() `test {
  Expr e = Expr.Add(5, 3);
  int val = match e {
    Num(v) => v,
    Add(l, r) => l + r,
    Neg(n) => -n,
  };
  assert(val == 8, "short destructure Add(5,3)");
}

test_short_destructure_neg() `test {
  Expr e = Expr.Neg(10);
  int val = match e {
    Num(v) => v,
    Add(l, r) => l + r,
    Neg(n) => -n,
  };
  assert(val == -10, "short destructure Neg(10)");
}

// --- match true with expression patterns (B0123) ---

test_match_true_fizzbuzz() `test {
  int n = 15;
  string result = match true {
    n % 15 == 0 => "fizzbuzz",
    n % 3 == 0 => "fizz",
    n % 5 == 0 => "buzz",
    _ => n.to_string(),
  };
  assert(result == "fizzbuzz", "match true: 15 is fizzbuzz");
}

test_match_true_fizz() `test {
  int n = 9;
  string result = match true {
    n % 15 == 0 => "fizzbuzz",
    n % 3 == 0 => "fizz",
    n % 5 == 0 => "buzz",
    _ => n.to_string(),
  };
  assert(result == "fizz", "match true: 9 is fizz");
}

test_match_true_buzz() `test {
  int n = 10;
  string result = match true {
    n % 15 == 0 => "fizzbuzz",
    n % 3 == 0 => "fizz",
    n % 5 == 0 => "buzz",
    _ => n.to_string(),
  };
  assert(result == "buzz", "match true: 10 is buzz");
}

test_match_true_default() `test {
  int n = 7;
  string result = match true {
    n % 15 == 0 => "fizzbuzz",
    n % 3 == 0 => "fizz",
    n % 5 == 0 => "buzz",
    _ => n.to_string(),
  };
  assert(result == "7", "match true: 7 falls through to default");
}

test_match_expression_pattern_int() `test {
  int x = 42;
  string result = match x {
    6 * 7 => "forty-two",
    5 + 5 => "ten",
    _ => "other",
  };
  assert(result == "forty-two", "match int expr: 6*7 == 42");
}

test_match_expression_pattern_string() `test {
  string s = "hello";
  string result = match s {
    "he" + "llo" => "matched",
    _ => "nope",
  };
  assert(result == "matched", "match string expr: concatenation");
}

test_match_expression_pattern_with_variables() `test {
  int threshold = 10;
  int x = 10;
  string result = match x {
    threshold => "at threshold",
    _ => "other",
  };
  assert(result == "at threshold", "match expr with variable");
}

test_match_true_with_block_arm() `test {
  int n = 3;
  match true {
    n > 10 => {
      assert(false, "should not reach big");
    },
    n > 0 => {
      assert(true, "match true with block arm: positive");
    },
    _ => {
      assert(false, "should not reach non-positive");
    },
  };
}
