{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "go run $(git rev-parse --show-toplevel)/tools/guard/guard.go || exit 2",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Edit",
      "Bash(*)",
      "Glob",
      "WebSearch",
      "Read",
      "mcp__tracker__list",
      "mcp__tracker__create",
      "mcp__tracker__update",
      "mcp__tracker__get",
      "mcp__tracker__search",
      "mcp__tracker__heartbeat",
      "mcp__tracker__agents"
    ],
    "deny": [
      "Read(.tracker/**)",
      "Edit(.tracker/**)",
      "Write(.tracker/**)"
    ],
    "additionalDirectories": [
      "/tmp",
      "~/.promise"
    ]
  }
}
