// Test map[K, V] operations: insert, lookup, contains, remove, keys, values, iteration
//
// B0355: top-level Row type for member-expr key/value dup tests.
type MapTestRow {
  string name;
}

test_literal_and_lookup() `test {
  map[string, int] m = {
    "a": 1, "b": 2, "c": 3
  };
  assert(m.len == 3, "literal len 3");
  if val := m["a"] {
    assert(val == 1, "m[a] == 1");
  } else {
    assert(false, "should find a");
  }
}

test_empty_literal() `test {
  map[string, int] m = {:};
  assert(m.is_empty, "empty literal is_empty");
  assert(m.len == 0, "empty literal len 0");
  m["a"] = 1;
  assert(m.len == 1, "after insert len 1");
}

test_insert() `test {
  map[string, int] m = {:};
  m["x"] = 10;
  m["y"] = 20;
  assert(m.len == 2, "after insert len 2");
  if val := m["x"] {
    assert(val == 10, "m[x] == 10");
  }
}

test_update() `test {
  map[string, int] m = {
    "x": 10
  };
  m["x"] = 99;
  assert(m.len == 1, "update preserves len");
  if val := m["x"] {
    assert(val == 99, "m[x] updated to 99");
  }
}

test_contains() `test {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  assert(m.contains("a"), "contains a");
  assert(!m.contains("z"), "not contains z");
}

test_remove() `test {
  map[string, int] m = {
    "a": 1, "b": 2, "c": 3
  };
  bool removed = m.remove("b");
  assert(removed, "remove b returns true");
  assert(m.len == 2, "after remove len 2");
  assert(!m.contains("b"), "b removed");

  bool not_found = m.remove("z");
  assert(!not_found, "remove z returns false");
}

test_keys_values() `test {
  map[string, int] m = {
    "x": 10
  };
  string[] keys = m.keys();
  assert(keys.len == 1, "keys len 1");
  assert(keys[0] == "x", "key is x");

  int[] vals = m.values();
  assert(vals.len == 1, "values len 1");
  assert(vals[0] == 10, "value is 10");
}

test_is_empty() `test {
  map[string, int] m = {:};
  assert(m.is_empty, "empty map is_empty");
  m["a"] = 1;
  assert(!m.is_empty, "non-empty not is_empty");
}

test_missing_key_returns_none() `test {
  map[string, int] m = {
    "a": 1
  };
  bool found = false;
  if _ := m["missing"] {
    found = true;
  }
  assert(!found, "missing key returns none");
}

test_int_keys() `test {
  map[int, string] m = {:};
  m[1] = "one";
  m[2] = "two";
  assert(m.len == 2, "int key map len 2");
  if val := m[1] {
    assert(val == "one", "m[1] == one");
  }
}

test_clear() `test {
  map[string, int] m = {
    "a": 1, "b": 2, "c": 3
  };
  assert(m.len == 3, "before clear len 3");
  m.clear();
  assert(m.len == 0, "after clear len 0");
  assert(m.is_empty, "after clear is_empty");
  assert(!m.contains("a"), "a not contained after clear");
  // Can insert after clear
  m["x"] = 99;
  assert(m.len == 1, "after re-insert len 1");
  if val := m["x"] {
    assert(val == 99, "m[x] == 99 after clear+insert");
  }
}

// --- for-in iteration ---

test_for_in_kv() `test {
  map[string, int] m = {
    "a": 1, "b": 2, "c": 3
  };
  int sum = 0;
  int count = 0;
  string[] seen_keys = [];
  for k, v in m {
    sum += v;
    count++;
    seen_keys.push(k);
  }
  assert(sum == 6, "for k, v sum == 6");
  assert(count == 3, "for k, v visits 3 entries");
  assert(seen_keys.contains("a"), "visited key a");
  assert(seen_keys.contains("b"), "visited key b");
  assert(seen_keys.contains("c"), "visited key c");
}

test_for_in_single() `test {
  map[string, int] m = {
    "x": 10, "y": 20
  };
  int sum = 0;
  for pair in m {
    (k, v) := pair;
    sum += v;
  }
  assert(sum == 30, "for pair sum == 30");
}

test_for_in_empty() `test {
  map[string, int] m = {:};
  int count = 0;
  for k, v in m {
    count++;
  }
  assert(count == 0, "empty map iterates zero times");
}

test_for_in_entry_name() `test {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  int sum = 0;
  for entry in m {
    (_, v) := entry;
    sum += v;
  }
  assert(sum == 3, "entry name doesn't collide");
}

// --- get_or ---

test_get_or() `test {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  assert(m.get_or("a", 99) == 1, "get_or existing returns value");
  assert(m.get_or("z", 99) == 99, "get_or missing returns default");
}

// --- pop ---

test_pop() `test {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  if val := m.pop("a") {
    assert(val == 1, "pop returns removed value");
  } else {
    assert(false, "pop should find key");
  }
  assert(m.len == 1, "pop reduces len");
  assert(!m.contains("a"), "pop removes key");
}

test_pop_missing() `test {
  map[string, int] m = {
    "a": 1
  };
  bool found = false;
  if _ := m.pop("z") {
    found = true;
  }
  assert(!found, "pop missing returns none");
  assert(m.len == 1, "pop missing preserves len");
}

// --- update ---

test_update_existing() `test {
  map[string, int] m = {
    "a": 1, "b": 2
  };
  assert(m.update("a", 99), "update existing returns true");
  assert(m.get_or("a", 0) == 99, "update changes value");
  assert(m.len == 2, "update preserves len");
}

test_update_missing() `test {
  map[string, int] m = {
    "a": 1
  };
  assert(!m.update("z", 99), "update missing returns false");
  assert(m.len == 1, "update missing preserves len");
  assert(!m.contains("z"), "update missing doesn't insert");
}

// --- entries ---

test_entries() `test {
  map[string, int] m = {
    "x": 10
  };
  (string, int)[] e = m.entries();
  assert(e.len == 1, "entries len 1");
  (k, v) := e[0];
  assert(k == "x", "entry key is x");
  assert(v == 10, "entry value is 10");
}

// --- merge ---

test_merge() `test {
  map[string, int] m1 = {
    "a": 1, "b": 2
  };
  map[string, int] m2 = {
    "b": 99, "c": 3
  };
  m1.merge(m2);
  assert(m1.len == 3, "merge len 3");
  assert(m1.get_or("a", 0) == 1, "merge preserves a");
  assert(m1.get_or("b", 0) == 99, "merge overwrites b");
  assert(m1.get_or("c", 0) == 3, "merge adds c");
}

// --- compound index assignment ---

test_compound_index_assign() `test {
  map[string, int] m = {
    "a": 10, "b": 20
  };
  m["a"] += 5;
  assert(m.get_or("a", 0) == 15, "+= on map element");
  m["b"] -= 3;
  assert(m.get_or("b", 0) == 17, "-= on map element");
  m["a"] *= 2;
  assert(m.get_or("a", 0) == 30, "*= on map element");
}

// --- tombstone probing ---

test_lookup_past_tombstone() `test {
  // Insert two keys that will occupy consecutive slots,
  // remove the first, verify the second is still found.
  map[int, int] m = {:};
  // Fill enough to create collisions
  for i in 0..20 {
    m[i] = i;
  }
  // Remove some entries, creating tombstones
  m.remove(3);
  m.remove(7);
  m.remove(11);
  // Verify remaining entries are still accessible past tombstones
  assert(m.get_or(4, -1) == 4, "lookup past tombstone 3");
  assert(m.get_or(8, -1) == 8, "lookup past tombstone 7");
  assert(m.get_or(12, -1) == 12, "lookup past tombstone 11");
  assert(m.len == 17, "len after 3 removes");
}

test_pop_creates_tombstone() `test {
  map[string, int] m = {:};
  m["a"] = 1;
  m["b"] = 2;
  m["c"] = 3;
  m.pop("b");
  // Lookup should skip tombstone left by pop
  assert(m.get_or("a", -1) == 1, "a still found after pop b");
  assert(m.get_or("c", -1) == 3, "c still found after pop b");
  assert(m.len == 2, "len after pop");
}

// --- entries with multiple entries ---

test_entries_multiple() `test {
  map[string, int] m = {
    "a": 1, "b": 2, "c": 3
  };
  (string, int)[] e = m.entries();
  assert(e.len == 3, "entries len 3");
  // Collect into map to verify order-independently
  int sum = 0;
  for pair in e {
    (_, v) := pair;
    sum += v;
  }
  assert(sum == 6, "entries values sum to 6");
}

// --- merge into empty ---

test_merge_into_empty() `test {
  map[string, int] m1 = {:};
  map[string, int] m2 = {
    "x": 10, "y": 20
  };
  m1.merge(m2);
  assert(m1.len == 2, "merge into empty len 2");
  assert(m1.get_or("x", 0) == 10, "merged x");
  assert(m1.get_or("y", 0) == 20, "merged y");
}

// --- for k, v with int keys ---

test_for_in_kv_int_keys() `test {
  map[int, string] m = {
    1: "one", 2: "two", 3: "three"
  };
  int key_sum = 0;
  string[] vals = [];
  for k, v in m {
    key_sum += k;
    vals.push(v);
  }
  assert(key_sum == 6, "int key sum == 6");
  assert(vals.len == 3, "3 values iterated");
}

// --- rehash ---

test_rehash_stress() `test {
  map[int, int] m = {:};
  // Insert enough entries to trigger rehash (initial capacity 16, load factor 75%)
  for i in 0..50 {
    m[i] = i * 10;
  }
  assert(m.len == 50, "50 entries after rehash");
  // Verify all entries survive rehash
  for i in 0..50 {
    assert(m.get_or(i, -1) == i * 10, "entry survived rehash");
  }
}

// --- B0232: Map destruction drops Slot enum element data (keys/values) ---

test_map_string_string_no_leak() `test {
  // B0232: Map[string, string] should not leak keys or values at destruction.
  // The Slot[string, string] elements in _buckets are dropped, and string
  // fields are dup'd on match destructure to prevent double-free.
  map[string, string] m = {:};
  m["hello"] = "world";
  m["foo"] = "bar";
  m["baz"] = "qux";
  // m goes out of scope — Slot elements should be dropped
}

test_map_string_int_no_leak() `test {
  // B0232: String keys should not leak even with int values.
  map[string, int] m = {:};
  m["a"] = 1;
  m["b"] = 2;
  m["c"] = 3;
}

test_map_int_string_no_leak() `test {
  // B0232: String values should not leak with int keys.
  map[int, string] m = {:};
  m[1] = "hello";
  m[2] = "world";
  m[3] = "test";
}

test_map_remove_no_leak() `test {
  // B0235
  // B0232: Removed entries should have their keys/values freed.
  map[string, string] m = {:};
  m["a"] = "one";
  m["b"] = "two";
  m["c"] = "three";
  m.remove("b");
  assert(m.len == 2, "len after remove");
}

test_map_overwrite_no_leak() `test {
  // B0235
  // B0232: Overwriting a value should free the old key/value.
  map[string, string] m = {:};
  m["key"] = "old_value";
  m["key"] = "new_value";
  if val := m["key"] {
    assert(val == "new_value", "should see new value");
  }
}

test_map_clear_no_leak() `test {
  // B0232: clear() should free all keys/values.
  map[string, string] m = {:};
  m["x"] = "one";
  m["y"] = "two";
  m["z"] = "three";
  m.clear();
  assert(m.len == 0, "cleared");
}

test_map_rehash_no_leak() `test {
  // B0232: Rehash should not leak old bucket data.
  // Insert enough to trigger rehash (>12 with initial cap 16 at 75% load).
  map[string, string] m = {:};
  for i in 0..20 {
    m[i.to_string()] = "val_{i}";
  }
  assert(m.len == 20, "20 entries after rehash");
}

test_map_read_after_insert() `test {
  // B0235
  // B0232: Reading values after insert should work correctly.
  // The dup-on-destructure ensures returned values are independent copies.
  map[string, string] m = {:};
  m["key"] = "value";
  string result = "";
  if v := m["key"] {
    result = v;
  }
  assert(result == "value", "read correct value");
}

test_map_pop_no_leak() `test {
  // B0235
  // B0232: pop() should return the value and free the key.
  map[string, string] m = {:};
  m["a"] = "one";
  m["b"] = "two";
  if val := m.pop("a") {
    assert(val == "one", "popped value");
  }
  assert(m.len == 1, "len after pop");
}

test_map_member_expr_key_no_double_free() `test {
  // B0355: MemberExpr key — struct still owns string, map must hold independent copy.
  MapTestRow r = MapTestRow(name: "hello");
  map[string, int] m = {:};
  m[r.name] = 42;
  assert(m.len == 1, "len after insert");
  if v := m["hello"] {
    assert(v == 42, "lookup by literal");
  } else {
    assert(false, "key not found");
  }
  // r.name still valid — no double-free
  assert(r.name == "hello", "original unchanged");
}

test_map_member_expr_value_no_double_free() `test {
  // B0355: MemberExpr value — struct still owns string, map must hold independent copy.
  MapTestRow r = MapTestRow(name: "world");
  map[string, string] m = {:};
  m["k"] = r.name;
  assert(m.len == 1, "len after insert");
  if v := m["k"] {
    assert(v == "world", "lookup value");
  } else {
    assert(false, "key not found");
  }
  // r.name still valid — no double-free
  assert(r.name == "world", "original unchanged");
}

// T0400: Map with tuple value type. Previously panicked at codegen with
// "no layout for type _FnIter[(K, V)]" because the mono spiral guard
// over-marked Vector[(K, V)] as spiral, preventing _FnIter[T] from being
// resolved during Vector.iter()'s body monomorphization.

test_map_tuple_value_basics() `test {
  m := map[string, (string, int)]();
  m["a"] = ("alpha", 1);
  m["b"] = ("beta", 2);

  assert(m.len == 2, "len");
  assert(m.contains("a"), "contains a");

  if v := m["a"] {
    (s, n) := v;
    assert(s == "alpha", "tuple str field");
    assert(n == 1, "tuple int field");
  } else {
    assert(false, "a missing");
  }

  m.remove("a");
  assert(m.len == 1, "after remove");
  assert(m.contains("a") == false, "a removed");
}

test_map_tuple_value_iter() `test {
  m := map[string, (string, int)]();
  m["x"] = ("ex", 10);
  m["y"] = ("why", 20);

  int total = 0;
  for entry in m.entries() {
    (k, v) := entry;
    (s, n) := v;
    total = total + n;
  }
  assert(total == 30, "iter total");
}

test_map_nested_tuple_value() `test {
  m := map[string, ((string, int), int)]();
  m["k"] = (("nested", 1), 99);

  if v := m["k"] {
    (inner, outer) := v;
    (s, n) := inner;
    assert(s == "nested", "nested str");
    assert(n == 1, "nested int");
    assert(outer == 99, "outer int");
  } else {
    assert(false, "k missing");
  }
}

test_map_string_tuple_drop() `test {
  // Exercises drop of (string, int) values — string elements must be freed
  // as the map is dropped at scope exit. Leak detector enforces zero leaks.
  m := map[string, (string, int)]();
  m["k1"] = ("alpha", 1);
  m["k2"] = ("beta", 2);
  m["k3"] = ("gamma", 3);
  assert(m.len == 3, "before drop");
}

// T0408: Map[K, V] for non-tuple heap V (Vector, channel, Set, nested map).
// Originally panicked at codegen with "no layout for type _FnIter[(K, V)]"
// because the mono spiral guard over-marked Vector[T]/Map[K, V] origins as
// spiral when V was a heap type. Fixed by T0400's spiral-guard refinement
// (originWrapsTypeParams precondition). These tests lock in the contract
// that Vector/Channel/Set/Map origins are not over-marked spiral, so
// _FnIter[(K, V)] resolves for any non-tuple-wrapping V.

test_map_vector_value() `test {
  m := map[string, int[]]();
  v := int[]();
  v.push(1);
  v.push(2);
  m["a"] = v;
  assert(m.contains("a"), "contains");
  if got := m["a"] {
    assert(got.len == 2, "vec len");
    assert(got[0] == 1, "vec[0]");
  }
}

test_map_channel_value() `test {
  m := map[string, channel[int]]();
  c := channel[int]();
  m["a"] = c;
  assert(m.contains("a"), "channel value");
  assert(m.len == 1, "len");
}

test_map_set_value() `test {
  m := map[string, Set[int]]();
  s := Set[int]();
  s.add(1);
  s.add(2);
  m["a"] = s;
  assert(m.contains("a"), "set value");
}

test_map_nested_map_value() `test {
  m := map[string, map[string, int]]();
  inner := map[string, int]();
  inner["x"] = 1;
  m["a"] = inner;
  assert(m.contains("a"), "nested map value");
  if got := m["a"] {
    assert(got.contains("x"), "inner key");
  }
}

test_map_vector_value_iter() `test {
  // Forces _FnIter[(string, int[])] codegen — the panic site in T0408.
  m := map[string, int[]]();
  v := int[]();
  v.push(42);
  m["a"] = v;
  count := 0;
  for entry in m.entries() {
    count = count + 1;
  }
  assert(count == 1, "iter count");
}

// T0404: Map[string, string[]] — heap-of-heap V (Vector wrapping heap strings).
// Mirrors the exact T0404 repro. Underlying fix: T0400 (originWrapsTypeParams
// precondition in resolveUnresolvedInstances). Locks in the contract for V's
// that themselves wrap a heap-droppable type (deeper chain than T0408).
test_map_string_vec_string() `test {
  m := map[string, string[]]();
  v := string[]();
  v.push("x" + "");
  m["k" + ""] = v;
  if got := m["k" + ""] {
    assert(got.len == 1, "len 1");
  }
}

// T0404: forces _FnIter[(string, string[])] codegen via entries() iteration —
// the exact mono panic site reported by T0404 ("no layout for _FnIter[(string, string[])]").
test_map_string_vec_string_iter() `test {
  m := map[string, string[]]();
  v := string[]();
  v.push("hello" + "");
  m["k" + ""] = v;
  count := 0;
  for entry in m.entries() {
    count = count + 1;
  }
  assert(count == 1, "iter count");
}

// T0397: Heap string in tuple-valued map — repeated reads must not double-free.
// Uses .to_string() to force heap allocation (literal-only tests miss the bug
// because pal_free short-circuits on the literal flag).
test_map_tuple_heap_string_repeated_read() `test {
  m := map[string, (string, int)]();
  m["a"] = ("first".to_string(), 100);
  m["b"] = ("second".to_string(), 200);
  if t := m["a"] {
    (s, n) := t;
    assert(s == "first", "first read string");
    assert(n == 100, "first read int");
  }
  if t0 := m["a"] {
    (s0, n0) := t0;
    assert(s0 == "first", "second read string");
    assert(n0 == 100, "second read int");
  }
}

// T0397: tuple with two heap-string fields (heap via concatenation).
test_map_tuple_two_heap_strings() `test {
  m := map[string, (string, string)]();
  m["k"] = ("a" + "b", "c" + "d");
  if t := m["k"] {
    (s1, s2) := t;
    assert(s1 == "ab", "s1");
    assert(s2 == "cd", "s2");
  }
}

// T0397: tuple with a vector field — drop must not free the map's vector.
test_map_tuple_with_vector() `test {
  m := map[string, (string, int[])]();
  vec := int[]();
  vec.push(1);
  vec.push(2);
  m["k"] = ("hello".to_string(), vec);
  if t := m["k"] {
    (s, ints) := t;
    assert(s == "hello", "string");
    assert(ints.len == 2, "vec len");
  }
}

// T0397: nested tuple in map.
test_map_nested_tuple_heap() `test {
  m := map[string, ((string, int), int)]();
  m["k"] = (("first".to_string(), 1), 10);
  if t := m["k"] {
    (inner, outer) := t;
    (s, n) := inner;
    assert(s == "first", "nested string");
    assert(n == 1, "nested int");
    assert(outer == 10, "outer");
  }
}

// T0397: typed Optional[Tuple] decl path — `(string, int)? opt = m["k"]`.
test_map_typed_optional_tuple_decl() `test {
  m := map[string, (string, int)]();
  m["k"] = ("hello".to_string(), 42);
  (string, int)? opt = m["k"];
  if t := opt {
    (s, n) := t;
    assert(s == "hello", "typed decl string");
    assert(n == 42, "typed decl int");
  }
}

// T0397: force unwrap with `!`.
test_map_tuple_force_unwrap() `test {
  m := map[string, (string, int)]();
  m["k"] = ("hello".to_string(), 1);
  t := m["k"]!;
  (s, n) := t;
  assert(s == "hello", "force unwrap string");
  assert(n == 1, "force unwrap int");
}

// T0397: re-read after typed-decl unwrap (catches the alias bug — the typed
// decl variable was holding a borrowed pointer into the map; the second read
// would double-free without the dup).
test_map_typed_decl_post_read() `test {
  m := map[string, (string, int)]();
  m["k"] = ("hello".to_string(), 42);
  (string, int)? opt = m["k"];
  if t := opt {
    (s, n) := t;
    assert(s == "hello", "first read");
  }
  if t2 := m["k"] {
    (s2, n2) := t2;
    assert(s2 == "hello", "post read after typed-decl unwrap");
  }
}

// T0397: while-let unwrap on map index — same alias bug as if-let. Each
// iteration re-reads the same key; without the dup, the binding's
// per-iteration drop would free the map's bucket data and the next
// iteration would crash.
test_map_while_let_tuple_heap() `test {
  m := map[string, (string, int)]();
  m["k"] = ("hello".to_string(), 1);
  count := 0;
  while t := m["k"] {
    (s, n) := t;
    assert(s == "hello", "while iter string");
    assert(n == 1, "while iter int");
    count = count + 1;
    if count >= 3 {
      break;
    }
  }
  assert(count == 3, "iter count");
}

// T0397: direct destructure of `m[k]!` aliases bucket data — without the dup,
// each destructured local takes a drop binding while the map still owns the
// underlying string, causing use-after-free when the same key is re-read.
test_map_destructure_force_unwrap_then_reread() `test {
  m := map[string, (string, int)]();
  m["k"] = ("hello".to_string(), 42);
  (s, n) := m["k"]!;
  assert(s == "hello", "first destructure");
  assert(n == 42, "first int");
  if t := m["k"] {
    (s2, n2) := t;
    assert(s2 == "hello", "post-destructure read");
  }
}

// T0397/T0439 coverage: typed Optional[Tuple] decl that is NEVER unwrapped —
// exercises maybeRegisterOptionalDrop's new Tuple case and
// emitOptionalLocalValueDrop's Tuple branch when `opt` drops at scope exit
// while still holding the dup'd inner tuple. Without the new branches,
// the dup'd tuple's heap fields would leak.
test_map_typed_decl_drop_no_unwrap() `test {
  m := map[string, (string, int)]();
  m["k"] = ("hello".to_string(), 42);
  (string, int)? opt = m["k"];
  // opt drops at scope exit without ever being unwrapped — must not leak.
  assert(m.contains("k"), "key still in map");
}

// T0397/T0439 coverage: inferred `opt := m[k]` decl without unwrap.
test_map_inferred_decl_drop_no_unwrap() `test {
  m := map[string, (string, int)]();
  m["k"] = ("hello".to_string(), 42);
  opt := m["k"];
  assert(m.contains("k"), "key still in map");
}

// T0397/T0439 coverage: missing key returns None — dup should not crash on
// zero-initialized tuple data. dupString/dupVector null-check, but the
// Tuple loop runs unconditionally so this verifies safety.
test_map_tuple_missing_key_none() `test {
  m := map[string, (string, int)]();
  m["a"] = ("alpha".to_string(), 1);
  if t := m["nonexistent"] {
    assert(false, "nonexistent should be None");
  } else {
    assert(true, "None branch taken");
  }
  // Re-read present key still works after a None lookup.
  if t := m["a"] {
    (s, n) := t;
    assert(s == "alpha", "present key");
  }
}

// T0397/T0439 coverage: nested 2-tuple with three heap-string slots
// exercises dupTupleValue's loop and the recursive nested-tuple branch.
// Encodes (a, (b, c)) since 3-tuple destructure has a parser limitation
// (T0441).
test_map_tuple_three_heap_strings_nested() `test {
  m := map[string, (string, (string, string))]();
  m["k"] = ("a".to_string(), ("b".to_string(), "c".to_string()));
  if t := m["k"] {
    (s1, rest) := t;
    (s2, s3) := rest;
    assert(s1 == "a", "f1");
    assert(s2 == "b", "f2");
    assert(s3 == "c", "f3");
  }
  // Re-read must not double-free any of the three heap strings.
  if t2 := m["k"] {
    (a, rest2) := t2;
    (b, c) := rest2;
    assert(a == "a", "re-read f1");
    assert(b == "b", "re-read f2");
    assert(c == "c", "re-read f3");
  }
}

// T0442 (pre-existing codegen bug): heap user type as a tuple field
// (Map[K, (HeapUserType, int)]) panics in wrapOptional with type mismatch.
// Once T0442 is fixed, add a regression test here that exercises the
// dupTupleValue → maybeDupPushElement heap-user-type clone path:
//
//   m := map[string, (MapTestRow, int)]();
//   m["k"] = (MapTestRow(name: "row1".to_string()), 7);
//   if t := m["k"] { (row, n) := t; ... }
//   if t2 := m["k"] { (row2, n2) := t2; ... }   // re-read no double-free

// T0397/T0439 coverage: vector field inside tuple — Vector dup path
// inside dupTupleValue (via maybeDupPushElement → dupVector + element clone).
test_map_tuple_with_inner_vector() `test {
  m := map[string, (string, int[])]();
  v := int[]();
  v.push(10);
  v.push(20);
  v.push(30);
  m["k"] = ("data".to_string(), v);
  if t := m["k"] {
    (s, ints) := t;
    assert(s == "data", "string field");
    assert(ints.len == 3, "vec len");
    assert(ints[0] == 10, "vec[0]");
    assert(ints[2] == 30, "vec[2]");
  }
  // Re-read — vector ownership must be fully independent.
  if t2 := m["k"] {
    (s2, ints2) := t2;
    assert(ints2.len == 3, "reread vec len");
  }
}
