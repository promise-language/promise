// Fire-and-forget goroutines: G struct should be freed by goroutine_exit
// (not leaked). Tests that go expressions used as statements don't leak.
noop() {
}

test_single_fire_and_forget() `test(exclude: wasm) {
  go {
    int x = 1 + 2;
  };
  sleep(Duration.from_millis(50));
  assert(true, "fire-and-forget goroutine completed without crash");
}

test_many_fire_and_forget() `test(exclude: wasm) {
  for i in 0..100 {
    go {
      int x = i * 2;
    };
  }
  sleep(Duration.from_millis(100));
  assert(true, "100 fire-and-forget goroutines completed without crash");
}

test_fire_and_forget_with_channel() `test(exclude: wasm) {
  ch := channel[int](capacity: 1);
  go {
    ch.send(42);
  };
  int v = (<-ch)!;
  assert(v == 42, "fire-and-forget goroutine sent value through channel");
}

test_task_go_block_still_works() `test(exclude: wasm) {
  // go { } used as a task (assigned + awaited) should still work
  t := go {
    int x = 10;
  };
  <-t;
  assert(true, "task go block completed");
}

test_fire_and_forget_go_call() `test(exclude: wasm) {
  // go func() as a statement (void function, fire-and-forget)
  go noop();
  sleep(Duration.from_millis(50));
  assert(true, "fire-and-forget go call completed without crash");
}

test_nested_fire_and_forget() `test(exclude: wasm) {
  // Nested go blocks: outer fire-and-forget spawns inner fire-and-forget
  go {
    go {
      int x = 42;
    };
    sleep(Duration.from_millis(10));
  };
  sleep(Duration.from_millis(100));
  assert(true, "nested fire-and-forget goroutines completed without crash");
}

test_go_call_as_task() `test(exclude: wasm) {
  // go void_func() used as a task — should set sentinel, receiver frees G
  t := go noop();
  <-t;
  assert(true, "go call as task completed");
}

test_fire_and_forget_captures() `test(exclude: wasm) {
  // Fire-and-forget with captured variables — verify no use-after-free
  ch := channel[int](capacity: 1);
  int x = 100;
  go {
    ch.send(x);
  };
  int v = (<-ch)!;
  assert(v == 100, "captured variable delivered correctly");
}

test_fire_and_forget_in_if_body() `test(exclude: wasm) {
  // Fire-and-forget go block inside an if body
  ch := channel[int](capacity: 1);
  bool flag = true;
  if flag {
    go {
      ch.send(77);
    };
  }
  int v = (<-ch)!;
  assert(v == 77, "fire-and-forget inside if body works");
}

test_mixed_fire_and_forget_and_task() `test(exclude: wasm) {
  // Interleave fire-and-forget and task go blocks
  ch := channel[int](capacity: 3);
  go {
    ch.send(1);
  };
  t := go {
    ch.send(2);
  };
  go {
    ch.send(3);
  };
  <-t;
  sleep(Duration.from_millis(50));

  int total = 0;
  for i in 0..3 {
    total += (<-ch)!;
  }
  assert(total == 6, "mixed fire-and-forget and task");
}

test_fire_and_forget_many_go_calls() `test(exclude: wasm) {
  // Many fire-and-forget go func() calls in a loop
  for i in 0..100 {
    go noop();
  }
  sleep(Duration.from_millis(100));
  assert(true, "100 fire-and-forget go calls completed");
}

// B0109: Non-void fire-and-forget go func() should not leak G or result buffer.
compute() int {
  return 42;
}

get_string() string {
  return "hello";
}

test_fire_and_forget_non_void() `test(exclude: wasm) {
  // go non_void_func() as fire-and-forget — result discarded, G must be freed
  go compute();
  sleep(Duration.from_millis(50));
  assert(true, "fire-and-forget non-void go call completed without crash");
}

test_fire_and_forget_non_void_many() `test(exclude: wasm) {
  // Many fire-and-forget non-void go calls — verifies no accumulating leaks
  for i in 0..100 {
    go compute();
  }
  sleep(Duration.from_millis(100));
  assert(true, "100 fire-and-forget non-void go calls completed");
}

test_fire_and_forget_non_void_string() `test(exclude: wasm) {
  // Fire-and-forget with string return type
  go get_string();
  sleep(Duration.from_millis(50));
  assert(true, "fire-and-forget non-void string go call completed");
}

test_non_void_task_still_works() `test(exclude: wasm) {
  // go non_void_func() as task (result received) should still work
  t := go compute();
  int result = <-t;
  assert(result == 42, "non-void task returned correct result");
}

// T1159: the free-function fast path (`go f(...)`) discarded a non-void heap
// result without dropping it — a heap struct leaked its instance, a vector its
// backing block. The body now drops the result via emitVariantFieldDrop when
// fire-and-forget. All leak-checked.
type Bag {
  int n;
}

build_bag(int x) Bag {
  return Bag(n: x);
}

build_ints(int x) int[] {
  return[x, x + 1, x + 2];
}

build_adder(int x)() -> int {
  return || -> x + 1;
}

// heap struct result, discarded — used to leak the struct instance (1 alloc).
test_ff_freefn_struct() `test(exclude: wasm) {
  go build_bag(5);
  sleep(Duration.from_millis(30));
}

// vector result, discarded — used to leak the backing block (1 alloc).
test_ff_freefn_vector() `test(exclude: wasm) {
  go build_ints(5);
  sleep(Duration.from_millis(30));
}

// capturing-closure result, discarded — the fast path drops it via
// emitVariantFieldDrop's closure (T0739) path, so no env-temp tracking is needed
// (unlike the via-block method path, blocked by T1160). Leak-checked.
test_ff_freefn_closure() `test(exclude: wasm) {
  go build_adder(10);
  sleep(Duration.from_millis(30));
}

// regression: the same struct-returning function received via a task handle
// still produces the correct result (buffer freed by the handle drop).
test_ff_freefn_struct_task_still_works() `test(exclude: wasm) {
  t := go build_bag(7);
  b := <-t;
  assert(b.n == 7, "struct task result");
}
