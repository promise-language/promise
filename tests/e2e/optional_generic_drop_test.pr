// B0209: Optional[TypeParam] fields should trigger synthesized drop at mono time.
// NOTE: Runtime tests blocked by B0210 (mono layout mismatch for Optional[TypeParam]).
// This file serves as a placeholder to be expanded once B0210 is fixed.
type MaybeVal[T] {
  T val;
}

// Non-optional TypeParam — works fine

test_typeparam_int() `test {
  MaybeVal[int] m = MaybeVal[int](val: 42);
  assert(m.val == 42, "TypeParam int works");
}
